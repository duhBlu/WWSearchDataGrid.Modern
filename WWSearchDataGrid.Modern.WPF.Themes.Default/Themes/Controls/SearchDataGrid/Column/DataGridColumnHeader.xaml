<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:commands="clr-namespace:WWSearchDataGrid.Modern.WPF.Commands;assembly=WWSearchDataGrid.Modern.WPF"
                    xmlns:converters="clr-namespace:WWSearchDataGrid.Modern.WPF.Converters;assembly=WWSearchDataGrid.Modern.WPF"
                    xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/SearchDataGrid/Column/ColumnHeaderContextMenu.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/Primitives/DefaultControls.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <converters:BooleanToVisibilityCollapsedConverter x:Key="SelectAllBoolToVisibilityConverter" />

    <!--
        Default (implicit, TargetType-only) style for the custom headers presenter. The
        presenter calls DefaultStyleKeyProperty.OverrideMetadata(typeof(SearchDataGridColumnHeadersPresenter)),
        so WPF looks up a Style under the type key in this theme dictionary; without this
        entry the presenter has no Template, the column-headers band renders empty, and
        no SearchDataGridColumnHeader instances are produced.

        The control template retargets PART_FillerColumnHeader to SearchDataGridColumnHeader.
        The DataGrid pushes its ColumnHeaderStyle setter to the filler header at
        ApplyTemplate time; that setter's TargetType is SearchDataGridColumnHeader, so the
        stock DataGridColumnHeader filler would fail the strict TargetType check.
    -->
    <Style TargetType="{x:Type sdg:SearchDataGridColumnHeadersPresenter}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:SearchDataGridColumnHeadersPresenter}">
                    <Grid>
                        <sdg:SearchDataGridColumnHeader x:Name="PART_FillerColumnHeader" IsHitTestVisible="False" />
                        <ItemsPresenter />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGridColumnHeader}" TargetType="{x:Type sdg:SearchDataGridColumnHeader}">
        <Setter Property="AllowDrop" Value="True" />
        <Setter Property="ContextMenu" Value="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridColumnHeaderContextMenu}}" />
        <Setter Property="Foreground" Value="#FF333333" />
        <Setter Property="Background" Value="#FFF9F9F9" />
        <Setter Property="BorderBrush" Value="#FFd0d0d0" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:SearchDataGridColumnHeader}">
                    <!--
                        Phase 5: the embedded ColumnSearchBox is removed entirely. The
                        DataGridColumnHeader template now hosts only the header chrome
                        (select-all checkbox, header text, sort arrow, gripper). The
                        per-column filter editor lives in the pinned FilterRowPresenter
                        below the headers.
                    -->
                    <ControlTemplate.Resources>
                        <!--
                            Wider hit area for the column resizers without the default Thumb
                            chrome. Hit-test surface is the transparent Border; the visible
                            1px separator is drawn by the inner Border via TemplateBinding,
                            so each gripper's own BorderBrush/BorderThickness decide which
                            edge (if any) shows a line.
                        -->
                        <Style x:Key="ColumnHeaderGripperThumbStyle" TargetType="{x:Type Thumb}">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                SnapsToDevicePixels="True" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ControlTemplate.Resources>
                    <Grid>
                        <Border x:Name="HeaderBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,1,1"
                                Margin="0,0,0,0"
                                Padding="{TemplateBinding Padding}">
                            <!--
                                Layout: [select-all][header text Auto][filter button Auto][spacer *][sort arrow Auto].
                                Header text sizes to its content (Auto), filter button sits
                                immediately to its right at a fixed width, the * spacer absorbs
                                remaining horizontal space, and the sort arrow stays at the far
                                right. Whether the button is Opacity 0 or 1, the Auto column
                                still reserves its 22px slot — header text and sort arrow stay
                                put across hover transitions.
                            -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--
                                    Select All Checkbox. Visibility and IsChecked are bound to
                                    the column's GridColumn descriptor (pinned via
                                    SearchDataGridColumnHeader.Descriptor at column-creation
                                    time). The checkbox is two-way bound to IsChecked so user
                                    clicks flow through the descriptor's DP callback into
                                    SearchDataGrid.ApplyHeaderCheckedValue. IsThreeState is
                                    false so the click cycle is true ↔ false only; the
                                    indeterminate visual still renders when the grid pushes
                                    IsChecked=null after detecting mixed state.
                                -->
                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center">

                                    <CheckBox x:Name="PART_SelectAllCheckBox"
                                              Style="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesCheckBox}}"
                                              Visibility="{Binding Column.(sdg:SearchDataGridColumnHeader.Descriptor).ActualShowCheckBoxInHeader, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGridColumnHeader}}, Converter={StaticResource SelectAllBoolToVisibilityConverter}, FallbackValue=Collapsed}"
                                              IsChecked="{Binding Column.(sdg:SearchDataGridColumnHeader.Descriptor).IsChecked, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGridColumnHeader}}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              VerticalAlignment="Center"
                                              IsThreeState="False" />

                                    <!--  Row Count Display (visible only when using SelectedRows scope)  -->
                                    <TextBlock x:Name="PART_SelectAllRowCount"
                                               Foreground="#666666"
                                               Visibility="Collapsed"
                                               Margin="0,0,0,2"
                                               VerticalAlignment="Center"
                                               FontSize="10" />
                                </StackPanel>

                                <!--  Header Content  -->
                                <ContentPresenter Grid.Column="1"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />

                                <Button x:Name="PART_RuleFilterEditorButton"
                                        Grid.Column="2"
                                        IsHitTestVisible="True"
                                        Focusable="False"
                                        Cursor="Hand"
                                        Command="{x:Static commands:ContextMenuCommands.ShowFilterEditorCommand}"
                                        CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="4,0,2,0"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        KeyboardNavigation.IsTabStop="False"
                                        ToolTip="Column Filter Editor">
                                    <sdg:Icon Width="12"
                                                 Height="12"
                                                 IconSource="{StaticResource {x:Static sdg:IconKeys.IconFilter}}"
                                                 IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Opacity" Value="0" />
                                            <Setter Property="Foreground" Value="DarkGray" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderBrush" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="3">
                                                            <ContentPresenter Focusable="False"
                                                                              Margin="{TemplateBinding Padding}"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"
                                                                              RecognizesAccessKey="True"
                                                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGridColumnHeader}}}" Value="True">
                                                    <Setter Property="Opacity" Value="1" />
                                                </DataTrigger>
                                                <!--
                                                    "Column is filtered" highlight. Walks:
                                                    header → Column (DataGridColumn) →
                                                    SearchDataGridColumnHeader.Descriptor
                                                    (attached ColumnDataBase pinned at column-creation
                                                    time) → IsFiltered (read-only DP driven from
                                                    SearchTemplateController.HasCustomExpression).
                                                    Every step is a DP that fires change
                                                    notifications, so no C# subscription is needed.
                                                -->
                                                <DataTrigger Binding="{Binding Column.(sdg:SearchDataGridColumnHeader.Descriptor).IsFiltered, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGridColumnHeader}}}" Value="True">
                                                    <Setter Property="Opacity" Value="1" />
                                                    <Setter Property="Foreground" Value="#0078D4" />
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="Gray" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Foreground" Value="Black" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!--  Sort Arrow (Grid.Column=4, with the *-spacer at Column=3 pushing it right)  -->
                                <!--<TextBlock x:Name="SortArrow"
                                           Grid.Column="4"
                                           Foreground="{TemplateBinding Foreground}"
                                           Visibility="Collapsed"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe Fluent Icons" />-->

                                <sdg:Icon x:Name="SortArrow"
                                             Grid.Column="4"
                                             Width="10"
                                             Height="10"
                                             StrokeThickness="1.2"
                                             IconBrush="{TemplateBinding Foreground}" />
                            </Grid>
                        </Border>

                        <!--
                            Column Resizers. Width is the grab target; the visible 1px
                            separator is drawn by the gripper's BorderBrush + BorderThickness
                            (see ColumnHeaderGripperThumbStyle above). Only the right gripper
                            draws a line — the boundary between cols N and N+1 is rendered by
                            col N's right gripper; col N+1's left gripper provides extra grab
                            area but stays invisible.
                        -->
                        <Thumb x:Name="PART_LeftHeaderGripper"
                               Style="{StaticResource ColumnHeaderGripperThumbStyle}"
                               Cursor="SizeWE"
                               HorizontalAlignment="Left"
                               Panel.ZIndex="55"
                               Width="6" />

                        <Thumb x:Name="PART_RightHeaderGripper"
                               Style="{StaticResource ColumnHeaderGripperThumbStyle}"
                               BorderBrush="{Binding VerticalGridLinesBrush, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}}"
                               BorderThickness="0,0,1,0"
                               Cursor="SizeWE"
                               HorizontalAlignment="Right"
                               Panel.ZIndex="55"
                               Width="6" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding ActualHasItems, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type sdg:SearchDataGrid}}}" Value="False">
                            <Setter TargetName="HeaderBorder" Property="BorderThickness" Value="0,0,0,1" />
                        </DataTrigger>

                        <!--  Sort Direction  -->
                        <Trigger Property="SortDirection" Value="Ascending">
                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SortArrow" Property="IconSource" Value="{StaticResource {x:Static sdg:IconKeys.IconChevronUp}}" />
                        </Trigger>

                        <Trigger Property="SortDirection" Value="Descending">
                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SortArrow" Property="IconSource" Value="{StaticResource {x:Static sdg:IconKeys.IconChevronDown}}" />
                        </Trigger>

                        <!--  Mouse States  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Background" Value="#FFF0F0F0" />
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Background" Value="#FFE0E0E0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
