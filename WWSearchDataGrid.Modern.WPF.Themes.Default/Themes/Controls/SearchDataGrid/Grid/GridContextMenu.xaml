<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:commands="clr-namespace:WWSearchDataGrid.Modern.WPF.Commands;assembly=WWSearchDataGrid.Modern.WPF"
                    xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Resources/Icons/Icons.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/Primitives/ContextMenu.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        Shared grid-body right-click menu — filter operations, column profiles, export,
        and layout actions. The menu's DataContext is rebound to a Commands.ContextMenuContext
        per opening, so a single instance is fine here (x:Shared defaults to True for ContextMenu).
    -->
    <ContextMenu x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGridContextMenu}"
                 Style="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesContextMenu}}"
                 AutomationProperties.AutomationId="cmuGridBody">
        <!--  Filter operations  -->
        <MenuItem x:Name="miClearAllFilters"
                  Command="{x:Static commands:ContextMenuCommands.ClearAllFiltersCommand}"
                  CommandParameter="{Binding Grid}"
                  Header="Clear All Filters (Not Implemented)">
            <MenuItem.Icon>
                <sdg:Icon Width="14"
                             Height="14"
                             IconSource="{StaticResource {x:Static sdg:IconKeys.IconClearFilter}}" />
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem x:Name="miToggleFilterPanel"
                  Command="{x:Static commands:ContextMenuCommands.ToggleFilterPanelCommand}"
                  CommandParameter="{Binding Grid}"
                  Header="Toggle Filter Panel (Not Implemented)" />
        <MenuItem x:Name="miSaveFilterPreset"
                  Command="{x:Static commands:ContextMenuCommands.SaveFilterPresetCommand}"
                  CommandParameter="{Binding Grid}"
                  Header="Save Filter Preset (Not Implemented)" />
        <MenuItem x:Name="miLoadFilterPreset"
                  Command="{x:Static commands:ContextMenuCommands.LoadFilterPresetCommand}"
                  CommandParameter="{Binding Grid}"
                  Header="Load Filter Preset (Not Implemented)" />
        <Separator />

        <!--  Column Profiles submenu  -->
        <MenuItem x:Name="miColumnProfiles" Header="Column Profiles">
            <MenuItem x:Name="miSaveCurrentProfile"
                      Command="{x:Static commands:ContextMenuCommands.SaveCurrentProfileCommand}"
                      CommandParameter="{Binding Grid}"
                      Header="Save Current Profile (Not Implemented)" />
            <MenuItem x:Name="miLoadProfile"
                      Command="{x:Static commands:ContextMenuCommands.LoadProfileCommand}"
                      CommandParameter="{Binding Grid}"
                      Header="Load Profile... (Not Implemented)" />
            <MenuItem x:Name="miManageProfiles"
                      Command="{x:Static commands:ContextMenuCommands.ManageProfilesCommand}"
                      CommandParameter="{Binding Grid}"
                      Header="Manage Profiles... (Not Implemented)" />
        </MenuItem>

        <Separator />

        <!--  Export operations  -->
        <MenuItem x:Name="miExportToCsv"
                  Command="{x:Static commands:ContextMenuCommands.ExportToCsvCommand}"
                  CommandParameter="{Binding Grid}"
                  Header="Export to CSV (Not Implemented)" />
        <MenuItem x:Name="miExportToExcel"
                  Command="{x:Static commands:ContextMenuCommands.ExportToExcelCommand}"
                  CommandParameter="{Binding Grid}"
                  Header="Export to Excel (Not Implemented)" />

        <Separator />

        <!--  Layout operations  -->
        <MenuItem x:Name="miShowColumnChooser"
                  Command="{x:Static commands:ContextMenuCommands.ShowColumnChooserCommand}"
                  CommandParameter="{Binding Grid}"
                  Header="Show Column Chooser">
            <MenuItem.Icon>
                <sdg:Icon Width="14"
                             Height="14"
                             IconSource="{StaticResource {x:Static sdg:IconKeys.IconColumnChooser}}" />
            </MenuItem.Icon>
            <MenuItem.Style>
                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesMenuItem}}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Grid.IsColumnChooserEnabled}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </MenuItem.Style>
        </MenuItem>
        <MenuItem x:Name="miResetLayout"
                  Command="{x:Static commands:ContextMenuCommands.ResetLayoutCommand}"
                  CommandParameter="{Binding Grid}"
                  Header="Reset Layout (Not Implemented)" />
    </ContextMenu>

</ResourceDictionary>
