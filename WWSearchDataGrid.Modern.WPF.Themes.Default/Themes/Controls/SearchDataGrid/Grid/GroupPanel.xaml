<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
                    xmlns:commands="clr-namespace:WWSearchDataGrid.Modern.WPF.Commands;assembly=WWSearchDataGrid.Modern.WPF"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Resources/Icons/Icons.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/Primitives/ContextMenu.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Adapts a GridColumn (pill DataContext) → ContextMenuContext so the pill can drive the
         existing column-header commands without a parallel set of GridColumn-typed twins. -->
    <commands:GridColumnToContextMenuContextConverter x:Key="GridColumnToContextMenuContextConverter" />

    <!-- Cascade-down indent for nested pills: Margin.Top = GroupLevel × GroupIndentWidth,
         plus a small Left gap between consecutive pills. Pairs with the horizontal ItemsPanel
         so deeper levels step down while the strip stays compact horizontally. -->
    <sdg:GroupPillIndentConverter x:Key="GroupPillIndentConverter" />

    <!--
        Right-click menu for the empty area of the GroupPanel. Three grid-wide actions; the
        ContextMenu's PlacementTarget is the GroupPanel, and GroupPanel.OwnerGrid resolves the
        owning SearchDataGrid (filled in on Loaded by walking the visual tree).
    -->
    <ContextMenu x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGridGroupPanelContextMenu}"
                 Style="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesContextMenu}}"
                 AutomationProperties.AutomationId="cmuGroupPanel">
        <MenuItem Header="Expand All Groups"
                  Command="{x:Static commands:ContextMenuCommands.ExpandAllGroupsCommand}"
                  CommandParameter="{Binding PlacementTarget.OwnerGrid, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
        <MenuItem Header="Collapse All Groups"
                  Command="{x:Static commands:ContextMenuCommands.CollapseAllGroupsCommand}"
                  CommandParameter="{Binding PlacementTarget.OwnerGrid, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
        <Separator />
        <MenuItem Header="Clear Grouping"
                  Command="{x:Static commands:ContextMenuCommands.ClearAllGroupingCommand}"
                  CommandParameter="{Binding PlacementTarget.OwnerGrid, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
    </ContextMenu>

    <!--
        Pill ContextMenu. Full Expand / Full Collapse + Ungroup at the top (pill-specific
        actions), then a separator, then a mirror of every column-header menu item driven
        through the GridColumnToContextMenuContextConverter so the existing commands work
        without modification. x:Shared="False" so each pill gets its own instance.

        ClearGroupingCommand takes a SearchDataGrid (per GroupingCommands.cs) — for the panel
        menu above we bind PlacementTarget (the panel); for the pill it's not surfaced because
        Clear Grouping is a global action and lives on the panel menu, not per-pill.
    -->
    <ContextMenu x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGridGroupPillContextMenu}"
                 x:Shared="False"
                 Style="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesContextMenu}}"
                 StaysOpen="True"
                 AutomationProperties.AutomationId="cmuGroupPanelPill"
                 DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
        <!-- Pill-specific group actions -->
        <MenuItem Header="Full Expand"
                  Command="{x:Static commands:ContextMenuCommands.FullExpandGroupCommand}"
                  CommandParameter="{Binding}" />
        <MenuItem Header="Full Collapse"
                  Command="{x:Static commands:ContextMenuCommands.FullCollapseGroupCommand}"
                  CommandParameter="{Binding}" />
        <Separator />
        <MenuItem Header="Ungroup"
                  Command="{x:Static commands:ContextMenuCommands.UngroupColumnCommand}"
                  CommandParameter="{Binding ., Converter={StaticResource GridColumnToContextMenuContextConverter}}" />
        <Separator />

        <!-- Mirror of the column-header menu, fed via the converter -->
        <MenuItem Header="Sort Ascending"
                  Command="{x:Static commands:ContextMenuCommands.SortAscendingCommand}"
                  CommandParameter="{Binding ., Converter={StaticResource GridColumnToContextMenuContextConverter}}">
            <MenuItem.Icon>
                <sdg:Icon Width="14" Height="14"
                          IconSource="{StaticResource {x:Static sdg:IconKeys.IconSortAscending}}" />
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="Sort Descending"
                  Command="{x:Static commands:ContextMenuCommands.SortDescendingCommand}"
                  CommandParameter="{Binding ., Converter={StaticResource GridColumnToContextMenuContextConverter}}">
            <MenuItem.Icon>
                <sdg:Icon Width="14" Height="14"
                          IconSource="{StaticResource {x:Static sdg:IconKeys.IconSortDescending}}" />
            </MenuItem.Icon>
        </MenuItem>
        <Separator />
        <MenuItem Header="Best Fit Column"
                  Command="{x:Static commands:ContextMenuCommands.BestFitColumnCommand}"
                  CommandParameter="{Binding ., Converter={StaticResource GridColumnToContextMenuContextConverter}}">
            <MenuItem.Icon>
                <sdg:Icon Width="14" Height="14"
                          IconSource="{StaticResource {x:Static sdg:IconKeys.IconBestFit}}" />
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="Best Fit All Columns"
                  Command="{x:Static commands:ContextMenuCommands.BestFitAllColumnsCommand}"
                  CommandParameter="{Binding ., Converter={StaticResource GridColumnToContextMenuContextConverter}}" />
        <Separator />
        <MenuItem Header="Hide Column"
                  Command="{x:Static commands:ContextMenuCommands.HideSelectedColumnCommand}"
                  CommandParameter="{Binding InternalColumn}">
            <MenuItem.Icon>
                <sdg:Icon Width="14" Height="14"
                          IconSource="{StaticResource {x:Static sdg:IconKeys.IconHideColumn}}" />
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="Fixed">
            <MenuItem.Style>
                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesMenuItem}}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding View.AllowFixedColumnMenu}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </MenuItem.Style>
            <MenuItem Header="Pin Left"
                      Command="{x:Static commands:ContextMenuCommands.PinColumnLeftCommand}"
                      CommandParameter="{Binding ., Converter={StaticResource GridColumnToContextMenuContextConverter}}">
                <MenuItem.Icon>
                    <sdg:Icon Width="14" Height="14"
                              IconSource="{StaticResource {x:Static sdg:IconKeys.IconPinLeft}}" />
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Pin Right"
                      Command="{x:Static commands:ContextMenuCommands.PinColumnRightCommand}"
                      CommandParameter="{Binding ., Converter={StaticResource GridColumnToContextMenuContextConverter}}">
                <MenuItem.Icon>
                    <sdg:Icon Width="14" Height="14"
                              IconSource="{StaticResource {x:Static sdg:IconKeys.IconPinRight}}" />
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Unpin"
                      Command="{x:Static commands:ContextMenuCommands.UnpinColumnCommand}"
                      CommandParameter="{Binding ., Converter={StaticResource GridColumnToContextMenuContextConverter}}">
                <MenuItem.Icon>
                    <sdg:Icon Width="14" Height="14"
                              IconSource="{StaticResource {x:Static sdg:IconKeys.IconUnpin}}" />
                </MenuItem.Icon>
            </MenuItem>
        </MenuItem>
    </ContextMenu>

    <!--
        Default Style for GroupPanel. The panel renders a horizontal strip across the top of
        the grid, with one pill per grouped column. Pills lay out horizontally side by side;
        each nested level steps DOWN (Margin.Top) rather than to the side, preserving
        horizontal space for the row of pills and keeping the panel compact. Right-clicking
        the empty area opens the panel context menu (Expand All / Collapse All / Clear
        Grouping).
    -->
    <Style x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGridGroupPanel}" TargetType="{x:Type sdg:GroupPanel}">
        <Setter Property="Background" Value="#FFF6F8FB" />
        <Setter Property="BorderBrush" Value="#FFD0D6DF" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="AllowDrop" Value="True" />
        <Setter Property="ContextMenu"
                Value="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridGroupPanelContextMenu}}" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <!--
                    Pill template. Mirrors the column-header layout (Foreground/Background, hover
                    & pressed states, IconChevronUp/Down for the sort glyph, IconFilter button
                    that opens the same popup the column header's filter button does) but as a
                    Button with rounded corners so clicks reliably reach the toggle-sort command.
                -->
                <DataTemplate>
                    <Button Command="{x:Static commands:ContextMenuCommands.ToggleGroupSortCommand}"
                            CommandParameter="{Binding}"
                            Cursor="Hand"
                            Focusable="False"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Left"
                            ContextMenu="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridGroupPillContextMenu}}"
                            ToolTip="Click to flip sort direction. Right-click for actions.">
                        <Button.Margin>
                            <MultiBinding Converter="{StaticResource GroupPillIndentConverter}">
                                <Binding Path="GroupLevel" />
                                <Binding Path="View.GroupIndentWidth" />
                            </MultiBinding>
                        </Button.Margin>
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Foreground" Value="#FF333333" />
                                <Setter Property="Background" Value="#FFF9F9F9" />
                                <Setter Property="BorderBrush" Value="#FFD0D0D0" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Padding" Value="8,3" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border x:Name="PillBorder"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}"
                                                    CornerRadius="3"
                                                    SnapsToDevicePixels="True">
                                                <!--
                                                    Layout mirrors the column header: caption (Auto)
                                                    | filter button (Auto, reveals on hover) |
                                                    sort arrow (Auto).
                                                -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding HeaderCaption}"
                                                               VerticalAlignment="Center"
                                                               Foreground="{TemplateBinding Foreground}" />

                                                    <Button x:Name="PART_FilterButton"
                                                            Grid.Column="1"
                                                            IsHitTestVisible="True"
                                                            Focusable="False"
                                                            Cursor="Hand"
                                                            Command="{x:Static commands:ContextMenuCommands.ShowFilterEditorForColumnCommand}"
                                                            CommandParameter="{Binding}"
                                                            Margin="6,0,2,0"
                                                            Padding="0"
                                                            VerticalAlignment="Center"
                                                            KeyboardNavigation.IsTabStop="False"
                                                            ToolTip="Column Filter Editor">
                                                        <sdg:Icon Width="12"
                                                                  Height="12"
                                                                  IconSource="{StaticResource {x:Static sdg:IconKeys.IconFilter}}"
                                                                  IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Opacity" Value="0" />
                                                                <Setter Property="Foreground" Value="DarkGray" />
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                                <Setter Property="BorderThickness" Value="0" />
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}"
                                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                                    CornerRadius="3">
                                                                                <ContentPresenter Focusable="False"
                                                                                                  Margin="{TemplateBinding Padding}"
                                                                                                  HorizontalAlignment="Center"
                                                                                                  VerticalAlignment="Center"
                                                                                                  RecognizesAccessKey="True"
                                                                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <!--
                                                                        Reveal on hover. AncestorType walks UP from the filter
                                                                        button, so the first Button ancestor is the outer pill —
                                                                        which is exactly what we want to mirror IsMouseOver from.
                                                                    -->
                                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" Value="True">
                                                                        <Setter Property="Opacity" Value="1" />
                                                                    </DataTrigger>
                                                                    <!-- Active-filter highlight, same blue as the column header. -->
                                                                    <DataTrigger Binding="{Binding IsFiltered}" Value="True">
                                                                        <Setter Property="Opacity" Value="1" />
                                                                        <Setter Property="Foreground" Value="#0078D4" />
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Foreground" Value="Gray" />
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter Property="Foreground" Value="Black" />
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>

                                                    <!-- Sort glyph: same icon family as the column header (IconChevronUp/Down). -->
                                                    <sdg:Icon x:Name="SortArrow"
                                                              Grid.Column="2"
                                                              Width="10"
                                                              Height="10"
                                                              Margin="2,0,0,0"
                                                              VerticalAlignment="Center"
                                                              StrokeThickness="1.2"
                                                              IconBrush="{TemplateBinding Foreground}" />
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <!-- Sort direction reads from GridColumn.SortOrder (the pill's DataContext). -->
                                                <DataTrigger Binding="{Binding SortOrder}" Value="Ascending">
                                                    <Setter TargetName="SortArrow" Property="IconSource"
                                                            Value="{StaticResource {x:Static sdg:IconKeys.IconChevronUp}}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SortOrder}" Value="Descending">
                                                    <Setter TargetName="SortArrow" Property="IconSource"
                                                            Value="{StaticResource {x:Static sdg:IconKeys.IconChevronDown}}" />
                                                </DataTrigger>
                                                <!-- Mouse states mirror the column header. -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="PillBorder" Property="Background" Value="#FFF0F0F0" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="PillBorder" Property="Background" Value="#FFE0E0E0" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:GroupPanel}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <!--
                                Empty-state hint when no columns are grouped. Hidden once any
                                pill is present so the strip just shows the pills.
                            -->
                            <TextBlock x:Name="EmptyHint"
                                       Text="Drag a column header here to group by that column."
                                       Foreground="#FF8B95A4"
                                       FontStyle="Italic"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left" />
                            <ItemsPresenter />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding HasItems, RelativeSource={RelativeSource Self}}" Value="True">
                            <Setter TargetName="EmptyHint" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type sdg:GroupPanel}"
           BasedOn="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridGroupPanel}}" />

</ResourceDictionary>
