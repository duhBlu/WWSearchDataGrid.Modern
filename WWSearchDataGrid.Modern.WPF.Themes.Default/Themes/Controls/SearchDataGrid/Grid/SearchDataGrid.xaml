<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:WWSearchDataGrid.Modern.WPF.Converters;assembly=WWSearchDataGrid.Modern.WPF"
                    xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/Primitives/DefaultControls.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/SearchDataGrid/Column/ColumnHeaderContextMenu.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/SearchDataGrid/Cell/CellContextMenu.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/SearchDataGrid/Row/RowHeaderContextMenu.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/SearchDataGrid/Grid/GridContextMenu.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/FilterSummaryPanel/FilterSummaryPanel.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/SearchDataGrid/Cell/DataGridCell.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/SearchDataGrid/Row/DataGridRow.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/SearchDataGrid/Column/DataGridColumnHeader.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/SearchDataGrid/Grid/GroupStyle.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/SearchDataGrid/Grid/GroupPanel.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <converters:NullOrEmptyToBooleanConverter x:Key="NullOrEmptyToBooleanConverter" />
    <converters:FilterRowVisibilityConverter x:Key="FilterRowVisibilityConverter" />
    <converters:BooleanToVisibilityCollapsedConverter x:Key="BooleanToVisibilityCollapsedConverter" />

    <Style x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGrid}" TargetType="{x:Type sdg:SearchDataGrid}">
        <Setter Property="CellStyle" Value="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridCell}}" />
        <Setter Property="RowStyle" Value="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridRow}}" />
        <Setter Property="ContextMenu" Value="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridContextMenu}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:SearchDataGrid}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <!-- Group panel strip (collapsed when IsGroupPanelVisible=false) -->
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <!--
                                Group Panel — stair-stepped pills for grouped columns. Sits
                                outside the ScrollViewer so it stays fixed during horizontal
                                scroll. Collapsed by default; IsGroupPanelVisible toggles it.
                            -->
                            <sdg:GroupPanel x:Name="PART_GroupPanel"
                                            Grid.Row="0"
                                            ItemsSource="{Binding GroupedColumns, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}}"
                                            Visibility="{Binding IsGroupPanelVisible, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}" />
                            <ScrollViewer x:Name="DG_ScrollViewer"
                                          Grid.Row="1"
                                          Focusable="false"
                                          Padding="0,0,1,1"
                                          sdg:HorizontalScrollBehavior.EnableShiftMouseWheelScroll="True"
                                          CanContentScroll="true">
                                <ScrollViewer.Template>
                                    <ControlTemplate TargetType="ScrollViewer">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>


                                            <!--  Per-Column Select All  -->
                                            <Button Style="{StaticResource {x:Static sdg:ThemeKeys.GridSelectAllButton}}"
                                                    Focusable="false"
                                                    Command="{x:Static DataGrid.SelectAllCommand}"
                                                    Panel.ZIndex="2" />

                                            <!--
                                                Filler under the SelectAllButton, aligned with the pinned
                                                FilterRowPresenter. Without this, Row 1 / Column 0
                                                renders empty (SearchDataGrid Background bleeds through),
                                                leaving a visible gap to the left of the filter row at the
                                                row-header column. Visibility mirrors the filter row so the
                                                gap is only filled when the filter row is showing.
                                            -->
                                            <Border Grid.Row="1"
                                                    Grid.Column="0"
                                                    Background="#FFf9f9f9"
                                                    BorderBrush="#FFd0d0d0"
                                                    BorderThickness="0,0,1,1"
                                                    UseLayoutRounding="True"
                                                    SnapsToDevicePixels="True">
                                                <Border.Visibility>
                                                    <MultiBinding Converter="{StaticResource FilterRowVisibilityConverter}">
                                                        <Binding RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" Path="ShowFilterRow" />
                                                        <Binding RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" Path="FilterEditorPlacement" />
                                                    </MultiBinding>
                                                </Border.Visibility>
                                                <sdg:Icon Width="12"
                                                          Height="12"
                                                          IconSource="{StaticResource {x:Static sdg:IconKeys.IconFilter}}"
                                                          IconBrush="Gray" />
                                            </Border>

                                            <!--
                                                Column Headers. The custom header type carries the OnClick
                                                override that suppresses sort when the click originated on an
                                                interactive child (the filter-popup button).
                                            -->
                                            <sdg:SearchDataGridColumnHeadersPresenter x:Name="PART_ColumnHeadersPresenter"
                                                                                      Grid.Column="1"
                                                                                      Margin="0,0,0,0" />

                                            <!--
                                                Pinned filter row. Lives in the same template grid-column
                                                as PART_ColumnHeadersPresenter so the horizontal scroll
                                                view applied by the ScrollViewer's clip and the
                                                FilterRowPanel's own offset binding stay aligned at the
                                                frozen-column boundary.
                                            -->
                                            <sdg:FilterRowPresenter x:Name="PART_FilterRow"
                                                                    Style="{StaticResource {x:Static sdg:ThemeKeys.FilterRowPresenter}}"
                                                                    Grid.Row="1"
                                                                    Grid.Column="1">
                                                <sdg:FilterRowPresenter.Visibility>
                                                    <MultiBinding Converter="{StaticResource FilterRowVisibilityConverter}">
                                                        <Binding RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" Path="ShowFilterRow" />
                                                        <Binding RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" Path="FilterEditorPlacement" />
                                                    </MultiBinding>
                                                </sdg:FilterRowPresenter.Visibility>
                                            </sdg:FilterRowPresenter>

                                            <!--
                                                Header-bottom separator. Shifted to row 2 (top edge of
                                                content) so it sits BELOW the filter row, not between the
                                                headers and the filter row. The negative top margin keeps
                                                it overlapping the header / filter-row gridline at the
                                                content seam.
                                            -->
                                            <Border x:Name="PART_ColumnHeaderBottomBorder"
                                                    Grid.Row="2"
                                                    Grid.Column="1"
                                                    Background="#d0d0d0"
                                                    Margin="0,-1,0,0"
                                                    VerticalAlignment="Top"
                                                    Panel.ZIndex="2"
                                                    Height="1" />

                                            <!--  Rows  -->
                                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                                    Grid.Row="2"
                                                                    Grid.ColumnSpan="2"
                                                                    Margin="0,0,-1,0"
                                                                    CanContentScroll="{TemplateBinding CanContentScroll}" />

                                            <!--
                                                Placeholder: top-right gap above the vertical scrollbar.
                                            -->
                                            <Border Grid.Row="0"
                                                    Grid.Column="2"
                                                    Background="#F9F9F9"
                                                    BorderBrush="#FFd0d0d0"
                                                    BorderThickness="1,0,0,1"
                                                    Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                                    Margin="-1,0,0,0"
                                                    UseLayoutRounding="True"
                                                    SnapsToDevicePixels="True" />
                                            <Border Grid.Row="1"
                                                    Grid.Column="2"
                                                    Background="#ffffff"
                                                    BorderBrush="#FFd0d0d0"
                                                    BorderThickness="1,0,0,1"
                                                    Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                                    Margin="-1,0,0,0"
                                                    UseLayoutRounding="True"
                                                    SnapsToDevicePixels="True" />


                                            <!--  Scrollbars  -->
                                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                                       Grid.Row="2"
                                                       Grid.Column="2"
                                                       Orientation="Vertical"
                                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                                       Maximum="{TemplateBinding ScrollableHeight}"
                                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                                       Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}" />
                                            <Grid Grid.Row="3" Grid.Column="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="{Binding NonFrozenColumnsViewportHorizontalOffset, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <ScrollBar x:Name="PART_HorizontalScrollBar"
                                                           Grid.Column="1"
                                                           Orientation="Horizontal"
                                                           Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                                           Maximum="{TemplateBinding ScrollableWidth}"
                                                           ViewportSize="{TemplateBinding ViewportWidth}"
                                                           Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}" />
                                            </Grid>

                                            <!--
                                                Placeholder: bottom-left gap (below row header area, left of horizontal scrollbar).
                                            -->
                                            <Border Grid.Row="3"
                                                    Grid.Column="0"
                                                    Background="#F9F9F9"
                                                    BorderBrush="#FFd0d0d0"
                                                    BorderThickness="0,1,1,0"
                                                    Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                                    Margin="0,-1,0,0" />
                                            <!--
                                                Placeholder: bottom-right corner (intersection of both scrollbars).
                                            -->
                                            <Border Grid.Row="3"
                                                    Grid.Column="2"
                                                    Background="#F9F9F9"
                                                    BorderBrush="#FFd0d0d0"
                                                    BorderThickness="1,1,0,0"
                                                    Margin="-1,-1,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding ComputedVerticalScrollBarVisibility, RelativeSource={RelativeSource TemplatedParent}}" Value="Visible" />
                                                                    <Condition Binding="{Binding ComputedHorizontalScrollBarVisibility, RelativeSource={RelativeSource TemplatedParent}}" Value="Visible" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                            <!-- Bottom Border of the grid when content extends offscreen -->
                                            <Border Grid.Row="3"
                                                    Grid.ColumnSpan="2"
                                                    BorderBrush="#FFd0d0d0"
                                                    BorderThickness="0,1,0,0"
                                                    Margin="0,0,0,-1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding ComputedVerticalScrollBarVisibility, RelativeSource={RelativeSource TemplatedParent}}" Value="Visible" />
                                                                    <Condition Binding="{Binding ComputedHorizontalScrollBarVisibility, RelativeSource={RelativeSource TemplatedParent}}" Value="Collapsed" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                            
                                            <!-- Right  Border of the grid when content extends offscreen -->
                                            <Border Grid.RowSpan="3"
                                                    Grid.Column="3"
                                                    BorderBrush="#FFd0d0d0"
                                                    BorderThickness="0,0,1,0"
                                                    Margin="0,0,-1,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ComputedVerticalScrollBarVisibility, RelativeSource={RelativeSource TemplatedParent}}" Value="Collapsed" >
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </Grid>
                                    </ControlTemplate>
                                </ScrollViewer.Template>
                                <ItemsPresenter />
                            </ScrollViewer>

                            <!--  FilterSummaryPanel  -->
                            <sdg:FilterSummaryPanel x:Name="PART_FilterSummaryPanel"
                                                    Style="{StaticResource {x:Static sdg:ThemeKeys.FilterSummaryPanel}}"
                                                    Grid.Row="2" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Background" Value="White" />
        <Setter Property="RowHeaderStyle" Value="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridRowHeader}}" />
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridColumnHeader}}" />
        <Setter Property="RowHeaderWidth" Value="24" />
        <Setter Property="BorderBrush" Value="#FFd0d0d0" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="RowBackground" Value="White" />
        <Setter Property="AlternatingRowBackground" Value="#FFF9F9F9" />
        <Setter Property="HorizontalGridLinesBrush" Value="#FFd0d0d0" />
        <Setter Property="VerticalGridLinesBrush" Value="#FFd0d0d0" />
        <Setter Property="HeadersVisibility" Value="All" />
        <Setter Property="GridLinesVisibility" Value="None" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="CanUserResizeRows" Value="False" />
        <Setter Property="CanUserReorderColumns" Value="True" />
        <Setter Property="CanUserResizeColumns" Value="True" />
        <Setter Property="CanUserSortColumns" Value="True" />
        <Setter Property="IsSynchronizedWithCurrentItem" Value="True" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="SelectionMode" Value="Extended" />
        <Setter Property="SelectionUnit" Value="FullRow" />
        <Setter Property="EnableRowVirtualization" Value="True" />
        <Setter Property="EnableColumnVirtualization" Value="True" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.IsVirtualizingWhenGrouping" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Item" />
        <Setter Property="ScrollViewer.IsDeferredScrollingEnabled" Value="False" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGrid}}" TargetType="{x:Type sdg:SearchDataGrid}" />
</ResourceDictionary>
