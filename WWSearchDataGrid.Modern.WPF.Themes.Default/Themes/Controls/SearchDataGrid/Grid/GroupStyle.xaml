<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
                    xmlns:commands="clr-namespace:WWSearchDataGrid.Modern.WPF.Commands;assembly=WWSearchDataGrid.Modern.WPF">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/Primitives/ContextMenu.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        Default group rendering for a grouped SearchDataGrid. The grid attaches this GroupStyle
        lazily the first time it is grouped (see SearchDataGrid.Grouping.cs / EnsureGroupStyle).
        Each group is an expander whose header shows the group VALUE (rendered per the owning
        column's GroupValueTemplate, resolved by GroupValueTemplateSelector) plus the item count;
        the ItemsPresenter hosts the group's rows (or nested groups).
    -->

    <!--  Fallback group-value rendering when a column declares no GroupValueTemplate.  -->
    <DataTemplate x:Key="DefaultGroupValueTemplate">
        <TextBlock Foreground="#FF222222"
                   Text="{Binding Name}"
                   FontWeight="SemiBold" />
    </DataTemplate>

    <!--
        Shared, stateless selector. Resolves the group's nesting level to the owning grouped column
        and returns that column's GroupValueTemplate (or the default above).
    -->
    <sdg:GroupValueTemplateSelector x:Key="GroupValueTemplateSelector" DefaultTemplate="{StaticResource DefaultGroupValueTemplate}" />

    <!--
        Resolves the owning column's HeaderCaption (by group nesting level) into the "ColumnName: "
        prefix rendered ahead of the value in DefaultGroupHeaderTemplate.
    -->
    <sdg:GroupColumnNameConverter x:Key="GroupColumnNameConverter" />

    <!--
        Default whole-header rendering. Used as the fallback by GroupHeaderTemplateSelector when
        the owning column declares no GroupHeaderTemplate. Lays out the column's
        GroupValueTemplate-rendered value followed by the row count chip — exactly what the
        Expander.Header used to host inline. A column-level GroupHeaderTemplate replaces this
        wholesale (including the count chip); GroupValueTemplate alone customizes only the value
        slot and keeps this chrome.
    -->
    <DataTemplate x:Key="DefaultGroupHeaderTemplate">
        <StackPanel Orientation="Horizontal"
                    Margin="2,3"
                    IsHitTestVisible="False"
                    VerticalAlignment="Center">
            <!--
                Column-name prefix: the owning column's HeaderCaption followed by ": ", resolved
                from the group's nesting level via GroupColumnNameConverter. Renders nothing (empty
                string) when the column or caption can't be resolved, so the value slot stands alone.
            -->
            <TextBlock Foreground="#FF808080" VerticalAlignment="Center">
                <TextBlock.Text>
                    <MultiBinding Converter="{StaticResource GroupColumnNameConverter}">
                        <Binding RelativeSource="{RelativeSource AncestorType={x:Type GroupItem}}" />
                        <Binding RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" />
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
            <!--  Value: per-column GroupValueTemplate, resolved by level.  -->
            <ContentControl VerticalAlignment="Center"
                            Content="{Binding}"
                            ContentTemplateSelector="{StaticResource GroupValueTemplateSelector}" />
            <!--  Count: always rendered by the chrome, after the value.  -->
            <TextBlock Foreground="#FF808080"
                       Text="{Binding ItemCount, StringFormat=' ({0})'}"
                       Margin="6,0,0,0"
                       VerticalAlignment="Center" />
        </StackPanel>
    </DataTemplate>

    <!--
        Whole-header selector. Resolves the group's nesting level to the owning grouped column
        and returns that column's GroupHeaderTemplate (or the default chrome above, which itself
        defers to GroupValueTemplate for the value slot).
    -->
    <sdg:GroupHeaderTemplateSelector x:Key="GroupHeaderTemplateSelector" DefaultTemplate="{StaticResource DefaultGroupHeaderTemplate}" />

    <!--
        Produces the Margin applied to a group header's chevron + label (inside the Expander
        template), positioning it at an absolute X offset from the GroupItem's left edge.
        Outermost group headers start at DataGrid.RowHeaderActualWidth (so they sit at the
        cell-content edge, clear of the row-header gutter); each additional nesting level
        compounds by SearchDataGrid.GroupIndentWidth. The Expander itself carries no
        horizontal margin — only the header is offset, so the Expander's content area (data
        rows) remains flush with the grid's left edge and DataGridRowHeaders stay pinned at
        x=0 regardless of how deeply the row is nested.
    -->
    <sdg:GroupHeaderMarginConverter x:Key="GroupHeaderMarginConverter" />

    <!--
        Default (non-animated) group Expander template. The Expander's outer Border carries the
        full-width background so the gray group bar extends across the entire grid row,
        including over the row-header gutter. The header (ToggleButton with chevron + label)
        is offset horizontally via GroupHeaderMarginConverter so the chevron sits at
        RowHeaderActualWidth (clear of the gutter) plus per-level group indent. The content
        ContentPresenter (data rows / nested groups) carries NO horizontal offset, so each
        DataGridRow inside renders at the GroupItem's left edge and its DataGridRowHeader
        remains pinned at the grid's x=0.
    -->
    <ControlTemplate x:Key="GroupExpanderTemplate" TargetType="{x:Type Expander}">
        <Border Background="{TemplateBinding Background}"
                Padding="{TemplateBinding Padding}"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True">
            <DockPanel>
                <!--
                    Header row container. Carries the bottom divider (TemplateBinding flows from
                    the Expander's BorderBrush/BorderThickness setters in GroupExpanderStyle) so
                    every group header — outer and nested — gets a line directly under the
                    chevron row, separating header chrome from content.
                -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                    <Grid>
                        <!--
                            Row-header gutter for the group header row. Pinned at the
                            GroupItem's left edge (which == grid x=0, since the Expander
                            carries no horizontal margin), sized to the grid's
                            RowHeaderActualWidth, styled to match DataGridRowHeader chrome.
                            Renders only across the header strip — content rows below have
                            their own DataGridRowHeader at the same x=0.
                        -->
                        <Border Background="#FFf9f9f9"
                                BorderBrush="#FFd0d0d0"
                                BorderThickness="0,0,1,0"
                                HorizontalAlignment="Left"
                                Width="{Binding RowHeaderActualWidth, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}}"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True" />
                        <ToggleButton x:Name="HeaderToggle"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      Focusable="False"
                                      Cursor="Hand"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Left">
                            <ToggleButton.Margin>
                                <MultiBinding Converter="{StaticResource GroupHeaderMarginConverter}">
                                    <Binding RelativeSource="{RelativeSource AncestorType={x:Type GroupItem}}" />
                                    <Binding RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" Path="RowHeaderActualWidth" />
                                    <Binding RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" Path="GroupIndentWidth" />
                                </MultiBinding>
                            </ToggleButton.Margin>
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                    <Border Background="{TemplateBinding Background}">
                                        <sdg:SimpleStackPanel Orientation="Horizontal" Spacing="8" Margin="6,0,0,0">
                                            <!--<Path x:Name="Chevron"
                                                  DockPanel.Dock="Left"
                                                  Margin="2,0,6,0"
                                                  Width="6"
                                                  Height="9"
                                                  Data="M 0,0 L 4,4 L 0,8 Z"
                                                  Fill="#FF555555"
                                                  Stretch="Uniform"
                                                  VerticalAlignment="Center"
                                                  RenderTransformOrigin="0.5,0.5" />-->

                                            <sdg:Icon x:Name="Chevron"
                                                      DockPanel.Dock="Left"
                                                      Width="10"
                                                      Height="10"
                                                      StrokeThickness="1.5"
                                                      IconSource="{StaticResource {x:Static sdg:IconKeys.IconChevronRight}}" />
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </sdg:SimpleStackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Chevron" Property="IconSource" Value="{StaticResource {x:Static sdg:IconKeys.IconChevronDown}}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                            <ContentPresenter Content="{TemplateBinding Header}"
                                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                                              ContentTemplateSelector="{TemplateBinding HeaderTemplateSelector}" />
                        </ToggleButton>
                    </Grid>
                </Border>
                <ContentPresenter x:Name="ContentSite" Visibility="Collapsed" />
            </DockPanel>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsExpanded" Value="True">
                <Setter TargetName="ContentSite" Property="Visibility" Value="Visible" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!--
        Animated Expander template. Applied when SearchDataGrid.UseGroupExpansionAnimation
        is true (see the DataTrigger on GroupExpanderStyle below). Mirrors
        GroupExpanderTemplate's layout — same header indent via GroupHeaderMarginConverter,
        same un-offset content area — and animates two things on expand/collapse: the
        chevron rotates via a RotateTransform driven by the ToggleButton's IsChecked
        trigger, and the content host's Height is animated between 0 and a viewport-bounded
        natural height by sdg:GroupExpansionAnimator. The animator also flips the host's
        Visibility for the steady collapsed state so the inner VirtualizingStackPanel
        skips measure work while the group is hidden.
    -->
    <ControlTemplate x:Key="AnimatedGroupExpanderTemplate" TargetType="{x:Type Expander}">
        <Border Background="{TemplateBinding Background}"
                Padding="{TemplateBinding Padding}"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True">
            <DockPanel>
                <!--
                    Header row container. Carries the bottom divider so every group header gets
                    a line directly under the chevron row, separating header chrome from content.
                -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                    <Grid>
                        <!--
                            Row-header gutter for the group header row, pinned at the grid's
                            x=0 with row-header chrome styling.
                        -->
                        <Border Background="#FFf9f9f9"
                                BorderBrush="#FFd0d0d0"
                                BorderThickness="0,0,1,0"
                                HorizontalAlignment="Left"
                                Width="{Binding RowHeaderActualWidth, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}}"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True" />
                        <ToggleButton x:Name="HeaderToggle"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      Focusable="False"
                                      Cursor="Hand"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Left">
                            <ToggleButton.Margin>
                                <MultiBinding Converter="{StaticResource GroupHeaderMarginConverter}">
                                    <Binding RelativeSource="{RelativeSource AncestorType={x:Type GroupItem}}" />
                                    <Binding RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" Path="RowHeaderActualWidth" />
                                    <Binding RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" Path="GroupIndentWidth" />
                                </MultiBinding>
                            </ToggleButton.Margin>
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                    <Border Background="{TemplateBinding Background}" Padding="2,3">
                                        <DockPanel LastChildFill="True">
                                            <Path x:Name="Chevron"
                                                  DockPanel.Dock="Left"
                                                  Fill="#FF555555"
                                                  Data="M 0,0 L 4,4 L 0,8 Z"
                                                  Margin="2,0,6,0"
                                                  VerticalAlignment="Center"
                                                  Width="6"
                                                  Height="9"
                                                  Stretch="Uniform"
                                                  RenderTransformOrigin="0.5,0.5">
                                                <Path.RenderTransform>
                                                    <RotateTransform x:Name="ChevronRotate" Angle="0" />
                                                </Path.RenderTransform>
                                            </Path>
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </DockPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="ChevronRotate"
                                                                         Storyboard.TargetProperty="Angle"
                                                                         To="90"
                                                                         Duration="0:0:0.18" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="ChevronRotate"
                                                                         Storyboard.TargetProperty="Angle"
                                                                         To="0"
                                                                         Duration="0:0:0.18" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                            <ContentPresenter Content="{TemplateBinding Header}"
                                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                                              ContentTemplateSelector="{TemplateBinding HeaderTemplateSelector}" />
                        </ToggleButton>
                    </Grid>
                </Border>
                <!--
                    Content host. ClipToBounds keeps mid-animation height transitions
                    from leaking row pixels past the host's bounds; the Height itself is
                    driven by sdg:GroupExpansionAnimator (which also toggles Visibility
                    so the inner virtualizing panel doesn't measure when the group is
                    fully collapsed).
                -->
                <Border x:Name="ContentClip"
                        sdg:GroupExpansionAnimator.IsHost="True"
                        ClipToBounds="True">
                    <ContentPresenter />
                </Border>
            </DockPanel>
        </Border>
    </ControlTemplate>

    <!--
        Style applied to every group's Expander. The IsExpanded setter binds OneWay to the grid's
        AutoExpandAllGroups, so each newly-materialized group starts with that initial state. The
        UseGroupExpansionAnimation DataTrigger swaps in the animated template above when on.
        Runtime AutoExpandAllGroups toggles are pushed actively by the grid (see
        OnAutoExpandAllGroupsChanged in SearchDataGrid.Grouping.cs) so already-realized groups
        also respond.
    -->
    <!--
        Right-click menu for the group header. Attached to every group Expander via the Style
        below (x:Shared="False" so each Expander gets its own ContextMenu instance).
        CommandParameter on each item binds to PlacementTarget, which WPF sets to the originating
        Expander when the menu opens. The Expand / Collapse "this group" items are
        visibility-gated via a DataTrigger on PlacementTarget.IsExpanded so only one of them is
        ever shown.
    -->
    <ContextMenu x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGridGroupHeaderContextMenu}"
                 AutomationProperties.AutomationId="cmuGroupHeader"
                 Style="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesContextMenu}}"
                 x:Shared="False">
        <MenuItem Command="{x:Static commands:ContextMenuCommands.ExpandGroupCommand}"
                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Expand this group">
            <MenuItem.Style>
                <Style TargetType="{x:Type MenuItem}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PlacementTarget.IsExpanded, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </MenuItem.Style>
        </MenuItem>
        <MenuItem Command="{x:Static commands:ContextMenuCommands.CollapseGroupCommand}"
                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Collapse this group">
            <MenuItem.Style>
                <Style TargetType="{x:Type MenuItem}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PlacementTarget.IsExpanded, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </MenuItem.Style>
        </MenuItem>
        <Separator />
        <MenuItem Command="{x:Static commands:ContextMenuCommands.ExpandAllAtLevelCommand}"
                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Expand all at this level" />
        <MenuItem Command="{x:Static commands:ContextMenuCommands.CollapseAllAtLevelCommand}"
                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Collapse all at this level" />
        <Separator />
        <MenuItem Command="{x:Static commands:ContextMenuCommands.UngroupAtLevelCommand}"
                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Ungroup at this level" />
    </ContextMenu>

    <Style x:Key="GroupExpanderStyle" TargetType="{x:Type Expander}">
        <!--
            Opt every group expander into the grid's state-persistence map (see
            SearchDataGrid.TrackGroupExpansion). The attached property hooks Loaded per instance
            so the grid replays user-toggled state across Items.Refresh and container recycling.
        -->
        <Setter Property="sdg:SearchDataGrid.TrackGroupExpansion" Value="True" />
        <!--
            x:Shared="False" on the ContextMenu resource above means each StaticResource lookup
            here returns a fresh instance — so every Expander that picks up this Style gets its
            own ContextMenu rather than fighting over a shared logical parent.
        -->
        <Setter Property="ContextMenu" Value="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridGroupHeaderContextMenu}}" />
        <!--
            The Expander spans the GroupItem's full width — no horizontal margin. Per-level
            indent lives on the header (ToggleButton) inside GroupExpanderTemplate, applied via
            GroupHeaderMarginConverter, so the chevron+label shift right while the Expander's
            content area (data rows / nested groups) stays flush with the GroupItem's left edge.
            That keeps each DataGridRowHeader pinned at the grid's x=0 regardless of group depth.
        -->
        <Setter Property="Template" Value="{StaticResource GroupExpanderTemplate}" />
        <Setter Property="IsExpanded" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}, Path=AutoExpandAllGroups, Mode=OneWay}" />
        <Setter Property="Background" Value="#FFF3F3F3" />
        <Setter Property="BorderBrush" Value="#FFd0d0d0" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}, Path=UseGroupExpansionAnimation}" Value="True">
                <Setter Property="Template" Value="{StaticResource AnimatedGroupExpanderTemplate}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <GroupStyle x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGridGroupStyle}">
        <GroupStyle.ContainerStyle>
            <Style TargetType="{x:Type GroupItem}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type GroupItem}">
                            <!--
                                Expander.Header bound to the CollectionViewGroup itself, with
                                HeaderTemplateSelector resolving the whole-header template per
                                grouped column (column.GroupHeaderTemplate wins, else
                                DefaultGroupHeaderTemplate — which in turn defers to
                                GroupValueTemplateSelector for the value slot). The Expander
                                spans the full GroupItem width (no horizontal margin) so its
                                content area — the data rows below — renders flush with the
                                grid's left edge, leaving each DataGridRowHeader pinned at x=0.
                                Per-level indent is applied to the header (chevron + label) only,
                                inside the Expander template via GroupHeaderMarginConverter.
                            -->
                            <Expander Style="{StaticResource GroupExpanderStyle}"
                                      Header="{Binding}"
                                      HeaderTemplateSelector="{StaticResource GroupHeaderTemplateSelector}">
                                <ItemsPresenter />
                            </Expander>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </GroupStyle.ContainerStyle>
    </GroupStyle>

</ResourceDictionary>
