<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
                    xmlns:sdgCore="clr-namespace:WWSearchDataGrid.Modern.Core;assembly=WWSearchDataGrid.Modern.Core"
                    xmlns:behaviors="clr-namespace:WWSearchDataGrid.Modern.WPF.Behaviors;assembly=WWSearchDataGrid.Modern.WPF"
                    xmlns:converters="clr-namespace:WWSearchDataGrid.Modern.WPF.Converters;assembly=WWSearchDataGrid.Modern.WPF">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/Primitives/DefaultControls.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <converters:BooleanToVisibilityCollapsedConverter x:Key="FilterEditorBoolToVis" />

    <!--
        Shared template selector. Both group and condition templates are looked up by resource
        key at runtime, so declaration order inside this dictionary doesn't matter.
    -->
    <sdg:FilterEditorNodeTemplateSelector x:Key="FilterEditorNodeTemplateSelector" />

    <!--  Condition row: column chip + search type chip + value chip + hover remove button.  -->
    <DataTemplate x:Key="{x:Static sdg:SdgThemeKeys.FilterEditorConditionRow}" DataType="{x:Type sdg:FilterConditionNode}">
        <Grid x:Name="ConditionRoot"
              Background="Transparent"
              Cursor="Hand"
              Margin="0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Background="Transparent"
                    Padding="2">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <sdg:ColumnNameTokenEditor SelectedColumn="{Binding Column, Mode=TwoWay}" AvailableColumns="{Binding AvailableColumns}" />
                    <sdg:SearchTypeTokenEditor SelectedSearchType="{Binding SearchType, Mode=TwoWay}" ValidSearchTypes="{Binding SearchTemplate.ValidSearchTypes}" />
                    <sdg:ValueTokenEditor SearchTemplate="{Binding SearchTemplate}" />
                </StackPanel>
            </Border>

            <!--  Remove button — visible only while the row is hovered  -->
            <Button Grid.Column="1"
                    BorderThickness="0"
                    Cursor="Hand"
                    Command="{Binding RemoveCommand}"
                    Padding="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Width="14"
                    Height="14"
                    FontSize="6"
                    FontFamily="Segoe Fluent Icons"
                    Content="&#xEF2C;"
                    ToolTip="Remove condition">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Gray" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="0"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=ConditionRoot, Path=IsMouseOver}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#ed4341" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </DataTemplate>

    <!--  Group: operator chip + add-popup button + warning banner + recursive child list.  -->
    <DataTemplate x:Key="{x:Static sdg:SdgThemeKeys.FilterEditorGroup}" DataType="{x:Type sdg:FilterGroupNode}">
        <Border BorderBrush="#E1E5E9"
                BorderThickness="0,0,0,0"
                Margin="0,2,0,2"
                Padding="0">
            <StackPanel Orientation="Vertical">

                <!--  Header: operator chip + [+] add popup button  -->
                <StackPanel x:Name="GroupHeaderRow"
                            Background="Transparent"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <sdg:GroupOperatorChip Operator="{Binding Operator, Mode=TwoWay}" />

                    <Button x:Name="AddConditionDirectButton"
                            Foreground="White"
                            Cursor="Hand"
                            Command="{Binding AddConditionCommand}"
                            Margin="4,0,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="10"
                            Width="16"
                            Height="16"
                            Content="&#xF8AA;"
                            FontFamily="Segoe Fluent Icons"
                            ToolTip="Add condition">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="AddBorder"
                                        Background="Gray"
                                        Padding="0"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="AddBorder" Property="Background" Value="#42a358" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <ToggleButton x:Name="AddPopupToggle"
                                  IsChecked="{Binding IsAddPopupOpen, Mode=TwoWay}"
                                  Cursor="Hand"
                                  Margin="0,0,0,0"
                                  Padding="0"
                                  Width="18"
                                  Height="22"
                                  FontFamily="Segoe MDL2 Assets"
                                  FontSize="8"
                                  Content="&#xE70D;"
                                  ToolTip="More options">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="ToggleBorder"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>

                    <Popup AllowsTransparency="True"
                           IsOpen="{Binding IsAddPopupOpen, Mode=TwoWay}"
                           StaysOpen="False"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=AddPopupToggle}"
                           PopupAnimation="Fade">
                        <Border Background="White"
                                BorderBrush="#BBB"
                                BorderThickness="1"
                                Padding="2"
                                MinWidth="180"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="#22000000"
                                                  BlurRadius="6"
                                                  ShadowDepth="2" />
                            </Border.Effect>
                            <StackPanel Orientation="Vertical">
                                <Button Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding AddConditionCommand}"
                                        Padding="8,4"
                                        HorizontalContentAlignment="Left"
                                        Content="Add condition" />
                                <Button Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding AddGroupCommand}"
                                        Padding="8,4"
                                        HorizontalContentAlignment="Left"
                                        Content="Add group" />
                                <Button Background="Transparent"
                                        BorderThickness="0"
                                        IsEnabled="False"
                                        Padding="8,4"
                                        HorizontalContentAlignment="Left"
                                        ToolTip="Coming soon"
                                        Content="Add custom expression" />
                            </StackPanel>
                        </Border>
                    </Popup>

                    <!--  Group-level remove (hidden for the root, which has no parent; otherwise visible on header hover)  -->
                    <Button BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding RemoveCommand}"
                            Margin="6,0,0,0"
                            Padding="0"
                            VerticalAlignment="Center"
                            Width="14"
                            Height="14"
                            FontSize="6"
                            FontFamily="Segoe Fluent Icons"
                            Content="&#xEF2C;"
                            ToolTip="Remove group">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Gray" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=GroupHeaderRow, Path=IsMouseOver}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#ed4341" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding Parent}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!--  Inline lossy-OR warning  -->
                <Border Background="#FFF4E5"
                        BorderBrush="#F0B27A"
                        BorderThickness="1"
                        Margin="0,4,0,0"
                        Padding="8,4"
                        CornerRadius="3">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasMixedColumnsWithOrOperator}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Foreground="#7A4F1B"
                               Text="Or / Not Or across multiple columns can't round-trip. The saved filter degrades to AND across columns."
                               TextWrapping="Wrap"
                               FontSize="11" />
                </Border>

                <!--  Recursive body. Indent nested groups by 24px.  -->
                <Border Margin="24,4,0,0">
                    <ItemsControl ItemsSource="{Binding Children}" ItemTemplateSelector="{StaticResource FilterEditorNodeTemplateSelector}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </Border>
    </DataTemplate>

    <!--
        FilterEditor default style. The recursive tree templates and chip control styles
        are picked up from Themes/Controls/FilterEditor/*.xaml merged in Generic.xaml.
    -->
    <Style x:Key="{x:Static sdg:SdgThemeKeys.FilterEditor}" TargetType="{x:Type sdg:FilterEditor}">
        <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:FilterEditor}">
                    <Border Background="{TemplateBinding Background}">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Body: recursive group tree, rooted at RootGroup  -->
                            <Border Grid.Row="0"
                                    Background="#F8F9FA"
                                    BorderBrush="#E1E5E9"
                                    BorderThickness="1"
                                    Padding="8"
                                    CornerRadius="3">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                    <ContentControl Content="{Binding RootGroup, RelativeSource={RelativeSource TemplatedParent}}" ContentTemplateSelector="{StaticResource FilterEditorNodeTemplateSelector}" />
                                </ScrollViewer>
                            </Border>

                            <!--  Footer: OK / Cancel / Apply  -->
                            <StackPanel Grid.Row="1"
                                        Orientation="Horizontal"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Right">
                                <Button Style="{StaticResource {x:Static sdg:SdgThemeKeys.PrimitivesButton}}"
                                        IsDefault="True"
                                        Command="{Binding OkCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,0,6,0"
                                        Padding="14,4"
                                        MinWidth="72"
                                        Content="OK" />
                                <Button Style="{StaticResource {x:Static sdg:SdgThemeKeys.PrimitivesButton}}"
                                        IsCancel="True"
                                        Command="{Binding CancelCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,0,6,0"
                                        Padding="14,4"
                                        MinWidth="72"
                                        Content="Cancel" />
                                <Button Style="{StaticResource {x:Static sdg:SdgThemeKeys.PrimitivesButton}}"
                                        Command="{Binding ApplyCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                        Padding="14,4"
                                        MinWidth="72"
                                        Content="Apply" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:SdgThemeKeys.FilterEditor}}" TargetType="{x:Type sdg:FilterEditor}" />

</ResourceDictionary>
