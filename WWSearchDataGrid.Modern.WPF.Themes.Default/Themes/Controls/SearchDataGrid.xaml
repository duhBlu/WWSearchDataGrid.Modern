<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:commands="clr-namespace:WWSearchDataGrid.Modern.WPF.Commands;assembly=WWSearchDataGrid.Modern.WPF"
                    xmlns:converters="clr-namespace:WWSearchDataGrid.Modern.WPF.Converters;assembly=WWSearchDataGrid.Modern.WPF"
                    xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/Primitives/DefaultControls.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/ColumnHeaderContextMenu.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/CellContextMenu.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/RowHeaderContextMenu.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/GridContextMenu.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/FilterPanel.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <converters:NullOrEmptyToBooleanConverter x:Key="NullOrEmptyToBooleanConverter" />
    <converters:BooleanToVisibilityCollapsedConverter x:Key="BooleanToVisibilityCollapsedConverter" />
    <converters:AutoFilterRowVisibilityConverter x:Key="AutoFilterRowVisibilityConverter" />

    <Style x:Key="{x:Static sdg:SdgThemeKeys.GridSelectAllButton}" TargetType="{x:Type Button}">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Width" Value="{Binding RowHeaderWidth, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="Border"
                                Background="#F0F0F0"
                                BorderBrush="#d0d0d0"
                                BorderThickness="0,0,1,1"
                                Margin="0,0,0,0" />
                        <Polygon x:Name="Arrow"
                                 Fill="#666"
                                 Opacity="0.5"
                                 Margin="8,8,3,3"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Bottom"
                                 Points="0,10 10,10 10,0"
                                 Stretch="Uniform" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Arrow" Property="Opacity" Value="0.8" />
                            <Setter TargetName="Border" Property="Background" Value="#E0F0FF" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Arrow" Property="Opacity" Value="1" />
                            <Setter TargetName="Border" Property="Background" Value="#CCE0FF" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Arrow" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="{x:Static sdg:SdgThemeKeys.GridSearchDataGridRowHeader}" TargetType="{x:Type DataGridRowHeader}">
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="#FF444444" />
        <Setter Property="Background" Value="#F9F9F9" />
        <Setter Property="BorderBrush" Value="#FFd0d0d0" />
        <Setter Property="BorderThickness" Value="1,0,1,1" />


        <Setter Property="ContextMenu" Value="{StaticResource {x:Static sdg:SdgThemeKeys.GridSearchDataGridRowHeaderContextMenu}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DataGridRowHeader}">
                    <Grid>
                        <Border x:Name="HeaderBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Margin="-1,0,0,0"
                                Padding="0,0,20,0">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>

                        <sdg:SdgIcon x:Name="RowStateIndicator"
                                     Width="10"
                                     Height="10"
                                     StrokeThickness="1.5"
                                     Visibility="Collapsed"
                                     IconBrush="{TemplateBinding Foreground}" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Background" Value="#FFF0F0F0" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}}" Value="True">
                            <Setter TargetName="RowStateIndicator" Property="IconSource" Value="{StaticResource {x:Static sdg:SdgIconKeys.IconChevronRight}}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}}" Value="True">
                            <Setter TargetName="RowStateIndicator" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsEditing, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}}" Value="True">
                            <Setter TargetName="RowStateIndicator" Property="IconSource" Value="{StaticResource {x:Static sdg:SdgIconKeys.IconEdit}}" />
                            <Setter TargetName="RowStateIndicator" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Default (implicit, TargetType-only) style for the custom headers presenter. The
        presenter calls DefaultStyleKeyProperty.OverrideMetadata(typeof(SearchDataGridColumnHeadersPresenter)),
        so WPF looks up a Style under the type key in this theme dictionary; without this
        entry the presenter has no Template, the column-headers band renders empty, and
        no SearchDataGridColumnHeader instances are produced.
        
        The control template retargets PART_FillerColumnHeader to SearchDataGridColumnHeader.
        The DataGrid pushes its ColumnHeaderStyle setter to the filler header at
        ApplyTemplate time; that setter's TargetType is SearchDataGridColumnHeader, so the
        stock DataGridColumnHeader filler would fail the strict TargetType check.
    -->
    <Style TargetType="{x:Type sdg:SearchDataGridColumnHeadersPresenter}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:SearchDataGridColumnHeadersPresenter}">
                    <Grid>
                        <sdg:SearchDataGridColumnHeader x:Name="PART_FillerColumnHeader" IsHitTestVisible="False" />
                        <ItemsPresenter />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="{x:Static sdg:SdgThemeKeys.GridSearchDataGridColumnHeader}" TargetType="{x:Type sdg:SearchDataGridColumnHeader}">
        <Setter Property="AllowDrop" Value="True" />
        <Setter Property="ContextMenu" Value="{StaticResource {x:Static sdg:SdgThemeKeys.GridSearchDataGridColumnHeaderContextMenu}}" />
        <Setter Property="Foreground" Value="#FF333333" />
        <Setter Property="Background" Value="#FFF9F9F9" />
        <Setter Property="BorderBrush" Value="#FFd0d0d0" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:SearchDataGridColumnHeader}">
                    <!--
                        Phase 5: the embedded ColumnSearchBox is removed entirely. The
                        DataGridColumnHeader template now hosts only the header chrome
                        (select-all checkbox, header text, sort arrow, gripper). The
                        per-column filter editor lives in the pinned AutoFilterRowPresenter
                        below the headers.
                    -->
                    <ControlTemplate.Resources>
                        <!--
                            Wider hit area for the column resizers without the default Thumb
                            chrome. Hit-test surface is the transparent Border; the visible
                            1px separator is drawn by the inner Border via TemplateBinding,
                            so each gripper's own BorderBrush/BorderThickness decide which
                            edge (if any) shows a line.
                        -->
                        <Style x:Key="ColumnHeaderGripperThumbStyle" TargetType="{x:Type Thumb}">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                SnapsToDevicePixels="True" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ControlTemplate.Resources>
                    <Grid>
                        <Border x:Name="HeaderBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,1,1"
                                Margin="0,0,0,0"
                                Padding="{TemplateBinding Padding}">
                            <!--
                                Layout: [select-all][header text Auto][filter button Auto][spacer *][sort arrow Auto].
                                Header text sizes to its content (Auto), filter button sits
                                immediately to its right at a fixed width, the * spacer absorbs
                                remaining horizontal space, and the sort arrow stays at the far
                                right. Whether the button is Opacity 0 or 1, the Auto column
                                still reserves its 22px slot — header text and sort arrow stay
                                put across hover transitions.
                            -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Select All Checkbox (visible only when IsSelectAllColumn is true AND column is boolean)  -->
                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center">

                                    <CheckBox x:Name="PART_SelectAllCheckBox"
                                              Style="{StaticResource {x:Static sdg:SdgThemeKeys.PrimitivesCheckBox}}"
                                              Visibility="Collapsed"
                                              VerticalAlignment="Center"
                                              IsThreeState="True" />

                                    <!--  Row Count Display (visible only when using SelectedRows scope)  -->
                                    <TextBlock x:Name="PART_SelectAllRowCount"
                                               Foreground="#666666"
                                               Visibility="Collapsed"
                                               Margin="0,0,0,2"
                                               VerticalAlignment="Center"
                                               FontSize="10" />
                                </StackPanel>

                                <!--  Header Content  -->
                                <ContentPresenter Grid.Column="1"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />

                                <Button x:Name="PART_RuleFilterEditorButton"
                                        Grid.Column="2"
                                        IsHitTestVisible="True"
                                        Focusable="False"
                                        Cursor="Hand"
                                        Command="{x:Static commands:ContextMenuCommands.ShowFilterEditorCommand}"
                                        CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="4,0,2,0"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        KeyboardNavigation.IsTabStop="False"
                                        ToolTip="Column Filter Editor">
                                    <sdg:SdgIcon Width="12"
                                                 Height="12"
                                                 IconSource="{StaticResource {x:Static sdg:SdgIconKeys.IconFilter}}"
                                                 IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Opacity" Value="0" />
                                            <Setter Property="Foreground" Value="DarkGray" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderBrush" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="3">
                                                            <ContentPresenter Focusable="False"
                                                                              Margin="{TemplateBinding Padding}"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"
                                                                              RecognizesAccessKey="True"
                                                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGridColumnHeader}}}" Value="True">
                                                    <Setter Property="Opacity" Value="1" />
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="Gray" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Foreground" Value="Black" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!--  Sort Arrow (Grid.Column=4, with the *-spacer at Column=3 pushing it right)  -->
                                <!--<TextBlock x:Name="SortArrow"
                                           Grid.Column="4"
                                           Foreground="{TemplateBinding Foreground}"
                                           Visibility="Collapsed"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe Fluent Icons" />-->

                                <sdg:SdgIcon x:Name="SortArrow"
                                             Grid.Column="4"
                                             Width="10"
                                             Height="10"
                                             StrokeThickness="1.2"
                                             IconBrush="{TemplateBinding Foreground}" />
                            </Grid>
                        </Border>

                        <!--
                            Column Resizers. Width is the grab target; the visible 1px
                            separator is drawn by the gripper's BorderBrush + BorderThickness
                            (see ColumnHeaderGripperThumbStyle above). Only the right gripper
                            draws a line — the boundary between cols N and N+1 is rendered by
                            col N's right gripper; col N+1's left gripper provides extra grab
                            area but stays invisible.
                        -->
                        <Thumb x:Name="PART_LeftHeaderGripper"
                               Style="{StaticResource ColumnHeaderGripperThumbStyle}"
                               Cursor="SizeWE"
                               HorizontalAlignment="Left"
                               Panel.ZIndex="55"
                               Width="6" />

                        <Thumb x:Name="PART_RightHeaderGripper"
                               Style="{StaticResource ColumnHeaderGripperThumbStyle}"
                               BorderBrush="{Binding VerticalGridLinesBrush, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}}"
                               BorderThickness="0,0,1,0"
                               Cursor="SizeWE"
                               HorizontalAlignment="Right"
                               Panel.ZIndex="55"
                               Width="6" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding ActualHasItems, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type sdg:SearchDataGrid}}}" Value="False">
                            <Setter TargetName="HeaderBorder" Property="BorderThickness" Value="0,0,0,1" />
                        </DataTrigger>

                        <!--  Sort Direction  -->
                        <Trigger Property="SortDirection" Value="Ascending">
                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SortArrow" Property="IconSource" Value="{StaticResource {x:Static sdg:SdgIconKeys.IconChevronUp}}" />
                        </Trigger>

                        <Trigger Property="SortDirection" Value="Descending">
                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SortArrow" Property="IconSource" Value="{StaticResource {x:Static sdg:SdgIconKeys.IconChevronDown}}" />
                        </Trigger>

                        <!--  Mouse States  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Background" Value="#FFF0F0F0" />
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Background" Value="#FFE0E0E0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="{x:Static sdg:SdgThemeKeys.GridSearchDataGridCell}" TargetType="{x:Type DataGridCell}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="ContextMenu" Value="{StaticResource {x:Static sdg:SdgThemeKeys.GridSearchDataGridCellContextMenu}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DataGridCell}">
                    <Grid>
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <Border BorderBrush="{Binding VerticalGridLinesBrush, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                BorderThickness="0,0,1,0"
                                Visibility="{Binding ShowVerticalGridLines, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}"
                                IsHitTestVisible="False" />
                        <Border BorderBrush="{Binding HorizontalGridLinesBrush, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                BorderThickness="0,0,0,1"
                                Visibility="{Binding ShowHorizontalGridLines, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}"
                                IsHitTestVisible="False" />
                        <!--  Focus indicator — keyboard-focused cell.  -->
                        <Border x:Name="FocusBorder"
                                BorderBrush="#0078D4"
                                BorderThickness="1"
                                Visibility="Collapsed"
                                IsHitTestVisible="False" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="FocusBorder" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True" />
                    <Condition Property="IsSelected" Value="False" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="#E8E8E8" />
            </MultiTrigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#CCE4F7" />
                <Setter Property="Foreground" Value="#1C1C1C" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsSelected" Value="True" />
                    <Condition Property="IsMouseOver" Value="True" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="#B3D7F2" />
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsSelected" Value="True" />
                    <Condition Property="Selector.IsSelectionActive" Value="False" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="#EDEDED" />
                <Setter Property="Foreground" Value="#1C1C1C" />
            </MultiTrigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="#999999" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="{x:Static sdg:SdgThemeKeys.GridSearchDataGridRow}" TargetType="{x:Type DataGridRow}">
        <Setter Property="Background" Value="{Binding RowBackground, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" />
        <Setter Property="ValidationErrorTemplate" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DataGridRow}">
                    <Border x:Name="DGR_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <SelectiveScrollingGrid>
                            <SelectiveScrollingGrid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </SelectiveScrollingGrid.ColumnDefinitions>
                            <SelectiveScrollingGrid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </SelectiveScrollingGrid.RowDefinitions>

                            <DataGridCellsPresenter Grid.Column="1" ItemsPanel="{TemplateBinding ItemsPanel}" />

                            <DataGridDetailsPresenter Grid.Row="1"
                                                      Grid.Column="1"
                                                      Visibility="{TemplateBinding DetailsVisibility}"
                                                      SelectiveScrollingGrid.SelectiveScrollingOrientation="{Binding AreRowDetailsFrozen, ConverterParameter={x:Static SelectiveScrollingOrientation.Vertical}, Converter={x:Static DataGrid.RowDetailsScrollingConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" />

                            <DataGridRowHeader Grid.RowSpan="2"
                                               Visibility="{Binding HeadersVisibility, ConverterParameter={x:Static DataGridHeadersVisibility.Row}, Converter={x:Static DataGrid.HeadersVisibilityConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                               SelectiveScrollingGrid.SelectiveScrollingOrientation="Vertical" />
                        </SelectiveScrollingGrid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="{x:Static sdg:SdgThemeKeys.GridSearchDataGrid}" TargetType="{x:Type sdg:SearchDataGrid}">
        <Setter Property="CellStyle" Value="{StaticResource {x:Static sdg:SdgThemeKeys.GridSearchDataGridCell}}" />
        <Setter Property="RowStyle" Value="{StaticResource {x:Static sdg:SdgThemeKeys.GridSearchDataGridRow}}" />
        <Setter Property="ContextMenu" Value="{StaticResource {x:Static sdg:SdgThemeKeys.GridSearchDataGridContextMenu}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:SearchDataGrid}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ScrollViewer x:Name="DG_ScrollViewer"
                                          Grid.Row="0"
                                          Focusable="false"
                                          Padding="0,0,1,1"
                                          sdg:HorizontalScrollBehavior.EnableShiftMouseWheelScroll="True"
                                          CanContentScroll="true">
                                <ScrollViewer.Template>
                                    <ControlTemplate TargetType="ScrollViewer">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>


                                            <!--  Per-Column Select All  -->
                                            <Button Style="{StaticResource {x:Static sdg:SdgThemeKeys.GridSelectAllButton}}"
                                                    Focusable="false"
                                                    Command="{x:Static DataGrid.SelectAllCommand}"
                                                    Panel.ZIndex="2" />

                                            <!--
                                                Filler under the SelectAllButton, aligned with the pinned
                                                AutoFilterRowPresenter. Without this, Row 1 / Column 0
                                                renders empty (SearchDataGrid Background bleeds through),
                                                leaving a visible gap to the left of the filter row at the
                                                row-header column. Visibility mirrors the filter row so the
                                                gap is only filled when the filter row is showing.
                                            -->
                                            <Border Grid.Row="1"
                                                    Grid.Column="0"
                                                    Background="#FFf9f9f9"
                                                    BorderBrush="#FFd0d0d0"
                                                    BorderThickness="0,0,1,1"
                                                    UseLayoutRounding="True"
                                                    SnapsToDevicePixels="True">
                                                <Border.Visibility>
                                                    <MultiBinding Converter="{StaticResource AutoFilterRowVisibilityConverter}">
                                                        <Binding RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" Path="ShowAutoFilterRow" />
                                                        <Binding RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" Path="AutoFilterRowPosition" />
                                                    </MultiBinding>
                                                </Border.Visibility>
                                                <sdg:SdgIcon Width="12"
                                                             Height="12"
                                                             IconSource="{StaticResource {x:Static sdg:SdgIconKeys.IconFilter}}"
                                                             IconBrush="Gray" />
                                            </Border>

                                            <!--
                                                Column Headers. Use the custom presenter so the
                                                column header containers are SearchDataGridColumnHeader
                                                instances rather than stock DataGridColumnHeader. The
                                                custom header type carries the OnClick override that
                                                suppresses sort when the click originated on an
                                                interactive child (the filter-popup button).
                                            -->
                                            <sdg:SearchDataGridColumnHeadersPresenter x:Name="PART_ColumnHeadersPresenter"
                                                                                      Grid.Column="1"
                                                                                      Margin="0,0,0,0" />

                                            <!--
                                                Pinned filter row. Lives in the same template grid-column
                                                as PART_ColumnHeadersPresenter so the horizontal scroll
                                                view applied by the ScrollViewer's clip and the
                                                FilterRowPanel's own offset binding stay aligned at the
                                                frozen-column boundary. Phase 2 hosts placeholder borders;
                                                Phase 3 swaps in ColumnFilterControl instances.
                                            -->
                                            <sdg:AutoFilterRowPresenter x:Name="PART_AutoFilterRow"
                                                                        Style="{StaticResource {x:Static sdg:SdgThemeKeys.FilterRowAutoFilterRowPresenter}}"
                                                                        Grid.Row="1"
                                                                        Grid.Column="1">
                                                <sdg:AutoFilterRowPresenter.Visibility>
                                                    <MultiBinding Converter="{StaticResource AutoFilterRowVisibilityConverter}">
                                                        <Binding RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" Path="ShowAutoFilterRow" />
                                                        <Binding RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" Path="AutoFilterRowPosition" />
                                                    </MultiBinding>
                                                </sdg:AutoFilterRowPresenter.Visibility>
                                            </sdg:AutoFilterRowPresenter>

                                            <!--
                                                Header-bottom separator. Shifted to row 2 (top edge of
                                                content) so it sits BELOW the filter row, not between the
                                                headers and the filter row. The negative top margin keeps
                                                it overlapping the header / filter-row gridline at the
                                                content seam.
                                            -->
                                            <Border x:Name="PART_ColumnHeaderBottomBorder"
                                                    Grid.Row="2"
                                                    Grid.Column="1"
                                                    Background="#d0d0d0"
                                                    Margin="0,-1,0,0"
                                                    VerticalAlignment="Top"
                                                    Panel.ZIndex="2"
                                                    Height="1" />

                                            <!--  Rows  -->
                                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                                    Grid.Row="2"
                                                                    Grid.ColumnSpan="2"
                                                                    Margin="0,0,-1,0"
                                                                    CanContentScroll="{TemplateBinding CanContentScroll}" />

                                            <!--
                                                Placeholder: top-right gap above the vertical scrollbar.
                                                Two sibling borders — one per band — each living in its
                                                own outer row so it stretches to that row's actual height
                                                without any ActualHeight binding. Avoids the RowSpan=2 +
                                                ActualHeight-binding feedback loop the previous wrapper
                                                Grid created: ActualHeight updates post-arrange, the
                                                spanner re-measures, and Row 0's height ends up coupled
                                                to Row 1's transient filter-row state. Left edge is
                                                provided by ContentRightSeparator below.
                                            -->
                                            <Border Grid.Row="0"
                                                    Grid.Column="2"
                                                    Background="#F9F9F9"
                                                    BorderBrush="#FFd0d0d0"
                                                    BorderThickness="1,0,0,1"
                                                    Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                                    Margin="-1,0,0,0"
                                                    UseLayoutRounding="True"
                                                    SnapsToDevicePixels="True" />
                                            <Border Grid.Row="1"
                                                    Grid.Column="2"
                                                    Background="#ffffff"
                                                    BorderBrush="#FFd0d0d0"
                                                    BorderThickness="1,0,0,1"
                                                    Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                                    Margin="-1,0,0,0"
                                                    UseLayoutRounding="True"
                                                    SnapsToDevicePixels="True" />


                                            <!--  Scrollbars  -->
                                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                                       Grid.Row="2"
                                                       Grid.Column="2"
                                                       Orientation="Vertical"
                                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                                       Maximum="{TemplateBinding ScrollableHeight}"
                                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                                       Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}" />
                                            <Grid Grid.Row="3" Grid.Column="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="{Binding NonFrozenColumnsViewportHorizontalOffset, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <ScrollBar x:Name="PART_HorizontalScrollBar"
                                                           Grid.Column="1"
                                                           Orientation="Horizontal"
                                                           Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                                           Maximum="{TemplateBinding ScrollableWidth}"
                                                           ViewportSize="{TemplateBinding ViewportWidth}"
                                                           Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}" />
                                            </Grid>

                                            <!--
                                                Placeholder: bottom-left gap (below row header area, left of horizontal scrollbar).
                                                Matches row header background. Top edge is provided by
                                                ContentBottomSeparator below — only the col0/col1 internal
                                                separator stays (right BorderThickness=1).
                                            -->
                                            <Border Grid.Row="3"
                                                    Grid.Column="0"
                                                    Background="#F9F9F9"
                                                    BorderBrush="#FFd0d0d0"
                                                    BorderThickness="0,1,1,0"
                                                    Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                                    Margin="0,-1,0,0" />
                                            <!--
                                                Placeholder: bottom-right corner (intersection of both scrollbars).
                                                Keeps its own left + top edges because the two separators below stop
                                                at the col1/col2 and row1/row2 boundaries — those edges of the corner
                                                live entirely inside col 2 / row 2 where the separators don't reach.
                                            -->
                                            <Border Grid.Row="3"
                                                    Grid.Column="2"
                                                    Background="#F9F9F9"
                                                    BorderBrush="#FFd0d0d0"
                                                    BorderThickness="1,1,0,0"
                                                    Margin="-1,-1,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding ComputedVerticalScrollBarVisibility, RelativeSource={RelativeSource TemplatedParent}}" Value="Visible" />
                                                                    <Condition Binding="{Binding ComputedHorizontalScrollBarVisibility, RelativeSource={RelativeSource TemplatedParent}}" Value="Visible" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>

                                            <!--<Border x:Name="ContentRightSeparator"
                                                    Grid.Row="0"
                                                    Grid.RowSpan="3"
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="2"
                                                    BorderBrush="#FFd0d0d0"
                                                    BorderThickness="0,0,1,0"
                                                    Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                                    IsHitTestVisible="False"
                                                    Margin="0,0,0,0"
                                                    Panel.ZIndex="3"
                                                    UseLayoutRounding="True"
                                                    SnapsToDevicePixels="True" />
                                            <Border x:Name="ContentBottomSeparator"
                                                    Grid.Row="0"
                                                    Grid.RowSpan="3"
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="2"
                                                    BorderBrush="#FFd0d0d0"
                                                    BorderThickness="0,0,0,1"
                                                    Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                                    IsHitTestVisible="False"
                                                    Panel.ZIndex="3"
                                                    UseLayoutRounding="True"
                                                    SnapsToDevicePixels="True" />-->
                                        </Grid>
                                    </ControlTemplate>
                                </ScrollViewer.Template>
                                <ItemsPresenter />
                            </ScrollViewer>

                            <!--  FilterPanel  -->
                            <sdg:FilterPanel x:Name="PART_FilterPanel"
                                             Style="{StaticResource {x:Static sdg:SdgThemeKeys.FilterPanel}}"
                                             Grid.Row="1" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Background" Value="White" />
        <Setter Property="RowHeaderStyle" Value="{StaticResource {x:Static sdg:SdgThemeKeys.GridSearchDataGridRowHeader}}" />
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource {x:Static sdg:SdgThemeKeys.GridSearchDataGridColumnHeader}}" />
        <Setter Property="RowHeaderWidth" Value="24" />
        <Setter Property="BorderBrush" Value="#FFd0d0d0" />
        <!--
            Explicit BorderThickness=1 on all sides. Control.BorderThickness defaults to
            Thickness(0) and DataGrid doesn't OverrideMetadata for it — without this setter
            the outer perimeter is invisible, which is why the bottom edge disappears when the
            horizontal scrollbar collapses (the ContentBottomSeparator was the only thing
            drawing a bottom line). The separator handles the seam between content and
            scrollbars when they're visible; this outer Border handles the perimeter at all
            times, including when scrollbars collapse and the separator goes with them.
        -->
        <Setter Property="BorderThickness" Value="1" />
        <!--
            Cascades pixel-snapped layout to every descendant. Without this, individual cells
            and rows can land at sub-pixel positions while the separator (already snapped via
            UseLayoutRounding on its own element) sits one device pixel further out — leaving
            a 1px sliver of cell content visible past the separator at the saturated-scroll
            edge. Forces the entire visual tree onto integer device pixels so the cell's outer
            gridline and the separator land on the same pixel reliably.
        -->
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="RowBackground" Value="White" />
        <Setter Property="AlternatingRowBackground" Value="#FFF9F9F9" />
        <Setter Property="HorizontalGridLinesBrush" Value="#FFd0d0d0" />
        <Setter Property="VerticalGridLinesBrush" Value="#FFd0d0d0" />


        <Setter Property="HeadersVisibility" Value="All" />
        <Setter Property="GridLinesVisibility" Value="None" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="CanUserResizeRows" Value="False" />
        <Setter Property="CanUserReorderColumns" Value="True" />
        <Setter Property="CanUserResizeColumns" Value="True" />
        <Setter Property="CanUserSortColumns" Value="True" />
        <Setter Property="IsSynchronizedWithCurrentItem" Value="True" />


        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="SelectionMode" Value="Extended" />
        <Setter Property="SelectionUnit" Value="FullRow" />
        <Setter Property="EnableRowVirtualization" Value="True" />
        <Setter Property="EnableColumnVirtualization" Value="True" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.IsVirtualizingWhenGrouping" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Item" />
        <Setter Property="ScrollViewer.IsDeferredScrollingEnabled" Value="False" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:SdgThemeKeys.GridSearchDataGrid}}" TargetType="{x:Type sdg:SearchDataGrid}" />
</ResourceDictionary>