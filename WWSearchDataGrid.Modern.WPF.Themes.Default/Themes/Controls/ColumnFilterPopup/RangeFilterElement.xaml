<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdgCore="clr-namespace:WWSearchDataGrid.Modern.Core;assembly=WWSearchDataGrid.Modern.Core"
                    xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
                    xmlns:converters="clr-namespace:WWSearchDataGrid.Modern.WPF.Converters;assembly=WWSearchDataGrid.Modern.WPF">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/Primitives/DefaultControls.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/Primitives/SearchTextBox.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/Primitives/NumericUpDown.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Themes/Controls/Primitives/RangeSlider.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <converters:NullableNumericFallbackConverter x:Key="NullableNumericFallbackConverter" />

    <!--  Layout for Number columns: range slider + numeric upDown low/high  -->
    <DataTemplate x:Key="RangeFilterElement.NumberLayout">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <sdg:RangeSlider Grid.Row="0"
                                Style="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesRangeSlider}}"
                                Margin="2,4,2,10"
                                Minimum="{Binding SliderMinimum, RelativeSource={RelativeSource AncestorType={x:Type sdg:RangeFilterElement}}}"
                                Maximum="{Binding SliderMaximum, RelativeSource={RelativeSource AncestorType={x:Type sdg:RangeFilterElement}}}">
                <sdg:RangeSlider.LowValue>
                    <MultiBinding Converter="{StaticResource NullableNumericFallbackConverter}"
                                  Mode="TwoWay"
                                  UpdateSourceTrigger="PropertyChanged">
                        <Binding Path="SelectedValue" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" />
                        <Binding Path="SliderMinimum" Mode="OneWay"
                                 RelativeSource="{RelativeSource AncestorType={x:Type sdg:RangeFilterElement}}" />
                    </MultiBinding>
                </sdg:RangeSlider.LowValue>
                <sdg:RangeSlider.HighValue>
                    <MultiBinding Converter="{StaticResource NullableNumericFallbackConverter}"
                                  Mode="TwoWay"
                                  UpdateSourceTrigger="PropertyChanged">
                        <Binding Path="SelectedSecondaryValue" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" />
                        <Binding Path="SliderMaximum" Mode="OneWay"
                                 RelativeSource="{RelativeSource AncestorType={x:Type sdg:RangeFilterElement}}" />
                    </MultiBinding>
                </sdg:RangeSlider.HighValue>
            </sdg:RangeSlider>

            <Grid Grid.Row="1" Grid.RowSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Grid.Row="0"
                           Foreground="#666666"
                           Text="From"
                           Margin="0,0,0,2"
                           FontSize="11" />
                <TextBlock Grid.Column="2" Grid.Row="0"
                           Foreground="#666666"
                           Text="To"
                           Margin="0,0,0,2"
                           FontSize="11" />

                <sdg:NumericUpDown Grid.Column="0" Grid.Row="1"
                                   Style="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesNumericUpDown}}"
                                   HorizontalAlignment="Stretch"
                                   Value="{Binding SelectedValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <sdg:NumericUpDown Grid.Column="2" Grid.Row="1"
                                   Style="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesNumericUpDown}}"
                                   HorizontalAlignment="Stretch"
                                   Value="{Binding SelectedSecondaryValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </Grid>
    </DataTemplate>

    <!--  Layout for DateTime columns: two segmented date editors  -->
    <DataTemplate x:Key="RangeFilterElement.DateTimeLayout">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Column="0" Grid.Row="0"
                       Foreground="#666666"
                       Text="From"
                       Margin="0,0,0,2"
                       FontSize="11" />
            <TextBlock Grid.Column="2" Grid.Row="0"
                       Foreground="#666666"
                       Text="To"
                       Margin="0,0,0,2"
                       FontSize="11" />

            <sdg:SegmentedDateTimeEditor Grid.Column="0" Grid.Row="1"
                                         HorizontalAlignment="Stretch"
                                         IsFilterRowEditor="True"
                                         MaskType="DateTime"
                                         Mask="{Binding SearchTemplateController.DisplayMaskPattern, TargetNullValue=d, FallbackValue=d}"
                                         Value="{Binding SelectedValue}" />
            <sdg:SegmentedDateTimeEditor Grid.Column="2" Grid.Row="1"
                                         HorizontalAlignment="Stretch"
                                         IsFilterRowEditor="True"
                                         MaskType="DateTime"
                                         Mask="{Binding SearchTemplateController.DisplayMaskPattern, TargetNullValue=d, FallbackValue=d}"
                                         Value="{Binding SelectedSecondaryValue}" />
        </Grid>
    </DataTemplate>

    <!--  Fallback layout for String / Unknown / Enum / Boolean columns: two SearchTextBoxes  -->
    <DataTemplate x:Key="RangeFilterElement.StringLayout">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Column="0" Grid.Row="0"
                       Foreground="#666666"
                       Text="From"
                       Margin="0,0,0,2"
                       FontSize="11" />
            <TextBlock Grid.Column="2" Grid.Row="0"
                       Foreground="#666666"
                       Text="To"
                       Margin="0,0,0,2"
                       FontSize="11" />

            <sdg:SearchTextBox Grid.Column="0" Grid.Row="1"
                               Style="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesSearchTextBox}}"
                               Text="{Binding SelectedValue, UpdateSourceTrigger=LostFocus}"
                               HorizontalAlignment="Stretch"
                               ItemsSource="{Binding SearchTemplateController.DisplayColumnValues}"
                               ShowClearButton="False"
                               ShowToggleButton="True"
                               PreserveValueOnSourceChange="True"
                               Watermark="Enter or select..." />
            <sdg:SearchTextBox Grid.Column="2" Grid.Row="1"
                               Style="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesSearchTextBox}}"
                               Text="{Binding SelectedSecondaryValue, UpdateSourceTrigger=LostFocus}"
                               HorizontalAlignment="Stretch"
                               ItemsSource="{Binding SearchTemplateController.DisplayColumnValues}"
                               ShowClearButton="False"
                               ShowToggleButton="True"
                               PreserveValueOnSourceChange="True"
                               Watermark="Enter or select..." />
        </Grid>
    </DataTemplate>

    <Style TargetType="{x:Type sdg:RangeFilterElement}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{x:Static SystemColors.WindowTextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinWidth" Value="280" />
        <Setter Property="MinHeight" Value="60" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:RangeFilterElement}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4">
                        <!--
                            DataContext is the underlying SearchTemplate so the inner templates
                            can bind to SelectedValue / SelectedSecondaryValue directly. Layout
                            switches on the hosting element's ColumnDataType DP.
                        -->
                        <Border Background="{x:Static SystemColors.WindowBrush}"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1"
                                CornerRadius="4"
                                ClipToBounds="True">
                            <ContentControl Margin="8"
                                            Content="{Binding SearchTemplate, RelativeSource={RelativeSource TemplatedParent}}">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Setter Property="ContentTemplate" Value="{StaticResource RangeFilterElement.StringLayout}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ColumnDataType, RelativeSource={RelativeSource AncestorType={x:Type sdg:RangeFilterElement}}}" Value="Number">
                                                <Setter Property="ContentTemplate" Value="{StaticResource RangeFilterElement.NumberLayout}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ColumnDataType, RelativeSource={RelativeSource AncestorType={x:Type sdg:RangeFilterElement}}}" Value="DateTime">
                                                <Setter Property="ContentTemplate" Value="{StaticResource RangeFilterElement.DateTimeLayout}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
