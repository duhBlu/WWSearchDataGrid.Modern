<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Resources/Icons/Icons.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        Separator inside a Menu/ContextMenu — WPF auto-looks up MenuItem.SeparatorStyleKey
        on every <Separator /> placed in a menu's items collection, so defining the style
        under that key automatically restyles every separator inside our menus.
    -->
    <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="{x:Type Separator}">
        <Setter Property="Background" Value="#FFE5E7EB" />
        <Setter Property="Margin" Value="6,4" />
        <Setter Property="Height" Value="1" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Border Background="{TemplateBinding Background}" Height="{TemplateBinding Height}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Modern flat MenuItem template for items hosted in an SDG context menu.

        Layout columns:  [ Icon (20) | Header (*) | Gesture (Auto) | SubmenuChevron (Auto) ]

        Roles handled:
            • SubmenuItem    — default leaf, no chevron, no popup
            • SubmenuHeader  — chevron visible, Popup carries nested ItemsPresenter

        Visual states:
            • IsHighlighted  — light gray pill background, 4px corner radius
            • IsEnabled=False — muted foreground and chevron

        Note: the icon column keeps its 20px reservation even when MenuItem.Icon is null,
        so every item in a menu — iconned or not — lines up on the same vertical guideline.
    -->
    <Style x:Key="{x:Static sdg:ThemeKeys.PrimitivesMenuItem}" TargetType="{x:Type MenuItem}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Grid>
                        <Border x:Name="HighlightBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True" />
                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="IconCol" Width="20" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  Icon column. Templated Icon content (MenuItem.Icon) plugs in here.  -->
                            <ContentPresenter x:Name="IconHost"
                                              Grid.Column="0"
                                              ContentSource="Icon"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Width="14"
                                              Height="14"
                                              SnapsToDevicePixels="True" />

                            <!--  Header text. RecognizesAccessKey enables _Mnemonics in the header.  -->
                            <ContentPresenter Grid.Column="1"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              Margin="8,0,16,0"
                                              SnapsToDevicePixels="True" />

                            <!--  Optional gesture text (Ctrl+C, etc.) — muted, right-aligned.  -->
                            <TextBlock x:Name="GestureText"
                                       Grid.Column="2"
                                       Text="{TemplateBinding InputGestureText}"
                                       Foreground="#888888"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />

                            <!--  Submenu chevron — visible only on SubmenuHeader role.  -->
                            <Path x:Name="SubmenuChevron"
                                  Grid.Column="3"
                                  Visibility="Collapsed"
                                  Data="M 0,0 L 4,4 L 0,8 Z"
                                  Fill="#888888"
                                  Width="6"
                                  Height="10"
                                  Stretch="Fill"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Right"
                                  Margin="0,0,2,0" />
                        </Grid>

                        <!--  Submenu popup. Rendered only when this item is a SubmenuHeader.  -->
                        <Popup x:Name="SubMenuPopup"
                               AllowsTransparency="True"
                               IsOpen="{TemplateBinding IsSubmenuOpen}"
                               Placement="Right"
                               HorizontalOffset="-4"
                               VerticalOffset="-4"
                               Focusable="False"
                               PopupAnimation="Fade">
                            <Grid Margin="0,0,8,8">
                                <Border CornerRadius="6"
                                        Background="#FFFFFFFF"
                                        BorderBrush="#FFE0E0E0"
                                        BorderThickness="1"
                                        Padding="4"
                                        SnapsToDevicePixels="True">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000"
                                                          Opacity="0.18"
                                                          BlurRadius="10"
                                                          ShadowDepth="2" />
                                    </Border.Effect>
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" SnapsToDevicePixels="True" />
                                </Border>
                            </Grid>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="SubmenuChevron" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="HighlightBorder" Property="Background" Value="#FFF0F0F0" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#FF9CA3AF" />
                            <Setter TargetName="GestureText" Property="Foreground" Value="#FFC4C7CC" />
                            <Setter TargetName="SubmenuChevron" Property="Fill" Value="#FFC4C7CC" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Modern flat ContextMenu shell. AllowsTransparency=True (inherited via HasDropShadow=False
        below) lets the rounded Border + drop shadow render without the popup clipping them.
    -->
    <Style x:Key="{x:Static sdg:ThemeKeys.PrimitivesContextMenu}" TargetType="{x:Type ContextMenu}">
        <!--
            Implicit MenuItem style scoped to this ContextMenu only. We can't use
            ItemContainerStyle here because the ContextMenu's items collection holds both
            MenuItem and Separator instances, and a MenuItem-typed ItemContainerStyle will
            throw when WPF tries to apply it to a Separator. The Style.Resources approach
            keeps the styling targeted: MenuItem children pick it up via implicit lookup;
            Separator continues to use MenuItem.SeparatorStyleKey from the merged dictionary.
        -->
        <Style.Resources>
            <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesMenuItem}}" />
        </Style.Resources>
        <Setter Property="Background" Value="#FFFFFFFF" />
        <Setter Property="BorderBrush" Value="#FFE0E0E0" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="HasDropShadow" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <!--  Outer margin gives the shadow room to render inside the popup surface.  -->
                    <Grid Margin="0,0,8,8">
                        <Border CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000"
                                                  Opacity="0.18"
                                                  BlurRadius="10"
                                                  ShadowDepth="2" />
                            </Border.Effect>
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" SnapsToDevicePixels="True" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
