<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF.Themes.Default;component/Resources/Icons/Icons.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--#region Button Style-->

    <Style x:Key="{x:Static sdg:ThemeKeys.PrimitivesButton}" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="BorderBrush" Value="#e3e3e3" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1,1,1,0"
                            CornerRadius="4">
                        <Border x:Name="innerBorder"
                                Background="Transparent"
                                BorderBrush="#bfbfbf"
                                BorderThickness="0,0,0,0.8"
                                Margin="0,0,0,-1"
                                CornerRadius="4">

                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#f0f0f0" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#d6d6d6" />
                            <Setter TargetName="innerBorder" Property="BorderBrush" Value="#b4b4b4" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#f7f7f7" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#ebebeb" />
                            <Setter TargetName="innerBorder" Property="BorderBrush" Value="#c5c5c5" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#F5F5F5" />
                            <Setter Property="Foreground" Value="#999999" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

    <!--#region CheckBox Style-->

    <Style x:Key="{x:Static sdg:ThemeKeys.PrimitivesCheckBox}" TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="#AAAAAA" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="6,0,0,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="Box"
                                Grid.Column="0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                VerticalAlignment="Center"
                                Width="16"
                                Height="16"
                                CornerRadius="3">
                            <Grid>
                                <sdg:Icon x:Name="CheckGlyph"
                                             Opacity="0"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Width="10"
                                             Height="10"
                                             StrokeThickness="3"
                                             IconSource="{StaticResource {x:Static sdg:IconKeys.IconCheck}}"
                                             IconBrush="White" />
                                <sdg:Icon x:Name="IndeterminateGlyph"
                                             Opacity="0"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Width="10"
                                             Height="10"
                                             IconBrush="#FFFFFF"
                                             IconSource="{StaticResource {x:Static sdg:IconKeys.IconCheckIntermediate}}" />
                            </Grid>
                        </Border>

                        <ContentPresenter Grid.Column="1"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="#0078D4" />
                            <Setter TargetName="Box" Property="BorderThickness" Value="0" />
                            <Setter TargetName="Box" Property="Padding" Value="1" />
                            <Setter TargetName="CheckGlyph" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="Box" Property="Background" Value="#0078D4" />
                            <Setter TargetName="Box" Property="BorderThickness" Value="0" />
                            <Setter TargetName="Box" Property="Padding" Value="1" />
                            <Setter TargetName="IndeterminateGlyph" Property="Opacity" Value="1" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Box" Property="BorderBrush" Value="#0078D4" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Box" Property="Background" Value="#005A9E" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#999999" />
                            <Setter TargetName="Box" Property="Background" Value="#F5F5F5" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="#CCCCCC" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

    <!--#region Resize Thumb Style-->

    <Style x:Key="{x:Static sdg:ThemeKeys.PrimitivesResizeThumb}" TargetType="{x:Type Thumb}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border Background="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

    <!--#region ToggleButton Style-->

    <!--
        Pill toggle — same chrome language as PrimitivesButton, but the checked state fills with
        the accent (white glyph) so an on/off state reads at a glance. Used by the summary
        text-styling editor's Bold / Italic / Underline toggles.
    -->
    <Style x:Key="{x:Static sdg:ThemeKeys.PrimitivesToggleButton}" TargetType="{x:Type ToggleButton}">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="BorderBrush" Value="#e3e3e3" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="MinWidth" Value="30" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#f0f0f0" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#d6d6d6" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#0078D4" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#0078D4" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border" Property="Background" Value="#005A9E" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#005A9E" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#F5F5F5" />
                            <Setter Property="Foreground" Value="#999999" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

    <!--#region Dropdown Item Styles-->

    <!--
        Shared "dropdown row" look used everywhere a popup lists pickable items —
        ComboBoxItem in PrimitivesComboBox, ListBoxItem in SearchTextBox suggestions
        and FilterEditor token popups. Visuals track PrimitivesMenuItem so every
        list-of-things in the library reads as the same control.

            Padding 8,5  |  CornerRadius 4  |  Foreground #1C1C1C  |  FontSize 12
            Hover    #F0F0F0     (subtle gray pill, matches MenuItem.IsHighlighted)
            Selected #E5F1FB     (accent tint, derived from PrimitivesComboBox focus blue)
            Sel+Over #D6E8F8     (one step darker on hover-over-selected)
            Disabled #9CA3AF foreground
    -->
    <Style x:Key="{x:Static sdg:ThemeKeys.PrimitivesComboBoxItem}" TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#F0F0F0" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#E5F1FB" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="IsHighlighted" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="#D6E8F8" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#9CA3AF" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="{x:Static sdg:ThemeKeys.PrimitivesListBoxItem}" TargetType="{x:Type ListBoxItem}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#F0F0F0" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#E5F1FB" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="#D6E8F8" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#9CA3AF" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

    <!--#region ComboBox Style-->

    <Style x:Key="{x:Static sdg:ThemeKeys.PrimitivesComboBox}" TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="BorderBrush" Value="#e3e3e3" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesComboBoxItem}}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid x:Name="LayoutRoot">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                        </Grid.ColumnDefinitions>

                        <!--  Background (spans both columns) — top/left/right only, bottom drawn by InnerBorder  -->
                        <Border x:Name="Background"
                            Grid.ColumnSpan="2"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1,1,1,0"
                            CornerRadius="3" />

                        <!--  Inner border — subtle bottom lip for depth (mirrors PrimitivesButton)  -->
                        <Border x:Name="InnerBorder"
                            Grid.ColumnSpan="2"
                            Background="Transparent"
                            BorderBrush="#bfbfbf"
                            BorderThickness="0,0,0,0.8"
                            Margin="0,0,0,0"
                            CornerRadius="3"
                            IsHitTestVisible="False" />

                        <!--  Selected content (column 0 only)  -->
                        <ContentPresenter x:Name="ContentPresenter"
                                      Grid.Column="0"
                                      IsHitTestVisible="False"
                                      Margin="4,2,0,2"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />

                        <!--  Toggle (transparent hit area, spans full width)  -->
                        <ToggleButton x:Name="ToggleButton"
                                  Grid.ColumnSpan="2"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Style>
                                <Style TargetType="{x:Type ToggleButton}">
                                    <Setter Property="OverridesDefaultStyle" Value="True" />
                                    <Setter Property="IsTabStop" Value="False" />
                                    <Setter Property="Focusable" Value="False" />
                                    <Setter Property="ClickMode" Value="Release" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="3" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>

                        <!--  Chevron (column 1, pass-through)  -->
                        <sdg:Icon x:Name="Arrow"
                                 Grid.Column="1"
                                 IsHitTestVisible="False"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Width="10"
                                 Height="10"
                                 StrokeThickness="1"
                                 IconSource="{StaticResource {x:Static sdg:IconKeys.IconChevronDown}}"
                                 IconBrush="{TemplateBinding Foreground}" />

                        <!--
                            Editable text — shown by the IsEditable trigger below (an editable
                            ComboBox renders its Text through this part; SelectionBoxItem stays
                            empty, so the ContentPresenter alone would show nothing). Chromeless
                            template: the combo's own Background/InnerBorder provide the chrome.
                            Declared after the ToggleButton so column-0 clicks reach the caret;
                            the chevron column still toggles the dropdown.
                        -->
                        <TextBox x:Name="PART_EditableTextBox"
                             Grid.Column="0"
                             Background="Transparent"
                             Visibility="Hidden"
                             IsReadOnly="{TemplateBinding IsReadOnly}"
                             Focusable="True"
                             VerticalContentAlignment="Center"
                             Margin="4,2,0,2">
                            <TextBox.Style>
                                <Style TargetType="{x:Type TextBox}">
                                    <Setter Property="OverridesDefaultStyle" Value="True" />
                                    <Setter Property="SelectionBrush" Value="#0078D4" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type TextBox}">
                                                <ScrollViewer x:Name="PART_ContentHost"
                                                              Background="Transparent"
                                                              Focusable="False"
                                                              HorizontalScrollBarVisibility="Hidden"
                                                              VerticalScrollBarVisibility="Hidden" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!--  Dropdown  -->
                        <Popup x:Name="PART_Popup"
                           AllowsTransparency="True"
                           IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                           Placement="Bottom"
                           StaysOpen="False"
                           PopupAnimation="Slide"
                           VerticalOffset="-12"
                           HorizontalOffset="-12"
                           PlacementTarget="{Binding ElementName=Background}">
                            <Border Padding="12">
                                <Border Background="Transparent">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000"
                                                      Opacity="0.2"
                                                      BlurRadius="12"
                                                      ShadowDepth="2"
                                                      Direction="270" />
                                    </Border.Effect>
                                    <Border Background="#FFFFFF"
                                        BorderBrush="#CCCCCC"
                                        BorderThickness="1"
                                        Padding="2"
                                        MinWidth="{Binding ActualWidth, ElementName=LayoutRoot}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        CornerRadius="3">
                                        <ScrollViewer>
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Border>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!--  Editable: text renders through PART_EditableTextBox instead of the
                              SelectionBoxItem presenter (which WPF leaves empty when editable).  -->
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ContentPresenter" Property="Visibility" Value="Hidden" />
                        </Trigger>
                        <!--  Hover — mirrors PrimitivesButton IsMouseOver  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Background" Property="Background" Value="#f0f0f0" />
                            <Setter TargetName="Background" Property="BorderBrush" Value="#d6d6d6" />
                            <Setter TargetName="InnerBorder" Property="BorderBrush" Value="#b4b4b4" />
                        </Trigger>
                        <!--  Open — analog of PrimitivesButton IsPressed  -->
                        <Trigger SourceName="ToggleButton" Property="IsChecked" Value="True">
                            <Setter TargetName="Background" Property="Background" Value="#f7f7f7" />
                            <Setter TargetName="Background" Property="BorderBrush" Value="#ebebeb" />
                            <Setter TargetName="InnerBorder" Property="BorderBrush" Value="#c5c5c5" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Background" Property="Background" Value="#F5F5F5" />
                            <Setter Property="Foreground" Value="#999999" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!--#endregion-->

    <!--#region TextBox Style-->

    <!--
        Plain text input matching the PrimitivesComboBox chrome — same border, corner radius,
        bottom-lip depth cue, and metrics. Focus swaps the lip for an accent underline
        (the same #0078D4 the tab strip and selection tints derive from).
    -->
    <Style x:Key="{x:Static sdg:ThemeKeys.PrimitivesTextBox}" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="BorderBrush" Value="#e3e3e3" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SelectionBrush" Value="#0078D4" />
        <Setter Property="CaretBrush" Value="#1C1C1C" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Grid>
                        <!--  Background — top/left/right only, bottom drawn by InnerBorder  -->
                        <Border x:Name="Background"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="3" />

                        <!--  Inner border — subtle bottom lip for depth (mirrors PrimitivesComboBox)  -->
                        <Border x:Name="InnerBorder"
                                Background="Transparent"
                                BorderBrush="#bfbfbf"
                                BorderThickness="0,0,0,1"
                                Margin="0,0,0,0"
                                CornerRadius="0,0,4,4"
                                Height="2"
                                VerticalAlignment="Bottom"
                                IsHitTestVisible="False" />

                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Background="Transparent"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Background" Property="BorderBrush" Value="#d6d6d6" />
                            <Setter TargetName="InnerBorder" Property="BorderBrush" Value="#b4b4b4" />
                        </Trigger>
                        <!--  Focus accent underline; listed after hover so it wins while typing  -->
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Background" Property="BorderBrush" Value="#d6d6d6" />
                            <Setter TargetName="InnerBorder" Property="Background" Value="#0179d4" />
                            <Setter TargetName="InnerBorder" Property="BorderBrush" Value="#0078D4" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Background" Property="Background" Value="#F5F5F5" />
                            <Setter Property="Foreground" Value="#999999" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

    <!--#region TabControl & TabItem Style-->

    <Style x:Key="{x:Static sdg:ThemeKeys.PrimitivesTabControl}" TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="Transparent"
                                Margin="-0,-0,-0,0"
                                Padding="4,4,0,0"
                                CornerRadius="4,4,0,0 ">

                            <TabPanel Background="Transparent"
                                      HorizontalAlignment="Center"
                                      IsItemsHost="True" />
                        </Border>
                        <Border Grid.Row="1"
                                BorderBrush="#AAAAAA"
                                BorderThickness="0,0,0,1"
                                Margin="0" />
                        <ContentPresenter Grid.Row="2"
                                          Margin="0,0,0,0"
                                          ContentSource="SelectedContent" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="{x:Static sdg:ThemeKeys.PrimitivesTabItem}" TargetType="{x:Type TabItem}">
        <Setter Property="Foreground" Value="#666666" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabItem}">
                    <Border x:Name="TabBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="0,0,0,2"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          TextElement.FontWeight="{TemplateBinding FontWeight}"
                                          ContentSource="Header" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="#0078D4" />
                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="#0078D4" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsSelected" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="#1C1C1C" />
                            <Setter TargetName="TabBorder" Property="Background" Value="#E8E8E8" />
                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="#E8E8E8" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

    <!--#region ScrollBar Style-->

    <!--  Vertical ScrollBar Context Menu  -->

    <Style x:Key="{x:Static sdg:ThemeKeys.PrimitivesScrollBar}" TargetType="{x:Type ScrollBar}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid Width="12" ClipToBounds="False">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="14" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="14" />
                        </Grid.RowDefinitions>

                        <!--  Always-visible track  -->
                        <Border x:Name="TrackBackground"
                                Grid.RowSpan="3"
                                Background="#FFFFFF"
                                BorderBrush="#CCCCCC"
                                CornerRadius="0" />

                        <!--  Line-Up button  -->
                        <RepeatButton x:Name="PART_LineUpButton"
                                      OverridesDefaultStyle="True"
                                      Grid.Row="0"
                                      Focusable="False"
                                      Command="ScrollBar.LineUpCommand"
                                      IsTabStop="False">
                            <RepeatButton.Template>
                                <ControlTemplate TargetType="{x:Type RepeatButton}">
                                    <Border Background="Transparent" CornerRadius="4,4,0,0">
                                        <sdg:Icon IconSource="{StaticResource {x:Static sdg:IconKeys.IconCaretUp}}" IconBrush="#646464" Width="8" Height="8" />
                                    </Border>
                                </ControlTemplate>
                            </RepeatButton.Template>
                        </RepeatButton>

                        <!--  Track + Thumb  -->
                        <Track x:Name="PART_Track"
                               Grid.Row="1"
                               Focusable="False"
                               ClipToBounds="False"
                               IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand">
                                    <RepeatButton.Style>
                                        <Style TargetType="{x:Type RepeatButton}">
                                            <Setter Property="OverridesDefaultStyle" Value="True" />
                                            <Setter Property="Focusable" Value="False" />
                                            <Setter Property="IsTabStop" Value="False" />
                                            <Setter Property="ClipToBounds" Value="False" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                        <Border Background="Transparent" />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </RepeatButton.Style>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>

                            <Track.Thumb>
                                <Thumb OverridesDefaultStyle="True"
                                       Margin="0,-2,0,-2"
                                       MinHeight="12"
                                       IsTabStop="False"
                                       ClipToBounds="False">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="{x:Type Thumb}">
                                            <Border x:Name="ThumbVisual"
                                                    Background="#646464"
                                                    Margin="2"
                                                    CornerRadius="4" />
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ThumbVisual" Property="Background" Value="#646464" />
                                                </Trigger>
                                                <Trigger Property="IsDragging" Value="True">
                                                    <Setter TargetName="ThumbVisual" Property="Background" Value="#646464" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>

                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand">
                                    <RepeatButton.Style>
                                        <Style TargetType="{x:Type RepeatButton}">
                                            <Setter Property="OverridesDefaultStyle" Value="True" />
                                            <Setter Property="Focusable" Value="False" />
                                            <Setter Property="IsTabStop" Value="False" />
                                            <Setter Property="ClipToBounds" Value="False" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                        <Border Background="Transparent" />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </RepeatButton.Style>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                        </Track>

                        <!--  Line-Down button  -->
                        <RepeatButton x:Name="PART_LineDownButton"
                                      OverridesDefaultStyle="True"
                                      Grid.Row="2"
                                      Focusable="False"
                                      Command="ScrollBar.LineDownCommand"
                                      IsTabStop="False">
                            <RepeatButton.Template>
                                <ControlTemplate TargetType="{x:Type RepeatButton}">
                                    <Border Background="Transparent" CornerRadius="0,0,4,4">
                                        <sdg:Icon IconSource="{StaticResource {x:Static sdg:IconKeys.IconCaretDown}}" IconBrush="#646464" Width="8" Height="8" />
                                    </Border>
                                </ControlTemplate>
                            </RepeatButton.Template>
                        </RepeatButton>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TrackBackground" Property="Background" Value="Transparent" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ContextMenu">
            <Setter.Value>
                <ContextMenu>
                    <MenuItem Command="ScrollBar.ScrollHereCommand"
                              CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                              Header="Scroll Here" />
                    <Separator Background="#E0E0E0" />
                    <MenuItem Command="ScrollBar.ScrollToTopCommand"
                              CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                              Header="Top" />
                    <MenuItem Command="ScrollBar.ScrollToBottomCommand"
                              CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                              Header="Bottom" />
                    <Separator Background="#E0E0E0" />
                    <MenuItem Command="ScrollBar.PageUpCommand"
                              CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                              Header="Page Up" />
                    <MenuItem Command="ScrollBar.PageDownCommand"
                              CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                              Header="Page Down" />
                    <Separator Background="#E0E0E0" />
                    <MenuItem Command="ScrollBar.LineUpCommand"
                              CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                              Header="Scroll Up" />
                    <MenuItem Command="ScrollBar.LineDownCommand"
                              CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                              Header="Scroll Down" />
                </ContextMenu>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Grid Height="12" ClipToBounds="False">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                </Grid.ColumnDefinitions>

                                <!--  Always-visible track  -->
                                <Border x:Name="TrackBackground"
                                        Grid.ColumnSpan="3"
                                        Background="Transparent"
                                        CornerRadius="6" />

                                <!--  Line-Left button  -->
                                <RepeatButton x:Name="PART_LineLeftButton"
                                              OverridesDefaultStyle="True"
                                              Grid.Column="0"
                                              Focusable="False"
                                              Command="ScrollBar.LineLeftCommand"
                                              IsTabStop="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                                            <Border Background="Transparent" CornerRadius="4,0,0,4">
                                                <sdg:Icon IconSource="{StaticResource {x:Static sdg:IconKeys.IconCaretLeft}}" IconBrush="#646464" Width="8" Height="8" />
                                            </Border>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>

                                <!--  Track + Thumb  -->
                                <Track x:Name="PART_Track"
                                       Grid.Column="1"
                                       Focusable="False"
                                       ClipToBounds="False"
                                       IsDirectionReversed="False">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageLeftCommand">
                                            <RepeatButton.Style>
                                                <Style TargetType="{x:Type RepeatButton}">
                                                    <Setter Property="OverridesDefaultStyle" Value="True" />
                                                    <Setter Property="Focusable" Value="False" />
                                                    <Setter Property="IsTabStop" Value="False" />
                                                    <Setter Property="ClipToBounds" Value="False" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                                <Border Background="Transparent" />
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </RepeatButton.Style>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>

                                    <Track.Thumb>
                                        <Thumb OverridesDefaultStyle="True"
                                               Margin="-2,0,-2,0"
                                               MinWidth="12"
                                               IsTabStop="False"
                                               ClipToBounds="False">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="{x:Type Thumb}">
                                                    <Border x:Name="ThumbVisual"
                                                            Background="#646464"
                                                            Margin="2"
                                                            CornerRadius="4" />
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ThumbVisual" Property="Background" Value="#646464" />
                                                        </Trigger>
                                                        <Trigger Property="IsDragging" Value="True">
                                                            <Setter TargetName="ThumbVisual" Property="Background" Value="#646464" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>

                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageRightCommand">
                                            <RepeatButton.Style>
                                                <Style TargetType="{x:Type RepeatButton}">
                                                    <Setter Property="OverridesDefaultStyle" Value="True" />
                                                    <Setter Property="Focusable" Value="False" />
                                                    <Setter Property="IsTabStop" Value="False" />
                                                    <Setter Property="ClipToBounds" Value="False" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                                <Border Background="Transparent" />
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </RepeatButton.Style>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>
                                </Track>

                                <!--  Line-Right button  -->
                                <RepeatButton x:Name="PART_LineRightButton"
                                              OverridesDefaultStyle="True"
                                              Grid.Column="2"
                                              Focusable="False"
                                              Command="ScrollBar.LineRightCommand"
                                              IsTabStop="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                                            <Border Background="Transparent" CornerRadius="0,4,4,0">
                                                <sdg:Icon IconSource="{StaticResource {x:Static sdg:IconKeys.IconCaretRight}}" IconBrush="#646464" Width="8" Height="8" />
                                            </Border>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TrackBackground" Property="Background" Value="Transparent" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="ContextMenu">
                    <Setter.Value>
                        <ContextMenu>
                            <MenuItem Command="ScrollBar.ScrollHereCommand"
                                      CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                                      Header="Scroll Here" />
                            <Separator Background="#E0E0E0" />
                            <MenuItem Command="ScrollBar.ScrollToLeftEndCommand"
                                      CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                                      Header="Left" />
                            <MenuItem Command="ScrollBar.ScrollToRightEndCommand"
                                      CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                                      Header="Right" />
                            <Separator Background="#E0E0E0" />
                            <MenuItem Command="ScrollBar.PageLeftCommand"
                                      CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                                      Header="Page Left" />
                            <MenuItem Command="ScrollBar.PageRightCommand"
                                      CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                                      Header="Page Right" />
                            <Separator Background="#E0E0E0" />
                            <MenuItem Command="ScrollBar.LineLeftCommand"
                                      CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                                      Header="Scroll Left" />
                            <MenuItem Command="ScrollBar.LineRightCommand"
                                      CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                                      Header="Scroll Right" />
                        </ContextMenu>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  Implicit: every ScrollBar inside a control that merges DefaultControls picks this up  -->
    <Style BasedOn="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesScrollBar}}" TargetType="{x:Type ScrollBar}" />

    <!--#endregion-->

</ResourceDictionary>
