<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF">


    <!--#region Button Style-->

    <Style x:Key="{x:Static sdg:SdgThemeKeys.PrimitivesButton}" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="BorderBrush" Value="#e3e3e3" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1,1,1,0"
                            CornerRadius="4">
                        <Border x:Name="innerBorder" Background="Transparent" BorderBrush="#bfbfbf" BorderThickness="0,0,0,1" CornerRadius="4">
                            
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#f0f0f0" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#d6d6d6" />
                            <Setter TargetName="innerBorder" Property="BorderBrush" Value="#b4b4b4" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#f7f7f7" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#ebebeb" />
                            <Setter TargetName="innerBorder" Property="BorderBrush" Value="#c5c5c5" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#F5F5F5" />
                            <Setter Property="Foreground" Value="#999999" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

    <!--#region CheckBox Style-->

    <Style x:Key="{x:Static sdg:SdgThemeKeys.PrimitivesCheckBox}" TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="#AAAAAA" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="6,0,0,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="Box"
                                Grid.Column="0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                VerticalAlignment="Center"
                                Width="16"
                                Height="16"
                                CornerRadius="3">
                            <TextBlock x:Name="Glyph"
                                       Foreground="#FFFFFF"
                                       Opacity="0"
                                       Text="&#xE73E;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="12" />
                        </Border>

                        <ContentPresenter Grid.Column="1"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="#0078D4" />
                            <Setter TargetName="Box" Property="BorderThickness" Value="0" />
                            <Setter TargetName="Box" Property="Padding" Value="1" />
                            <Setter TargetName="Glyph" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="Box" Property="Background" Value="#0078D4" />
                            <Setter TargetName="Box" Property="BorderThickness" Value="0" />
                            <Setter TargetName="Box" Property="Padding" Value="1" />
                            <Setter TargetName="Glyph" Property="Text" Value="&#xE738;" />
                            <Setter TargetName="Glyph" Property="FontSize" Value="10" />
                            <Setter TargetName="Glyph" Property="Opacity" Value="1" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Box" Property="BorderBrush" Value="#0078D4" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Box" Property="Background" Value="#005A9E" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#999999" />
                            <Setter TargetName="Box" Property="Background" Value="#F5F5F5" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="#CCCCCC" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

    <!--#region Resize Thumb Style-->

    <Style x:Key="{x:Static sdg:SdgThemeKeys.PrimitivesResizeThumb}" TargetType="{x:Type Thumb}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border Background="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

    <!--#region ComboBox Style-->


    <Style x:Key="{x:Static sdg:SdgThemeKeys.PrimitivesComboBox}" TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="BorderBrush" Value="#CCCCCC" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid x:Name="LayoutRoot">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                        </Grid.ColumnDefinitions>

                        <!--  Background (spans both columns)  -->
                        <Border x:Name="Background"
                                Grid.ColumnSpan="2"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" />

                        <!--  Selected content (column 0 only)  -->
                        <ContentPresenter x:Name="ContentPresenter"
                                          Grid.Column="0"
                                          IsHitTestVisible="False"
                                          Margin="4,2,0,2"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />

                        <!--  Toggle (transparent hit area, spans full width)  -->
                        <ToggleButton x:Name="ToggleButton"
                                      Grid.ColumnSpan="2"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Style>
                                <Style TargetType="{x:Type ToggleButton}">
                                    <Setter Property="OverridesDefaultStyle" Value="True" />
                                    <Setter Property="IsTabStop" Value="False" />
                                    <Setter Property="Focusable" Value="False" />
                                    <Setter Property="ClickMode" Value="Release" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="3" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>

                        <!--  Chevron (column 1, pass-through)  -->
                        <TextBlock x:Name="Arrow"
                                   Grid.Column="1"
                                   Text="&#xE70D;"
                                   IsHitTestVisible="False"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe Fluent Icons" />

                        <!--  Editable text (hidden for standard combo)  -->
                        <TextBox x:Name="PART_EditableTextBox"
                                 Style="{x:Null}"
                                 Grid.Column="0"
                                 Background="Transparent"
                                 Visibility="Hidden"
                                 IsReadOnly="{TemplateBinding IsReadOnly}"
                                 Focusable="True"
                                 Margin="{TemplateBinding Padding}" />

                        <!--  Dropdown  -->
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                               Placement="Bottom"
                               StaysOpen="False"
                               PopupAnimation="Slide"
                               VerticalOffset="-4"
                               HorizontalOffset="-4"
                               PlacementTarget="{Binding ElementName=Background}">
                            <Border Padding="4">
                                <Border Background="Transparent">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000"
                                                          Opacity="0.2"
                                                          BlurRadius="12"
                                                          ShadowDepth="2"
                                                          Direction="270" />
                                    </Border.Effect>
                                    <Border Background="#FFFFFF"
                                            BorderBrush="#CCCCCC"
                                            BorderThickness="1"
                                            Padding="2"
                                            MinWidth="{Binding ActualWidth, ElementName=LayoutRoot}"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                            CornerRadius="3">
                                        <ScrollViewer>
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Border>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Background" Property="Background" Value="#F8F9FA" />
                            <Setter TargetName="Background" Property="BorderBrush" Value="#AAAAAA" />
                        </Trigger>
                        <Trigger SourceName="ToggleButton" Property="IsChecked" Value="True">
                            <Setter TargetName="Background" Property="BorderBrush" Value="#0078D4" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#999999" />
                            <Setter TargetName="Arrow" Property="Foreground" Value="#999999" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Resources>
            <Style TargetType="{x:Type ComboBoxItem}">
                <Setter Property="Padding" Value="4,2" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                            <Border x:Name="Bd"
                                    Background="Transparent"
                                    Padding="{TemplateBinding Padding}"
                                    CornerRadius="2">
                                <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#E8E8E8" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#E8E8E8" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Style.Resources>
    </Style>

    <!--#endregion-->

    <!--#region TabControl & TabItem Style-->

    <Style x:Key="{x:Static sdg:SdgThemeKeys.PrimitivesTabControl}" TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="#F0F0F0"
                                Margin="-0,-0,-0,0"
                                Padding="4,4,0,0"
                                CornerRadius="4,4,0,0 ">

                            <TabPanel Background="Transparent"
                                      HorizontalAlignment="Center"
                                      IsItemsHost="True" />
                        </Border>
                        <Border Grid.Row="1"
                                BorderBrush="#AAAAAA"
                                BorderThickness="0,0,0,1"
                                Margin="0" />
                        <ContentPresenter Grid.Row="2"
                                          Margin="0,0,0,0"
                                          ContentSource="SelectedContent" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="{x:Static sdg:SdgThemeKeys.PrimitivesTabItem}" TargetType="{x:Type TabItem}">
        <Setter Property="Foreground" Value="#666666" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabItem}">
                    <Border x:Name="TabBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="0,0,0,2"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          TextElement.FontWeight="{TemplateBinding FontWeight}"
                                          ContentSource="Header" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="#0078D4" />
                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="#0078D4" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsSelected" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="#1C1C1C" />
                            <Setter TargetName="TabBorder" Property="Background" Value="#E8E8E8" />
                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="#E8E8E8" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

    <!--#region ScrollBar Style-->

    <!--  Vertical ScrollBar Context Menu  -->

    <Style x:Key="{x:Static sdg:SdgThemeKeys.PrimitivesScrollBar}" TargetType="{x:Type ScrollBar}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid Width="12" ClipToBounds="False">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="14" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="14" />
                        </Grid.RowDefinitions>

                        <!--  Always-visible track  -->
                        <Border x:Name="TrackBackground"
                                Grid.RowSpan="3"
                                BorderBrush="#CCCCCC"
                                Background="Transparent"
                                CornerRadius="0" />

                        <!--  Line-Up button  -->
                        <RepeatButton x:Name="PART_LineUpButton"
                                      OverridesDefaultStyle="True"
                                      Grid.Row="0"
                                      Focusable="False"
                                      Command="ScrollBar.LineUpCommand"
                                      IsTabStop="False">
                            <RepeatButton.Template>
                                <ControlTemplate TargetType="{x:Type RepeatButton}">
                                    <Border Background="Transparent" CornerRadius="4,4,0,0">
                                        <TextBlock Foreground="#646464"
                                                   Text="&#xEDDB;"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="8" />
                                    </Border>
                                </ControlTemplate>
                            </RepeatButton.Template>
                        </RepeatButton>

                        <!--  Track + Thumb  -->
                        <Track x:Name="PART_Track"
                               Grid.Row="1"
                               Focusable="False"
                               ClipToBounds="False"
                               IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand">
                                    <RepeatButton.Style>
                                        <Style TargetType="{x:Type RepeatButton}">
                                            <Setter Property="OverridesDefaultStyle" Value="True" />
                                            <Setter Property="Focusable" Value="False" />
                                            <Setter Property="IsTabStop" Value="False" />
                                            <Setter Property="ClipToBounds" Value="False" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                        <Border Background="Transparent" />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </RepeatButton.Style>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>

                            <Track.Thumb>
                                <Thumb OverridesDefaultStyle="True"
                                       Margin="0,-2,0,-2"
                                       MinHeight="12"
                                       IsTabStop="False"
                                       ClipToBounds="False">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="{x:Type Thumb}">
                                            <Border x:Name="ThumbVisual"
                                                    Background="#646464"
                                                    Margin="2"
                                                    CornerRadius="4" />
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ThumbVisual" Property="Background" Value="#646464" />
                                                </Trigger>
                                                <Trigger Property="IsDragging" Value="True">
                                                    <Setter TargetName="ThumbVisual" Property="Background" Value="#646464" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>

                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand">
                                    <RepeatButton.Style>
                                        <Style TargetType="{x:Type RepeatButton}">
                                            <Setter Property="OverridesDefaultStyle" Value="True" />
                                            <Setter Property="Focusable" Value="False" />
                                            <Setter Property="IsTabStop" Value="False" />
                                            <Setter Property="ClipToBounds" Value="False" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                        <Border Background="Transparent" />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </RepeatButton.Style>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                        </Track>

                        <!--  Line-Down button  -->
                        <RepeatButton x:Name="PART_LineDownButton"
                                      OverridesDefaultStyle="True"
                                      Grid.Row="2"
                                      Focusable="False"
                                      Command="ScrollBar.LineDownCommand"
                                      IsTabStop="False">
                            <RepeatButton.Template>
                                <ControlTemplate TargetType="{x:Type RepeatButton}">
                                    <Border Background="Transparent" CornerRadius="0,0,4,4">
                                        <TextBlock Foreground="#646464"
                                                   Text="&#xEDDC;"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="8" />
                                    </Border>
                                </ControlTemplate>
                            </RepeatButton.Template>
                        </RepeatButton>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TrackBackground" Property="Background" Value="Transparent" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ContextMenu">
            <Setter.Value>
                <ContextMenu>
                    <MenuItem Command="ScrollBar.ScrollHereCommand"
                              CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                              Header="Scroll Here" />
                    <Separator Background="#E0E0E0" />
                    <MenuItem Command="ScrollBar.ScrollToTopCommand"
                              CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                              Header="Top" />
                    <MenuItem Command="ScrollBar.ScrollToBottomCommand"
                              CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                              Header="Bottom" />
                    <Separator Background="#E0E0E0" />
                    <MenuItem Command="ScrollBar.PageUpCommand"
                              CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                              Header="Page Up" />
                    <MenuItem Command="ScrollBar.PageDownCommand"
                              CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                              Header="Page Down" />
                    <Separator Background="#E0E0E0" />
                    <MenuItem Command="ScrollBar.LineUpCommand"
                              CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                              Header="Scroll Up" />
                    <MenuItem Command="ScrollBar.LineDownCommand"
                              CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                              Header="Scroll Down" />
                </ContextMenu>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Grid Height="12" ClipToBounds="False">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                </Grid.ColumnDefinitions>

                                <!--  Always-visible track  -->
                                <Border x:Name="TrackBackground"
                                        Grid.ColumnSpan="3"
                                        Background="Transparent"
                                        CornerRadius="6" />

                                <!--  Line-Left button  -->
                                <RepeatButton x:Name="PART_LineLeftButton"
                                              OverridesDefaultStyle="True"
                                              Grid.Column="0"
                                              Focusable="False"
                                              Command="ScrollBar.LineLeftCommand"
                                              IsTabStop="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                                            <Border Background="Transparent" CornerRadius="4,0,0,4">
                                                <TextBlock Foreground="#646464"
                                                           Text="&#xEDD9;"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                           FontSize="8" />
                                            </Border>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>

                                <!--  Track + Thumb  -->
                                <Track x:Name="PART_Track"
                                       Grid.Column="1"
                                       Focusable="False"
                                       ClipToBounds="False"
                                       IsDirectionReversed="False">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageLeftCommand" >
                                            <RepeatButton.Style>
                                                <Style TargetType="{x:Type RepeatButton}">
                                                    <Setter Property="OverridesDefaultStyle" Value="True" />
                                                    <Setter Property="Focusable" Value="False" />
                                                    <Setter Property="IsTabStop" Value="False" />
                                                    <Setter Property="ClipToBounds" Value="False" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                                <Border Background="Transparent" />
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </RepeatButton.Style>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>

                                    <Track.Thumb>
                                        <Thumb OverridesDefaultStyle="True"
                                               Margin="-2,0,-2,0"
                                               MinWidth="12"
                                               IsTabStop="False"
                                               ClipToBounds="False">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="{x:Type Thumb}">
                                                    <Border x:Name="ThumbVisual"
                                                            Background="#646464"
                                                            Margin="2"
                                                            CornerRadius="4" />
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ThumbVisual" Property="Background" Value="#646464" />
                                                        </Trigger>
                                                        <Trigger Property="IsDragging" Value="True">
                                                            <Setter TargetName="ThumbVisual" Property="Background" Value="#646464" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>

                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageRightCommand" >
                                            <RepeatButton.Style>
                                                <Style TargetType="{x:Type RepeatButton}">
                                                    <Setter Property="OverridesDefaultStyle" Value="True" />
                                                    <Setter Property="Focusable" Value="False" />
                                                    <Setter Property="IsTabStop" Value="False" />
                                                    <Setter Property="ClipToBounds" Value="False" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                                <Border Background="Transparent" />
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </RepeatButton.Style>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>
                                </Track>

                                <!--  Line-Right button  -->
                                <RepeatButton x:Name="PART_LineRightButton"
                                              OverridesDefaultStyle="True"
                                              Grid.Column="2"
                                              Focusable="False"
                                              Command="ScrollBar.LineRightCommand"
                                              IsTabStop="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                                            <Border Background="Transparent" CornerRadius="0,4,4,0">
                                                <TextBlock Foreground="#646464"
                                                           Text="&#xEDDA;"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                           FontSize="8" />
                                            </Border>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TrackBackground" Property="Background" Value="Transparent" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="ContextMenu">
                    <Setter.Value>
                        <ContextMenu>
                            <MenuItem Command="ScrollBar.ScrollHereCommand"
                                      CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                                      Header="Scroll Here" />
                            <Separator Background="#E0E0E0" />
                            <MenuItem Command="ScrollBar.ScrollToLeftEndCommand"
                                      CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                                      Header="Left" />
                            <MenuItem Command="ScrollBar.ScrollToRightEndCommand"
                                      CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                                      Header="Right" />
                            <Separator Background="#E0E0E0" />
                            <MenuItem Command="ScrollBar.PageLeftCommand"
                                      CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                                      Header="Page Left" />
                            <MenuItem Command="ScrollBar.PageRightCommand"
                                      CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                                      Header="Page Right" />
                            <Separator Background="#E0E0E0" />
                            <MenuItem Command="ScrollBar.LineLeftCommand"
                                      CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                                      Header="Scroll Left" />
                            <MenuItem Command="ScrollBar.LineRightCommand"
                                      CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                                      Header="Scroll Right" />
                        </ContextMenu>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  Implicit: every ScrollBar inside a control that merges DefaultControls picks this up  -->
    <Style BasedOn="{StaticResource {x:Static sdg:SdgThemeKeys.PrimitivesScrollBar}}" TargetType="{x:Type ScrollBar}" />

    <!--#endregion-->

</ResourceDictionary>
