<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF">

    <!--
        The library's generic window chrome (PrimitivesWindow) — borderless DWM window with
        rounded corners, drop shadow, and accent border (sdg:DwmWindowHelper), plus a 30px
        caption row with Min / Max / Close buttons. Applied by every window the library opens
        (Filter Editor, group summary editor, Column Chooser) via WindowHostHelper, which also
        registers the SystemCommands bindings the caption buttons invoke. Consumer windows can
        use the style too — they must provide those command bindings themselves (class-level
        registration in App startup, or per-window).
    -->

    <!--  Caption-bar button (Min / Max)  -->
    <Style x:Key="PrimitivesWindowChromeButtonStyle" TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#666666" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#E5E5E5" />
                            <Setter Property="Foreground" Value="#333333" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#CCCCCC" />
                            <Setter Property="Foreground" Value="#000000" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Close button — red hover  -->
    <Style x:Key="PrimitivesWindowChromeCloseButtonStyle"
           BasedOn="{StaticResource PrimitivesWindowChromeButtonStyle}"
           TargetType="Button">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#E81123" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#C50F1F" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="{x:Static sdg:ThemeKeys.PrimitivesWindow}" TargetType="{x:Type Window}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="WindowStyle" Value="None" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, sans-serif" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="MinWidth" Value="150" />

        <!--  DWM: drop shadow, rounded corners, accent border, taskbar-respecting maximize  -->
        <Setter Property="sdg:DwmWindowHelper.IsEnabled" Value="True" />
        <Setter Property="sdg:DwmWindowHelper.EnableDropShadow" Value="True" />
        <Setter Property="sdg:DwmWindowHelper.BorderColor">
            <Setter.Value>
                <Color>#0078D4</Color>
            </Setter.Value>
        </Setter>
        <Setter Property="sdg:DwmWindowHelper.BorderColorInactive">
            <Setter.Value>
                <Color>#DDDDDD</Color>
            </Setter.Value>
        </Setter>
        <Setter Property="sdg:DwmWindowHelper.CornerPreference" Value="Round" />
        <Setter Property="sdg:DwmWindowHelper.RespectTaskbar" Value="True" />

        <Setter Property="WindowChrome.WindowChrome">
            <Setter.Value>
                <WindowChrome CaptionHeight="30"
                              GlassFrameThickness="0"
                              UseAeroCaptionButtons="False"
                              CornerRadius="0"
                              ResizeBorderThickness="4" />
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Window}">
                    <Grid x:Name="WindowGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  TITLE BAR  -->
                        <Border x:Name="TitleBarBorder"
                                Grid.Row="0"
                                BorderThickness="0">
                            <DockPanel x:Name="TitleBar" Background="#F8F9FA">

                                <!--  CLOSE  -->
                                <Button x:Name="CloseButton"
                                        Style="{StaticResource PrimitivesWindowChromeCloseButtonStyle}"
                                        DockPanel.Dock="Right"
                                        Command="{x:Static SystemCommands.CloseWindowCommand}"
                                        Padding="15,0"
                                        Content="&#xE711;"
                                        WindowChrome.IsHitTestVisibleInChrome="True"
                                        FontWeight="Normal"
                                        RenderOptions.BitmapScalingMode="NearestNeighbor"
                                        FontSize="14"
                                        FontFamily="Segoe MDL2 Assets" />

                                <!--  MAX / RESTORE — shown when the window is resizable  -->
                                <Button x:Name="MaxButton"
                                        Style="{StaticResource PrimitivesWindowChromeButtonStyle}"
                                        DockPanel.Dock="Right"
                                        Visibility="Collapsed"
                                        Command="{x:Static SystemCommands.MaximizeWindowCommand}"
                                        Padding="15,0"
                                        Content="&#xE922;"
                                        FontSize="10"
                                        FontWeight="Thin"
                                        FontFamily="Segoe MDL2 Assets" />

                                <!--  MIN — shown only for taskbar windows (a non-taskbar dialog
                                      has nowhere sensible to minimize to)  -->
                                <Button x:Name="MinButton"
                                        Style="{StaticResource PrimitivesWindowChromeButtonStyle}"
                                        DockPanel.Dock="Right"
                                        Visibility="Collapsed"
                                        Command="{x:Static SystemCommands.MinimizeWindowCommand}"
                                        Padding="15,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Top"
                                        Content="&#xE921;"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="10"
                                        FontWeight="Thin" />

                                <!--  Icon + Title  -->
                                <Image x:Name="IconImage"
                                       Source="{TemplateBinding Icon}"
                                       Margin="10,0,0,0"
                                       Width="16"
                                       Height="16"
                                       RenderOptions.BitmapScalingMode="HighQuality" />

                                <TextBlock Foreground="#1C1C1C"
                                           Text="{TemplateBinding Title}"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold" />

                                <!--  Filler  -->
                                <Border DockPanel.Dock="Left" Background="Transparent" />
                            </DockPanel>
                        </Border>

                        <!--  CONTENT  -->
                        <!--  AdornerDecorator: the default Window template includes one, but this
                              custom chrome template replaces the whole tree. Without it,
                              AdornerLayer.GetAdornerLayer(child) returns null for anything inside
                              ContentBorder, which makes GridSplitter (ShowsPreview=True), Popup
                              positioning, and validation adorners throw NREs.  -->
                        <Border x:Name="ContentBorder"
                                Grid.Row="1"
                                Background="#FFFFFF"
                                ClipToBounds="True">
                            <AdornerDecorator>
                                <ContentPresenter />
                            </AdornerDecorator>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!--  No icon set → don't reserve the 16px slot  -->
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="IconImage" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!--  Max button tracks resizability  -->
                        <Trigger Property="ResizeMode" Value="CanResize">
                            <Setter TargetName="MaxButton" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="ResizeMode" Value="CanResizeWithGrip">
                            <Setter TargetName="MaxButton" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <!--  Min button additionally requires a taskbar presence  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ResizeMode" Value="CanResize" />
                                <Condition Property="ShowInTaskbar" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="MinButton" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ResizeMode" Value="CanResizeWithGrip" />
                                <Condition Property="ShowInTaskbar" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="MinButton" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ResizeMode" Value="CanMinimize" />
                                <Condition Property="ShowInTaskbar" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="MinButton" Property="Visibility" Value="Visible" />
                        </MultiTrigger>

                        <!--  Max/Restore icon swap + command swap  -->
                        <Trigger Property="WindowState" Value="Maximized">
                            <Setter TargetName="MaxButton" Property="Content" Value="&#xE923;" />
                            <Setter TargetName="MaxButton" Property="Command" Value="{x:Static SystemCommands.RestoreWindowCommand}" />
                            <Setter Property="WindowChrome.WindowChrome">
                                <Setter.Value>
                                    <WindowChrome CaptionHeight="30"
                                                  GlassFrameThickness="0"
                                                  UseAeroCaptionButtons="False"
                                                  CornerRadius="0"
                                                  ResizeBorderThickness="0" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
