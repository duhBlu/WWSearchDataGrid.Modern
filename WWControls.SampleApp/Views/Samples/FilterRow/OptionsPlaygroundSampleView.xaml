<UserControl x:Class="WWControls.SampleApp.Views.Samples.FilterRow.OptionsPlaygroundSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:sdg="clr-namespace:WWControls.Wpf;assembly=WWControls.Wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Views.Samples.FilterRow"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:OptionsPlaygroundSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,6,0,2" />
            <Setter Property="Foreground" Value="#333" />
        </Style>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.OptionsPlayground}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Filter-row options playground" />
                <LineBreak />
                <Run Text="Every grid-level and column-level filter-row DP, exposed as runtime toggles. Pick a column from the dropdown to see and tweak its per-column settings; the grid-level group always binds to the grid." />
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    ItemsSource="{Binding Items}"
                                    AutoGenerateColumns="False"
                                    FilterClearButtonMode="Edit"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    IsReadOnly="True"
                                    ShowCriteriaInFilterRow="True"
                                    SelectionMode="Extended"
                                    SelectionUnit="FullRow">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn x:Name="OrderNumberColumn"
                                        Width="80"
                                        FieldName="OrderNumber"
                                        Header="Order #" />
                        <sdg:GridColumn x:Name="CustomerNameColumn"
                                        Width="200"
                                        FieldName="CustomerName"
                                        Header="Customer" />
                        <sdg:GridColumn x:Name="StatusColumn"
                                        Width="120"
                                        FieldName="OrderStatusName"
                                        Header="Status"
                                        DefaultSearchType="Equals" />
                        <sdg:GridColumn x:Name="OrderDateColumn"
                                        Width="150"
                                        FieldName="OrderDate"
                                        Header="Order Date"
                                        DisplayStringFormat="MM/dd/yyyy" />
                        <sdg:GridColumn x:Name="TotalColumn"
                                        Width="100"
                                        FieldName="OrderItemsTotalPrice"
                                        Header="Total"
                                        DisplayStringFormat="C2" />
                        <sdg:GridColumn x:Name="CancelledColumn"
                                        Width="80"
                                        FieldName="OrderCancelled"
                                        Header="Cancelled" />
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Background="#CCCCCC" />

                <ScrollViewer Grid.Column="2" Background="#FFFFFF" VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">

                        <Expander Header="Grid settings">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="6">
                                <CheckBox Content="ShowCriteriaInFilterRow"
                                          IsChecked="{Binding ElementName=Grid, Path=ShowCriteriaInFilterRow, Mode=TwoWay}"
                                          ToolTip="Grid-wide default. Individual columns can override via ShowCriteriaInFilterRow (bool?)." />

                                <CheckBox Content="EnableLiveFiltering"
                                          IsChecked="{Binding ElementName=Grid, Path=EnableLiveFiltering, Mode=TwoWay}"
                                          ToolTip="When checked, filter changes apply as you make them. When unchecked, typing and popup edits are deferred until you commit (Enter / Tab / focus loss / popup close)." />

                                <TextBlock Style="{StaticResource SectionLabelStyle}">
                                    <Run Text="FilterRowDelay:" />
                                    <Run Text="{Binding ElementName=Grid, Path=FilterRowDelay, Mode=OneWay}" />
                                    <Run Text="ms" />
                                </TextBlock>
                                <Slider Minimum="0"
                                        Maximum="2000"
                                        TickFrequency="250"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding ElementName=Grid, Path=FilterRowDelay, Mode=TwoWay}" />

                                <TextBlock Style="{StaticResource SectionLabelStyle}" Text="FilterClearButtonMode" />
                                <ComboBox ItemsSource="{Binding FilterClearButtonModeChoices}"
                                          SelectedItem="{Binding ElementName=Grid, Path=FilterClearButtonMode, Mode=TwoWay}" />

                                <Button Content="Clear all filters"
                                        Margin="0,8,0,0"
                                        HorizontalAlignment="Left"
                                        Click="OnClearAllFiltersClicked" />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Selected column settings">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="6">
                                <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Column" />
                                <ComboBox ItemsSource="{Binding Columns}"
                                          SelectedItem="{Binding SelectedColumnConfig, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayLabel" />

                                <Border DataContext="{Binding SelectedColumnConfig}"
                                        Margin="0,6,0,0">
                                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="6">
                                        <CheckBox Content="AllowFiltering  (cell collapsed when off)"
                                                  IsChecked="{Binding AllowFiltering, Mode=TwoWay}" />
                                        <CheckBox Content="AllowAutoFilter  (cell greyed when off)"
                                                  IsChecked="{Binding AllowAutoFilter, Mode=TwoWay}" />

                                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="ShowCriteriaInFilterRow override" />
                                        <ComboBox ItemsSource="{Binding DataContext.ShowCriteriaOverrideChoices, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding ShowCriteriaOverride, Mode=TwoWay}" />

                                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="DefaultSearchType" />
                                        <ComboBox ItemsSource="{Binding DataContext.DefaultSearchTypeChoices, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedItem="{Binding DefaultSearchType, Mode=TwoWay}" />

                                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="EnableLiveFiltering override" />
                                        <ComboBox ItemsSource="{Binding DataContext.EnableLiveFilteringChoices, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding EnableLiveFiltering, Mode=TwoWay}"
                                                  ToolTip="Per-column override of the grid's EnableLiveFiltering. Inherit = follow the grid; Live = always filter as you type; Deferred = wait for Enter/Tab/blur, even when the grid is live." />

                                        <!--  focus toggles (per-column). NavigationIndex lives in its own group below since
                                             it's a cross-column concern best edited by reordering rather than picking an int per column.  -->
                                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Focus" />
                                        <CheckBox Content="AllowFocus  (Tab + arrow + click all skip when off)"
                                                  IsChecked="{Binding AllowFocus, Mode=TwoWay}"
                                                  ToolTip="When unchecked, the cell goes non-focusable. Native WPF skips it for Tab, arrow keys, and mouse clicks, and edit-mode entry is suppressed." />
                                        <CheckBox Content="TabStop  (only Tab skips; arrows still reach the cell)"
                                                  IsChecked="{Binding TabStop, Mode=TwoWay}"
                                                  ToolTip="Sets KeyboardNavigation.IsTabStop=false on the cell when off, so Tab passes through but Left/Right still focus the cell." />

                                        <TextBlock Style="{StaticResource SectionLabelStyle}">
                                            <Run Text="NavigationIndex:" />
                                            <Run Text="{Binding NavigationIndex, Mode=OneWay}" />
                                            <Run Text="(edit via Tab order group below)" />
                                        </TextBlock>
                                    </sdg:SimpleStackPanel>
                                </Border>
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Tab navigation order">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="6">
                                <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap"
                                           Text="Drag rows to reorder Tab traversal. Reordering assigns explicit NavigationIndex values (0, 1, 2, …) — columns with explicit indices are visited first, ascending. Click Reset to clear every NavigationIndex back to -1 (natural display order)." />
                                <sdg:ReorderableListBox x:Name="NavigationOrderListBox"
                                                        ItemsSource="{Binding NavigationOrder}"
                                                        ItemReordered="OnNavigationOrderItemReordered"
                                                        MaxHeight="200">
                                    <sdg:ReorderableListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding DisplayLabel}"
                                                           VerticalAlignment="Center" />
                                                <Border Grid.Column="1"
                                                        Background="#EEE"
                                                        CornerRadius="3"
                                                        Padding="6,1"
                                                        Margin="6,0,0,0">
                                                    <TextBlock FontSize="10"
                                                               Foreground="#555">
                                                        <Run Text="idx " />
                                                        <Run Text="{Binding NavigationIndex, Mode=OneWay}" />
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </sdg:ReorderableListBox.ItemTemplate>
                                </sdg:ReorderableListBox>
                                <Button Content="Reset to natural order"
                                        HorizontalAlignment="Left"
                                        Command="{Binding ResetNavigationOrderCommand}" />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Try it" IsExpanded="False">
                            <TextBlock Margin="4" FontSize="11" Foreground="#666" TextWrapping="Wrap">
                                <Run Text="• Toggle ShowCriteriaInFilterRow — every cell sprouts a search-type selector." />
                                <LineBreak />
                                <Run Text="• Uncheck EnableLiveFiltering on the grid, then type — filter waits for Enter." />
                                <LineBreak />
                                <Run Text="• Leave the grid's EnableLiveFiltering on, pick a column, set its EnableLiveFiltering override to Deferred — only that column waits for Enter while the rest stay live." />
                                <LineBreak />
                                <Run Text="• Pick Cancelled, set AllowAutoFilter=false — cell greys but keeps its space." />
                                <LineBreak />
                                <Run Text="• Pick Cancelled, set AllowFiltering=false — cell collapses entirely." />
                                <LineBreak />
                                <Run Text="• Pick Status, set TabStop=false — Tab skips filter and data cells; Left/Right still reach them." />
                                <LineBreak />
                                <Run Text="• Pick Cancelled, set AllowFocus=false — Tab, arrows, and clicks all skip; the cell is keyboard-inert." />
                                <LineBreak />
                                <Run Text="• Drag rows in the Tab navigation order list — Tab visits columns in that order, ignoring DisplayIndex until you Reset." />
                            </TextBlock>
                        </Expander>

                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
