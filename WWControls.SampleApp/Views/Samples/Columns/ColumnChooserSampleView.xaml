<UserControl x:Class="WWControls.SampleApp.Views.Samples.Columns.ColumnChooserSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Views.Samples.Columns"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:ColumnChooserSampleViewModel />
    </UserControl.DataContext>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.ColumnChooser}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Column Chooser" />
                <LineBreak />
                <Run Text="A floating, non-modal window listing every column with a visibility checkbox. The 'Notes' column sets ShowInColumnChooser=False, so it never appears in the chooser even though it's visible in the grid." />
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    ItemsSource="{Binding Items}"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    IsReadOnly="True"
                                    IsColumnChooserEnabled="True">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn Width="80" FieldName="OrderNumber" Header="Order #" />
                        <sdg:GridColumn Width="120" FieldName="OrderStatusName" Header="Status" />
                        <sdg:GridColumn Width="150" FieldName="OrderDate" Header="Date" DisplayStringFormat="MM/dd/yyyy" />
                        <sdg:GridColumn Width="200" FieldName="CustomerName" Header="Customer" />
                        <sdg:GridColumn Width="160" FieldName="EmployeeName" Header="Employee" />
                        <sdg:GridColumn Width="110" FieldName="OrderItemsTotalPrice" Header="Total" DisplayStringFormat="C2" />
                        <sdg:GridColumn Width="80" FieldName="OrderCancelled" Header="Cancelled" />
                        <sdg:GridColumn Width="200" FieldName="SpecialInstructionsText" Header="Notes" ShowInColumnChooser="False" />
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Background="#CCCCCC" />

                <ScrollViewer Grid.Column="2" Background="#FFFFFF" VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">

                        <Expander Header="Chooser options">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="6">
                                <CheckBox IsChecked="{Binding ElementName=Grid, Path=IsColumnChooserEnabled}" Content="Enabled"
                                          ToolTip="Master switch. When off, the chooser cannot be opened and the right-click 'Show Column Chooser' menu item disappears." />
                                <CheckBox IsEnabled="{Binding ElementName=Grid, Path=IsColumnChooserEnabled}"
                                          IsChecked="{Binding ElementName=Grid, Path=IsColumnChooserVisible}" Content="Show Window"
                                          ToolTip="Opens / closes the chooser window. The window is non-modal — interact with the grid while it's open." />
                                <CheckBox IsEnabled="{Binding ElementName=Grid, Path=IsColumnChooserEnabled}"
                                          IsChecked="{Binding ElementName=Grid, Path=IsColumnChooserConfinedToGrid}" Content="Confine to Grid"
                                          ToolTip="Constrains the chooser window's position so it can't be dragged outside the grid bounds." />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Try it" IsExpanded="False">
                            <TextBlock Margin="4" FontSize="11" Foreground="#666" TextWrapping="Wrap">
                                <Run Text="Right-click any column header to find the 'Show Column Chooser' menu item — same effect as toggling Show Window." />
                            </TextBlock>
                        </Expander>

                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
