<UserControl x:Class="WWControls.SampleApp.Views.Samples.Filtering.CustomFilterElementsSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWControls.Wpf;assembly=WWControls.Wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Views.Samples.Filtering"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:CustomFilterElementsSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="ColumnLegendChip" TargetType="Border">
            <Setter Property="Background" Value="#F5F5F5" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="Margin" Value="0,2" />
        </Style>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.CustomFilterElements}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Custom filter elements — one per column" />
                <LineBreak />
                <Run Text="Each column supplies a single ColumnFilterTab built from one FilterElementBase subclass — no FilterPopupMode change required. Click a column's funnel icon to see its element; Employee keeps the default tabbed popup for comparison." />
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    ItemsSource="{Binding Items}"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    IsReadOnly="True"
                                    SelectionMode="Extended"
                                    SelectionUnit="FullRow">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn Width="80" FieldName="OrderNumber" Header="Order #" />

                        <!--  Status: CheckedListFilterElement (Excel-style picker)  -->
                        <sdg:GridColumn x:Name="StatusColumn"
                                        Width="130"
                                        FieldName="OrderStatusName"
                                        Header="Status">
                            <sdg:GridColumn.CustomColumnFilterTabs>
                                <sdg:ColumnFilterTab Header="Values">
                                    <sdg:ColumnFilterTab.Template>
                                        <ControlTemplate>
                                            <sdg:CheckedListFilterElement x:Name="PART_FilterElement"
                                                                          Margin="6"
                                                                          ShowCounts="True" />
                                        </ControlTemplate>
                                    </sdg:ColumnFilterTab.Template>
                                </sdg:ColumnFilterTab>
                            </sdg:GridColumn.CustomColumnFilterTabs>
                        </sdg:GridColumn>

                        <!--  OrderDate: DateTreeFilterElement (Year/Month/Day tree)  -->
                        <sdg:GridColumn x:Name="OrderDateColumn"
                                        Width="120"
                                        FieldName="OrderDate"
                                        Header="Order Date"
                                        DisplayStringFormat="MM/dd/yyyy">
                            <sdg:GridColumn.CustomColumnFilterTabs>
                                <sdg:ColumnFilterTab Header="Calendar">
                                    <sdg:ColumnFilterTab.Template>
                                        <ControlTemplate>
                                            <sdg:DateTreeFilterElement x:Name="PART_FilterElement"
                                                                       Margin="6"
                                                                       ShowCounts="True" />
                                        </ControlTemplate>
                                    </sdg:ColumnFilterTab.Template>
                                </sdg:ColumnFilterTab>
                            </sdg:GridColumn.CustomColumnFilterTabs>
                        </sdg:GridColumn>

                        <!--  ScheduleDate: DatePeriodsFilterElement (Today / This Week / …)  -->
                        <sdg:GridColumn x:Name="ScheduleDateColumn"
                                        Width="120"
                                        FieldName="ScheduleDate"
                                        Header="Order Period"
                                        DisplayStringFormat="MM/dd/yyyy">
                            <sdg:GridColumn.CustomColumnFilterTabs>
                                <sdg:ColumnFilterTab Header="Period">
                                    <sdg:ColumnFilterTab.Template>
                                        <ControlTemplate>
                                            <sdg:DatePeriodsFilterElement x:Name="PART_FilterElement" Margin="6" />
                                        </ControlTemplate>
                                    </sdg:ColumnFilterTab.Template>
                                </sdg:ColumnFilterTab>
                            </sdg:GridColumn.CustomColumnFilterTabs>
                        </sdg:GridColumn>

                        <!--  Total: RangeFilterElement (slider + numeric inputs)  -->
                        <sdg:GridColumn x:Name="TotalColumn"
                                        Width="120"
                                        FieldName="OrderItemsTotalPrice"
                                        Header="Total"
                                        DisplayStringFormat="C2">
                            <sdg:GridColumn.CustomColumnFilterTabs>
                                <sdg:ColumnFilterTab Header="Range">
                                    <sdg:ColumnFilterTab.Template>
                                        <ControlTemplate>
                                            <sdg:RangeFilterElement x:Name="PART_FilterElement"
                                                                    Margin="6"
                                                                    SliderMinimum="0"
                                                                    SliderMaximum="100000" />
                                        </ControlTemplate>
                                    </sdg:ColumnFilterTab.Template>
                                </sdg:ColumnFilterTab>
                            </sdg:GridColumn.CustomColumnFilterTabs>
                        </sdg:GridColumn>

                        <!--  Customer: MultiFilterElement (single-rule editor — Contains / StartsWith / …)  -->
                        <sdg:GridColumn x:Name="CustomerColumn"
                                        Width="200"
                                        FieldName="CustomerName"
                                        Header="Customer">
                            <sdg:GridColumn.CustomColumnFilterTabs>
                                <sdg:ColumnFilterTab Header="Rule">
                                    <sdg:ColumnFilterTab.Template>
                                        <ControlTemplate>
                                            <sdg:MultiFilterElement x:Name="PART_FilterElement"
                                                                    Margin="6"
                                                                    ShowCounts="True" />
                                        </ControlTemplate>
                                    </sdg:ColumnFilterTab.Template>
                                </sdg:ColumnFilterTab>
                            </sdg:GridColumn.CustomColumnFilterTabs>
                        </sdg:GridColumn>

                        <!--  Employee: Default popup (Rules + Values tabs) — comparison point  -->
                        <sdg:GridColumn Width="160" FieldName="EmployeeName" Header="Employee (Default)" />
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1"
                              Width="5"
                              HorizontalAlignment="Stretch"
                              Background="#CCCCCC" />

                <ScrollViewer Grid.Column="2"
                              Padding="8,4"
                              Background="#FFFFFF"
                              VerticalScrollBarVisibility="Auto">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">

                        <Expander Header="Filter element per column">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="2">
                                <Border Style="{StaticResource ColumnLegendChip}">
                                    <TextBlock FontSize="12">
                                        <Run FontWeight="SemiBold" Text="Status" />
                                        <Run Text=" — CheckedList" />
                                    </TextBlock>
                                </Border>
                                <Border Style="{StaticResource ColumnLegendChip}">
                                    <TextBlock FontSize="12">
                                        <Run FontWeight="SemiBold" Text="Order Date" />
                                        <Run Text=" — DateTree" />
                                    </TextBlock>
                                </Border>
                                <Border Style="{StaticResource ColumnLegendChip}">
                                    <TextBlock FontSize="12">
                                        <Run FontWeight="SemiBold" Text="Order Period" />
                                        <Run Text=" — DatePeriods" />
                                    </TextBlock>
                                </Border>
                                <Border Style="{StaticResource ColumnLegendChip}">
                                    <TextBlock FontSize="12">
                                        <Run FontWeight="SemiBold" Text="Total" />
                                        <Run Text=" — Range" />
                                    </TextBlock>
                                </Border>
                                <Border Style="{StaticResource ColumnLegendChip}">
                                    <TextBlock FontSize="12">
                                        <Run FontWeight="SemiBold" Text="Customer" />
                                        <Run Text=" — Multi (single-rule)" />
                                    </TextBlock>
                                </Border>
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Try it" IsExpanded="False">
                            <TextBlock Margin="4" FontSize="11" Foreground="#666" TextWrapping="Wrap">
                                <Run Text="• Open Status → CheckedListFilterElement (Excel-style picker)." />
                                <LineBreak />
                                <Run Text="• Open Order Date → DateTreeFilterElement (Year/Month/Day tree)." />
                                <LineBreak />
                                <Run Text="• Open Order Period → DatePeriodsFilterElement (Today / This Week / etc.)." />
                                <LineBreak />
                                <Run Text="• Open Total → RangeFilterElement (slider + numeric inputs)." />
                                <LineBreak />
                                <Run Text="• Open Customer → MultiFilterElement (single-rule editor — Contains, StartsWith, etc.)." />
                                <LineBreak />
                                <Run Text="• Compare against Employee, which uses the default tabbed UI. The column header keeps a tinted funnel icon for as long as a filter is applied." />
                            </TextBlock>
                        </Expander>

                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
