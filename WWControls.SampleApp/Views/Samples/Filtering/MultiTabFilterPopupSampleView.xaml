<UserControl x:Class="WWControls.SampleApp.Views.Samples.Filtering.MultiTabFilterPopupSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWControls.Wpf;assembly=WWControls.Wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Views.Samples.Filtering"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:MultiTabFilterPopupSampleViewModel />
    </UserControl.DataContext>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.MultiTabFilterPopup}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Multi-tab custom filter popup" />
                <LineBreak />
                <Run Text="CustomColumnFilterTabs takes any number of ColumnFilterTab entries, hosted in a TabControl that matches the default chrome. Every tab drives the same column's filter, so switching tabs swaps the editing surface without losing filter state." />
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    ItemsSource="{Binding Items}"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    IsReadOnly="True"
                                    SelectionMode="Extended"
                                    SelectionUnit="FullRow">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn Width="80" FieldName="OrderNumber" Header="Order #" />
                        <sdg:GridColumn Width="120" FieldName="OrderStatusName" Header="Status" />

                        <!--
                            Order Date: two custom tabs — Periods (DateInterval enum picker) and
                            Calendar (Year/Month/Day tree). Same column, same controller, two ways
                            to author the date filter.
                        -->
                        <sdg:GridColumn Width="140"
                                        FieldName="OrderDate"
                                        Header="Order Date"
                                        DisplayStringFormat="MM/dd/yyyy">
                            <sdg:GridColumn.CustomColumnFilterTabs>
                                <sdg:ColumnFilterTab Header="Periods">
                                    <sdg:ColumnFilterTab.Template>
                                        <ControlTemplate>
                                            <sdg:DatePeriodsFilterElement x:Name="PART_FilterElement" Margin="6" />
                                        </ControlTemplate>
                                    </sdg:ColumnFilterTab.Template>
                                </sdg:ColumnFilterTab>
                                <sdg:ColumnFilterTab Header="Calendar">
                                    <sdg:ColumnFilterTab.Template>
                                        <ControlTemplate>
                                            <sdg:DateTreeFilterElement x:Name="PART_FilterElement"
                                                                       Margin="6"
                                                                       ShowCounts="True" />
                                        </ControlTemplate>
                                    </sdg:ColumnFilterTab.Template>
                                </sdg:ColumnFilterTab>
                            </sdg:GridColumn.CustomColumnFilterTabs>
                        </sdg:GridColumn>

                        <sdg:GridColumn Width="180" FieldName="CustomerName" Header="Customer" />

                        <!--
                            Total: three custom tabs — Slider (Between with numeric inputs),
                            Values (CheckedList of distinct prices), and Rule (single-rule editor
                            for "is greater than X", "is between A and B", etc.).
                        -->
                        <sdg:GridColumn Width="120"
                                        FieldName="OrderItemsTotalPrice"
                                        Header="Total"
                                        DisplayStringFormat="C2">
                            <sdg:GridColumn.CustomColumnFilterTabs>
                                <sdg:ColumnFilterTab Header="Slider">
                                    <sdg:ColumnFilterTab.Template>
                                        <ControlTemplate>
                                            <sdg:RangeFilterElement x:Name="PART_FilterElement"
                                                                    Margin="6"
                                                                    SliderMinimum="0"
                                                                    SliderMaximum="100000" />
                                        </ControlTemplate>
                                    </sdg:ColumnFilterTab.Template>
                                </sdg:ColumnFilterTab>
                                <sdg:ColumnFilterTab Header="Values">
                                    <sdg:ColumnFilterTab.Template>
                                        <ControlTemplate>
                                            <sdg:CheckedListFilterElement x:Name="PART_FilterElement"
                                                                          Margin="6"
                                                                          ShowCounts="True" />
                                        </ControlTemplate>
                                    </sdg:ColumnFilterTab.Template>
                                </sdg:ColumnFilterTab>
                                <sdg:ColumnFilterTab Header="Rule">
                                    <sdg:ColumnFilterTab.Template>
                                        <ControlTemplate>
                                            <sdg:MultiFilterElement x:Name="PART_FilterElement" Margin="6" />
                                        </ControlTemplate>
                                    </sdg:ColumnFilterTab.Template>
                                </sdg:ColumnFilterTab>
                            </sdg:GridColumn.CustomColumnFilterTabs>
                        </sdg:GridColumn>

                        <sdg:GridColumn Width="80" FieldName="OrderCancelled" Header="Cancelled" />
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Background="#CCCCCC" />

                <ScrollViewer Grid.Column="2" Background="#FFFFFF" VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">

                        <Expander Header="Tabs per column">
                            <TextBlock Margin="4" FontSize="11" Foreground="#666" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Text="Order Date" />
                                <Run Text="— Periods (Today / This Week / …) and Calendar (Year/Month/Day tree)." />
                                <LineBreak />
                                <Run FontWeight="SemiBold" Text="Total" />
                                <Run Text="— Slider (range), Values (checked list), and Rule (single-rule editor)." />
                                <LineBreak />
                                <Run Text="The other columns keep the default Rules + Values popup for comparison." />
                            </TextBlock>
                        </Expander>

                        <Expander Header="Try it" IsExpanded="False">
                            <TextBlock Margin="4" FontSize="11" Foreground="#666" TextWrapping="Wrap">
                                <Run Text="• Open the Order Date popup — pick 'This Month' on the Periods tab, then switch to the Calendar tab. The tree reflects the dates the period rule produced." />
                                <LineBreak />
                                <Run Text="• Open Total — set a range on the Slider tab, switch to Rule, and inspect the underlying Between template." />
                            </TextBlock>
                        </Expander>

                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
