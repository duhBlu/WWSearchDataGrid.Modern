<UserControl x:Class="WWControls.SampleApp.Views.Samples.Summaries.TotalSummariesSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWControls.Wpf;assembly=WWControls.Wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Views.Samples.Summaries"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:TotalSummariesSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style BasedOn="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesButton}}" TargetType="{x:Type Button}">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="FieldLabelText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#444" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,4,0,1" />
        </Style>

        <!--  GridColumn descriptors are FrameworkContentElements, which a ComboBox can't host in
              its selection box — DisplayMemberPath then renders only in the dropdown while the
              selection box falls back to ToString(). An explicit ItemTemplate flows into
              SelectionBoxItemTemplate, so the header renders in both places.  -->
        <DataTemplate x:Key="ColumnPickerItemTemplate">
            <TextBlock Text="{Binding HeaderCaption}" />
        </DataTemplate>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.TotalSummaries}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Foreground="#444"
                       Margin="16,12,16,4"
                       FontSize="13"
                       TextWrapping="Wrap">
                <Run Text="Summary surfaces" FontWeight="SemiBold" />
                <LineBreak />
                <Run Text="Four surfaces for summaries over the filtered rows: the column-aligned total summary row, the fixed total summary panel, group-header summaries, and per-group footer rows. Each panel group controls one surface." />
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    ItemsSource="{Binding Items}"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    ShowTotalSummary="True"
                                    IsGroupPanelVisible="True">
                    <sdg:SearchDataGrid.GroupSummaries>
                        <sdg:SummaryItem SummaryType="Sum" FieldName="OrderItemsTotalPrice" />
                        <sdg:SummaryItem SummaryType="Max" FieldName="OrderDate" DisplayFormat="Latest: {0:MM/dd/yyyy}" />
                    </sdg:SearchDataGrid.GroupSummaries>
                    <sdg:SearchDataGrid.FixedTotalSummaries>
                        <sdg:SummaryItem SummaryType="Count" />
                        <sdg:SummaryItem SummaryType="Sum" FieldName="OrderItemsTotalPrice" />
                    </sdg:SearchDataGrid.FixedTotalSummaries>
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn Width="140"
                                        FieldName="OrderStatusName"
                                        Header="Status" />
                        <sdg:GridColumn Width="100"
                                        FieldName="OrderNumber"
                                        Header="Order #">
                            <sdg:GridColumn.TotalSummaries>
                                <sdg:SummaryItem SummaryType="Count" />
                            </sdg:GridColumn.TotalSummaries>
                            <sdg:GridColumn.GroupFooterSummaries>
                                <sdg:SummaryItem SummaryType="Count" />
                            </sdg:GridColumn.GroupFooterSummaries>
                        </sdg:GridColumn>
                        <sdg:GridColumn Width="160"
                                        FieldName="CustomerName"
                                        Header="Customer"
                                        AllowedTotalSummaries="Count" />
                        <sdg:GridColumn Width="140"
                                        FieldName="ProductLineName"
                                        Header="Product Line" />

                        <sdg:GridColumn Width="120"
                                        FieldName="OrderItemsTotalPrice"
                                        Header="Total"
                                        DisplayStringFormat="C2">
            <!--  Per-segment styling demo: the prefix label reads muted/italic, the summed value bold green.  -->
                            <sdg:GridColumn.TotalSummaries>
                                <sdg:SummaryItem SummaryType="Sum">
                                    <sdg:SummaryItem.PrefixStyle>
                                        <sdg:SummaryTextStyle FontStyle="Italic" Foreground="#888888" />
                                    </sdg:SummaryItem.PrefixStyle>
                                    <sdg:SummaryItem.ValueStyle>
                                        <sdg:SummaryTextStyle FontWeight="Bold" Foreground="#1B5E20" />
                                    </sdg:SummaryItem.ValueStyle>
                                </sdg:SummaryItem>
                                <sdg:SummaryItem SummaryType="Average" DisplayFormat="Avg: {0:C2}">
                                    <sdg:SummaryItem.ValueStyle>
                                        <sdg:SummaryTextStyle FontStyle="Italic" Foreground="#6A1B9A" />
                                    </sdg:SummaryItem.ValueStyle>
                                </sdg:SummaryItem>
                            </sdg:GridColumn.TotalSummaries>
                            <sdg:GridColumn.GroupFooterSummaries>
                                <sdg:SummaryItem SummaryType="Sum" />
                                <sdg:SummaryItem SummaryType="Average" DisplayFormat="Avg: {0:C2}" />
                            </sdg:GridColumn.GroupFooterSummaries>
                        </sdg:GridColumn>
                        <sdg:GridColumn Width="150"
                                        FieldName="OrderDate"
                                        Header="Order Date"
                                        DisplayStringFormat="MM/dd/yyyy">
                            <sdg:GridColumn.TotalSummaries>
                                <sdg:SummaryItem SummaryType="Max" DisplayFormat="Latest: {0:MM/dd/yyyy}" />
                            </sdg:GridColumn.TotalSummaries>
                        </sdg:GridColumn>
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Background="#CCCCCC" />

                <ScrollViewer Grid.Column="2" Background="#FFFFFF" VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">

                        <Expander Header="Total summary">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="5">
                                <CheckBox IsChecked="{Binding AllowTotalSummary, ElementName=Grid}"
                                          Content="Enable total summary feature"
                                          ToolTip="Master feature gate. When off, the row can't be shown, its editor can't be opened, and its column-header menu entries are removed." />
                                <CheckBox IsChecked="{Binding ShowTotalSummary, ElementName=Grid}"
                                          IsEnabled="{Binding AllowTotalSummary, ElementName=Grid}"
                                          Content="Show total summary row"
                                          ToolTip="Master opt-in for the column-aligned totals row (stays visible even when empty, so the picker is reachable)." />
                                <TextBlock Style="{StaticResource FieldLabelText}" Text="Position" />
                                <ComboBox SelectedValuePath="Tag"
                                          IsEnabled="{Binding AllowTotalSummary, ElementName=Grid}"
                                          SelectedValue="{Binding TotalSummaryPosition, ElementName=Grid}"
                                          ToolTip="Docks the totals row Top (beneath the filter row) or Bottom; None suppresses it.">
                                    <ComboBoxItem Content="Bottom" Tag="{x:Static sdg:TotalSummaryPosition.Bottom}" />
                                    <ComboBoxItem Content="Top" Tag="{x:Static sdg:TotalSummaryPosition.Top}" />
                                    <ComboBoxItem Content="None" Tag="{x:Static sdg:TotalSummaryPosition.None}" />
                                </ComboBox>
                                <TextBlock Style="{StaticResource FieldLabelText}" Text="Column" />
                                <ComboBox x:Name="TotalColumnPicker"
                                          ItemsSource="{Binding GridColumns, ElementName=Grid}"
                                          ItemTemplate="{StaticResource ColumnPickerItemTemplate}"
                                          IsEnabled="{Binding AllowTotalSummary, ElementName=Grid}"
                                          ToolTip="The column whose totals-cell editor the button below opens." />
                                <Button Click="TotalSummaryEditor_Click"
                                        Content="Show Summary Editor"
                                        IsEnabled="{Binding AllowTotalSummary, ElementName=Grid}"
                                        ToolTip="Opens the column-scoped totals editor ('Totals for X') for the selected column." />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Fixed total summary panel">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="5">
                                <CheckBox IsChecked="{Binding AllowFixedTotalSummary, ElementName=Grid}"
                                          Content="Enable fixed panel feature"
                                          ToolTip="Master feature gate. When off, the panel can't be shown, its editor can't be opened, and its 'Show Fixed Total Summary' context-menu item is removed." />
                                <Button Click="FixedToggle_Click"
                                        Content="Show / hide fixed panel"
                                        IsEnabled="{Binding AllowFixedTotalSummary, ElementName=Grid}"
                                        ToolTip="Toggles the fixed panel's visibility (only meaningful while the feature is enabled)." />
                                <Button Click="FixedEditor_Click"
                                        Content="Show Summary Editor"
                                        IsEnabled="{Binding AllowFixedTotalSummary, ElementName=Grid}"
                                        ToolTip="Opens the fixed panel's own summary editor." />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Group summary">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="5">
                                <TextBlock Style="{StaticResource FieldLabelText}" Text="Display mode" />
                                <RadioButton x:Name="GroupModeDefault"
                                             GroupName="GroupSummaryMode"
                                             Content="Default (in header)"
                                             IsChecked="True"
                                             Checked="GroupModeDefault_Checked"
                                             ToolTip="Group summaries render inline in each group header's runs." />
                                <RadioButton x:Name="GroupModeAligned"
                                             GroupName="GroupSummaryMode"
                                             Content="Aligned by columns"
                                             Checked="GroupModeAligned_Checked"
                                             ToolTip="Column-targeted group summaries render aligned under their columns in the header row." />
                                <CheckBox IsChecked="{Binding ShowGroupRowCount, ElementName=Grid}"
                                          Content="Show row count"
                                          ToolTip="Opt-in Count entry in every group header." />
                                <Button Click="GroupSummaryEditor_Click"
                                        Content="Show Summary Editor"
                                        ToolTip="Opens the group-header summary editor (the shared set rendered at every level)." />
                                <Button Click="GroupByStatus_Click" Content="Group by Status" />
                                <Button Click="GroupByProductLine_Click" Content="Group by Product Line" />
                                <Button Click="ClearGrouping_Click" Content="Clear grouping" />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Group footer summary">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="5">
                                <TextBlock Foreground="#6F7A8C"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Text="A per-group totals row: docks at the bottom of an expanded group, pins beneath the header when collapsed. Group the grid to see it." />
                                <TextBlock Style="{StaticResource FieldLabelText}" Text="Column" />
                                <ComboBox x:Name="FooterColumnPicker"
                                          ItemsSource="{Binding GridColumns, ElementName=Grid}"
                                          ItemTemplate="{StaticResource ColumnPickerItemTemplate}"
                                          ToolTip="The column whose group-footer editor the button below opens." />
                                <Button Click="GroupFooterEditor_Click"
                                        Content="Show Summary Editor"
                                        ToolTip="Opens the column-scoped group-footer editor ('Footer for X') for the selected column." />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Context menus">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="5">
                                <CheckBox IsChecked="{Binding SummaryContextMenusEnabled, ElementName=Grid}"
                                          Content="Summary context menus"
                                          ToolTip="When off, the summary right-click pickers and the summary-editing menu items are removed everywhere — the configured summaries become read-only to the user." />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Sort groups by summary">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="5">
                                <Button Click="SortGroupsBySum_Click"
                                        Content="Sort groups by Sum(Total)"
                                        ToolTip="Orders groups by the aggregate over each group's rows instead of by the group key." />
                                <Button Click="SortGroupsByCount_Click" Content="Sort groups by row count" />
                                <Button Click="ClearSummarySort_Click" Content="Clear summary sort" />
                                <Button Click="RefreshSummaries_Click"
                                        Content="Refresh summaries"
                                        Margin="0,8,0,0"
                                        ToolTip="Explicit RefreshSummaries() — totals already recompute on filter, source, grouping, and edit-commit changes." />
                            </sdg:SimpleStackPanel>
                        </Expander>

                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
