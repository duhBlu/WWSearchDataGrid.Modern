<UserControl x:Class="WWControls.SampleApp.Views.Samples.Editing.DataErrorIndicationSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWControls.Wpf;assembly=WWControls.Wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Views.Samples.Editing"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:DataErrorIndicationSampleViewModel />
    </UserControl.DataContext>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.DataErrorIndication}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Severity-aware error badges from a self-reporting row" />
                <LineBreak />
                <Run Text="Rows report their own errors through INotifyDataErrorInfo; IValidationSeverityProvider maps each to a red Error (missing name), amber Warning (badly formatted Phone / Email), or blue Info (missing Address / Email) badge. Edit a cell and commit — the badge re-evaluates, and advisory badges never block the edit." />
            </TextBlock>

            <sdg:SearchDataGrid x:Name="Grid"
                                Margin="8"
                                ItemsSource="{Binding People}"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                ShowValidationAttributeErrors="True"
                                AllowCommitOnValidationAttributeError="True">
                <sdg:SearchDataGrid.GridColumns>
                    <sdg:GridColumn FieldName="FirstName" IsSmart="True" Width="120" />
                    <sdg:GridColumn FieldName="LastName"  IsSmart="True" Width="120" />
                    <sdg:GridColumn FieldName="Address"   IsSmart="True" Width="190" />
                    <sdg:GridColumn FieldName="Phone"     IsSmart="True" Width="140" />
                    <sdg:GridColumn FieldName="Email"     IsSmart="True" Width="220" />
                </sdg:SearchDataGrid.GridColumns>
            </sdg:SearchDataGrid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
