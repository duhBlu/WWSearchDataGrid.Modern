<UserControl x:Class="WWControls.SampleApp.Views.Samples.Editing.EditFormSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Views.Samples.Editing"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:EditFormSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <!--  Custom edit-form layout, toggled on from the side panel. DataContext is the edited row
              item; each EditFormEditor drops in the matching column's editor by FieldName.  -->
        <DataTemplate x:Key="CustomEditForm">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Name:" VerticalAlignment="Center" Margin="0,4,12,4" />
                <sdg:EditFormEditor FieldName="Name" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,2" />

                <TextBlock Text="Department:" Grid.Row="1" VerticalAlignment="Center" Margin="0,4,12,4" />
                <sdg:EditFormEditor FieldName="Department" Grid.Row="1" Grid.Column="1" Margin="0,2" />

                <TextBlock Text="Priority:" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="16,4,12,4" />
                <sdg:EditFormEditor FieldName="PriorityId" Grid.Row="1" Grid.Column="3" Margin="0,2" />

                <TextBlock Text="Salary:" Grid.Row="2" VerticalAlignment="Center" Margin="0,4,12,4" />
                <sdg:EditFormEditor FieldName="Salary" Grid.Row="2" Grid.Column="1" Margin="0,2" />

                <TextBlock Text="Active:" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Margin="16,4,12,4" />
                <sdg:EditFormEditor FieldName="IsActive" Grid.Row="2" Grid.Column="3" Margin="0,2" HorizontalAlignment="Left" />
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.EditForm}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Inline edit form — edit a whole row through a form" />
                <LineBreak />
                <Run Text="With EditFormShowMode set, the row promotes (on RowEditTrigger) into a caption/editor form hosted in the row's details area instead of the column-aligned strip. The form reuses each column's editor and the row's IEditableObject transaction, so Update commits every field and Cancel reverts them all." />
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="340" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    ItemsSource="{Binding People}"
                                    AutoGenerateColumns="False"
                                    RowEditTrigger="{Binding SelectedTrigger}"
                                    EditFormShowMode="{Binding SelectedShowMode}"
                                    EditFormPostConfirmationMode="{Binding SelectedConfirmation}"
                                    EditFormCaption="Edit Employee">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn Width="50" FieldName="Id" Header="#" IsReadOnly="True" EditFormCaption="Employee #" />

                        <!--  Name spans the full form width (EditFormColumnSpan = 2 renders it full-width).  -->
                        <sdg:GridColumn Width="2*" FieldName="Name" Header="Name" EditFormColumnSpan="2" />

                        <sdg:GridColumn Width="130" FieldName="Department" Header="Department">
                            <sdg:GridColumn.EditSettings>
                                <sdg:ComboBoxEditSettings ItemsSource="{Binding Departments}" />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>

                        <sdg:GridColumn Width="100" FieldName="PriorityId" Header="Priority" EditFormCaption="Priority level">
                            <sdg:GridColumn.EditSettings>
                                <sdg:ComboBoxEditSettings ItemsSource="{Binding Priorities}"
                                                          DisplayMemberPath="Name"
                                                          SelectedValuePath="Id" />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>

                        <sdg:GridColumn Width="110" FieldName="Salary" Header="Salary" DisplayStringFormat="C0" EditFormCaption="Annual Salary">
                            <sdg:GridColumn.EditSettings>
                                <sdg:SpinEditSettings Minimum="0" Maximum="500000" Increment="1000" LargeIncrement="10000" />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>

                        <sdg:GridColumn Width="120" FieldName="StartDate" Header="Start Date">
                            <sdg:GridColumn.EditSettings>
                                <sdg:DateEditSettings />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>

                        <sdg:GridColumn Width="70" FieldName="IsActive" Header="Active">
                            <sdg:GridColumn.EditSettings>
                                <sdg:CheckBoxEditSettings />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Background="#CCCCCC" />

                <ScrollViewer Grid.Column="2" Background="#FFFFFF" VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">

                        <Expander Header="Form options" IsExpanded="True">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="8">
                                <TextBlock FontWeight="Bold" Text="EditFormShowMode:" />
                                <ComboBox ItemsSource="{Binding ShowModeChoices}"
                                          SelectedItem="{Binding SelectedShowMode, Mode=TwoWay}" />
                                <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap">
                                    <Run Text="• None — full-row editing uses the column-aligned strip (no form)." />
                                    <LineBreak />
                                    <Run Text="• Inline — the form shows beneath the row; the row's cells stay visible." />
                                    <LineBreak />
                                    <Run Text="• InlineHideRow — the form replaces the row (its cells are hidden)." />
                                </TextBlock>

                                <TextBlock FontWeight="Bold" Text="RowEditTrigger:" Margin="0,4,0,0" />
                                <ComboBox ItemsSource="{Binding TriggerChoices}"
                                          SelectedItem="{Binding SelectedTrigger, Mode=TwoWay}" />

                                <TextBlock FontWeight="Bold" Text="EditFormPostConfirmationMode:" Margin="0,4,0,0" />
                                <ComboBox ItemsSource="{Binding ConfirmationChoices}"
                                          SelectedItem="{Binding SelectedConfirmation, Mode=TwoWay}" />
                                <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap"
                                           Text="When set, moving focus out of a form with unsaved changes prompts before discarding the edit." />

                                <CheckBox x:Name="CustomLayoutToggle"
                                          Margin="0,8,0,0"
                                          Content="Use custom form layout (EditFormTemplate)"
                                          Checked="OnCustomLayoutToggled"
                                          Unchecked="OnCustomLayoutToggled" />
                                <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap"
                                           Text="Swaps the auto-generated layout for a two-column custom template built from EditFormEditor elements." />

                                <Button Margin="0,8,0,0"
                                        Padding="8,4"
                                        Content="Show edit form for selected row"
                                        Click="OnShowEditFormClick" />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Last action" IsExpanded="True">
                            <TextBlock Margin="4" FontSize="12" Foreground="#444" TextWrapping="Wrap"
                                       Text="{Binding LastAction}" />
                        </Expander>

                        <Expander Header="Try it" IsExpanded="False">
                            <TextBlock Margin="4" FontSize="11" Foreground="#666" TextWrapping="Wrap">
                                <Run Text="• Click any cell — the row opens as a form (Inline shows it under the row; InlineHideRow replaces the row)." />
                                <LineBreak />
                                <Run Text="• Edit fields, then Update to commit them together, or Cancel / Esc to revert the whole row." />
                                <LineBreak />
                                <Run Text="• Select a row and click 'Show edit form' to open it programmatically (works with RowEditTrigger = Never too)." />
                                <LineBreak />
                                <Run Text="• Turn on the custom layout to see EditFormTemplate + EditFormEditor; note Name spans full-width and Salary's caption is customized in the auto layout." />
                                <LineBreak />
                                <Run Text="• Set a confirmation mode, edit a field, then click another row — you'll be asked before the edit is abandoned." />
                            </TextBlock>
                        </Expander>

                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
