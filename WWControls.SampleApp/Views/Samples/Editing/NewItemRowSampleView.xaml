<UserControl x:Class="WWControls.SampleApp.Views.Samples.Editing.NewItemRowSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWControls.Wpf;assembly=WWControls.Wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Views.Samples.Editing"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:NewItemRowSampleViewModel />
    </UserControl.DataContext>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.NewItemRow}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="New item row — Top / Bottom / None" />
                <LineBreak />
                <Run Text="NewRowPosition places the add-new-row above the data, below it, or removes it entirely (adding disabled). Click into the row and type to add a task; new rows are initialized by the app (see the panel), not the grid. Select a row and press Delete to remove it." />
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    ItemsSource="{Binding Tasks}"
                                    AutoGenerateColumns="False"
                                    CanUserDeleteRows="True"
                                    NewRowPosition="{Binding NewRowPosition}">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn Width="50" FieldName="Id" Header="#" IsReadOnly="True" />

                        <sdg:GridColumn Width="2*" FieldName="Title" Header="Title" />

                        <sdg:GridColumn Width="110" FieldName="AssignedTo" Header="Assigned">
                            <sdg:GridColumn.EditSettings>
                                <sdg:ComboBoxEditSettings ItemsSource="{Binding Assignees}" />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>

                        <sdg:GridColumn Width="100" FieldName="PriorityId" Header="Priority">
                            <sdg:GridColumn.EditSettings>
                                <sdg:ComboBoxEditSettings ItemsSource="{Binding Priorities}"
                                                          DisplayMemberPath="Name"
                                                          SelectedValuePath="Id" />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>

                        <sdg:GridColumn Width="90" FieldName="HoursEstimate" Header="Hours" DisplayStringFormat="N2">
                            <sdg:GridColumn.EditSettings>
                                <sdg:SpinEditSettings Minimum="0" Maximum="80" LargeIncrement="1" Increment="0.25" />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>

                        <sdg:GridColumn Width="120" FieldName="DueDate" Header="Due">
                            <sdg:GridColumn.EditSettings>
                                <sdg:DateEditSettings />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>

                        <sdg:GridColumn Width="70" FieldName="IsComplete" Header="Done">
                            <sdg:GridColumn.EditSettings>
                                <sdg:CheckBoxEditSettings />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Background="#CCCCCC" />

                <ScrollViewer Grid.Column="2" Background="#FFFFFF" VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">

                        <Expander Header="New row" IsExpanded="True">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="8">
                                <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2">
                                    <TextBlock FontWeight="Bold" Text="New Row Position:" />
                                    <ComboBox ItemsSource="{Binding NewRowPositionChoices}"
                                              SelectedItem="{Binding NewRowPosition, Mode=TwoWay}" />
                                </sdg:SimpleStackPanel>
                                <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap">
                                    <Run Text="• Top — add-new-row sits above the data." />
                                    <LineBreak />
                                    <Run Text="• Bottom — add-new-row sits below the data (the WPF default)." />
                                    <LineBreak />
                                    <Run Text="• None — no add-new-row; CanUserAddRows is turned off." />
                                </TextBlock>

                                <CheckBox Content="Seed new rows via InitializingNewItem"
                                          IsChecked="{Binding SeedNewRows, Mode=TwoWay}" />

                                <Border Background="#F2F7FC" BorderBrush="#C9DDEE" BorderThickness="1"
                                        CornerRadius="4" Padding="8">
                                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="4">
                                        <TextBlock FontWeight="SemiBold" FontSize="12" Foreground="#0C5460"
                                                   Text="ⓘ  Consumer responsibility" />
                                        <TextBlock FontSize="11" Foreground="#33555F" TextWrapping="Wrap">
                                            <Run Text="The grid only adds a blank item — it can't know your defaults. The auto-filled Id and due date are application code handling the grid's " />
                                            <Run FontWeight="SemiBold" Text="InitializingNewItem" />
                                            <Run Text=" event (see the code-behind in the Source tab). Untick the box above to add a raw, unseeded row." />
                                        </TextBlock>
                                    </sdg:SimpleStackPanel>
                                </Border>
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Try it" IsExpanded="False">
                            <TextBlock Margin="4" FontSize="11" Foreground="#666" TextWrapping="Wrap">
                                <Run Text="• Click the empty row and type a Title to start a new task." />
                                <LineBreak />
                                <Run Text="• With seeding on, the app fills # with the next Id and Due a week out; turn it off to see the raw blank row." />
                                <LineBreak />
                                <Run Text="• Press Enter or click away to commit, Esc to cancel the add." />
                                <LineBreak />
                                <Run Text="• Flip the position to Top / Bottom / None and watch the row move or disappear." />
                                <LineBreak />
                                <Run Text="• Select a committed row and press Delete to remove it." />
                            </TextBlock>
                        </Expander>

                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
