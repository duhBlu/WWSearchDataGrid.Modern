<UserControl x:Class="WWControls.SampleApp.Controls.SampleFooterControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             x:Name="Root">
    <Grid Background="#F0F0F0">
        <!-- Row counts moved to the shared chrome status bar (SampleHostControl). This footer is
             now just the data-generation controls used by generatable samples. -->
        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
            <sdg:NumericUpDown VerticalContentAlignment="Center"
                               Increment="1000"
                               Value="{Binding RowCount, ElementName=Root, Mode=TwoWay}" />
            <Button Command="{Binding GenerateCommand, ElementName=Root}"
                    CommandParameter="{Binding RowCount, ElementName=Root}"
                    Margin="5"
                    Padding="10,5"
                    Content="Generate" />
            <Button Command="{Binding ClearCommand, ElementName=Root}"
                    Margin="5"
                    Padding="10,5"
                    Content="Clear" />
        </StackPanel>
    </Grid>
</UserControl>
