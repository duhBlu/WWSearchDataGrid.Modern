<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Shim: the default theme lives in WWControls.Wpf.Themes.Default. This file exists so
         [ThemeInfo(GenericDictionaryLocation = SourceAssembly)] resolves to a valid Generic.xaml
         inside this assembly, giving every WW control (primitives + editors) its default style
         without the consumer having to merge anything.

         Order matters — shared parts before consumers:
           1. DefaultControls  — shared brushes + icons + keyed styles (referenced by everything).
           2. the primitive dictionaries.
           3. EditorParts      — shared editor inner-part styles (flat TextBox, spin button, chevron,
              themed CheckBox) that the per-editor dictionaries reference via StaticResource.
           4. the per-editor dictionaries, then the EditSettings element styles. -->
    <ResourceDictionary.MergedDictionaries>
        <!-- shared base -->
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Primitives/DefaultControls.xaml" />

        <!-- primitives -->
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Primitives/WWSpinningWheel.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Primitives/WWButton.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Primitives/StatusIcon.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Primitives/WWMessageBox.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Primitives/WWTreeView.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Primitives/ContextMenu.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Primitives/Window.xaml" />

        <!-- editors -->
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Editors/EditorParts.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Editors/WWTextBox.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Editors/WWNumericUpDown.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Editors/WWComboBox.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Editors/WWDatePicker.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Editors/WWCheckBox.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Editors/Calendar.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Editors/EditSettings.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Editors/WWSearchTextBox.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Editors/WWRangeSlider.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Editors/WWListBox.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Editors/WWColorPicker.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Editors/WWPropertyGrid.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WWControls.Wpf.Themes.Default;component/Themes/Editors/ValidationCellPresenter.xaml" />
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
