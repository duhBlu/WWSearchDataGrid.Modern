<UserControl x:Class="WWControls.SampleApp.Editors.Views.Samples.Editors.ColorPickerSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Editors.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Editors.Views.Samples.Editors"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:ColorPickerSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#444" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="OptionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#666" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#888" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="Readout" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#0066AA" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="ToggleRow" BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.CheckBox}}" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Foreground" Value="#333" />
        </Style>
        <Style x:Key="OptionCombo" TargetType="{x:Type sdg:WWComboBox}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.ComboBox}}">
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <!--  Each role picker: default templated chrome (BasedOn the themed key) + a shared height / margin.  -->
        <Style x:Key="RolePicker" TargetType="{x:Type sdg:WWColorPicker}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.ColorPicker}}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.ColorPicker}">
        <ScrollViewer Background="#FFFFFF" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" MaxWidth="820" HorizontalAlignment="Left">
                <TextBlock FontSize="13" Foreground="#444" TextWrapping="Wrap" Margin="0,0,0,16">
                    <Run FontWeight="SemiBold" Text="WWColorPicker" />
                    <LineBreak />
                    <Run Text="A swatch toggle that drops a popup with preset swatches, HSV sliders, and a hex box. Here six pickers each bind two-way to a theme role, and the mock dashboard on the right reskins live as you drag. SelectedColor is a Color (not a Brush), so the view model projects each role to a frozen brush — that one adapter is all a real consumer needs." />
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Palette + options — every picker here reskins the preview card on the right.  -->
                    <Border Grid.Column="0"
                            Background="#FAFAFA"
                            BorderBrush="#E3E3E3"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14"
                            VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Caption}" Text="Palette" Margin="0,0,0,10" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="Canvas (page)" />
                            <sdg:WWColorPicker Style="{StaticResource RolePicker}"
                                               SelectedColor="{Binding Canvas, Mode=TwoWay}"
                                               DisplayColorAndName="{Binding DisplayColorAndName}"
                                               PresetColors="{Binding CurrentPresets}" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="Surface (card)" />
                            <sdg:WWColorPicker Style="{StaticResource RolePicker}"
                                               SelectedColor="{Binding Surface, Mode=TwoWay}"
                                               DisplayColorAndName="{Binding DisplayColorAndName}"
                                               PresetColors="{Binding CurrentPresets}" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="Accent" />
                            <sdg:WWColorPicker x:Name="AccentPicker"
                                               Style="{StaticResource RolePicker}"
                                               SelectedColor="{Binding Accent, Mode=TwoWay}"
                                               DisplayColorAndName="{Binding DisplayColorAndName}"
                                               PresetColors="{Binding CurrentPresets}" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="Heading text" />
                            <sdg:WWColorPicker Style="{StaticResource RolePicker}"
                                               SelectedColor="{Binding Heading, Mode=TwoWay}"
                                               DisplayColorAndName="{Binding DisplayColorAndName}"
                                               PresetColors="{Binding CurrentPresets}" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="Body text" />
                            <sdg:WWColorPicker Style="{StaticResource RolePicker}"
                                               SelectedColor="{Binding Body, Mode=TwoWay}"
                                               DisplayColorAndName="{Binding DisplayColorAndName}"
                                               PresetColors="{Binding CurrentPresets}" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="Border" />
                            <sdg:WWColorPicker Style="{StaticResource RolePicker}"
                                               SelectedColor="{Binding Border, Mode=TwoWay}"
                                               DisplayColorAndName="{Binding DisplayColorAndName}"
                                               PresetColors="{Binding CurrentPresets}" />

                            <Separator Margin="0,4,0,12" />

                            <TextBlock Style="{StaticResource Caption}" Text="Options" Margin="0,0,0,10" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="Preset set (PresetColors)" />
                            <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                            ItemsSource="{Binding PresetSets}"
                                            SelectedItem="{Binding PresetSet, Mode=TwoWay}" />

                            <!--  Mirrors the swatch grid each picker offers in its popup, so switching the set shows a change out here too.  -->
                            <ItemsControl ItemsSource="{Binding CurrentPresets}" Margin="0,0,0,4">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="16" Height="16" Margin="2"
                                                CornerRadius="3"
                                                BorderBrush="#CCCCCC"
                                                BorderThickness="1">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding}" />
                                            </Border.Background>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Style="{StaticResource Hint}" Margin="0,0,0,12"
                                       Text="Switching the set re-themes the six roles above and restocks these swatches inside every picker's popup — all drawn from this set." />

                            <CheckBox Style="{StaticResource ToggleRow}" Content="DisplayColorAndName"
                                      ToolTip="Off shows a color-only swatch; on adds the hex text beside it"
                                      IsChecked="{Binding DisplayColorAndName, Mode=TwoWay}" />

                            <sdg:WWButton Content="Reset palette"
                                          HorizontalAlignment="Left"
                                          Padding="12,4"
                                          Command="{Binding ResetPaletteCommand}" />
                        </StackPanel>
                    </Border>

                    <!--  Live preview — a mock dashboard card wired entirely to the palette brushes.  -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource Caption}" Text="Live preview" />
                        <Border Background="{Binding CanvasBrush}"
                                CornerRadius="8"
                                Padding="22"
                                MinHeight="330">
                            <Border Background="{Binding SurfaceBrush}"
                                    BorderBrush="{Binding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    MaxWidth="400"
                                    HorizontalAlignment="Left">
                                <StackPanel>
                                    <!--  Header bar (accent) — logo badge + title in the contrast foreground.  -->
                                    <Border Background="{Binding AccentBrush}"
                                            CornerRadius="8,8,0,0"
                                            Padding="16,12">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="26" Height="26" CornerRadius="13"
                                                    Background="{Binding SurfaceBrush}"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="W"
                                                           Foreground="{Binding AccentBrush}"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="Production Dashboard"
                                                       Foreground="{Binding AccentForegroundBrush}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <!--  Body — headings, copy, stat tiles, and faux buttons, all palette-driven.  -->
                                    <StackPanel Margin="16">
                                        <TextBlock Text="This week at a glance"
                                                   Foreground="{Binding HeadingBrush}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Foreground="{Binding BodyBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"
                                                   Text="Every surface, line of type, and border on this card is bound to one of the pickers. Drag a slider or type a hex and the whole card re-themes in place." />

                                        <UniformGrid Columns="2" Margin="0,14,0,0">
                                            <Border Background="{Binding AccentSoftBrush}"
                                                    BorderBrush="{Binding BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="12,10"
                                                    Margin="0,0,6,0">
                                                <StackPanel>
                                                    <TextBlock Text="1,284"
                                                               Foreground="{Binding AccentBrush}"
                                                               FontSize="22"
                                                               FontWeight="Bold" />
                                                    <TextBlock Text="Orders shipped"
                                                               Foreground="{Binding BodyBrush}"
                                                               FontSize="11"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                            <Border Background="{Binding AccentSoftBrush}"
                                                    BorderBrush="{Binding BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="12,10"
                                                    Margin="6,0,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="98.2%"
                                                               Foreground="{Binding AccentBrush}"
                                                               FontSize="22"
                                                               FontWeight="Bold" />
                                                    <TextBlock Text="On-time rate"
                                                               Foreground="{Binding BodyBrush}"
                                                               FontSize="11"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>

                                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                            <Border Background="{Binding AccentBrush}"
                                                    CornerRadius="6"
                                                    Padding="16,7">
                                                <TextBlock Text="Primary action"
                                                           Foreground="{Binding AccentForegroundBrush}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                            <Border BorderBrush="{Binding BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="16,7"
                                                    Margin="8,0,0,0">
                                                <TextBlock Text="Secondary"
                                                           Foreground="{Binding BodyBrush}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Border>

                        <!--  Accent breakdown — read straight off the accent picker's live HSV / hex.  -->
                        <TextBlock Style="{StaticResource Caption}" Text="Accent breakdown" Margin="0,20,0,4" />
                        <TextBlock Style="{StaticResource Readout}"
                                   Text="{Binding ElementName=AccentPicker, Path=HexText, StringFormat='Hex: {0}'}" />
                        <TextBlock Style="{StaticResource Readout}">
                            <Run Text="HSV:" />
                            <Run Text="{Binding ElementName=AccentPicker, Path=Hue, Mode=OneWay, StringFormat='H {0:0}°'}" />
                            <Run Text="{Binding ElementName=AccentPicker, Path=Saturation, Mode=OneWay, StringFormat='· S {0:0}%'}" />
                            <Run Text="{Binding ElementName=AccentPicker, Path=Brightness, Mode=OneWay, StringFormat='· B {0:0}%'}" />
                        </TextBlock>

                        <TextBlock Style="{StaticResource Hint}" Margin="0,14,0,0">
                            <Run FontWeight="SemiBold" Text="Popup:" />
                            <Run Text="click a swatch to open it — pick a preset, drag the H / S / B sliders (the tracks recolor as you go), or type a hex and press Enter. The preview border and hex box mirror the live color." />
                        </TextBlock>
                        <TextBlock Style="{StaticResource Hint}">
                            <Run FontWeight="SemiBold" Text="PresetColors:" />
                            <Run Text="the Preset set combo is a coordinated theme — it re-seeds all six roles and swaps the swatch grid on every picker at once (Material, a grayscale ramp, or the web-safe basics). Then fine-tune any single role from that set's swatches." />
                        </TextBlock>
                        <TextBlock Style="{StaticResource Hint}">
                            <Run FontWeight="SemiBold" Text="Auto-contrast:" />
                            <Run Text="the header title and primary-button label bind to a foreground the view model flips between black and white by the accent's brightness, so text stays readable however dark or light you drag the accent." />
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </sampleControls:SampleHostControl>
</UserControl>
