<UserControl x:Class="WWControls.SampleApp.Editors.Views.Samples.Editors.CheckBoxSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Editors.Controls"
             xmlns:converters="clr-namespace:WWControls.SampleApp.Editors.Converters"
             xmlns:local="clr-namespace:WWControls.SampleApp.Editors.Views.Samples.Editors"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:CheckBoxSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#444" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="OptionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#666" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#888" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="BoundValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#0066AA" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
        <Style x:Key="ToggleRow" BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.CheckBox}}" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Foreground" Value="#333" />
        </Style>
        <Style x:Key="OptionCombo" TargetType="{x:Type sdg:WWComboBox}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.ComboBox}}">
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.CheckBox}">
        <ScrollViewer Background="#FFFFFF" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" MaxWidth="760" HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource SampleIntro}">
                    <Run FontWeight="SemiBold" Text="WWCheckBox" />
                    <LineBreak />
                    <Run Text="Boolean editor over a nullable IsChecked — two-state, or three-state (checked → unchecked → indeterminate). A glyph control, so it stays flat regardless of ShowBorder." />
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="230" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Options — every control here drives the demo checkbox on the right.  -->
                    <Border Grid.Column="0"
                            Background="#FAFAFA"
                            BorderBrush="#E3E3E3"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14"
                            VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Caption}" Text="Options" Margin="0,0,0,10" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="ClickMode" />
                            <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                            ToolTip="Release toggles on mouse-up (dragging away cancels); Press toggles on mouse-down; Hover toggles as the pointer enters — no click"
                                            ItemsSource="{Binding ClickModes}"
                                            SelectedItem="{Binding ClickMode, Mode=TwoWay}" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="HoverModifier (Hover mode only)" />
                            <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                            ToolTip="In Hover mode the box only toggles while this modifier is held — an unmodified hover does nothing (a plain click still toggles)"
                                            IsEnabled="{Binding ClickMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Hover}"
                                            ItemsSource="{Binding HoverModifiers}"
                                            SelectedItem="{Binding HoverModifier, Mode=TwoWay}" />

                            <CheckBox Style="{StaticResource ToggleRow}" Content="IsThreeState"
                                      ToolTip="Clicking cycles checked → unchecked → indeterminate (null)"
                                      IsChecked="{Binding IsThreeState, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource ToggleRow}" Margin="0" Content="IsReadOnly"
                                      ToolTip="Blocks user toggling; the bound value can still change programmatically"
                                      IsChecked="{Binding IsReadOnly, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>

                    <!--  The demo checkbox.  -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource Caption}" Text="Editor" />
                        <sdg:WWCheckBox Height="26"
                                        HorizontalAlignment="Left"
                                        IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                        IsThreeState="{Binding IsThreeState}"
                                        ClickMode="{Binding ClickMode}"
                                        HoverModifier="{Binding HoverModifier}"
                                        IsReadOnly="{Binding IsReadOnly}" />
                        <TextBlock Style="{StaticResource BoundValue}"
                                   Text="{Binding IsChecked, StringFormat='Bound value: {0}', TargetNullValue='Bound value: (null)'}" />


                        <!--  Hover playground — only shown in Hover mode: sweep the pointer down the list.  -->
                        <StackPanel Margin="0,18,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ClickMode}" Value="Hover">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Style="{StaticResource Caption}" Text="Hover playground" />
                            <TextBlock Style="{StaticResource Hint}" Margin="0,0,0,8"
                                       Text="Sweep the pointer down the list — each box toggles as you cross it (hold the HoverModifier, if set, to arm it)." />
                            <Border BorderBrush="#E3E3E3"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12,8"
                                    MinWidth="220"
                                    HorizontalAlignment="Left">
                                <ItemsControl ItemsSource="{Binding HoverItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                                <sdg:WWCheckBox Height="20"
                                                                IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                                ClickMode="Hover"
                                                                IsThreeState="{Binding DataContext.IsThreeState, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                HoverModifier="{Binding DataContext.HoverModifier, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                IsReadOnly="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                                <TextBlock Text="{Binding Name}"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0"
                                                           FontSize="12"
                                                           Foreground="#333" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                            <TextBlock Style="{StaticResource BoundValue}" Text="{Binding CheckedSummary}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </sampleControls:SampleHostControl>
</UserControl>
