<UserControl x:Class="WWControls.SampleApp.Editors.Views.Samples.Editors.PropertyGridSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Editors.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Editors.Views.Samples.Editors"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:PropertyGridSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#444" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#888" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="ReadoutLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#666" />
        </Style>
        <Style x:Key="ReadoutValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#0066AA" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.PropertyGrid}">
        <ScrollViewer Background="#FFFFFF" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" MaxWidth="820" HorizontalAlignment="Left">
                <TextBlock FontSize="13" Foreground="#444" TextWrapping="Wrap" Margin="0,0,0,16">
                    <Run FontWeight="SemiBold" Text="WWPropertyGrid" />
                    <LineBreak />
                    <Run Text="Reflects a bound object's public properties, groups them by [Category], and labels them from [DisplayName] / [Description]. Editors are supplied per property through EditorDefinitions — here Name, SKU, Active, Currency, and Status get custom editors built from the WWControls editor controls." />
                    <LineBreak />
                    <Run FontWeight="SemiBold" Foreground="#A15C00" Text="Note: " /><Run Foreground="#A15C00" Text="the grid has no built-in per-type editors yet, so properties without a custom template (Unit Price, Quantity On Hand, Created On, Internal Id) fall back to a read-only placeholder." />
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  The property grid, bound to the demo object.  -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Caption}" Text="Property grid" />
                        <sdg:WWPropertyGrid Width="360"
                                            Height="470"
                                            NameColumnWidth="140"
                                            SelectedObject="{Binding Product}">
                            <sdg:WWPropertyGrid.EditorDefinitions>
                                <!--  Text editor for the string properties.  -->
                                <sdg:WWEditorDefinition TargetProperties="Name, Sku">
                                    <sdg:WWEditorDefinition.EditingTemplate>
                                        <DataTemplate>
                                            <sdg:WWTextBox ShowBorder="False"
                                                           VerticalAlignment="Stretch"
                                                           IsReadOnly="{Binding IsReadOnly}"
                                                           Value="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                        </DataTemplate>
                                    </sdg:WWEditorDefinition.EditingTemplate>
                                </sdg:WWEditorDefinition>

                                <!--  Checkbox editor for the boolean.  -->
                                <sdg:WWEditorDefinition TargetProperties="IsActive">
                                    <sdg:WWEditorDefinition.EditingTemplate>
                                        <DataTemplate>
                                            <sdg:WWCheckBox Margin="6,0,0,0"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center"
                                                            IsReadOnly="{Binding IsReadOnly}"
                                                            IsChecked="{Binding Value, Mode=TwoWay}" />
                                        </DataTemplate>
                                    </sdg:WWEditorDefinition.EditingTemplate>
                                </sdg:WWEditorDefinition>

                                <!--  Combo editor for the enum properties, bound to the item's EnumValues.  -->
                                <sdg:WWEditorDefinition TargetProperties="Status, Currency">
                                    <sdg:WWEditorDefinition.EditingTemplate>
                                        <DataTemplate>
                                            <sdg:WWComboBox ShowBorder="False"
                                                            VerticalAlignment="Stretch"
                                                            ItemsSource="{Binding EnumValues}"
                                                            SelectedItem="{Binding Value, Mode=TwoWay}" />
                                        </DataTemplate>
                                    </sdg:WWEditorDefinition.EditingTemplate>
                                </sdg:WWEditorDefinition>
                            </sdg:WWPropertyGrid.EditorDefinitions>
                        </sdg:WWPropertyGrid>
                        <TextBlock Style="{StaticResource Hint}" MaxWidth="360" Margin="0,8,0,0"
                                   Text="Click a row to see its description below the grid. Type in the search box to filter by name or category. Drag the divider between the two columns to resize." />
                    </StackPanel>

                    <!--  Live readout — reflects edits made through the grid.  -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                        <TextBlock Style="{StaticResource Caption}" Text="Live object" />
                        <Border Background="#FAFAFA"
                                BorderBrush="#E3E3E3"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14"
                                HorizontalAlignment="Left"
                                MinWidth="240">
                            <StackPanel>
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Name" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.Name}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="SKU" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.Sku}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Active" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.IsActive}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Status" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.Status}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Currency" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.Currency}" />
                            </StackPanel>
                        </Border>
                        <TextBlock Style="{StaticResource Hint}" MaxWidth="260"
                                   Text="Edit Name, SKU, Active, Status, or Currency in the grid and watch these update — each editor two-way binds through the property item's Value." />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </sampleControls:SampleHostControl>
</UserControl>
