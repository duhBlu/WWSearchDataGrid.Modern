<UserControl x:Class="WWControls.SampleApp.Editors.Views.Samples.Editors.NumericUpDownSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Editors.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Editors.Views.Samples.Editors"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:NumericUpDownSampleViewModel />
    </UserControl.DataContext>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.NumericUpDown}">
        <ScrollViewer Background="#FFFFFF" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" MaxWidth="620" HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource SampleIntro}">
                    <Run FontWeight="SemiBold" Text="WWNumericUpDown" />
                    <LineBreak />
                    <Run Text="Numeric editor with a spinner column and keyboard stepping. Minimum / Maximum clamp typed and stepped values alike." />
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Editor" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,6" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Bound value" FontWeight="SemiBold" Foreground="#666" Margin="12,0,0,6" />

                    <!-- Unbounded: no Minimum/Maximum set. -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Unbounded (default)" VerticalAlignment="Center" Margin="0,4" Foreground="#333" />
                    <sdg:WWNumericUpDown Grid.Row="1" Grid.Column="1" Height="26" Margin="0,4"
                                    ToolTip="No Minimum / Maximum set — accepts any value"
                                    Value="{Binding Unbounded, Mode=TwoWay}" />
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding Unbounded}" VerticalAlignment="Center" Margin="12,4" Foreground="#0066AA" />

                    <!-- Clamped to 0..100. -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Bounded 0–100" VerticalAlignment="Center" Margin="0,4" Foreground="#333" />
                    <sdg:WWNumericUpDown Grid.Row="2" Grid.Column="1" Height="26" Margin="0,4"
                                    Minimum="0" Maximum="100"
                                    ToolTip="Minimum=0, Maximum=100 — clamps typed and stepped values"
                                    Value="{Binding Percentage, Mode=TwoWay}" />
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding Percentage}" VerticalAlignment="Center" Margin="12,4" Foreground="#0066AA" />

                    <!-- Large step: Ctrl+Shift+Up/Down jumps by 25. -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="LargeIncrement 25" VerticalAlignment="Center" Margin="0,4" Foreground="#333" />
                    <sdg:WWNumericUpDown Grid.Row="3" Grid.Column="1" Height="26" Margin="0,4"
                                    Minimum="0" Maximum="1000" Increment="5" LargeIncrement="25"
                                    ToolTip="Increment=5, LargeIncrement=25 (Ctrl+Shift+↑/↓)"
                                    Value="{Binding Stock, Mode=TwoWay}" />
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding Stock}" VerticalAlignment="Center" Margin="12,4" Foreground="#0066AA" />

                    <!-- Fractional increment. -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Fractional (0.25 steps)" VerticalAlignment="Center" Margin="0,4" Foreground="#333" />
                    <sdg:WWNumericUpDown Grid.Row="4" Grid.Column="1" Height="26" Margin="0,4"
                                    Minimum="0" Maximum="10" Increment="0.25" LargeIncrement="1"
                                    ToolTip="Increment=0.25 — fractional stepping"
                                    Value="{Binding Hours, Mode=TwoWay}" />
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding Hours}" VerticalAlignment="Center" Margin="12,4" Foreground="#0066AA" />

                    <!-- Read-only: spinner and typing both disabled. -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Read-only" VerticalAlignment="Center" Margin="0,4" Foreground="#333" />
                    <sdg:WWNumericUpDown Grid.Row="5" Grid.Column="1" Height="26" Margin="0,4" IsReadOnly="True"
                                    ToolTip="IsReadOnly — spinner and typing both disabled"
                                    Value="{Binding Locked, Mode=TwoWay}" />
                    <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding Locked}" VerticalAlignment="Center" Margin="12,4" Foreground="#0066AA" />
                </Grid>

                <TextBlock Style="{StaticResource SampleNoteHeader}" Text="Keyboard" Margin="0,22,0,6" />
                <StackPanel Style="{StaticResource SampleKbdRow}">
                    <Border Style="{StaticResource SampleKbd}"><TextBlock Style="{StaticResource SampleKbdText}" Text="Ctrl + ↑ / ↓" /></Border>
                    <TextBlock Style="{StaticResource SampleKbdDesc}" Text="Step by Increment" />
                </StackPanel>
                <StackPanel Style="{StaticResource SampleKbdRow}">
                    <Border Style="{StaticResource SampleKbd}"><TextBlock Style="{StaticResource SampleKbdText}" Text="Ctrl + Shift + ↑ / ↓" /></Border>
                    <TextBlock Style="{StaticResource SampleKbdDesc}" Text="Jump by LargeIncrement" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </sampleControls:SampleHostControl>
</UserControl>
