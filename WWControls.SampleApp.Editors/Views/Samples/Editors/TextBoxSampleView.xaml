<UserControl x:Class="WWControls.SampleApp.Editors.Views.Samples.Editors.TextBoxSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Editors.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Editors.Views.Samples.Editors"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:TextBoxSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#444" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#666" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>
        <Style x:Key="BoundValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#0066AA" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Margin" Value="0,14,0,0" />
        </Style>

        <!--  Example-card chrome: a titled panel holding one editor + its own options.  -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E3E3E3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#222" />
        </Style>
        <Style x:Key="CardDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#777" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,16" />
        </Style>
        <Style x:Key="OptionsPanel" TargetType="Border">
            <Setter Property="Background" Value="#FAFAFA" />
            <Setter Property="BorderBrush" Value="#EEEEEE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style x:Key="CardHint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#999" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,10,0,0" />
        </Style>

        <Style x:Key="ToggleRow" BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.CheckBox}}" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Foreground" Value="#333" />
        </Style>
        <Style x:Key="OptionCombo" TargetType="{x:Type sdg:WWComboBox}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.ComboBox}}">
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="OptionNumeric" TargetType="{x:Type sdg:WWNumericUpDown}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.NumericUpDown}}">
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.TextBox}">
        <ScrollViewer Background="#F4F5F7" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" MaxWidth="820" HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource SampleIntro}">
                    <Run FontWeight="SemiBold" Text="WWTextBox" />
                    <LineBreak />
                    <Run Text="The workhorse text editor. Each card below is a different kind of text box — single-line input, multi-line memo, adorned input — with the options that shape it grouped alongside. Right-click any editor for the themed edit menu. Masking has its own sample." />
                </TextBlock>

                <!--  ── Card 1: single-line input ─────────────────────────────  -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardTitle}" Text="Single-line input" />
                        <TextBlock Style="{StaticResource CardDesc}"
                                   Text="The everyday field — a watermark while empty, an optional clear button, a length cap, text alignment, automatic casing, and a debounce on the value push." />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="250" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Top">
                                <sdg:WWTextBox Width="320"
                                               Height="30"
                                               HorizontalAlignment="Left"
                                               Watermark="Search customers…"
                                               Value="{Binding BasicText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                               ShowClearButton="{Binding BasicShowClearButton}"
                                               MaxLength="{Binding BasicMaxLength}"
                                               TextAlignment="{Binding BasicTextAlignment}"
                                               CharacterCasing="{Binding BasicCharacterCasing}"
                                               UpdateDelay="{Binding BasicUpdateDelay}" />
                                <TextBlock Style="{StaticResource BoundValue}"
                                           Text="{Binding BasicText, StringFormat='Value: {0}', TargetNullValue='Value: (empty)', FallbackValue='Value: (empty)'}" />
                            </StackPanel>

                            <Border Grid.Column="2" Style="{StaticResource OptionsPanel}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Caption}" Text="Options" Margin="0,0,0,12" />

                                    <CheckBox Style="{StaticResource ToggleRow}" Content="ShowClearButton"
                                              ToolTip="Inline clear button, shown while the editor is non-empty and editable"
                                              IsChecked="{Binding BasicShowClearButton, Mode=TwoWay}" />

                                    <TextBlock Style="{StaticResource FieldLabel}" Text="MaxLength (0 = unlimited)" />
                                    <sdg:WWNumericUpDown Style="{StaticResource OptionNumeric}"
                                                         Minimum="0" Maximum="100" Increment="1"
                                                         Value="{Binding BasicMaxLength, Mode=TwoWay}" />

                                    <TextBlock Style="{StaticResource FieldLabel}" Text="TextAlignment" />
                                    <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                                    ItemsSource="{Binding TextAlignments}"
                                                    SelectedItem="{Binding BasicTextAlignment, Mode=TwoWay}" />

                                    <TextBlock Style="{StaticResource FieldLabel}" Text="CharacterCasing" />
                                    <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                                    ItemsSource="{Binding CharacterCasings}"
                                                    SelectedItem="{Binding BasicCharacterCasing, Mode=TwoWay}" />

                                    <TextBlock Style="{StaticResource FieldLabel}" Text="UpdateDelay (ms)" />
                                    <sdg:WWNumericUpDown Style="{StaticResource OptionNumeric}"
                                                         Margin="0"
                                                         Minimum="0" Maximum="2000" Increment="50" LargeIncrement="250"
                                                         ToolTip="Debounces the binding (Binding.Delay) — the value echo lags typing by this many ms"
                                                         Value="{Binding BasicUpdateDelay, Mode=TwoWay}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!--  ── Card 2: multi-line memo ────────────────────────────────  -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardTitle}" Text="Memo (multi-line)" />
                        <TextBlock Style="{StaticResource CardDesc}"
                                   Text="For long, free-form text like descriptions or notes. AcceptsReturn and top-aligned content are baked in; tune how it wraps, when the scrollbar shows, and the visible line bounds." />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="250" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Top">
                                <!--  AcceptsReturn + Top alignment make this a memo; MinLines/MaxLines drive its height.  -->
                                <sdg:WWTextBox Width="400"
                                               HorizontalAlignment="Left"
                                               AcceptsReturn="True"
                                               VerticalContentAlignment="Top"
                                               Value="{Binding MemoText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                               TextWrapping="{Binding MemoTextWrapping}"
                                               VerticalScrollBarVisibility="{Binding MemoVerticalScrollBarVisibility}"
                                               MinLines="{Binding MemoMinLines}"
                                               MaxLines="{Binding MemoMaxLines}"
                                               IsSpellCheckEnabled="{Binding MemoSpellCheck}" />
                                <TextBlock Style="{StaticResource BoundValue}"
                                           Text="{Binding MemoText.Length, StringFormat='{}{0} characters', FallbackValue='0 characters'}" />
                            </StackPanel>

                            <Border Grid.Column="2" Style="{StaticResource OptionsPanel}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Caption}" Text="Options" Margin="0,0,0,12" />

                                    <TextBlock Style="{StaticResource FieldLabel}" Text="TextWrapping" />
                                    <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                                    ItemsSource="{Binding TextWrappings}"
                                                    SelectedItem="{Binding MemoTextWrapping, Mode=TwoWay}" />

                                    <TextBlock Style="{StaticResource FieldLabel}" Text="VerticalScrollBarVisibility" />
                                    <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                                    ItemsSource="{Binding ScrollBarVisibilities}"
                                                    SelectedItem="{Binding MemoVerticalScrollBarVisibility, Mode=TwoWay}" />

                                    <TextBlock Style="{StaticResource FieldLabel}" Text="MinLines" />
                                    <sdg:WWNumericUpDown Style="{StaticResource OptionNumeric}"
                                                         Minimum="1" Maximum="10" Increment="1"
                                                         Value="{Binding MemoMinLines, Mode=TwoWay}" />

                                    <TextBlock Style="{StaticResource FieldLabel}" Text="MaxLines" />
                                    <sdg:WWNumericUpDown Style="{StaticResource OptionNumeric}"
                                                         Minimum="1" Maximum="20" Increment="1"
                                                         Value="{Binding MemoMaxLines, Mode=TwoWay}" />

                                    <CheckBox Style="{StaticResource ToggleRow}" Margin="0"
                                              Content="IsSpellCheckEnabled"
                                              ToolTip="Feeds SpellCheck.IsEnabled — the OS underlines misspellings"
                                              IsChecked="{Binding MemoSpellCheck, Mode=TwoWay}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock Style="{StaticResource CardHint}"
                                   Text="Type past MaxLines to see it scroll instead of grow. Set MinLines = MaxLines for a fixed-height box." />
                    </StackPanel>
                </Border>

                <!--  ── Card 3: adorned input (glyph) ──────────────────────────  -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardTitle}" Text="Adorned input (glyph)" />
                        <TextBlock Style="{StaticResource CardDesc}"
                                   Text="An input with a monochrome icon docked inside it — search fields, filters, labeled inputs. The glyph tints to the foreground and sits on the leading or trailing edge." />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="250" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Top">
                                <!--  Glyph is an enum choice mapped to an icon resource by the triggers below;
                                      GlyphPlacement binds straight through.  -->
                                <sdg:WWTextBox Width="320"
                                               Height="30"
                                               HorizontalAlignment="Left"
                                               Watermark="Filter…"
                                               ShowClearButton="True"
                                               Value="{Binding GlyphText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                               GlyphPlacement="{Binding GlyphPlacement}">
                                    <sdg:WWTextBox.Style>
                                        <Style TargetType="{x:Type sdg:WWTextBox}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.TextBox}}">
                                            <Style.Triggers>
                                                <!--  Glyph choice → icon resource (None leaves Glyph null).  -->
                                                <DataTrigger Binding="{Binding GlyphKind}" Value="Edit">
                                                    <Setter Property="Glyph" Value="{StaticResource {x:Static sdg:IconKeys.IconEdit}}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding GlyphKind}" Value="Calendar">
                                                    <Setter Property="Glyph" Value="{StaticResource {x:Static sdg:IconKeys.IconCalendar}}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding GlyphKind}" Value="Filter">
                                                    <Setter Property="Glyph" Value="{StaticResource {x:Static sdg:IconKeys.IconFilter}}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </sdg:WWTextBox.Style>
                                </sdg:WWTextBox>
                                <TextBlock Style="{StaticResource BoundValue}"
                                           Text="{Binding GlyphText, StringFormat='Value: {0}', TargetNullValue='Value: (empty)', FallbackValue='Value: (empty)'}" />
                            </StackPanel>

                            <Border Grid.Column="2" Style="{StaticResource OptionsPanel}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Caption}" Text="Options" Margin="0,0,0,12" />

                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Glyph" />
                                    <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                                    ToolTip="An icon docked on the GlyphPlacement edge, tinted to the editor's foreground"
                                                    ItemsSource="{Binding GlyphKinds}"
                                                    SelectedItem="{Binding GlyphKind, Mode=TwoWay}" />

                                    <TextBlock Style="{StaticResource FieldLabel}" Text="GlyphPlacement" />
                                    <sdg:WWComboBox Style="{StaticResource OptionCombo}" Margin="0"
                                                    ItemsSource="{Binding GlyphPlacements}"
                                                    SelectedItem="{Binding GlyphPlacement, Mode=TwoWay}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </sampleControls:SampleHostControl>
</UserControl>
