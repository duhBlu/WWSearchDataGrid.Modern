<UserControl x:Class="WWControls.SampleApp.Editors.Views.Samples.Editors.TextBoxSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Editors.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Editors.Views.Samples.Editors"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:TextBoxSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#444" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#666" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#888" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,8,0,0" />
        </Style>
        <Style x:Key="BoundValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#0066AA" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Margin" Value="0,14,0,0" />
        </Style>
        <Style x:Key="ToggleRow" BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.CheckBox}}" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Foreground" Value="#333" />
        </Style>
        <Style x:Key="OptionCombo" TargetType="{x:Type sdg:WWComboBox}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.ComboBox}}">
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="OptionNumeric" TargetType="{x:Type sdg:WWNumericUpDown}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.NumericUpDown}}">
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="OptionText" TargetType="{x:Type sdg:WWTextBox}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.TextBox}}">
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.TextBox}">
        <ScrollViewer Background="#FFFFFF" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" MaxWidth="740" HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource SampleIntro}">
                    <Run FontWeight="SemiBold" Text="WWTextBox" />
                    <LineBreak />
                    <Run Text="The workhorse text editor — chrome, watermark, clear button, an edge glyph, and an input debounce. Masking has its own sample." />
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Options — every property of the single demo editor.  -->
                    <Border Grid.Column="0"
                            Background="#FAFAFA"
                            BorderBrush="#E3E3E3"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14"
                            VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Caption}" Text="Options" Margin="0,0,0,12" />

                            <CheckBox Style="{StaticResource ToggleRow}" Content="ShowBorder"
                                      IsChecked="{Binding ShowBorder, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource ToggleRow}" Content="IsReadOnly"
                                      IsChecked="{Binding IsReadOnly, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource ToggleRow}" Content="ShowClearButton"
                                      ToolTip="Shows an inline clear button while the editor is non-empty and editable"
                                      IsChecked="{Binding ShowClearButton, Mode=TwoWay}" />

                            <TextBlock Style="{StaticResource FieldLabel}" Text="Watermark" />
                            <sdg:WWTextBox Style="{StaticResource OptionText}"
                                           Value="{Binding Watermark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Style="{StaticResource FieldLabel}" Text="TextAlignment" />
                            <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                            ItemsSource="{Binding TextAlignments}"
                                            SelectedItem="{Binding TextAlignment, Mode=TwoWay}" />

                            <TextBlock Style="{StaticResource FieldLabel}" Text="Glyph" />
                            <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                            ToolTip="An icon docked on the GlyphPlacement edge, tinted to the editor's foreground"
                                            ItemsSource="{Binding GlyphKinds}"
                                            SelectedItem="{Binding Glyph, Mode=TwoWay}" />

                            <TextBlock Style="{StaticResource FieldLabel}" Text="GlyphPlacement" />
                            <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                            ItemsSource="{Binding GlyphPlacements}"
                                            SelectedItem="{Binding GlyphPlacement, Mode=TwoWay}" />

                            <TextBlock Style="{StaticResource FieldLabel}" Text="MaxLength (0 = unlimited)" />
                            <sdg:WWNumericUpDown Style="{StaticResource OptionNumeric}"
                                                 Minimum="0" Maximum="100" Increment="1"
                                                 Value="{Binding MaxLength, Mode=TwoWay}" />

                            <TextBlock Style="{StaticResource FieldLabel}" Text="UpdateDelay (ms)" />
                            <sdg:WWNumericUpDown Style="{StaticResource OptionNumeric}"
                                                 Margin="0"
                                                 Minimum="0" Maximum="2000" Increment="50" LargeIncrement="250"
                                                 ToolTip="Debounces the binding (Binding.Delay) — the value echo lags typing by this many ms"
                                                 Value="{Binding UpdateDelay, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>

                    <!--  The single live editor. Glyph and Mask are enum/preset choices, mapped to
                          concrete resources/patterns by the DataTriggers below; every other property
                          binds straight to the option it mirrors.  -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                        <TextBlock Style="{StaticResource Caption}" Text="Live editor" />
                        <sdg:WWTextBox x:Name="Demo"
                                       Width="340"
                                       Height="30"
                                       HorizontalAlignment="Left"
                                       Value="{Binding SampleText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       ShowBorder="{Binding ShowBorder}"
                                       IsReadOnly="{Binding IsReadOnly}"
                                       ShowClearButton="{Binding ShowClearButton}"
                                       Watermark="{Binding Watermark}"
                                       TextAlignment="{Binding TextAlignment}"
                                       GlyphPlacement="{Binding GlyphPlacement}"
                                       MaxLength="{Binding MaxLength}"
                                       UpdateDelay="{Binding UpdateDelay}">
                            <sdg:WWTextBox.Style>
                                <Style TargetType="{x:Type sdg:WWTextBox}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.TextBox}}">
                                    <Style.Triggers>
                                        <!--  Glyph choice → icon resource (None leaves Glyph null).  -->
                                        <DataTrigger Binding="{Binding Glyph}" Value="Edit">
                                            <Setter Property="Glyph" Value="{StaticResource {x:Static sdg:IconKeys.IconEdit}}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Glyph}" Value="Calendar">
                                            <Setter Property="Glyph" Value="{StaticResource {x:Static sdg:IconKeys.IconCalendar}}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Glyph}" Value="Filter">
                                            <Setter Property="Glyph" Value="{StaticResource {x:Static sdg:IconKeys.IconFilter}}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </sdg:WWTextBox.Style>
                        </sdg:WWTextBox>

                        <TextBlock Style="{StaticResource BoundValue}"
                                   Text="{Binding SampleText, StringFormat='Value: {0}', TargetNullValue='Value: (empty)', FallbackValue='Value: (empty)'}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </sampleControls:SampleHostControl>
</UserControl>
