<UserControl x:Class="WWControls.SampleApp.Editors.Views.Samples.Editors.DatePickerSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Editors.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Editors.Views.Samples.Editors"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:DatePickerSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#444" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="OptionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#666" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#888" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="BoundValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#0066AA" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
        <Style x:Key="ToggleRow" BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.CheckBox}}" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Foreground" Value="#333" />
        </Style>
        <Style x:Key="OptionCombo" TargetType="{x:Type sdg:WWComboBox}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.ComboBox}}">
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.DatePicker}">
        <ScrollViewer Background="#FFFFFF" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" MaxWidth="760" HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource SampleIntro}">
                    <Run FontWeight="SemiBold" Text="WWDatePicker" />
                    <LineBreak />
                    <Run Text="Date/time editor masked by standard .NET format strings, binding a nullable DateTime. The dropdown offers a calendar or looping scroll columns, with a time surface when the mask carries time parts." />
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="230" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Options — every control here drives the demo picker on the right.  -->
                    <Border Grid.Column="0"
                            Background="#FAFAFA"
                            BorderBrush="#E3E3E3"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14"
                            VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Caption}" Text="Options" Margin="0,0,0,10" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="Mask (editable — type your own)" />
                            <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                            IsEditable="True"
                                            ToolTip="A .NET date/time format (MM/dd/yyyy, g, t…) — time parts light up the popup's time surface"
                                            ItemsSource="{Binding MaskPresets}"
                                            Text="{Binding Mask, Mode=TwoWay}" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="PopupMode" />
                            <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                            ToolTip="Calendar, looping ScrollList columns, or both"
                                            ItemsSource="{Binding PopupModes}"
                                            SelectedItem="{Binding PopupMode, Mode=TwoWay}" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="TimeInput" />
                            <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                            ToolTip="Whether and where the popup shows a time editor"
                                            ItemsSource="{Binding TimeInputModes}"
                                            SelectedItem="{Binding TimeInput, Mode=TwoWay}" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="CycleModifier (for Up/Down spin)" />
                            <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                            ToolTip="The modifier that must be held for Up/Down to cycle the focused segment"
                                            ItemsSource="{Binding CycleModifiers}"
                                            SelectedItem="{Binding CycleModifier, Mode=TwoWay}" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="DisplayFormat (unfocused text)" />
                            <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                            IsEditable="True"
                                            ToolTip="How the value renders while the editor is unfocused"
                                            ItemsSource="{Binding DisplayFormatPresets}"
                                            Text="{Binding DisplayFormat, Mode=TwoWay}" />

                            <CheckBox Style="{StaticResource ToggleRow}" Content="AllowNullInput"
                                      ToolTip="Ctrl+0 / Ctrl+Delete clears; emptied editor commits null"
                                      IsChecked="{Binding AllowNullInput, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource ToggleRow}" Content="ShowClearButton"
                                      ToolTip="An inline clear button (needs AllowNullInput)"
                                      IsEnabled="{Binding AllowNullInput}"
                                      IsChecked="{Binding ShowClearButton, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource ToggleRow}" Content="ShowTodayButton"
                                      ToolTip="Hidden automatically on a time-only mask"
                                      IsChecked="{Binding ShowTodayButton, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource ToggleRow}" Content="ShowNowButton"
                                      ToolTip="Shows only while the popup has a time surface"
                                      IsChecked="{Binding ShowNowButton, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource ToggleRow}" Content="ShowWeekNumbers"
                                      ToolTip="Adds an ISO week-number column to the calendar"
                                      IsChecked="{Binding ShowWeekNumbers, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource ToggleRow}" Content="DisableWeekends"
                                      ToolTip="Saturday/Sunday can't be picked — calendar cells disable, typing/spin/scroll/Today reject a weekend result"
                                      IsChecked="{Binding DisableWeekends, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource ToggleRow}" Content="HighlightHolidays"
                                      ToolTip="Accents US federal holidays in the calendar with a marker dot and a naming tooltip (highlight only)"
                                      IsChecked="{Binding HighlightHolidays, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource ToggleRow}" Content="Clamp to this year"
                                      ToolTip="Sets MinDate / MaxDate to Jan 1 – Dec 31 of the current year"
                                      IsChecked="{Binding ClampToThisYear, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource ToggleRow}" Margin="0" Content="DefaultDate = next month"
                                      ToolTip="Popup seeds at the first of next month while the value is null"
                                      IsChecked="{Binding SeedNextMonth, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>

                    <!--  The demo picker.  -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource Caption}" Text="Editor" />
                        <sdg:WWDatePicker Height="28"
                                          Width="260"
                                          HorizontalAlignment="Left"
                                          Value="{Binding Value, Mode=TwoWay}"
                                          Mask="{Binding Mask}"
                                          PopupMode="{Binding PopupMode}"
                                          TimeInput="{Binding TimeInput}"
                                          CycleModifier="{Binding CycleModifier}"
                                          DisplayFormat="{Binding DisplayFormat}"
                                          AllowNullInput="{Binding AllowNullInput}"
                                          ShowClearButton="{Binding ShowClearButton}"
                                          ShowTodayButton="{Binding ShowTodayButton}"
                                          ShowNowButton="{Binding ShowNowButton}"
                                          ShowWeekNumbers="{Binding ShowWeekNumbers}"
                                          DisableWeekends="{Binding DisableWeekends}"
                                          HighlightHolidays="{Binding HighlightHolidays}"
                                          MinDate="{Binding MinDate}"
                                          MaxDate="{Binding MaxDate}"
                                          DefaultDate="{Binding DefaultDate}" />
                        <TextBlock Style="{StaticResource BoundValue}"
                                   Text="{Binding Value, StringFormat='Bound value: {0}', TargetNullValue='Bound value: (null)'}" />

                        <TextBlock Style="{StaticResource SampleNoteHeader}" Text="Keyboard" Margin="0,16,0,6" />
                        <StackPanel Style="{StaticResource SampleKbdRow}">
                            <Border Style="{StaticResource SampleKbd}"><TextBlock Style="{StaticResource SampleKbdText}" Text="← / →" /></Border>
                            <TextBlock Style="{StaticResource SampleKbdDesc}" Text="Move between segments (or click one); digits overwrite" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource SampleKbdRow}">
                            <Border Style="{StaticResource SampleKbd}"><TextBlock Style="{StaticResource SampleKbdText}" Text="↑ / ↓" /></Border>
                            <TextBlock Style="{StaticResource SampleKbdDesc}" Text="Cycle the focused segment (gated by CycleModifier)" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource SampleKbdRow}">
                            <Border Style="{StaticResource SampleKbd}"><TextBlock Style="{StaticResource SampleKbdText}" Text="Ctrl + Del" /></Border>
                            <TextBlock Style="{StaticResource SampleKbdDesc}" Text="Clear the whole value to blank (with AllowNullInput)" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource SampleTip}" Margin="0,6,0,0"
                                   Text="• A mask with time parts (try 'g' or 'MM/dd/yyyy HH:mm') lights up the popup's time surface; a time-only mask ('t') collapses the calendar." />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </sampleControls:SampleHostControl>
</UserControl>
