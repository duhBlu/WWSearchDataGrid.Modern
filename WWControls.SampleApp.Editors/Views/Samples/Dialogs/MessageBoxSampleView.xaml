<UserControl x:Class="WWControls.SampleApp.Editors.Views.Samples.Dialogs.MessageBoxSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Editors.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Editors.Views.Samples.Dialogs"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:MessageBoxSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="OptionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#666" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>
        <Style x:Key="OptionGroup" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#444" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="Readout" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#0066AA" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="OptionCombo" TargetType="{x:Type sdg:WWComboBox}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.ComboBox}}">
            <Setter Property="Height" Value="26" />
        </Style>
        <Style x:Key="ToggleRow" BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.CheckBox}}" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Foreground" Value="#333" />
        </Style>
        <Style x:Key="ActionButton" TargetType="{x:Type sdg:WWButton}">
            <Setter Property="MinWidth" Value="200" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.MessageBox}">
        <ScrollViewer Background="#FFFFFF" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" MaxWidth="760" HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource SampleIntro}">
                    <Run FontWeight="SemiBold" Text="WWMessageBox" />
                    <LineBreak />
                    <Run Text="A modal message dialog in the library's window chrome. Buttons are not a fixed set — pass a list of UICommand and each becomes a button; the box returns the one the user picked. Standard MessageBoxButton / MessageBoxResult overloads drop in for existing MessageBox.Show calls." />
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Options — drive the standard-button demo.  -->
                    <Border Grid.Column="0"
                            Background="#FAFAFA"
                            BorderBrush="#E3E3E3"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14"
                            VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="Message" />

                            <StackPanel Style="{StaticResource OptionGroup}">
                                <TextBlock Style="{StaticResource OptionLabel}" Text="Caption" />
                                <sdg:WWTextBox Value="{Binding Caption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="26" />
                            </StackPanel>

                            <StackPanel Style="{StaticResource OptionGroup}">
                                <TextBlock Style="{StaticResource OptionLabel}" Text="Message" />
                                <TextBox Text="{Binding Message, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Height="72"
                                         Padding="6,4"
                                         BorderBrush="#E3E3E3"
                                         BorderThickness="1" />
                            </StackPanel>

                            <StackPanel Style="{StaticResource OptionGroup}">
                                <TextBlock Style="{StaticResource OptionLabel}" Text="Icon (MessageBoxImage)" />
                                <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                                ToolTip="Each severity has its own StatusIcon shape — a triangle for Warning, a circle for the rest"
                                                ItemsSource="{Binding Icons}"
                                                SelectedItem="{Binding Icon, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Style="{StaticResource OptionGroup}">
                                <TextBlock Style="{StaticResource OptionLabel}" Text="Buttons (MessageBoxButton)" />
                                <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                                ItemsSource="{Binding ButtonSets}"
                                                SelectedItem="{Binding Buttons, Mode=TwoWay}" />
                            </StackPanel>

                            <CheckBox Style="{StaticResource ToggleRow}"
                                      Content="Show Copy Message button (custom demo)"
                                      IsChecked="{Binding ShowCopyButton, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>

                    <!--  Preview — the three ways to show the box.  -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Show it" />

                        <sdg:WWButton Style="{StaticResource ActionButton}"
                                      Content="Standard buttons (drop-in)"
                                      ToolTip="WWMessageBox.Show(message, caption, MessageBoxButton, MessageBoxImage) → MessageBoxResult"
                                      Command="{Binding ShowStandardCommand}" />

                        <sdg:WWButton Style="{StaticResource ActionButton}"
                                      Content="Custom: Save / Don't Save / Cancel"
                                      ToolTip="A UICommand list with glyphs, a default and a cancel — returns the chosen UICommand"
                                      Command="{Binding ShowCustomCommand}" />

                        <sdg:WWButton Style="{StaticResource ActionButton}"
                                      Content="Custom: five choices"
                                      ToolTip="Any number of UICommands render as buttons"
                                      Command="{Binding ShowManyChoicesCommand}" />

                        <TextBlock Style="{StaticResource SectionHeader}" Text="Result" Margin="0,20,0,6" />
                        <TextBlock Style="{StaticResource Readout}" Text="{Binding LastResult}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </sampleControls:SampleHostControl>
</UserControl>
