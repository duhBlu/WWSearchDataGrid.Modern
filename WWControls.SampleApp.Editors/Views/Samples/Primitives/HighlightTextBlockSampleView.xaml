<UserControl x:Class="WWControls.SampleApp.Editors.Views.Samples.Primitives.HighlightTextBlockSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Editors.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Editors.Views.Samples.Primitives"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:HighlightTextBlockSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#444" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="OptionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#666" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#888" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="BoundValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#0066AA" />
        </Style>
        <Style x:Key="OptionCombo" TargetType="{x:Type sdg:WWComboBox}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.ComboBox}}">
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="ToggleRow" BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.CheckBox}}" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Foreground" Value="#333" />
        </Style>
        <Style x:Key="ColorOption" TargetType="{x:Type sdg:WWColorPicker}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.ColorPicker}}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style x:Key="RowText" TargetType="{x:Type sdg:HighlightTextBlock}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#333" />
            <Setter Property="Margin" Value="0,3" />
        </Style>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.HighlightTextBlock}">
        <ScrollViewer Background="#FFFFFF" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" MaxWidth="820" HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource SampleIntro}">
                    <Run FontWeight="SemiBold" Text="HighlightTextBlock" />
                    <LineBreak />
                    <Run Text="A TextBlock that emits the first (case-insensitive) match of a search term as its own Run — the highlight behind a search combo." />
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Options — search + a live-composed HighlightRunStyle.  -->
                    <Border Grid.Column="0"
                            Background="#FAFAFA"
                            BorderBrush="#E3E3E3"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14"
                            VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Caption}" Text="Search" Margin="0,0,0,10" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="Search term (HighlightText)" />
                            <sdg:WWTextBox Height="26" Margin="0,0,0,12"
                                           ToolTip="The term to find and highlight inside each string"
                                           Value="{Binding SearchTerm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="MatchMode" />
                            <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                            ToolTip="Contains = match anywhere; StartsWith / EndsWith anchor to the ends (try 'base' with EndsWith). Case-insensitive, first match only"
                                            ItemsSource="{Binding MatchModes}"
                                            SelectedItem="{Binding MatchMode, Mode=TwoWay}" />

                            <Separator Margin="0,2,0,12" />

                            <TextBlock Style="{StaticResource Caption}" Text="Highlight run style" Margin="0,0,0,10" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="Font weight" />
                            <sdg:WWComboBox Style="{StaticResource OptionCombo}"
                                            ItemsSource="{Binding Weights}"
                                            SelectedItem="{Binding Weight, Mode=TwoWay}" />

                            <CheckBox Style="{StaticResource ToggleRow}" Content="Italic"
                                      IsChecked="{Binding Italic, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource ToggleRow}" Content="Underline"
                                      IsChecked="{Binding Underline, Mode=TwoWay}" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="Foreground" />
                            <sdg:WWColorPicker Style="{StaticResource ColorOption}"
                                               SelectedColor="{Binding Foreground, Mode=TwoWay}"
                                               PresetColors="{Binding StylePresets}"
                                               DisplayColorAndName="True" />

                            <CheckBox Style="{StaticResource ToggleRow}" Content="Background fill"
                                      ToolTip="Adds a Background setter to the matched run"
                                      IsChecked="{Binding UseBackground, Mode=TwoWay}" />
                            <sdg:WWColorPicker Style="{StaticResource ColorOption}"
                                               IsEnabled="{Binding UseBackground}"
                                               SelectedColor="{Binding Background, Mode=TwoWay}"
                                               PresetColors="{Binding StylePresets}"
                                               DisplayColorAndName="True" />

                            <Separator Margin="0,0,0,10" />

                            <TextBlock Style="{StaticResource BoundValue}"
                                       Text="{Binding MatchCount, StringFormat='Matches: {0}'}" />
                        </StackPanel>
                    </Border>

                    <!--  Live preview + highlighted list, both using the composed HighlightRunStyle.  -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource Caption}" Text="Preview" />
                        <Border Background="#F7F7F7"
                                BorderBrush="#E3E3E3"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="16,14"
                                HorizontalAlignment="Left"
                                MinWidth="320">
                            <sdg:HighlightTextBlock FontSize="18"
                                                    Foreground="#333"
                                                    HighlightTextBlockText="Base Cabinet order — the matched run is styled live."
                                                    HighlightText="{Binding SearchTerm}"
                                                    MatchMode="{Binding MatchMode}"
                                                    HighlightRunStyle="{Binding HighlightRunStyle}" />
                        </Border>

                        <TextBlock Style="{StaticResource Caption}" Text="Live list" Margin="0,20,0,4" />
                        <Border Background="#F7F7F7"
                                BorderBrush="#E3E3E3"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="16,10"
                                HorizontalAlignment="Left"
                                MinWidth="320">
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <sdg:HighlightTextBlock Style="{StaticResource RowText}"
                                                                HighlightTextBlockText="{Binding}"
                                                                HighlightText="{Binding DataContext.SearchTerm, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                MatchMode="{Binding DataContext.MatchMode, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                HighlightRunStyle="{Binding DataContext.HighlightRunStyle, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </sampleControls:SampleHostControl>
</UserControl>
