<UserControl x:Class="WWControls.SampleApp.Editors.Views.Samples.Trees.TreeSearchSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Editors.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Editors.Views.Samples.Trees"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:TreeSearchSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#444" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="Readout" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#0066AA" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="ToggleRow" BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.CheckBox}}" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Foreground" Value="#333" />
        </Style>

        <!--  ShowSearchBar is off, so the item template drives the highlight itself: HighlightText reads
              the tree's live FilterText (the same property the custom find bar's text box is bound to).  -->
        <HierarchicalDataTemplate x:Key="NodeTemplate" ItemsSource="{Binding ChildrenView}">
            <sdg:HighlightTextBlock HighlightTextBlockText="{Binding Name}"
                                    HighlightText="{Binding FilterText, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWTreeView}}}"
                                    VerticalAlignment="Center"
                                    Padding="2,1" />
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.TreeSearch}">
        <ScrollViewer Background="#FFFFFF" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" MaxWidth="820" HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource SampleIntro}">
                    <Run FontWeight="SemiBold" Text="WWTreeView — Search &amp; Navigation" />
                    <LineBreak />
                    <Run Text="The tree's built-in search bar is turned off (ShowSearchBar=False) and driven from a hand-built find bar instead. The same engine is exposed as bindable members — FilterText, the Next / Previous match commands, and the MatchDisplay counter — plus imperative BringItemIntoView and SelectItems calls for driving it from code." />
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Options  -->
                    <Border Grid.Column="0"
                            Background="#FAFAFA"
                            BorderBrush="#E3E3E3"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14"
                            VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="Search mode" />
                            <ComboBox ItemsSource="{Binding SearchModes}"
                                      SelectedItem="{Binding SearchMode, Mode=TwoWay}"
                                      ToolTip="Highlight keeps every node and cycles matches; Filter hides non-matches (keeping the ancestor path)."
                                      Margin="0,0,0,12" />

                            <CheckBox Style="{StaticResource ToggleRow}"
                                      Content="SelectMatchOnNavigate"
                                      ToolTip="Off: cycling a match only scrolls to and accents it. On: the current match also becomes the selection."
                                      IsChecked="{Binding SelectMatchOnNavigate, Mode=TwoWay}" />

                            <TextBlock Style="{StaticResource SectionHeader}" Text="Search debounce" Margin="0,0,0,2" />
                            <Slider Minimum="0"
                                    Maximum="600"
                                    TickFrequency="50"
                                    IsSnapToTickEnabled="True"
                                    ToolTip="How long typing pauses before the filter pass runs (WWTreeView.SearchDebounce)."
                                    Value="{Binding DebounceMs, Mode=TwoWay}" />
                            <TextBlock Style="{StaticResource Readout}"
                                       Text="{Binding DebounceMs, StringFormat='{}{0:0} ms'}"
                                       Margin="0,0,0,12" />

                            <Border Height="1" Background="#E3E3E3" Margin="0,0,0,12" />

                            <TextBlock Style="{StaticResource SectionHeader}" Text="Go to node" />
                            <ComboBox ItemsSource="{Binding AllNodes}"
                                      SelectedItem="{Binding JumpTarget, Mode=TwoWay}"
                                      DisplayMemberPath="Path"
                                      ToolTip="Pick any node; Reveal scrolls it into view and expands its ancestors — without selecting it (WWTreeView.BringItemIntoView)."
                                      Margin="0,0,0,8" />
                            <sdg:WWButton Content="Reveal"
                                          HorizontalAlignment="Left"
                                          Padding="12,4"
                                          Click="OnReveal"
                                          Margin="0,0,0,12" />

                            <TextBlock Style="{StaticResource SectionHeader}" Text="Selection" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <sdg:WWButton Content="Select all matches"
                                              Padding="10,4"
                                              Click="OnSelectMatches"
                                              ToolTip="Replaces the selection with every node matching the find text at once (WWTreeView.SelectItems). Extended mode." />
                                <sdg:WWButton Content="Clear"
                                              Padding="10,4"
                                              Margin="8,0,0,0"
                                              Click="OnClearSelection" />
                            </StackPanel>

                            <TextBlock Style="{StaticResource SectionHeader}" Text="Selected items" Margin="0,4,0,6" />
                            <TextBlock Style="{StaticResource Readout}"
                                       Text="{Binding SelectionSummary}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!--  Live tree with its own find bar  -->
                    <Border Grid.Column="2"
                            Background="#FFFFFF"
                            BorderBrush="#E3E3E3"
                            BorderThickness="1"
                            CornerRadius="6"
                            MinHeight="360"
                            Padding="6">
                        <DockPanel>
                            <!--  Custom find bar — every binding here targets the tree by ElementName.  -->
                            <Grid DockPanel.Dock="Top" Margin="2,2,2,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <sdg:WWTextBox Grid.Column="0"
                                               Height="28"
                                               Watermark="Find in tree…"
                                               ShowClearButton="True"
                                               Value="{Binding ElementName=Tree, Path=FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <sdg:WWButton Grid.Column="1"
                                              Content="Prev"
                                              Padding="10,4"
                                              Margin="8,0,0,0"
                                              ToolTip="Previous match (wraps). Disabled when there are none."
                                              Command="{Binding ElementName=Tree, Path=PreviousMatchCommand}" />
                                <sdg:WWButton Grid.Column="2"
                                              Content="Next"
                                              Padding="10,4"
                                              Margin="6,0,0,0"
                                              ToolTip="Next match (wraps)."
                                              Command="{Binding ElementName=Tree, Path=NextMatchCommand}" />
                                <TextBlock Grid.Column="3"
                                           VerticalAlignment="Center"
                                           MinWidth="52"
                                           Margin="10,0,2,0"
                                           TextAlignment="Right"
                                           Foreground="#666"
                                           Text="{Binding ElementName=Tree, Path=MatchDisplay}" />
                            </Grid>

                            <sdg:WWTreeView x:Name="Tree"
                                            ItemsSource="{Binding Roots}"
                                            ItemTemplate="{StaticResource NodeTemplate}"
                                            ShowSearchBar="False"
                                            SearchMode="{Binding SearchMode}"
                                            SelectMatchOnNavigate="{Binding SelectMatchOnNavigate}"
                                            SearchDebounce="{Binding SearchDebounce}"
                                            SelectionMode="Extended"
                                            SelectionChangedCommand="{Binding SelectionChangedCommand}"
                                            FilterKeepsAncestors="True"
                                            ExpandOnLoad="False" />
                        </DockPanel>
                    </Border>
                </Grid>

                <TextBlock Style="{StaticResource SampleNoteHeader}" Text="Tips" Margin="0,16,0,6" />
                <TextBlock Style="{StaticResource SampleTip}" Text="• Type in the find box, then Prev / Next to cycle matches — the current match gets an amber accent. The 'n of m' counter is the tree's MatchDisplay." />
                <TextBlock Style="{StaticResource SampleTip}" Text="• The find bar owns no logic: the text box is bound to FilterText, the buttons to the match commands, the counter to MatchDisplay. Swap Highlight / Filter to see both engines drive the same chrome." />
                <TextBlock Style="{StaticResource SampleTip}" Text="• 'Go to node' → Reveal scrolls a node into view and expands its ancestors without changing the selection (BringItemIntoView)." />
                <TextBlock Style="{StaticResource SampleTip}" Text="• 'Select all matches' selects every matching node in one call (SelectItems); Extended mode lets Ctrl / Shift-clicks refine it afterward." />
            </StackPanel>
        </ScrollViewer>
    </sampleControls:SampleHostControl>
</UserControl>
