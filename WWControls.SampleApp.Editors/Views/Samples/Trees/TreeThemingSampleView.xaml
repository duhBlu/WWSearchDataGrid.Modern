<UserControl x:Class="WWControls.SampleApp.Editors.Views.Samples.Trees.TreeThemingSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Editors.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Editors.Views.Samples.Trees"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:TreeThemingSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#444" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="OptionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#666" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>
        <Style x:Key="Readout" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#0066AA" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="ToggleRow" BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.CheckBox}}" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Foreground" Value="#333" />
        </Style>
        <!--  Each role picker: default templated chrome (BasedOn the themed key) + a shared height / margin.  -->
        <Style x:Key="RolePicker" TargetType="{x:Type sdg:WWColorPicker}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.ColorPicker}}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <HierarchicalDataTemplate x:Key="ThemeNodeTemplate" ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Padding="2,1" />
        </HierarchicalDataTemplate>

        <!--  Custom empty state. EmptyContent is bound to the view model (below), so this template's
              DataContext is the VM and the call-to-action button can bind its RestoreNodes command.  -->
        <DataTemplate x:Key="EmptyStateTemplate">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="260">
                <Viewbox Width="56" Height="56" HorizontalAlignment="Center">
                    <Path Fill="#C3CBD3"
                          Data="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z" />
                </Viewbox>
                <TextBlock Text="This tree is empty"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#555"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0" />
                <TextBlock Text="Your EmptyTemplate renders here whenever the tree has no items — icon, copy, and a call to action, all your own."
                           FontSize="12"
                           Foreground="#888"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,4,0,0" />
                <sdg:WWButton Content="Restore sample nodes"
                              HorizontalAlignment="Center"
                              Padding="14,5"
                              Margin="0,14,0,0"
                              Command="{Binding RestoreNodesCommand}" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.TreeTheming}">
        <ScrollViewer Background="#FFFFFF" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" MaxWidth="820" HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource SampleIntro}">
                    <Run FontWeight="SemiBold" Text="WWTreeView — Theming" />
                    <LineBreak />
                    <Run Text="Restyle the tree's chrome with plain brush and metric properties — no retemplating. The connector lines, item hover, and selection each take a brush; ConnectorLineThickness sizes the lines; and EmptyTemplate replaces the empty-state placeholder with your own content." />
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Palette + metrics — every control here reskins the tree on the right.  -->
                    <Border Grid.Column="0"
                            Background="#FAFAFA"
                            BorderBrush="#E3E3E3"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14"
                            VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="Theme preset" />
                            <ComboBox ItemsSource="{Binding Presets}"
                                      SelectedItem="{Binding Preset, Mode=TwoWay}"
                                      ToolTip="A coordinated look — reseeds all four role colors and the line thickness at once."
                                      Margin="0,0,0,14" />

                            <TextBlock Style="{StaticResource SectionHeader}" Text="Brushes" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="Selection (SelectionBrush)" />
                            <sdg:WWColorPicker Style="{StaticResource RolePicker}"
                                               SelectedColor="{Binding SelectionColor, Mode=TwoWay}"
                                               DisplayColorAndName="True"
                                               PresetColors="{Binding Swatches}" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="Item hover (ItemHoverBrush)" />
                            <sdg:WWColorPicker Style="{StaticResource RolePicker}"
                                               SelectedColor="{Binding ItemHoverColor, Mode=TwoWay}"
                                               DisplayColorAndName="True"
                                               PresetColors="{Binding Swatches}" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="Connector line (ConnectorLineBrush)" />
                            <sdg:WWColorPicker Style="{StaticResource RolePicker}"
                                               SelectedColor="{Binding ConnectorLineColor, Mode=TwoWay}"
                                               DisplayColorAndName="True"
                                               PresetColors="{Binding Swatches}" />

                            <TextBlock Style="{StaticResource OptionLabel}" Text="Line hover accent (LineHoverBrush)" />
                            <sdg:WWColorPicker Style="{StaticResource RolePicker}"
                                               SelectedColor="{Binding LineHoverColor, Mode=TwoWay}"
                                               DisplayColorAndName="True"
                                               PresetColors="{Binding Swatches}" />

                            <TextBlock Style="{StaticResource SectionHeader}" Text="Lines" Margin="0,4,0,8" />
                            <TextBlock Style="{StaticResource OptionLabel}" Text="ConnectorLineThickness" />
                            <Slider Minimum="0.5"
                                    Maximum="3"
                                    TickFrequency="0.5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding LineThickness, Mode=TwoWay}" />
                            <TextBlock Style="{StaticResource Readout}"
                                       Text="{Binding LineThickness, StringFormat='{}{0:0.0} px'}"
                                       Margin="0,0,0,10" />
                            <CheckBox Style="{StaticResource ToggleRow}"
                                      Content="ShowConnectorLines"
                                      ToolTip="Draw the parent/child connector lines."
                                      IsChecked="{Binding ShowConnectorLines, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource ToggleRow}"
                                      Content="RowFullWidthHover"
                                      ToolTip="Extend the hover / selection brush across the whole row (including the indent) so the brushes read further."
                                      IsChecked="{Binding RowFullWidthHover, Mode=TwoWay}" />

                            <Border Height="1" Background="#E3E3E3" Margin="0,4,0,12" />

                            <TextBlock Style="{StaticResource SectionHeader}" Text="Empty state" />
                            <CheckBox Style="{StaticResource ToggleRow}"
                                      Content="Show empty state"
                                      ToolTip="Empty the tree to show the custom EmptyTemplate (icon + copy + a Restore button)."
                                      IsChecked="{Binding ShowEmptyState, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>

                    <!--  Live tree — chrome bound entirely to the palette above.  -->
                    <Border Grid.Column="2"
                            Background="#FFFFFF"
                            BorderBrush="#E3E3E3"
                            BorderThickness="1"
                            CornerRadius="6"
                            MinHeight="360"
                            Padding="6">
                        <sdg:WWTreeView x:Name="Tree"
                                        ItemsSource="{Binding Roots}"
                                        ItemTemplate="{StaticResource ThemeNodeTemplate}"
                                        ExpandOnLoad="True"
                                        SelectionMode="Extended"
                                        ShowConnectorLines="{Binding ShowConnectorLines}"
                                        ConnectorLineBrush="{Binding ConnectorLineBrush}"
                                        ConnectorLineThickness="{Binding LineThickness}"
                                        LineHoverBrush="{Binding LineHoverBrush}"
                                        SelectionBrush="{Binding SelectionBrush}"
                                        ItemHoverBrush="{Binding ItemHoverBrush}"
                                        RowFullWidthHover="{Binding RowFullWidthHover}"
                                        EmptyContent="{Binding}"
                                        EmptyTemplate="{StaticResource EmptyStateTemplate}" />
                    </Border>
                </Grid>

                <TextBlock Style="{StaticResource SampleNoteHeader}" Text="Tips" Margin="0,16,0,6" />
                <TextBlock Style="{StaticResource SampleTip}" Text="• Pick a preset, then hand-tune any role with its color picker — SelectedColor is a Color, so the view model projects each one to a frozen brush the tree binds." />
                <TextBlock Style="{StaticResource SampleTip}" Text="• Select a few rows (Ctrl / Shift-click) and hover others to see SelectionBrush and ItemHoverBrush; RowFullWidthHover makes both span the whole row." />
                <TextBlock Style="{StaticResource SampleTip}" Text="• Hover a connector line: the hovered branch's children take the LineHoverBrush accent. Thicken the lines with the slider." />
                <TextBlock Style="{StaticResource SampleTip}" Text="• Toggle 'Show empty state' to swap in the custom EmptyTemplate; its Restore button repopulates the tree." />
            </StackPanel>
        </ScrollViewer>
    </sampleControls:SampleHostControl>
</UserControl>
