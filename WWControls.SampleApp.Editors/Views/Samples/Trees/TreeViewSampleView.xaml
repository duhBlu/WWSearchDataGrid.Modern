<UserControl x:Class="WWControls.SampleApp.Editors.Views.Samples.Trees.TreeViewSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Editors.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Editors.Views.Samples.Trees"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:TreeViewSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#444" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="Readout" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#0066AA" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="ToggleRow" BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.CheckBox}}" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Foreground" Value="#333" />
        </Style>

        <!--  One HierarchicalDataTemplate drives every level of the tree. ItemsSource binds ChildrenView
              (not Children) so Filter mode can hide non-matching nodes; the label highlights the term.  -->
        <HierarchicalDataTemplate x:Key="NodeTemplate" ItemsSource="{Binding ChildrenView}">
            <sdg:HighlightTextBlock HighlightTextBlockText="{Binding Name}"
                                    HighlightText="{Binding FilterText, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWTreeView}}}"
                                    VerticalAlignment="Center"
                                    Padding="2,1" />
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.TreeView}">
        <ScrollViewer Background="#FFFFFF" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" MaxWidth="820" HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource SampleIntro}">
                    <Run FontWeight="SemiBold" Text="WWTreeView" />
                    <LineBreak />
                    <Run Text="A themed tree with two-way selection binding, drag-and-drop reparenting, and expand / collapse-all." />
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Options  -->
                    <Border Grid.Column="0"
                            Background="#FAFAFA"
                            BorderBrush="#E3E3E3"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14"
                            VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="Options" />
                            <CheckBox Style="{StaticResource ToggleRow}"
                                      Content="AllowDragDrop"
                                      ToolTip="Drag a node onto a folder to reparent it; dropping onto itself or its own subtree is rejected"
                                      IsChecked="{Binding AllowDragDrop, Mode=TwoWay}" />

                            <TextBlock Style="{StaticResource SectionHeader}" Text="Selection mode" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding SelectionModes}"
                                      SelectedItem="{Binding SelectionMode, Mode=TwoWay}"
                                      ToolTip="Extended = click replaces, Ctrl toggles, Shift ranges. Multiple = click toggles."
                                      Margin="0,0,0,12" />

                            <TextBlock Style="{StaticResource SectionHeader}" Text="Search mode" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding SearchModes}"
                                      SelectedItem="{Binding SearchMode, Mode=TwoWay}"
                                      ToolTip="Highlight = keep every node, cycle matches. Filter = hide non-matches (keeps ancestors)."
                                      Margin="0,0,0,8" />
                            <CheckBox Style="{StaticResource ToggleRow}"
                                      Content="FilterKeepsAncestors"
                                      ToolTip="In Filter mode, keep a matched node's full subtree visible for context"
                                      IsChecked="{Binding FilterKeepsAncestors, Mode=TwoWay}" />

                            <TextBlock Style="{StaticResource SectionHeader}" Text="Per-item buttons" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding ExpandCollapseButtonModes}"
                                      SelectedItem="{Binding ExpandCollapseButtonMode, Mode=TwoWay}"
                                      ToolTip="When the hover-revealed expand-all / collapse-all buttons appear on a node: never, every node with children, roots only, or only nodes with grandchildren."
                                      Margin="0,0,0,12" />

                            <TextBlock Style="{StaticResource SectionHeader}" Text="Layout" Margin="0,0,0,6" />
                            <CheckBox Style="{StaticResource ToggleRow}"
                                      Content="ShowConnectorLines"
                                      ToolTip="Draw the parent/child connector lines"
                                      IsChecked="{Binding ShowConnectorLines, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource ToggleRow}"
                                      Content="RowFullWidthHover"
                                      ToolTip="Extend the hover / selection highlight across the indent column, not just the content"
                                      IsChecked="{Binding RowFullWidthHover, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource ToggleRow}"
                                      Content="Show empty state"
                                      ToolTip="Empty the tree to show the EmptyContent placeholder"
                                      IsChecked="{Binding ShowEmptyState, Mode=TwoWay}" />

                            <TextBlock Style="{StaticResource SectionHeader}" Text="Indentation" Margin="0,0,0,2" />
                            <Slider Minimum="8"
                                    Maximum="40"
                                    TickFrequency="2"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding Indentation, Mode=TwoWay}" />
                            <TextBlock Style="{StaticResource Readout}"
                                       Text="{Binding Indentation, StringFormat='{}{0:0} px'}"
                                       Margin="0,0,0,12" />

                            <StackPanel Orientation="Horizontal" Margin="0,2,0,12">
                                <sdg:WWButton Content="Expand all"
                                              Padding="10,4"
                                              Command="{Binding ElementName=Tree, Path=ExpandAllCommand}" />
                                <sdg:WWButton Content="Collapse all"
                                              Padding="10,4"
                                              Margin="8,0,0,0"
                                              Command="{Binding ElementName=Tree, Path=CollapseAllCommand}" />
                            </StackPanel>

                            <TextBlock Style="{StaticResource SectionHeader}" Text="Selection (anchor)" Margin="0,4,0,6" />
                            <TextBlock Style="{StaticResource Readout}"
                                       Text="{Binding Selected.Name, TargetNullValue='(none)', FallbackValue='(none)'}" />

                            <TextBlock Style="{StaticResource SectionHeader}" Text="Selected items" Margin="0,10,0,6" />
                            <TextBlock Style="{StaticResource Readout}"
                                       Text="{Binding SelectionSummary}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!--  Live tree  -->
                    <Border Grid.Column="2"
                            Background="#FFFFFF"
                            BorderBrush="#E3E3E3"
                            BorderThickness="1"
                            CornerRadius="6"
                            MinHeight="340"
                            Padding="6">
                        <sdg:WWTreeView x:Name="Tree"
                                        ItemsSource="{Binding Roots}"
                                        ItemTemplate="{StaticResource NodeTemplate}"
                                        SelectedObject="{Binding Selected, Mode=TwoWay}"
                                        SelectionMode="{Binding SelectionMode}"
                                        SelectionChangedCommand="{Binding SelectionChangedCommand}"
                                        ShowSearchBar="True"
                                        SearchMode="{Binding SearchMode}"
                                        FilterKeepsAncestors="{Binding FilterKeepsAncestors}"
                                        ExpandOnLoad="false"
                                        AllowDragDrop="{Binding AllowDragDrop}"
                                        OnDropCommand="{Binding DropCommand}"
                                        ExpandCollapseButtonMode="{Binding ExpandCollapseButtonMode}"
                                        Indentation="{Binding Indentation}"
                                        ShowConnectorLines="{Binding ShowConnectorLines}"
                                        RowFullWidthHover="{Binding RowFullWidthHover}"
                                        EmptyContent="No items — turn off &quot;Show empty state&quot; to restore." />
                    </Border>
                </Grid>

                <TextBlock Style="{StaticResource SampleNoteHeader}" Text="Tips" Margin="0,16,0,6" />
                <TextBlock Style="{StaticResource SampleTip}" Text="• Hover a node with grandchildren to reveal its expand / collapse button." />
                <TextBlock Style="{StaticResource SampleTip}" Text="• With AllowDragDrop on, drag a file or folder onto another folder to reparent it." />
                <TextBlock Style="{StaticResource SampleTip}" Text="• The two structural root nodes opt out of dragging (IWWTreeViewDragItem)." />
                <TextBlock Style="{StaticResource SampleTip}" Text="• In Extended mode: Ctrl+click toggles a node, Shift+click selects a range. Multiple mode toggles on plain click." />
                <TextBlock Style="{StaticResource SampleTip}" Text="• Type in the search bar; ↑ / ↓ cycle matches — the current match gets an amber accent without changing selection. Switch Highlight / Filter above." />
                <TextBlock Style="{StaticResource SampleTip}" Text="• The 'Lazy load demo' node fetches its children on first expand (IWWLazyTreeNode), showing 'Loading...' briefly." />
                <TextBlock Style="{StaticResource SampleTip}" Text="• Layout knobs: drag Indentation to re-space levels (connector lines track it), toggle the connector lines, and switch full-width vs content-only hover highlighting." />
            </StackPanel>
        </ScrollViewer>
    </sampleControls:SampleHostControl>
</UserControl>
