<UserControl x:Class="WWControls.SampleApp.Editors.Views.Samples.PropertyGrid.PropertyGridCustomTemplatesSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Editors.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Editors.Views.Samples.PropertyGrid"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:PropertyGridCustomTemplatesSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#444" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#888" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="ReadoutLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#666" />
        </Style>
        <Style x:Key="ReadoutValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#0066AA" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.PropertyGridCustomTemplates}">
        <ScrollViewer Background="#FFFFFF" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" MaxWidth="820" HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource SampleIntro}">
                    <Run FontWeight="SemiBold" Text="WWPropertyGrid — custom templates" />
                    <LineBreak />
                    <Run Text="A WWPropertyDefinition.EditTemplate supplies any control as the editor for a property — here a rating slider, a discount slider, and a multiline notes box. The template's DataContext is the property item, so it binds {Binding Value}. Properties without a template use the auto editor." />
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Caption}" Text="Property grid" />
                        <sdg:WWPropertyGrid Width="380"
                                            Height="420"
                                            NameColumnWidth="130"
                                            SelectedObject="{Binding Product}">
                            <sdg:WWPropertyGrid.PropertyDefinitions>
                                <!--  Rating — a 0–5 snap slider with a live readout.  -->
                                <sdg:WWPropertyDefinition TargetProperties="Rating">
                                    <sdg:WWPropertyDefinition.EditTemplate>
                                        <DataTemplate>
                                            <DockPanel LastChildFill="True" Margin="6,0">
                                                <TextBlock DockPanel.Dock="Right"
                                                           MinWidth="18"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="#0066AA"
                                                           Text="{Binding Value}" />
                                                <Slider Minimum="0"
                                                        Maximum="5"
                                                        TickFrequency="1"
                                                        IsSnapToTickEnabled="True"
                                                        VerticalAlignment="Center"
                                                        Value="{Binding Value, Mode=TwoWay}" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </sdg:WWPropertyDefinition.EditTemplate>
                                </sdg:WWPropertyDefinition>

                                <!--  Discount — a 0–100% slider with a percent readout.  -->
                                <sdg:WWPropertyDefinition TargetProperties="Discount">
                                    <sdg:WWPropertyDefinition.EditTemplate>
                                        <DataTemplate>
                                            <DockPanel LastChildFill="True" Margin="6,0">
                                                <TextBlock DockPanel.Dock="Right"
                                                           MinWidth="34"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="#0066AA"
                                                           Text="{Binding Value, StringFormat=P0}" />
                                                <Slider Minimum="0"
                                                        Maximum="1"
                                                        VerticalAlignment="Center"
                                                        Value="{Binding Value, Mode=TwoWay}" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </sdg:WWPropertyDefinition.EditTemplate>
                                </sdg:WWPropertyDefinition>

                                <!--  Notes — a multiline, wrapping text box.  -->
                                <sdg:WWPropertyDefinition TargetProperties="Notes">
                                    <sdg:WWPropertyDefinition.EditTemplate>
                                        <DataTemplate>
                                            <TextBox Margin="4,2"
                                                     MinHeight="52"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     VerticalScrollBarVisibility="Auto"
                                                     Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </sdg:WWPropertyDefinition.EditTemplate>
                                </sdg:WWPropertyDefinition>
                            </sdg:WWPropertyGrid.PropertyDefinitions>
                        </sdg:WWPropertyGrid>
                        <TextBlock Style="{StaticResource SampleNoteHeader}" Text="Tips" Margin="0,10,0,6" />
                        <TextBlock Style="{StaticResource SampleTip}" MaxWidth="380" Text="• A custom EditTemplate wins over EditSettings and the auto editor." />
                        <TextBlock Style="{StaticResource SampleTip}" MaxWidth="380" Text="• The template binds {Binding Value} — the property item's two-way value." />
                        <TextBlock Style="{StaticResource SampleTip}" MaxWidth="380" Text="• Name and Featured have no template, so they use the auto text / checkbox editors." />
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                        <TextBlock Style="{StaticResource Caption}" Text="Live object" />
                        <Border Background="#FAFAFA"
                                BorderBrush="#E3E3E3"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14"
                                HorizontalAlignment="Left"
                                MinWidth="240">
                            <StackPanel>
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Name" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.Name}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Featured" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.IsFeatured}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Rating" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.Rating}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Discount" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.Discount, StringFormat=P0}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Notes" />
                                <TextBlock Style="{StaticResource ReadoutValue}" TextWrapping="Wrap" Text="{Binding Product.Notes}" />
                            </StackPanel>
                        </Border>
                        <TextBlock Style="{StaticResource Hint}" MaxWidth="260"
                                   Text="Drag the sliders or edit the notes — the model updates live through {Binding Value}." />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </sampleControls:SampleHostControl>
</UserControl>
