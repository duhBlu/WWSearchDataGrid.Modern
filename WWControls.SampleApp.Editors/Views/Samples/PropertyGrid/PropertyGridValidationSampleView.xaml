<UserControl x:Class="WWControls.SampleApp.Editors.Views.Samples.PropertyGrid.PropertyGridValidationSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Editors.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Editors.Views.Samples.PropertyGrid"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:PropertyGridValidationSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#444" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="ToggleRow" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#888" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="ReadoutLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#666" />
        </Style>
        <Style x:Key="ReadoutValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#0066AA" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.PropertyGridValidation}">
        <ScrollViewer Background="#FFFFFF" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" MaxWidth="820" HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource SampleIntro}">
                    <Run FontWeight="SemiBold" Text="WWPropertyGrid — validation" />
                    <LineBreak />
                    <Run Text="Each row wraps its editor in the same validation presenter the SearchDataGrid uses: data-annotation attributes ([Required] / [Range] / [StringLength] / [EmailAddress]) and INotifyDataErrorInfo both surface as a badge, with per-property severity. The grid-wide toggles drive whether errors show and whether a failing value may still commit." />
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Caption}" Text="Property grid" />
                        <StackPanel Style="{StaticResource ToggleRow}">
                            <CheckBox Content="Show errors" IsChecked="{Binding ShowValidationErrors}" Margin="0,0,16,0" />
                            <CheckBox Content="Allow commit on error" IsChecked="{Binding AllowCommitOnValidationError}" />
                        </StackPanel>
                        <sdg:WWPropertyGrid Width="360"
                                            Height="420"
                                            NameColumnWidth="140"
                                            ShowSearchBox="False"
                                            SelectedObject="{Binding Order}"
                                            ShowValidationErrors="{Binding ShowValidationErrors}"
                                            AllowCommitOnValidationError="{Binding AllowCommitOnValidationError}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                        <!--  Live readout — the committed model value. With commit-on-error OFF an
                              invalid edit is held, so these keep the last valid value until it passes.  -->
                        <TextBlock Style="{StaticResource Caption}" Text="Live object" />
                        <Border Background="#FAFAFA"
                                BorderBrush="#E3E3E3"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14"
                                HorizontalAlignment="Left"
                                MinWidth="240">
                            <StackPanel>
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Customer Name" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Order.CustomerName}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Email" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Order.Email}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Quantity" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Order.Quantity}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Stock Level" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Order.StockLevel}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Discount Code" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Order.DiscountCode}" />
                            </StackPanel>
                        </Border>
                        <TextBlock Style="{StaticResource Hint}" MaxWidth="260"
                                   Text="These reflect the committed model value — with commit-on-error OFF, an invalid edit is held and the readout keeps the last valid value until the edit passes." />

                        <TextBlock Style="{StaticResource Caption}" Text="Try it" Margin="0,16,0,6" />
                        <TextBlock Style="{StaticResource SampleTip}" MaxWidth="300" Text="• Opens with several fields already invalid — the badges are live on load. Edit a field to clear (or re-trigger) its badge." />
                        <TextBlock Style="{StaticResource SampleTip}" MaxWidth="300" Text="• Clear the customer name or type 1–2 characters → [Required] / length badge." />
                        <TextBlock Style="{StaticResource SampleTip}" MaxWidth="300" Text="• Break the email format → [EmailAddress] badge." />
                        <TextBlock Style="{StaticResource SampleTip}" MaxWidth="300" Text="• Set Quantity outside 1–500 → [Range] badge." />
                        <TextBlock Style="{StaticResource SampleTip}" MaxWidth="300" Text="• Set Stock Level below 10 → an amber warning badge (IValidationSeverityProvider), not a blocking error." />
                        <TextBlock Style="{StaticResource SampleTip}" MaxWidth="300" Margin="0,8,0,0" Text="• With commit-on-error OFF, a failing edit is held (the model keeps its last valid value) and shown in-progress; turn it ON and the value commits with an advisory badge." />
                        <TextBlock Style="{StaticResource SampleTip}" MaxWidth="300" Text="• Untick “Show errors” to suppress every badge grid-wide." />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </sampleControls:SampleHostControl>
</UserControl>
