<UserControl x:Class="WWControls.SampleApp.Editors.Views.Samples.PropertyGrid.PropertyGridEditorSettingsSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Editors.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Editors.Views.Samples.PropertyGrid"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:PropertyGridEditorSettingsSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#444" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#888" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="ReadoutLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#666" />
        </Style>
        <Style x:Key="ReadoutValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#0066AA" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.PropertyGridEditorSettings}">
        <ScrollViewer Background="#FFFFFF" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" MaxWidth="820" HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource SampleIntro}">
                    <Run FontWeight="SemiBold" Text="WWPropertyGrid — editor settings" />
                    <LineBreak />
                    <Run Text="A WWPropertyDefinition attaches the same BaseEditorSettings the SearchDataGrid uses for its cells — a mask, an ItemsSource, numeric bounds, a date editor — per property. Anything without a definition still falls back to the auto editor." />
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Caption}" Text="Property grid" />
                        <sdg:WWPropertyGrid Width="360"
                                            Height="420"
                                            NameColumnWidth="140"
                                            SelectedObject="{Binding Product}">
                            <sdg:WWPropertyGrid.PropertyDefinitions>
                                <!--  Currency mask on the decimal, also used to format the display.  -->
                                <sdg:WWPropertyDefinition TargetProperties="UnitPrice">
                                    <sdg:WWPropertyDefinition.EditSettings>
                                        <sdg:TextBoxSettings Mask="C2" MaskType="Numeric" UseMaskAsDisplayFormat="True" />
                                    </sdg:WWPropertyDefinition.EditSettings>
                                </sdg:WWPropertyDefinition>

                                <!--  Simple phone mask on the string.  -->
                                <sdg:WWPropertyDefinition TargetProperties="ContactPhone">
                                    <sdg:WWPropertyDefinition.EditSettings>
                                        <sdg:TextBoxSettings Mask="(000) 000-0000" MaskType="Simple" />
                                    </sdg:WWPropertyDefinition.EditSettings>
                                </sdg:WWPropertyDefinition>

                                <!--  Bounded spinner on the int.  -->
                                <sdg:WWPropertyDefinition TargetProperties="QuantityOnHand">
                                    <sdg:WWPropertyDefinition.EditSettings>
                                        <sdg:NumericUpDownSettings Minimum="0" Maximum="1000" Increment="5" />
                                    </sdg:WWPropertyDefinition.EditSettings>
                                </sdg:WWPropertyDefinition>

                                <!--  Combo bound to the view model's warehouse list.  -->
                                <sdg:WWPropertyDefinition TargetProperties="Warehouse">
                                    <sdg:WWPropertyDefinition.EditSettings>
                                        <sdg:ComboBoxSettings ItemsSource="{Binding Warehouses}" />
                                    </sdg:WWPropertyDefinition.EditSettings>
                                </sdg:WWPropertyDefinition>

                                <!--  Explicit date editor.  -->
                                <sdg:WWPropertyDefinition TargetProperties="ReorderDate">
                                    <sdg:WWPropertyDefinition.EditSettings>
                                        <sdg:DatePickerSettings PopupMode="ScrollList" ShowWeekNumbers="True" ShowTodayButton="True" ShowNowButton="True" TimeInput="Enabled"/>
                                    </sdg:WWPropertyDefinition.EditSettings>
                                </sdg:WWPropertyDefinition>
                            </sdg:WWPropertyGrid.PropertyDefinitions>
                        </sdg:WWPropertyGrid>
                        <TextBlock Style="{StaticResource SampleNoteHeader}" Text="Tips" Margin="0,10,0,6" />
                        <TextBlock Style="{StaticResource SampleTip}" MaxWidth="360" Text="• The mask, bounds, and item source come from the definition — not from the model." />
                        <TextBlock Style="{StaticResource SampleTip}" MaxWidth="360" Text="• The combo ItemsSource binds to the view model because the grid propagates its DataContext to the definitions." />
                        <TextBlock Style="{StaticResource SampleTip}" MaxWidth="360" Text="• Quantity clamps to 0–1000 and steps by 5 (Ctrl+Up/Down or the spinner)." />
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                        <TextBlock Style="{StaticResource Caption}" Text="Live object" />
                        <Border Background="#FAFAFA"
                                BorderBrush="#E3E3E3"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14"
                                HorizontalAlignment="Left"
                                MinWidth="240">
                            <StackPanel>
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Unit Price" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.UnitPrice, StringFormat=C2}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Contact Phone" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.ContactPhone}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Quantity On Hand" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.QuantityOnHand}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Warehouse" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.Warehouse}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Reorder Date" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.ReorderDate, StringFormat=d}" />
                            </StackPanel>
                        </Border>
                        <TextBlock Style="{StaticResource Hint}" MaxWidth="260"
                                   Text="Each editor is the same control the datagrid builds for a cell with these EditSettings." />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </sampleControls:SampleHostControl>
</UserControl>
