<UserControl x:Class="WWControls.SampleApp.Editors.Views.Samples.PropertyGrid.PropertyGridBasicsSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Editors.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Editors.Views.Samples.PropertyGrid"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:PropertyGridBasicsSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#444" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#888" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="ReadoutLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#666" />
        </Style>
        <Style x:Key="ReadoutValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#0066AA" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.PropertyGridBasics}">
        <ScrollViewer Background="#FFFFFF" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" MaxWidth="820" HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource SampleIntro}">
                    <Run FontWeight="SemiBold" Text="WWPropertyGrid — basics" />
                    <LineBreak />
                    <Run Text="Point the grid at any object and it reflects the public properties: grouped by [Category] / [Display(GroupName)], labeled from [DisplayName] / [Display(Name)], described in the panel below, and edited with a typed editor picked from each property's CLR type — no per-property setup." />
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  The property grid, bound to the demo object — no EditorDefinitions / PropertyDefinitions.  -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Caption}" Text="Property grid" />
                        <sdg:WWPropertyGrid Width="360"
                                            Height="470"
                                            NameColumnWidth="140"
                                            SelectedObject="{Binding Product}" />
                        <TextBlock Style="{StaticResource SampleNoteHeader}" Text="Tips" Margin="0,10,0,6" />
                        <TextBlock Style="{StaticResource SampleTip}" MaxWidth="360" Text="• Every editable property gets a typed editor automatically — string, bool, enum, number, and date." />
                        <TextBlock Style="{StaticResource SampleTip}" MaxWidth="360" Text="• Read-only properties (no setter) render disabled; a type with no editor (Guid) shows as read-only text." />
                        <TextBlock Style="{StaticResource SampleTip}" MaxWidth="360" Text="• Click a row for its description; the search box filters by name or category; drag the divider to resize." />
                    </StackPanel>

                    <!--  Live readout — reflects edits made through the grid.  -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                        <TextBlock Style="{StaticResource Caption}" Text="Live object" />
                        <Border Background="#FAFAFA"
                                BorderBrush="#E3E3E3"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14"
                                HorizontalAlignment="Left"
                                MinWidth="240">
                            <StackPanel>
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Name" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.Name}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Active" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.IsActive}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Unit Price" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.UnitPrice}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Quantity On Hand" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.QuantityOnHand}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Status" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.Status}" />
                                <TextBlock Style="{StaticResource ReadoutLabel}" Text="Launch Date" />
                                <TextBlock Style="{StaticResource ReadoutValue}" Text="{Binding Product.LaunchDate, StringFormat=d}" />
                            </StackPanel>
                        </Border>
                        <TextBlock Style="{StaticResource Hint}" MaxWidth="260"
                                   Text="Edit in the grid and these update live — each auto editor two-way binds straight to the model property." />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </sampleControls:SampleHostControl>
</UserControl>
