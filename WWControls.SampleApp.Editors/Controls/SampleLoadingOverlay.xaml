<UserControl x:Class="WWControls.SampleApp.Editors.Controls.SampleLoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             x:Name="Root">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>
    <Border Background="#88FFFFFF"
            Visibility="{Binding IsBusy, ElementName=Root, Converter={StaticResource BoolToVisibility}}"
            Panel.ZIndex="50">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <sdg:WWSpinningWheel Width="56" Height="56" StrokeThickness="3.5" />
            <TextBlock Foreground="#1C1C1C"
                       Text="{Binding Status, ElementName=Root}"
                       Margin="0,12,0,0"
                       HorizontalAlignment="Center"
                       FontSize="13"
                       FontWeight="SemiBold" />
        </StackPanel>
    </Border>
</UserControl>
