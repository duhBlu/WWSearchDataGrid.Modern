<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Shared formatting for sample on-screen notes. The samples let tooltips on the option
        controls carry the per-property explanations; anything that survives on screen (keyboard
        shortcuts, gestures, real caveats) uses these keys so the look stays consistent and is
        tweakable in one place. Keyed (not implicit) so nothing leaks onto the demo controls.
    -->

    <!--  One-line intro under the control name.  -->
    <Style x:Key="SampleIntro" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="#444" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <!--  Small header above a notes block ("Keyboard", "Tips").  -->
    <Style x:Key="SampleNoteHeader" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#666" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <!--  One shortcut row: a key chip + its meaning.  Compose as
          <StackPanel Style="{StaticResource SampleKbdRow}">
            <Border Style="{StaticResource SampleKbd}"><TextBlock Style="{StaticResource SampleKbdText}" Text="Ctrl + C"/></Border>
            <TextBlock Style="{StaticResource SampleKbdDesc}" Text="Copy"/>
          </StackPanel>  -->
    <Style x:Key="SampleKbdRow" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>
    <Style x:Key="SampleKbd" TargetType="Border">
        <Setter Property="Background" Value="#F0F0F0" />
        <Setter Property="BorderBrush" Value="#D5D5D5" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Padding" Value="6,1" />
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style x:Key="SampleKbdText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Consolas, Cascadia Mono" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="#444" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style x:Key="SampleKbdDesc" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="#777" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!--  A bullet tip line for a non-discoverable gesture or caveat.  Text should start with "• ".  -->
    <Style x:Key="SampleTip" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="#777" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,0,0,3" />
    </Style>

</ResourceDictionary>
