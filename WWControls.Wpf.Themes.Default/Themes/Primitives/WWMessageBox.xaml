<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <!--  Icons.xaml carries IconCopy for the footer's copy button.  -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Resources/Icons/Icons.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        WWMessageBox — a message dialog hosted in the library's window chrome. Two rows: the
        message (a severity StatusIcon plus wrapping, scrollable text) over a footer band with a
        left-docked "Copy Message" button and a right-docked ItemsControl (PART_Commands) that
        renders one WWButton per UICommand. The control's code adds a class handler for the
        buttons' Click, so a click records the chosen command and closes the host window.
    -->
    <Style x:Key="{x:Static sdg:PrimitiveThemeKeys.WWMessageBox}" TargetType="{x:Type sdg:WWMessageBox}">
        <Setter Property="MinWidth" Value="320" />
        <Setter Property="MaxWidth" Value="640" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, sans-serif" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:WWMessageBox}">
                    <Border Background="{TemplateBinding Background}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Message  -->
                            <Grid Grid.Row="0" Margin="20,20,20,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <sdg:StatusIcon x:Name="Icon"
                                                Grid.Column="0"
                                                Status="{TemplateBinding Status}"
                                                AnimationKind="None"
                                                Width="30"
                                                Height="30"
                                                VerticalAlignment="Top"
                                                HorizontalAlignment="Left"
                                                Margin="0,1,16,0" />

                                <ScrollViewer Grid.Column="1"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              MaxHeight="460">
                                    <TextBlock Text="{TemplateBinding Message}"
                                               TextWrapping="Wrap"
                                               MinWidth="120"
                                               MaxWidth="460"
                                               VerticalAlignment="Center"
                                               Foreground="{TemplateBinding Foreground}"
                                               FontSize="13"
                                               LineHeight="19"
                                               LineStackingStrategy="BlockLineHeight" />
                                </ScrollViewer>
                            </Grid>

                            <!--  Footer  -->
                            <Border Grid.Row="1"
                                    Background="#F8F9FA"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="0,1,0,0"
                                    Padding="14,10">
                                <DockPanel LastChildFill="False">
                                    <sdg:WWButton x:Name="PART_CopyButton"
                                                  DockPanel.Dock="Left"
                                                  Content="{TemplateBinding CopyButtonCaption}"
                                                  Glyph="{StaticResource {x:Static sdg:IconKeys.IconCopy}}"
                                                  GlyphWidth="12"
                                                  GlyphHeight="12"
                                                  Padding="10,3"
                                                  IsTabStop="False"
                                                  IsDefault="False"
                                                  IsCancel="False" />

                                    <ItemsControl x:Name="PART_Commands"
                                                  DockPanel.Dock="Right"
                                                  Focusable="False"
                                                  KeyboardNavigation.TabNavigation="Continue"
                                                  ItemsSource="{TemplateBinding Commands}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <sdg:WWButton Content="{Binding Caption}"
                                                              Glyph="{Binding Glyph}"
                                                              GlyphWidth="{Binding GlyphSize}"
                                                              GlyphHeight="{Binding GlyphSize}"
                                                              GlyphStrokeThickness="{Binding GlyphStrokeThickness}"
                                                              ToolTip="{Binding ToolTip}"
                                                              Command="{Binding Command}"
                                                              CommandParameter="{Binding CommandParameter}"
                                                              AsyncDisplayMode="{Binding AsyncDisplayMode}"
                                                              IsDefault="{Binding IsDefault}"
                                                              IsCancel="{Binding IsCancel}"
                                                              IsEnabled="{Binding IsEnabled}"
                                                              MinWidth="80"
                                                              Margin="8,0,0,0"
                                                              Padding="12,3" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowCopyButton" Value="False">
                            <Setter TargetName="PART_CopyButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Implicit default so a bare <sdg:WWMessageBox> picks up the style.  -->
    <Style BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.WWMessageBox}}" TargetType="{x:Type sdg:WWMessageBox}" />

</ResourceDictionary>
