<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <!--  Self-merged dependencies — icons (cancel glyph) + shared corner-radius resource.  -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Primitives/DefaultControls.xaml" />
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Primitives/WWSpinningWheel.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        WWButton — same chrome language as the PrimitivesButton style (bottom-lip depth cue,
        hover / pressed grays) plus: CornerRadius from the control (defaulted to the shared
        ControlCornerRadius resource), a Foreground-tinted glyph docked by GlyphAlignment, the
        toggle checked / indeterminate accent states, and the async overlay (spinning wheel, or a
        cancel "×" while hovered in WaitCancel mode).
    -->
    <Style x:Key="{x:Static sdg:PrimitiveThemeKeys.WWButton}" TargetType="{x:Type sdg:WWButton}">
        <Setter Property="CornerRadius" Value="{StaticResource {x:Static sdg:PrimitiveThemeKeys.ControlCornerRadius}}" />
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="BorderBrush" Value="#E0E0E0" />
        <Setter Property="GlyphBrush" Value="{Binding Foreground, RelativeSource={RelativeSource Self}}" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FocusVisualStyle">
            <Setter.Value>
                <Style>
                    <Setter Property="Control.Template">
                        <Setter.Value>
                            <ControlTemplate>
                                <Rectangle Stroke="Black"
                                           StrokeThickness="1"
                                           Margin="2,2,2,1"
                                           StrokeDashArray="1 2"
                                           RadiusX="{Binding AdornedElement.CornerRadius.TopLeft, RelativeSource={RelativeSource AncestorType={x:Type Adorner}}}"
                                           RadiusY="{Binding AdornedElement.CornerRadius.TopLeft, RelativeSource={RelativeSource AncestorType={x:Type Adorner}}}"
                                           SnapsToDevicePixels="true" />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:WWButton}">
                    <Grid x:Name="Root" SnapsToDevicePixels="True">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <Border x:Name="innerBorder"
                                    Background="Transparent"
                                    BorderBrush="#BDBDBD"
                                    BorderThickness="0,0,0,0.8"
                                    Margin="-1,0,-1,-1"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                <DockPanel x:Name="contentRoot"
                                           Margin="{TemplateBinding Padding}"
                                           HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                           VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                           RenderTransform="{x:Null}">
                                    <sdg:Icon x:Name="GlyphIcon"
                                              DockPanel.Dock="{TemplateBinding GlyphAlignment}"
                                              Margin="{TemplateBinding GlyphMargin}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Width="{TemplateBinding GlyphWidth}"
                                              Height="{TemplateBinding GlyphHeight}"
                                              StrokeThickness="{TemplateBinding GlyphStrokeThickness}"
                                              IconSource="{TemplateBinding Glyph}"
                                              IconBrush="{TemplateBinding GlyphBrush}" />
                                    <ContentPresenter x:Name="contentPresenter"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="True" />
                                </DockPanel>
                            </Border>
                        </Border>

                        <!--  Async overlay — collapsed while idle, so the wheel costs nothing.  -->
                        <sdg:WWSpinningWheel x:Name="Spinner"
                                             WheelKind="{TemplateBinding AsyncWheelKind}"
                                             Fill="{TemplateBinding Foreground}"
                                             Stroke="{TemplateBinding Foreground}"
                                             Visibility="Collapsed"
                                             IsHitTestVisible="False"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Width="14"
                                             Height="14"
                                             StrokeThickness="2" />
                        <sdg:Icon x:Name="CancelGlyph"
                                  Visibility="Collapsed"
                                  IsHitTestVisible="False"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Width="10"
                                  Height="10"
                                  IconSource="{StaticResource {x:Static sdg:LucideIconKeys.X}}"
                                  IconBrush="{TemplateBinding Foreground}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Glyph" Value="{x:Null}">
                            <Setter TargetName="GlyphIcon" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="HasContent" Value="False">
                            <Setter TargetName="contentPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!--
                            ============ Neutral (unchecked) ============
                            rest:    fill FFFFFF | outer E0E0E0 | lip BDBDBD
                        -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#F5F5F5" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#D4D4D4" />
                            <Setter TargetName="innerBorder" Property="BorderBrush" Value="#ABABAB" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#EBEBEB" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#C9C9C9" />
                            <Setter TargetName="innerBorder" Property="BorderBrush" Value="#C9C9C9" />
                            <Setter TargetName="contentRoot" Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="1" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                        <!--
                            ============ Checked (accent) ============
                            Declared AFTER the neutral hover/pressed triggers so it wins,
                            with its own hover/pressed re-declared below.
                        -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#0078D4" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#0069BA" />
                            <Setter TargetName="innerBorder" Property="BorderBrush" Value="#00559C" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border" Property="Background" Value="#006CBE" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#005FA7" />
                            <Setter TargetName="innerBorder" Property="BorderBrush" Value="#004C8B" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsPressed" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border" Property="Background" Value="#005A9E" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#004F8B" />
                            <Setter TargetName="innerBorder" Property="BorderBrush" Value="#004F8B" />
                            <Setter TargetName="contentRoot" Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="1" />
                                </Setter.Value>
                            </Setter>
                        </MultiTrigger>

                        <!--
                            ============ Indeterminate (accent tint) ============
                            Softer than checked: tinted fill, accent-dark text.
                        -->
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="border" Property="Background" Value="#E9F3FC" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#B3D5F0" />
                            <Setter TargetName="innerBorder" Property="BorderBrush" Value="#86BCE7" />
                            <Setter Property="Foreground" Value="#005A9E" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="{x:Null}" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border" Property="Background" Value="#DCECF9" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#A4CCEC" />
                            <Setter TargetName="innerBorder" Property="BorderBrush" Value="#76B1E1" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="{x:Null}" />
                                <Condition Property="IsPressed" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border" Property="Background" Value="#CFE4F6" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#95C2E7" />
                            <Setter TargetName="innerBorder" Property="BorderBrush" Value="#95C2E7" />
                            <Setter TargetName="contentRoot" Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="1" />
                                </Setter.Value>
                            </Setter>
                        </MultiTrigger>

                        <!--  Async — wheel replaces the content; WaitCancel swaps to "x" on hover.  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsAsyncOperationInProgress" Value="True" />
                                <Condition Property="AsyncDisplayMode" Value="Wait" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="contentRoot" Property="Opacity" Value="0" />
                            <Setter TargetName="Spinner" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsAsyncOperationInProgress" Value="True" />
                                <Condition Property="AsyncDisplayMode" Value="WaitCancel" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="contentRoot" Property="Opacity" Value="0" />
                            <Setter TargetName="Spinner" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsAsyncOperationInProgress" Value="True" />
                                <Condition Property="AsyncDisplayMode" Value="WaitCancel" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Spinner" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="CancelGlyph" Property="Visibility" Value="Visible" />
                        </MultiTrigger>

                        <!--
                            ============ Disabled ============
                            Last, so it overrides every interaction trigger above.
                            Flat (lip == border) because depth is the interactivity cue.
                            Checked / indeterminate keep a washed-out version of their
                            ramp so toggle state stays legible while disabled.
                        -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#F5F5F5" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#E8E8E8" />
                            <Setter TargetName="innerBorder" Property="BorderBrush" Value="#E8E8E8" />
                            <Setter Property="Foreground" Value="#9D9D9D" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsEnabled" Value="False" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border" Property="Background" Value="#A9C8E4" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#9BBCDA" />
                            <Setter TargetName="innerBorder" Property="BorderBrush" Value="#9BBCDA" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsEnabled" Value="False" />
                                <Condition Property="IsChecked" Value="{x:Null}" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border" Property="Background" Value="#EDF3F9" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#DEE7F0" />
                            <Setter TargetName="innerBorder" Property="BorderBrush" Value="#DEE7F0" />
                            <Setter Property="Foreground" Value="#94A7B8" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <!--
                Repeat buttons click on press (matching RepeatButton), so the first repeat
                doesn't wait for release. Overridable per instance.
            -->
            <Trigger Property="ButtonKind" Value="Repeat">
                <Setter Property="ClickMode" Value="Press" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.WWButton}}" TargetType="{x:Type sdg:WWButton}" />


</ResourceDictionary>
