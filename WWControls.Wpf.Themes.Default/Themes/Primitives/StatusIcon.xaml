<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <!--  The status glyphs (IconKeys.IconStatus*) live in Icons.xaml; merge it so the
          StaticResource lookups below resolve when this default style is applied.  -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Resources/Icons/Icons.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        StatusIcon — a small circular severity badge.
        
        Status drives the fill color + glyph (and collapses the badge when None). AnimationKind
        selects how the badge animates the moment it becomes visible: Blink flashes three times
        then holds; Pulse scales in/out forever while shown. Both animations are keyed off the
        control's Visibility flipping to Visible — which happens whenever Status leaves None — so a
        badge re-animates each time it (re)appears, not on every revalidation.
    -->
    <Style x:Key="{x:Static sdg:PrimitiveThemeKeys.StatusIcon}" TargetType="{x:Type sdg:StatusIcon}">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="ToolTip" Value="{Binding Message, RelativeSource={RelativeSource Self}}" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="200" />
        <Setter Property="ToolTipService.ShowDuration" Value="20000" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:StatusIcon}">
                    <Border x:Name="PART_Badge"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            CornerRadius="8"
                            RenderTransformOrigin="0.5,0.5"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000"
                                              Opacity="0.28"
                                              BlurRadius="4"
                                              Direction="270"
                                              ShadowDepth="1" />
                        </Border.Effect>
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <sdg:Icon x:Name="PART_Glyph"
                                  Width="8"
                                  Height="8"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IconBrush="White"
                                  IconSource="{StaticResource {x:Static sdg:IconKeys.IconStatusError}}" />
                    </Border>
                    <ControlTemplate.Triggers>

                        <!--  Status → color + glyph  -->
                        <Trigger Property="Status" Value="Info">
                            <Setter TargetName="PART_Badge" Property="Background" Value="#0F6CBD" />
                            <Setter TargetName="PART_Glyph" Property="IconSource" Value="{StaticResource {x:Static sdg:IconKeys.IconStatusInfo}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Success">
                            <Setter TargetName="PART_Badge" Property="Background" Value="#0F7B0F" />
                            <Setter TargetName="PART_Glyph" Property="IconSource" Value="{StaticResource {x:Static sdg:IconKeys.IconStatusSuccess}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Warning">
                            <Setter TargetName="PART_Badge" Property="Background" Value="#C77700" />
                            <Setter TargetName="PART_Glyph" Property="IconSource" Value="{StaticResource {x:Static sdg:IconKeys.IconStatusWarning}}" />
                            
                        </Trigger>
                        <Trigger Property="Status" Value="Error">
                            <Setter TargetName="PART_Badge" Property="Background" Value="#C42B1C" />
                            <Setter TargetName="PART_Glyph" Property="IconSource" Value="{StaticResource {x:Static sdg:IconKeys.IconStatusError}}" />
                        </Trigger>

                        <!--  Blink three times when the badge appears  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Visibility" Value="Visible" />
                                <Condition Property="AnimationKind" Value="Blink" />
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation AutoReverse="True"
                                                         RepeatBehavior="3x"
                                                         FillBehavior="Stop"
                                                         Storyboard.TargetName="PART_Badge"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="1"
                                                         To="0"
                                                         Duration="0:0:0.18" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                        </MultiTrigger>

                        <!--  Pulse continuously while the badge is shown  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Visibility" Value="Visible" />
                                <Condition Property="AnimationKind" Value="Pulse" />
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard x:Name="PulseStoryboard">
                                    <Storyboard>
                                        <DoubleAnimation AutoReverse="True"
                                                         RepeatBehavior="Forever"
                                                         Storyboard.TargetName="PART_Badge"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         From="1"
                                                         To="1.3"
                                                         Duration="0:0:0.6" />
                                        <DoubleAnimation AutoReverse="True"
                                                         RepeatBehavior="Forever"
                                                         Storyboard.TargetName="PART_Badge"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         From="1"
                                                         To="1.3"
                                                         Duration="0:0:0.6" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="PulseStoryboard" />
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <!--  No status → no badge.  -->
            <Trigger Property="Status" Value="None">
                <Setter Property="Visibility" Value="Collapsed" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.StatusIcon}}" TargetType="{x:Type sdg:StatusIcon}" />

</ResourceDictionary>
