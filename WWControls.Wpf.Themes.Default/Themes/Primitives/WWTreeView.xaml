<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <!--  Icons.xaml backs the chevron / expand-all / collapse-all glyphs. DefaultControls.xaml backs
          the search bar's TextBox and prev/next Buttons — the search box and buttons reference the
          primitive keyed styles explicitly (below) so they render correctly regardless of ambient
          resources, including when the tree is hosted in the ColumnChooser's own top-level window
          (which does not inherit a consumer's window-scoped implicit styles).  -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Icons;component/Icons.xaml" />
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Primitives/DefaultControls.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <sdg:TreeViewIsLastItemConverter x:Key="TreeViewIsLastItemConverter" />
    <sdg:IndentationToThicknessConverter x:Key="IndentationToThicknessConverter" />
    <sdg:IndentationScaleConverter x:Key="IndentationScaleConverter" />
    <sdg:HorizontalConnectorWidthConverter x:Key="HorizontalConnectorWidthConverter" />
    <sdg:FullWidthHighlightMarginConverter x:Key="FullWidthHighlightMarginConverter" />

    <!--  Expander caret for a WWTreeViewItem: chevron-right when collapsed, chevron-down when expanded.  -->
    <Style x:Key="WWTreeViewItem_ExpanderButton_Style" TargetType="{x:Type ToggleButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Foreground" Value="#646464" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="outer_border"
                            Background="Transparent"
                            Margin="0,0,0,0">
                        <Border x:Name="inner_border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <Grid x:Name="grid">
                                <!--  Collapsed: ChevronRight  -->
                                <sdg:Icon x:Name="PART_Arrow" IconBrush="{TemplateBinding Foreground}" IconSource="{StaticResource {x:Static sdg:LucideIconKeys.ChevronRight}}" Width="8" Height="8" />
                            </Grid>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="PART_Arrow" Property="IconSource" Value="{StaticResource {x:Static sdg:LucideIconKeys.ChevronDown}}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F5F5F5" />
                            <Setter Property="Foreground" Value="#1C1C1C" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#EBEBEB" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="false">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="#9D9D9D" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  Subtle transparent button hosting the expand-all / collapse-all glyphs.  -->
    <Style x:Key="WWTreeViewItem_SubtleButton_Style" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="inner_border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter x:Name="contentPresenter"
                                          Focusable="False"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F5F5F5" />
                <Setter Property="Foreground" Value="#1C1C1C" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#EBEBEB" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="#9D9D9D" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="{x:Static sdg:PrimitiveThemeKeys.WWTreeViewItem}" TargetType="{x:Type sdg:WWTreeViewItem}">
        <Setter Property="AllowDrop" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="HandleRightClickToSelect" Value="True" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Padding" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:WWTreeViewItem}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <!--  Highlight layers for the header row, drawn behind the header content (which
                              sits over a transparent background). IsHitTestVisible=False so clicks reach the
                              toggle / header / line hit area. RowFullWidthHover spans them across the indent
                              column (Grid.Column/ColumnSpan trigger below) and pulls their left edge out to
                              the tree's left with a negative margin of one indent per level. Each brush is
                              inherited from the owning WWTreeView.  -->
                        <Border x:Name="PART_HoverHighlight"
                                Grid.Row="0"
                                Grid.Column="1"
                                Background="{Binding ItemHoverBrush, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWTreeView}}}"
                                IsHitTestVisible="False"
                                Visibility="Collapsed">
                            <Border.Margin>
                                <MultiBinding Converter="{StaticResource FullWidthHighlightMarginConverter}">
                                    <Binding Path="RowFullWidthHover" RelativeSource="{RelativeSource AncestorType={x:Type sdg:WWTreeView}}" />
                                    <Binding Path="Level" RelativeSource="{RelativeSource TemplatedParent}" />
                                    <Binding Path="Indentation" RelativeSource="{RelativeSource AncestorType={x:Type sdg:WWTreeView}}" />
                                </MultiBinding>
                            </Border.Margin>
                        </Border>
                        <Border x:Name="PART_SelectionHighlight"
                                Grid.Row="0"
                                Grid.Column="1"
                                Background="{Binding SelectionBrush, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWTreeView}}}"
                                IsHitTestVisible="False"
                                Visibility="Collapsed">
                            <Border.Margin>
                                <MultiBinding Converter="{StaticResource FullWidthHighlightMarginConverter}">
                                    <Binding Path="RowFullWidthHover" RelativeSource="{RelativeSource AncestorType={x:Type sdg:WWTreeView}}" />
                                    <Binding Path="Level" RelativeSource="{RelativeSource TemplatedParent}" />
                                    <Binding Path="Indentation" RelativeSource="{RelativeSource AncestorType={x:Type sdg:WWTreeView}}" />
                                </MultiBinding>
                            </Border.Margin>
                        </Border>
                        <Border x:Name="PART_CurrentMatchHighlight"
                                Grid.Row="0"
                                Grid.Column="1"
                                Background="#FFE8A3"
                                IsHitTestVisible="False"
                                Visibility="Collapsed">
                            <Border.Margin>
                                <MultiBinding Converter="{StaticResource FullWidthHighlightMarginConverter}">
                                    <Binding Path="RowFullWidthHover" RelativeSource="{RelativeSource AncestorType={x:Type sdg:WWTreeView}}" />
                                    <Binding Path="Level" RelativeSource="{RelativeSource TemplatedParent}" />
                                    <Binding Path="Indentation" RelativeSource="{RelativeSource AncestorType={x:Type sdg:WWTreeView}}" />
                                </MultiBinding>
                            </Border.Margin>
                        </Border>

                        <!--  Connector lines: drawn under the expander so the chevron sits on the line. Their
                              offsets derive from the tree's Indentation (converter factors), so they track it.
                              Layout/visual values come from the owning WWTreeView via AncestorType bindings.  -->
                        <!--  Hit area for the vertical line - transparent but clickable  -->
                        <Border x:Name="PART_VerticalLineHitArea"
                                Grid.RowSpan="2"
                                Grid.Column="0"
                                Background="Transparent"
                                Cursor="Hand"
                                HorizontalAlignment="Left"
                                Margin="{Binding Indentation, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWTreeView}}, Converter={StaticResource IndentationToThicknessConverter}, ConverterParameter=-1}"
                                Width="{Binding Indentation, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWTreeView}}}" />

                        <!--  Horizontal stub: runs from the vertical line (-0.5 indent) rightward. A leaf
                              gets the full 1.5 indents so the line reaches the header content; a node with a
                              chevron gets a 0.5-indent stub that stops at the expander column instead of
                              running under and past the chevron glyph.  -->
                        <Rectangle x:Name="PART_RectangleHorizontal"
                                   Grid.Row="0"
                                   Grid.Column="0"
                                   Stroke="{Binding ConnectorLineBrush, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWTreeView}}}"
                                   IsHitTestVisible="False"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Margin="{Binding Indentation, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWTreeView}}, Converter={StaticResource IndentationToThicknessConverter}, ConverterParameter=-0.5}"
                                   Height="{Binding ConnectorLineThickness, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWTreeView}}}"
                                   StrokeThickness="{Binding ConnectorLineThickness, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWTreeView}}}">
                            <Rectangle.Width>
                                <MultiBinding Converter="{StaticResource HorizontalConnectorWidthConverter}">
                                    <Binding Path="Indentation" RelativeSource="{RelativeSource AncestorType={x:Type sdg:WWTreeView}}" />
                                    <Binding Path="HasExpandableChildren" RelativeSource="{RelativeSource TemplatedParent}" />
                                </MultiBinding>
                            </Rectangle.Width>
                        </Rectangle>

                        <Rectangle x:Name="PART_RectangleVertical"
                                   Grid.RowSpan="2"
                                   Grid.Column="0"
                                   Stroke="{Binding ConnectorLineBrush, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWTreeView}}}"
                                   IsHitTestVisible="False"
                                   HorizontalAlignment="Left"
                                   Margin="{Binding Indentation, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWTreeView}}, Converter={StaticResource IndentationToThicknessConverter}, ConverterParameter=-0.5}"
                                   Panel.ZIndex="1"
                                   Width="{Binding ConnectorLineThickness, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWTreeView}}}"
                                   StrokeThickness="{Binding ConnectorLineThickness, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWTreeView}}}" />

                        <!--  Accent overlay for the vertical line, shown while the parent's line is hovered.  -->
                        <Rectangle x:Name="PART_RectangleVerticalHover"
                                   Grid.RowSpan="2"
                                   Grid.Column="0"
                                   Stroke="{Binding LineHoverBrush, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWTreeView}}}"
                                   IsHitTestVisible="False"
                                   HorizontalAlignment="Left"
                                   Margin="{Binding Indentation, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWTreeView}}, Converter={StaticResource IndentationToThicknessConverter}, ConverterParameter=-0.5}"
                                   Panel.ZIndex="1"
                                   Width="2"
                                   StrokeThickness="2"
                                   Visibility="Collapsed" />

                        <ToggleButton x:Name="PART_ToggleButton"
                                      Grid.Row="0"
                                      Grid.Column="0"
                                      Style="{StaticResource WWTreeViewItem_ExpanderButton_Style}"
                                      Background="{TemplateBinding Background}"
                                      Foreground="{TemplateBinding Foreground}"
                                      Width="{Binding Indentation, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWTreeView}}}"
                                      HorizontalAlignment="Center"
                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                      Padding="3"
                                      ClickMode="Press" />

                        <Border x:Name="PART_HeaderBorder"
                                Grid.Column="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter x:Name="PART_Header"
                                                  Grid.Column="0"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  ContentSource="Header" />

                                <!--  Expand/Collapse All Buttons  -->
                                <StackPanel x:Name="PART_ExpandCollapseButtons"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Visibility="Collapsed"
                                            Margin="5,0,0,0">
                                    <Button x:Name="PART_ExpandAllButton"
                                            Style="{StaticResource WWTreeViewItem_SubtleButton_Style}"
                                            Background="Transparent"
                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type TreeViewItem}}}"
                                            Command="{x:Static sdg:WWTreeViewItem.ExpandAllCommand}"
                                            Padding="2"
                                            BorderBrush="Transparent"
                                            VerticalAlignment="Stretch"
                                            Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                                            ToolTip="Expand All">
                                        <sdg:Icon IconSource="{StaticResource {x:Static sdg:LucideIconKeys.ListChevronsUpDown}}"
                                                  IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                                  Width="9" Height="9" />
                                    </Button>
                                    <Button x:Name="PART_CollapseAllButton"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Style="{StaticResource WWTreeViewItem_SubtleButton_Style}"
                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type TreeViewItem}}}"
                                            Command="{x:Static sdg:WWTreeViewItem.CollapseAllCommand}"
                                            Padding="2"
                                            VerticalAlignment="Stretch"
                                            Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                                            ToolTip="Collapse All">
                                        <sdg:Icon IconSource="{StaticResource {x:Static sdg:LucideIconKeys.ListChevronsDownUp}}"
                                                  IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                                  Width="9" Height="9" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ItemsPresenter x:Name="PART_ItemsHost"
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Visibility="Collapsed" />

                        <!--  Lazy-load placeholder, shown while a node's children are being fetched.  -->
                        <TextBlock x:Name="PART_LoadingIndicator"
                                   Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="5,2,0,4"
                                   Foreground="#909090"
                                   Text="Loading..."
                                   Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger SourceName="PART_HeaderBorder" Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_HoverHighlight" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger SourceName="PART_ToggleButton" Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_HoverHighlight" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="PART_ItemsHost" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <Trigger Property="HasExpandableChildren" Value="false">
                            <Setter TargetName="PART_ToggleButton" Property="Visibility" Value="Hidden" />
                        </Trigger>
                        <Trigger Property="IsLoading" Value="True">
                            <Setter TargetName="PART_LoadingIndicator" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <!--  Selection / multi-selection / current-match highlights (overlay borders).  -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="PART_SelectionHighlight" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMultiSelected" Value="True">
                            <Setter TargetName="PART_SelectionHighlight" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsCurrentSearchMatch" Value="True">
                            <Setter TargetName="PART_CurrentMatchHighlight" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <!--  Full-width highlight: extend the header-row highlights across the indent column.  -->
                        <DataTrigger Binding="{Binding RowFullWidthHover, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWTreeView}}}" Value="True">
                            <Setter TargetName="PART_HoverHighlight" Property="Grid.Column" Value="0" />
                            <Setter TargetName="PART_HoverHighlight" Property="Grid.ColumnSpan" Value="2" />
                            <Setter TargetName="PART_SelectionHighlight" Property="Grid.Column" Value="0" />
                            <Setter TargetName="PART_SelectionHighlight" Property="Grid.ColumnSpan" Value="2" />
                            <Setter TargetName="PART_CurrentMatchHighlight" Property="Grid.Column" Value="0" />
                            <Setter TargetName="PART_CurrentMatchHighlight" Property="Grid.ColumnSpan" Value="2" />
                        </DataTrigger>

                        <!--  Show Expand/Collapse buttons on hover when enabled  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition SourceName="PART_HeaderBorder" Property="IsMouseOver" Value="True" />
                                <Condition Property="ShowExpandCollapseButtons" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_ExpandCollapseButtons" Property="Visibility" Value="Visible" />
                        </MultiTrigger>

                        <!--  When the PARENT's line is hovered, reveal this item's accent line overlay.  -->
                        <DataTrigger Binding="{Binding Path=IsParentLineHovered, RelativeSource={RelativeSource Self}}" Value="True">
                            <Setter TargetName="PART_RectangleVerticalHover" Property="Visibility" Value="Visible" />
                        </DataTrigger>

                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Converter={StaticResource TreeViewIsLastItemConverter}}" Value="True">
                            <Setter TargetName="PART_RectangleVertical" Property="Height" Value="10" />
                            <Setter TargetName="PART_RectangleVertical" Property="VerticalAlignment" Value="Top" />
                            <Setter TargetName="PART_RectangleVerticalHover" Property="Height" Value="10" />
                            <Setter TargetName="PART_RectangleVerticalHover" Property="VerticalAlignment" Value="Top" />
                            <Setter TargetName="PART_VerticalLineHitArea" Property="Height" Value="10" />
                            <Setter TargetName="PART_VerticalLineHitArea" Property="VerticalAlignment" Value="Top" />
                        </DataTrigger>

                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Converter={StaticResource TreeViewIsLastItemConverter}}" Value="False">
                            <Setter TargetName="PART_RectangleVertical" Property="Height" Value="Auto" />
                            <Setter TargetName="PART_RectangleVertical" Property="VerticalAlignment" Value="Stretch" />
                            <Setter TargetName="PART_RectangleVerticalHover" Property="Height" Value="Auto" />
                            <Setter TargetName="PART_RectangleVerticalHover" Property="VerticalAlignment" Value="Stretch" />
                            <Setter TargetName="PART_VerticalLineHitArea" Property="Height" Value="Auto" />
                            <Setter TargetName="PART_VerticalLineHitArea" Property="VerticalAlignment" Value="Stretch" />
                        </DataTrigger>

                        <!--  Hide all connectors when the tree disables them.  -->
                        <DataTrigger Binding="{Binding ShowConnectorLines, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWTreeView}}}" Value="False">
                            <Setter TargetName="PART_RectangleHorizontal" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_RectangleVertical" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_RectangleVerticalHover" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_VerticalLineHitArea" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>

                        <!--  Hide lines and hit area ONLY for root level items  -->
                        <DataTrigger Binding="{Binding Path=IsRootLevel, RelativeSource={RelativeSource Self}}" Value="True">
                            <Setter TargetName="PART_RectangleHorizontal" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_RectangleVertical" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_RectangleVerticalHover" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_VerticalLineHitArea" Property="Visibility" Value="Hidden" />
                        </DataTrigger>

                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                            <Setter TargetName="PART_RectangleHorizontal" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_RectangleVertical" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_RectangleVerticalHover" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_VerticalLineHitArea" Property="Visibility" Value="Hidden" />
                        </DataTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="HasHeader" Value="false" />
                                <Condition Property="Width" Value="Auto" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_Header" Property="MinWidth" Value="75" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="HasHeader" Value="false" />
                                <Condition Property="Height" Value="Auto" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_Header" Property="MinHeight" Value="19" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Style.Triggers>
            <!--  Selection, multi-selection, hover, and current-match visuals are drawn by overlay borders
                  inside the ControlTemplate so their brushes come from the tree's SelectionBrush /
                  ItemHoverBrush DPs. Only the disabled state tints the row background directly here.  -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="#F5F5F5" />
                <Setter Property="Foreground" Value="#9CA3AF" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.WWTreeViewItem}}" TargetType="{x:Type sdg:WWTreeViewItem}" />

    <Style x:Key="{x:Static sdg:PrimitiveThemeKeys.WWTreeView}" TargetType="{x:Type sdg:WWTreeView}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource {x:Static sdg:PrimitiveThemeKeys.WWTreeViewItem}}" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:WWTreeView}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  Built-in search bar: shown when ShowSearchBar is true. Search box + "n of m" + prev/next.  -->
                        <Border x:Name="PART_SearchBar"
                                Grid.Row="0"
                                Background="#FAFAFA"
                                BorderBrush="#E0E0E0"
                                BorderThickness="0,0,0,1"
                                Padding="4"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PART_SearchBox"
                                         Grid.Column="0"
                                         Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.TextBox}}"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding FilterText, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Margin="8,0,4,0"
                                           Foreground="#646464"
                                           Text="{Binding MatchDisplay, RelativeSource={RelativeSource TemplatedParent}}" />
                                <Button Grid.Column="2"
                                        Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.Button}}"
                                        Content="&#x2191;"
                                        Width="22"
                                        Padding="0"
                                        Margin="0,0,2,0"
                                        ToolTip="Previous match"
                                        Command="{Binding PreviousMatchCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                        IsEnabled="{Binding HasMatches, RelativeSource={RelativeSource TemplatedParent}}" />
                                <Button Grid.Column="3"
                                        Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.Button}}"
                                        Content="&#x2193;"
                                        Width="22"
                                        Padding="0"
                                        ToolTip="Next match"
                                        Command="{Binding NextMatchCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                        IsEnabled="{Binding HasMatches, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Grid>
                        </Border>

                        <Border Name="PART_Border"
                                Grid.Row="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="1">
                            <Grid>
                                <ScrollViewer x:Name="PART_ScrollViewer"
                                              Focusable="False"
                                              Padding="4"
                                              CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}">
                                    <ItemsPresenter x:Name="PART_Presenter" MaxWidth="{Binding RelativeSource={RelativeSource AncestorType={x:Type ScrollViewer}}, Path=ViewportWidth}" />
                                </ScrollViewer>

                                <!--  Empty-state placeholder, shown when the tree has no items.  -->
                                <ContentPresenter x:Name="PART_EmptyContent"
                                                  Content="{TemplateBinding EmptyContent}"
                                                  ContentTemplate="{TemplateBinding EmptyTemplate}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Visibility="Collapsed" />
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowSearchBar" Value="True">
                            <Setter TargetName="PART_SearchBar" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="PART_EmptyContent" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.WWTreeView}}" TargetType="{x:Type sdg:WWTreeView}" />

</ResourceDictionary>
