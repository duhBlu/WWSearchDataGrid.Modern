<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <!--  The chevron / expand-all / collapse-all glyphs live in Icons.xaml; merge it so the
          StaticResource lookups below resolve when these default styles are applied.  -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Resources/Icons/Icons.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <sdg:TreeViewIsLastItemConverter x:Key="TreeViewIsLastItemConverter" />

    <!--  Expander caret for a WWTreeViewItem: chevron-right when collapsed, chevron-down when expanded.  -->
    <Style x:Key="WWTreeViewItem_ExpanderButton_Style" TargetType="{x:Type ToggleButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Foreground" Value="#646464" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="outer_border"
                            Background="Transparent"
                            Margin="0,0,0,0">
                        <Border x:Name="inner_border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <Grid x:Name="grid">
                                <!--  Collapsed: ChevronRight  -->
                                <sdg:Icon x:Name="PART_Arrow" IconBrush="{TemplateBinding Foreground}" IconSource="{StaticResource {x:Static sdg:IconKeys.IconChevronRight}}" Width="8" Height="8" />
                            </Grid>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="PART_Arrow" Property="IconSource" Value="{StaticResource {x:Static sdg:IconKeys.IconChevronDown}}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F5F5F5" />
                            <Setter Property="Foreground" Value="#1C1C1C" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#EBEBEB" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="false">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="#9D9D9D" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  Subtle transparent button hosting the expand-all / collapse-all glyphs.  -->
    <Style x:Key="WWTreeViewItem_SubtleButton_Style" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="inner_border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter x:Name="contentPresenter"
                                          Focusable="False"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F5F5F5" />
                <Setter Property="Foreground" Value="#1C1C1C" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#EBEBEB" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="#9D9D9D" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="{x:Static sdg:PrimitiveThemeKeys.WWTreeViewItem}" TargetType="{x:Type sdg:WWTreeViewItem}">
        <Setter Property="AllowDrop" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="HandleRightClickToSelect" Value="True" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Padding" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:WWTreeViewItem}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <ToggleButton x:Name="PART_ToggleButton"
                                      Style="{StaticResource WWTreeViewItem_ExpanderButton_Style}"
                                      Background="{TemplateBinding Background}"
                                      Foreground="{TemplateBinding Foreground}"
                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                      Padding="3"
                                      ClickMode="Press" />

                        <!--  Hit area for the vertical line - transparent but clickable  -->
                        <Border x:Name="PART_VerticalLineHitArea"
                                Grid.RowSpan="2"
                                Background="Transparent"
                                Cursor="Hand"
                                Margin="-35,0,0,0"
                                Width="20" />

                        <Rectangle x:Name="PART_RectangleVertical"
                                   Grid.RowSpan="2"
                                   Stroke="#E0E0E0"
                                   IsHitTestVisible="False"
                                   Margin="-28,0,0,0"
                                   Panel.ZIndex="1"
                                   Width="1"
                                   StrokeThickness="1" />

                        <Rectangle x:Name="PART_RectangleHorizontal"
                                   Grid.Row="0"
                                   Stroke="#E0E0E0"
                                   Margin="-7,1,0,0"
                                   HorizontalAlignment="Left"
                                   Width="15"
                                   Height="1"/>

                        <Border x:Name="PART_HeaderBorder"
                                Grid.Column="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter x:Name="PART_Header"
                                                  Grid.Column="0"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  ContentSource="Header" />

                                <!--  Expand/Collapse All Buttons  -->
                                <StackPanel x:Name="PART_ExpandCollapseButtons"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Visibility="Collapsed"
                                            Margin="5,0,0,0">
                                    <Button x:Name="PART_ExpandAllButton"
                                            Style="{StaticResource WWTreeViewItem_SubtleButton_Style}"
                                            Background="Transparent"
                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type TreeViewItem}}}"
                                            Command="{x:Static sdg:WWTreeViewItem.ExpandAllCommand}"
                                            Padding="2"
                                            BorderBrush="Transparent"
                                            VerticalAlignment="Stretch"
                                            Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                                            ToolTip="Expand All">
                                        <sdg:Icon IconSource="{StaticResource {x:Static sdg:IconKeys.IconExpandGroups}}"
                                                  IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                                  Width="9" Height="9" />
                                    </Button>
                                    <Button x:Name="PART_CollapseAllButton"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Style="{StaticResource WWTreeViewItem_SubtleButton_Style}"
                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type TreeViewItem}}}"
                                            Command="{x:Static sdg:WWTreeViewItem.CollapseAllCommand}"
                                            Padding="2"
                                            VerticalAlignment="Stretch"
                                            Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                                            ToolTip="Collapse All">
                                        <sdg:Icon IconSource="{StaticResource {x:Static sdg:IconKeys.IconCollapseGroups}}"
                                                  IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                                  Width="9" Height="9" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ItemsPresenter x:Name="PART_ItemsHost"
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger SourceName="PART_HeaderBorder" Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F0F0F0" />
                        </Trigger>
                        <Trigger SourceName="PART_ToggleButton" Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F0F0F0" />
                        </Trigger>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="PART_ItemsHost" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <Trigger Property="HasItems" Value="false">
                            <Setter TargetName="PART_ToggleButton" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_HeaderBorder" Property="Margin" Value="-13,0,0,0" />
                            <Setter TargetName="PART_Header" Property="Margin" Value="5,0,0,0" />
                        </Trigger>
                        <Trigger Property="HasItems" Value="true">
                            <Setter TargetName="PART_RectangleHorizontal" Property="Width" Value="8" />
                        </Trigger>

                        <!--  Show Expand/Collapse buttons on hover when enabled  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition SourceName="PART_HeaderBorder" Property="IsMouseOver" Value="True" />
                                <Condition Property="ShowExpandCollapseButtons" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_ExpandCollapseButtons" Property="Visibility" Value="Visible" />
                        </MultiTrigger>

                        <!--  When the PARENT's line is hovered, make this item's vertical line bold + accented  -->
                        <DataTrigger Binding="{Binding Path=IsParentLineHovered, RelativeSource={RelativeSource Self}}" Value="True">
                            <Setter TargetName="PART_RectangleVertical" Property="StrokeThickness" Value="2" />
                            <Setter TargetName="PART_RectangleVertical" Property="Width" Value="2" />
                            <Setter TargetName="PART_RectangleVertical" Property="Stroke" Value="#0078D4" />
                        </DataTrigger>

                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Converter={StaticResource TreeViewIsLastItemConverter}}" Value="True">
                            <Setter TargetName="PART_RectangleVertical" Property="Height" Value="10" />
                            <Setter TargetName="PART_RectangleVertical" Property="VerticalAlignment" Value="Top" />
                            <Setter TargetName="PART_VerticalLineHitArea" Property="Height" Value="10" />
                            <Setter TargetName="PART_VerticalLineHitArea" Property="VerticalAlignment" Value="Top" />
                        </DataTrigger>

                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Converter={StaticResource TreeViewIsLastItemConverter}}" Value="False">
                            <Setter TargetName="PART_RectangleVertical" Property="Height" Value="Auto" />
                            <Setter TargetName="PART_RectangleVertical" Property="VerticalAlignment" Value="Stretch" />
                            <Setter TargetName="PART_VerticalLineHitArea" Property="Height" Value="Auto" />
                            <Setter TargetName="PART_VerticalLineHitArea" Property="VerticalAlignment" Value="Stretch" />
                        </DataTrigger>

                        <!--  Hide lines and hit area ONLY for root level items  -->
                        <DataTrigger Binding="{Binding Path=IsRootLevel, RelativeSource={RelativeSource Self}}" Value="True">
                            <Setter TargetName="PART_RectangleHorizontal" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_RectangleVertical" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_VerticalLineHitArea" Property="Visibility" Value="Hidden" />
                        </DataTrigger>

                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                            <Setter TargetName="PART_RectangleHorizontal" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_RectangleVertical" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_VerticalLineHitArea" Property="Visibility" Value="Hidden" />
                        </DataTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="HasHeader" Value="false" />
                                <Condition Property="Width" Value="Auto" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_Header" Property="MinWidth" Value="75" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="HasHeader" Value="false" />
                                <Condition Property="Height" Value="Auto" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_Header" Property="MinHeight" Value="19" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Style.Triggers>
            <!--  Selected state uses neutral item hover brushes so selection doesn't clash with the theme accent.  -->
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#E5F1FB" />
                <Setter Property="Foreground" Value="#1C1C1C" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsSelected" Value="True" />
                    <Condition Property="IsSelectionActive" Value="False" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="#E5F1FB" />
            </MultiTrigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="#F5F5F5" />
                <Setter Property="Foreground" Value="#9CA3AF" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.WWTreeViewItem}}" TargetType="{x:Type sdg:WWTreeViewItem}" />

    <Style x:Key="{x:Static sdg:PrimitiveThemeKeys.WWTreeView}" TargetType="{x:Type sdg:WWTreeView}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource {x:Static sdg:PrimitiveThemeKeys.WWTreeViewItem}}" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:WWTreeView}">
                    <Border Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="1">
                        <ScrollViewer x:Name="PART_ScrollViewer"
                                      Focusable="False"
                                      Padding="4"
                                      CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}">
                            <ItemsPresenter x:Name="PART_Presenter" MaxWidth="{Binding RelativeSource={RelativeSource AncestorType={x:Type ScrollViewer}}, Path=ViewportWidth}" />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.WWTreeView}}" TargetType="{x:Type sdg:WWTreeView}" />

</ResourceDictionary>
