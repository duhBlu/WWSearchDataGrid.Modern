<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdgCore="clr-namespace:WWControls.Core;assembly=WWControls.Core"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf"
                    xmlns:converters="clr-namespace:WWControls.Wpf.Converters;assembly=WWControls.Wpf">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Controls/Primitives/DefaultControls.xaml" />
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Controls/FilterEditor/SharedFilterRuleTemplates.xaml" />
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Controls/Primitives/NumericUpDown.xaml" />
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Controls/Primitives/SearchTextBox.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <converters:EnumToStringConverter x:Key="EnumToStringConverter" />

    <Style TargetType="{x:Type sdg:MultiFilterElement}">
        <Setter Property="Padding" Value="8" />
        <Setter Property="MinWidth" Value="260" />
        <Setter Property="MinHeight" Value="80" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:MultiFilterElement}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <!--
                            DataContext is the single SearchTemplate this element drives. All the
                            switched DataTemplates below assume that — same shape as
                            AdvancedFilterSearchGroupContentTemplate's inner item layout.
                        -->
                        <ContentControl VerticalAlignment="Top"
                                        Content="{Binding SearchTemplate, RelativeSource={RelativeSource TemplatedParent}}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate DataType="{x:Type sdgCore:SearchTemplate}">
                                    <!--
                                        Both rows are Auto-sized so the element measures to natural
                                        content height. Hosted in a custom tab (no ItemsControl
                                        wrapper) a "*" row would consume the whole tab and stretch
                                        the input control to fill it — see the default popup's
                                        Rules tab for the contrasting context (ItemsControl with
                                        VirtualizingStackPanel passes infinite vertical to each
                                        item, so "*" there sizes to content too).
                                    -->
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- SearchType picker -->
                                        <ComboBox Style="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesComboBox}}"
                                                  Grid.Row="0"
                                                  Margin="0,0,0,4"
                                                  Padding="4,2"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalContentAlignment="Center"
                                                  FontSize="11"
                                                  ItemsSource="{Binding ValidSearchTypes}"
                                                  SelectedItem="{Binding SearchType}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <sdg:Icon IconSource="{Binding Converter={StaticResource SearchTypeToIconConverter}}"
                                                                  Margin="0,0,6,0"
                                                                  VerticalAlignment="Center"
                                                                  Width="14"
                                                                  Height="14" />
                                                        <TextBlock Text="{Binding Converter={StaticResource EnumToStringConverter}}" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <!-- Type-specific input editor -->
                                        <ContentControl Grid.Row="1"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Top"
                                                        Content="{Binding}">
                                            <ContentControl.Style>
                                                <Style TargetType="ContentControl">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding InputTemplate}" Value="SingleSearchTextBox">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource SingleSearchTextBoxTemplate}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding InputTemplate}" Value="DualSearchTextBox">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource DualSearchTextBoxTemplate}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding InputTemplate}" Value="DualDateTimePicker">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource DualDateTimePickerTemplate}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding InputTemplate}" Value="NumericUpDown">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource NumericUpDownTemplate}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding InputTemplate}" Value="NoInput">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource NoInputTemplate}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding InputTemplate}" Value="SearchTextBoxList">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource SearchTextBoxListTemplate}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding InputTemplate}" Value="DateTimePickerList">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource DateTimePickerListTemplate}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding InputTemplate}" Value="DateIntervalCheckList">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource DateIntervalCheckListTemplate}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ContentControl.Style>
                                        </ContentControl>
                                    </Grid>
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
