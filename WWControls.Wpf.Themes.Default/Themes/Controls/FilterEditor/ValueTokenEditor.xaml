<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Controls/FilterEditor/SharedFilterRuleTemplates.xaml" />
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Controls/Primitives/SearchTextBox.xaml" />
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Controls/Primitives/NumericUpDown.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="{x:Static sdg:ThemeKeys.FilterEditorValueToken}" TargetType="{x:Type sdg:ValueTokenEditor}">
        <Setter Property="Focusable" Value="True" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:ValueTokenEditor}">
                    <Border x:Name="OuterBorder"
                            Background="#bbe2c5"
                            CornerRadius="4"
                            Padding="6,2"
                            Margin="1,0"
                            MinHeight="22">
                        <Grid>
                            <TextBlock x:Name="PART_Display"
                                       Text="{TemplateBinding DisplayText}"
                                       VerticalAlignment="Center"
                                       Foreground="Black" />

                            <!--  Editor mode: the underlying SearchTemplate's InputTemplate drives
                                 which DataTemplate gets applied via Style.Triggers. The triggers
                                 bind through the SearchTemplate property path so WPF subscribes to
                                 SearchTemplate.PropertyChanged for InputTemplate — switching to a
                                 different SearchType (e.g. Contains -> IsAnyOf) swaps the inner
                                 editor immediately.  -->
                            <ContentControl x:Name="PART_Editor"
                                            Visibility="Collapsed"
                                            Content="{TemplateBinding SearchTemplate}"
                                            VerticalAlignment="Stretch"
                                            HorizontalAlignment="Stretch"
                                            MinWidth="140">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Content.InputTemplate, RelativeSource={RelativeSource Self}}" Value="SingleSearchTextBox">
                                                <Setter Property="ContentTemplate" Value="{StaticResource SingleSearchTextBoxTemplate}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Content.InputTemplate, RelativeSource={RelativeSource Self}}" Value="DualSearchTextBox">
                                                <Setter Property="ContentTemplate" Value="{StaticResource DualSearchTextBoxTemplate}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Content.InputTemplate, RelativeSource={RelativeSource Self}}" Value="DualDateTimePicker">
                                                <Setter Property="ContentTemplate" Value="{StaticResource DualDateTimePickerTemplate}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Content.InputTemplate, RelativeSource={RelativeSource Self}}" Value="NumericUpDown">
                                                <Setter Property="ContentTemplate" Value="{StaticResource NumericUpDownTemplate}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Content.InputTemplate, RelativeSource={RelativeSource Self}}" Value="NoInput">
                                                <Setter Property="ContentTemplate" Value="{StaticResource NoInputTemplate}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Content.InputTemplate, RelativeSource={RelativeSource Self}}" Value="SearchTextBoxList">
                                                <Setter Property="ContentTemplate" Value="{StaticResource SearchTextBoxListTemplate}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Content.InputTemplate, RelativeSource={RelativeSource Self}}" Value="DateTimePickerList">
                                                <Setter Property="ContentTemplate" Value="{StaticResource DateTimePickerListTemplate}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Content.InputTemplate, RelativeSource={RelativeSource Self}}" Value="DateIntervalCheckList">
                                                <Setter Property="ContentTemplate" Value="{StaticResource DateIntervalCheckListTemplate}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="PART_Display" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_Editor" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEditing" Value="True">
                            <Setter TargetName="PART_Display" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_Editor" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!--  List-mode (IsAnyOf / IsNoneOf): flatten the outer pill and keep the
                             per-value pill editor visible at all times — each value renders as its
                             own sibling pill, with a trailing + button outside the pills.  -->
                        <DataTrigger Binding="{Binding SearchTemplate.InputTemplate, RelativeSource={RelativeSource Self}}" Value="SearchTextBoxList">
                            <Setter TargetName="OuterBorder" Property="Background" Value="Transparent" />
                            <Setter TargetName="OuterBorder" Property="Padding" Value="0" />
                            <Setter TargetName="OuterBorder" Property="Margin" Value="0" />
                            <Setter TargetName="PART_Display" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_Editor" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PART_Editor" Property="MinWidth" Value="0" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <!--  Unary search types (IsNull, IsNotNull, Today, Yesterday, AboveAverage,
                 BelowAverage, Unique, Duplicate) carry no value — hide the chip entirely
                 instead of rendering an empty green pill.  -->
            <DataTrigger Binding="{Binding SearchTemplate.InputTemplate, RelativeSource={RelativeSource Self}}" Value="NoInput">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:ThemeKeys.FilterEditorValueToken}}" TargetType="{x:Type sdg:ValueTokenEditor}" />

</ResourceDictionary>
