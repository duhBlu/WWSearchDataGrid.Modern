<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf"
                    xmlns:sdgCore="clr-namespace:WWControls.Core;assembly=WWControls.Core"
                    xmlns:behaviors="clr-namespace:WWControls.Wpf.Behaviors;assembly=WWControls.Wpf.Grid"
                    xmlns:converters="clr-namespace:WWControls.Wpf.Converters;assembly=WWControls.Wpf.Grid">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Controls/Primitives/DefaultControls.xaml" />
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Controls/Primitives/ContextMenu.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <converters:BooleanToVisibilityCollapsedConverter x:Key="FilterEditorBoolToVis" />

    <!--
        Shared template selector. Both group and condition templates are looked up by resource
        key at runtime, so declaration order inside this dictionary doesn't matter.
    -->
    <sdg:FilterEditorNodeTemplateSelector x:Key="FilterEditorNodeTemplateSelector" />

    <!--  Condition row: column chip + search type chip + value chip + hover remove button.  -->
    <DataTemplate x:Key="{x:Static sdg:ThemeKeys.FilterEditorConditionRow}" DataType="{x:Type sdg:FilterConditionNode}">
        <Grid x:Name="ConditionRoot"
              Background="Transparent"
              Cursor="Hand"
              Margin="0,2">
            <Border Background="Transparent" Padding="2">
                <!--  WrapPanel so a long row (e.g. IsAnyOf with many values) wraps to the next
                     line at the viewport edge instead of stretching horizontally. The hover
                     remove button is the trailing item so it stays beside the value chip.  -->
                <WrapPanel Orientation="Horizontal">
                    <sdg:ColumnNameTokenEditor SelectedColumn="{Binding Column, Mode=TwoWay}" AvailableColumns="{Binding AvailableColumns}" />
                    <sdg:SearchTypeTokenEditor SelectedSearchType="{Binding SearchType, Mode=TwoWay}" ValidSearchTypes="{Binding SearchTemplate.ValidSearchTypes}" />
                    <sdg:ValueTokenEditor SearchTemplate="{Binding SearchTemplate}" />

                    <!--  Remove button — visible only while the row is hovered  -->
                    <Button BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding RemoveCommand}"
                            Padding="0"
                            Margin="2,0,0,0"
                            VerticalAlignment="Center"
                            Width="14"
                            Height="14"
                            ToolTip="Remove condition">
                        <sdg:Icon Width="6"
                                  Height="6"
                                  StrokeThickness="4"
                                  IconSource="{StaticResource {x:Static sdg:IconKeys.IconClear}}"
                                  IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Gray" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="7">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=ConditionRoot, Path=IsMouseOver}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#ed4341" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#c83532" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </WrapPanel>
            </Border>
        </Grid>
    </DataTemplate>

    <!--  Group: operator chip + add-popup button + warning banner + recursive child list.  -->
    <DataTemplate x:Key="{x:Static sdg:ThemeKeys.FilterEditorGroup}" DataType="{x:Type sdg:FilterGroupNode}">
        <Border BorderBrush="#E1E5E9"
                BorderThickness="0,0,0,0"
                Margin="0,2,0,2"
                Padding="0">
            <StackPanel Orientation="Vertical">

                <!--  Header: operator chip + [+] add popup button  -->
                <StackPanel x:Name="GroupHeaderRow"
                            Background="Transparent"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <sdg:GroupOperatorChip Operator="{Binding Operator, Mode=TwoWay}" />

                    <Button x:Name="AddConditionDirectButton"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding AddConditionCommand}"
                            Margin="4,0,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="14"
                            Height="14">
                        <sdg:Icon Width="8"
                                     Height="8"
                                     StrokeThickness="3.5"
                                     IconSource="{StaticResource {x:Static sdg:IconKeys.IconAdd}}"
                                     IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Gray" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#42a358" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#358648" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="AddMenuButton"
                            behaviors:ButtonContextMenuBehavior.OpenOnClick="True"
                            Cursor="Hand"
                            Margin="0,0,0,0"
                            Padding="0"
                            Width="18"
                            Height="22">
                        <sdg:Icon Width="8"
                                     Height="8"
                                     IconSource="{StaticResource {x:Static sdg:IconKeys.IconChevronDown}}"
                                     IconBrush="Gray" />
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.ContextMenu>
                            <ContextMenu Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.ContextMenu}}">
                                <MenuItem Header="Add condition"
                                          Command="{Binding AddConditionCommand}">
                                    <MenuItem.Icon>
                                        <sdg:Icon Width="14"
                                                     Height="14"
                                                     IconSource="{StaticResource {x:Static sdg:IconKeys.IconAddCondition}}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Add group"
                                          Command="{Binding AddGroupCommand}">
                                    <MenuItem.Icon>
                                        <sdg:Icon Width="14"
                                                     Height="14"
                                                     IconSource="{StaticResource {x:Static sdg:IconKeys.IconAddGroup}}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Add custom expression"
                                          IsEnabled="False"
                                          ToolTip="Coming soon" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <!--  Group-level remove (hidden for the root, which has no parent; otherwise visible on header hover)  -->
                    <Button BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding RemoveCommand}"
                            Margin="6,0,0,0"
                            Padding="0"
                            VerticalAlignment="Center"
                            Width="14"
                            Height="14"
                            ToolTip="Remove group">
                        <sdg:Icon Width="6"
                                     Height="6"
                                     StrokeThickness="4"
                                     IconSource="{StaticResource {x:Static sdg:IconKeys.IconClear}}"
                                     IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Gray" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="7">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=GroupHeaderRow, Path=IsMouseOver}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#ed4341" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#c83532" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding Parent}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!--  Inline lossy-OR warning  -->
                <Border Background="#FFF4E5"
                        BorderBrush="#F0B27A"
                        BorderThickness="1"
                        Margin="0,4,0,0"
                        Padding="8,4"
                        CornerRadius="3">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasMixedColumnsWithOrOperator}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Foreground="#7A4F1B"
                               Text="Or / Not Or across multiple columns can't round-trip. The saved filter degrades to AND across columns."
                               TextWrapping="Wrap"
                               FontSize="11" />
                </Border>

                <!--  Recursive body. Indent nested groups by 24px.  -->
                <Border Margin="24,4,0,0">
                    <ItemsControl ItemsSource="{Binding Children}" ItemTemplateSelector="{StaticResource FilterEditorNodeTemplateSelector}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </Border>
    </DataTemplate>

    <!--
        FilterEditorDialog default style. The recursive tree templates and chip control styles
        are picked up from Themes/Controls/FilterEditor/*.xaml merged in Generic.xaml.
    -->
    <Style x:Key="{x:Static sdg:ThemeKeys.FilterEditorDialog}" TargetType="{x:Type sdg:FilterEditorDialog}">
        <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:FilterEditorDialog}">
                    <Border Background="{TemplateBinding Background}">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Body: recursive group tree, rooted at RootGroup  -->
                            <Border Grid.Row="0"
                                    Background="#F8F9FA"
                                    BorderBrush="#E1E5E9"
                                    BorderThickness="1"
                                    Padding="8"
                                    CornerRadius="3">
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                    <ContentControl Content="{Binding RootGroup, RelativeSource={RelativeSource TemplatedParent}}" ContentTemplateSelector="{StaticResource FilterEditorNodeTemplateSelector}" />
                                </ScrollViewer>
                            </Border>

                            <!--  Footer: OK / Cancel / Apply  -->
                            <StackPanel Grid.Row="1"
                                        Orientation="Horizontal"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Right">
                                <Button Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.Button}}"
                                        IsDefault="True"
                                        Command="{Binding OkCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,0,6,0"
                                        Padding="14,4"
                                        MinWidth="72"
                                        Content="OK" />
                                <Button Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.Button}}"
                                        IsCancel="True"
                                        Command="{Binding CancelCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,0,6,0"
                                        Padding="14,4"
                                        MinWidth="72"
                                        Content="Cancel" />
                                <Button Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.Button}}"
                                        Command="{Binding ApplyCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                        Padding="14,4"
                                        MinWidth="72"
                                        Content="Apply" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:ThemeKeys.FilterEditorDialog}}" TargetType="{x:Type sdg:FilterEditorDialog}" />

</ResourceDictionary>
