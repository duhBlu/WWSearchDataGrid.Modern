<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:commands="clr-namespace:WWControls.Wpf.Commands;assembly=WWControls.Wpf"
                    xmlns:converters="clr-namespace:WWControls.Wpf.Converters;assembly=WWControls.Wpf"
                    xmlns:sdg="clr-namespace:WWControls.Wpf;assembly=WWControls.Wpf">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Controls/SearchDataGrid/Column/ColumnHeaderContextMenu.xaml" />
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Controls/Primitives/DefaultControls.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <converters:BooleanToVisibilityCollapsedConverter x:Key="SelectAllBoolToVisibilityConverter" />

    <!--
        Default (implicit, TargetType-only) style for the custom headers presenter. The
        presenter calls DefaultStyleKeyProperty.OverrideMetadata(typeof(SearchDataGridColumnHeadersPresenter)),
        so WPF looks up a Style under the type key in this theme dictionary; without this
        entry the presenter has no Template, the column-headers band renders empty, and
        no SearchDataGridColumnHeader instances are produced.

        The control template retargets PART_FillerColumnHeader to SearchDataGridColumnHeader.
        The DataGrid pushes its ColumnHeaderStyle setter to the filler header at
        ApplyTemplate time; that setter's TargetType is SearchDataGridColumnHeader, so the
        stock DataGridColumnHeader filler would fail the strict TargetType check.
    -->
    <Style TargetType="{x:Type sdg:SearchDataGridColumnHeadersPresenter}">
        <!--  Same panel the row cells use (Row/DataGridRow.xaml), so headers and data cells
              share one arrangement — including the right-fixed band overlay.  -->
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <sdg:FixedColumnsCellsPanel />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:SearchDataGridColumnHeadersPresenter}">
                    <Grid>
                        <sdg:SearchDataGridColumnHeader x:Name="PART_FillerColumnHeader" IsHitTestVisible="False" />
                        <ItemsPresenter />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGridColumnHeader}" TargetType="{x:Type sdg:SearchDataGridColumnHeader}">
        <Setter Property="AllowDrop" Value="True" />
        <Setter Property="ContextMenu" Value="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridColumnHeaderContextMenu}}" />
        <Setter Property="Foreground" Value="#FF333333" />
        <Setter Property="Background" Value="#FFF9F9F9" />
        <Setter Property="BorderBrush" Value="#FFd0d0d0" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:SearchDataGridColumnHeader}">
                    <ControlTemplate.Resources>
                        <Style x:Key="ColumnHeaderGripperThumbStyle" TargetType="{x:Type Thumb}">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                SnapsToDevicePixels="True" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ControlTemplate.Resources>
                    <Grid>
                        <Border x:Name="HeaderBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,1,1"
                                Margin="0,0,0,0"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Select All CheckBox -->
                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center">

                                    <CheckBox x:Name="PART_SelectAllCheckBox"
                                              Style="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesCheckBox}}"
                                              Visibility="{Binding Column.(sdg:SearchDataGridColumnHeader.Descriptor).ActualShowCheckBoxInHeader, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGridColumnHeader}}, Converter={StaticResource SelectAllBoolToVisibilityConverter}, FallbackValue=Collapsed}"
                                              IsChecked="{Binding Column.(sdg:SearchDataGridColumnHeader.Descriptor).IsChecked, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGridColumnHeader}}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              VerticalAlignment="Center"
                                              IsThreeState="False" />

                                    <!--  Row Count Display (visible only when using SelectedRows scope)  -->
                                    <TextBlock x:Name="PART_SelectAllRowCount"
                                               Foreground="#666666"
                                               Visibility="Collapsed"
                                               Margin="0,0,0,2"
                                               VerticalAlignment="Center"
                                               FontSize="10" />
                                </StackPanel>

                                <!--  Header Content  -->
                                <ContentPresenter Grid.Column="1"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />

                                <Button x:Name="PART_RuleFilterEditorButton"
                                        Grid.Column="2"
                                        IsHitTestVisible="True"
                                        Focusable="False"
                                        Cursor="Hand"
                                        Command="{x:Static commands:ContextMenuCommands.ShowFilterEditorCommand}"
                                        CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="4,0,2,0"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        KeyboardNavigation.IsTabStop="False"
                                        ToolTip="Column Filter Editor">
                                    <sdg:Icon Width="12"
                                                 Height="12"
                                                 IconSource="{StaticResource {x:Static sdg:IconKeys.IconFilter}}"
                                                 IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Opacity" Value="0" />
                                            <Setter Property="Foreground" Value="DarkGray" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderBrush" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="3">
                                                            <ContentPresenter Focusable="False"
                                                                              Margin="{TemplateBinding Padding}"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"
                                                                              RecognizesAccessKey="True"
                                                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGridColumnHeader}}}" Value="True">
                                                    <Setter Property="Opacity" Value="1" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Column.(sdg:SearchDataGridColumnHeader.Descriptor).IsFiltered, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGridColumnHeader}}}" Value="True">
                                                    <Setter Property="Opacity" Value="1" />
                                                    <Setter Property="Foreground" Value="#0078D4" />
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="Gray" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Foreground" Value="Black" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!--  Sort Arrow -->
                                <sdg:Icon x:Name="SortArrow"
                                             Grid.Column="4"
                                             Width="10"
                                             Height="10"
                                             StrokeThickness="1.2"
                                             IconBrush="{TemplateBinding Foreground}" />
                            </Grid>
                        </Border>

                        <!--  Grippers -->
                        <Thumb x:Name="PART_LeftHeaderGripper"
                               Style="{StaticResource ColumnHeaderGripperThumbStyle}"
                               Cursor="SizeWE"
                               HorizontalAlignment="Left"
                               Panel.ZIndex="55"
                               Width="6" />

                        <Thumb x:Name="PART_RightHeaderGripper"
                               Style="{StaticResource ColumnHeaderGripperThumbStyle}"
                               BorderBrush="{Binding VerticalGridLinesBrush, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}}"
                               BorderThickness="0,0,1,0"
                               Cursor="SizeWE"
                               HorizontalAlignment="Right"
                               Panel.ZIndex="55"
                               Width="6" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding ActualHasItems, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type sdg:SearchDataGrid}}}" Value="False">
                            <Setter TargetName="HeaderBorder" Property="BorderThickness" Value="0,0,0,1" />
                        </DataTrigger>
                        <Trigger Property="SortDirection" Value="Ascending">
                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SortArrow" Property="IconSource" Value="{StaticResource {x:Static sdg:IconKeys.IconChevronUp}}" />
                        </Trigger>
                        <Trigger Property="SortDirection" Value="Descending">
                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SortArrow" Property="IconSource" Value="{StaticResource {x:Static sdg:IconKeys.IconChevronDown}}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Background" Value="#FFF0F0F0" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Background" Value="#FFE0E0E0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
