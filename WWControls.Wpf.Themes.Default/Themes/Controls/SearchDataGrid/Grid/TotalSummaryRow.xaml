<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:WWControls.Wpf.Converters;assembly=WWControls.Wpf.Grid"
                    xmlns:commands="clr-namespace:WWControls.Wpf.Commands;assembly=WWControls.Wpf.Grid"
                    xmlns:core="clr-namespace:WWControls.Core;assembly=WWControls.Core"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <!--
        ═══════════════════════════════════════════════════════════════════════
        Total Summary Row — pinned beneath the data area.

        TotalSummaryRowPresenter hosts a FilterRowPanel (the generic column-aligned
        layout panel shared with the filter row) carrying one TotalSummaryCell per
        data column. Each cell renders its descriptor's computed TotalSummaryText
        and carries the runtime summary picker on right-click.
        ═══════════════════════════════════════════════════════════════════════
    -->

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Resources/Icons/Icons.xaml" />
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Controls/Primitives/ContextMenu.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <converters:SummaryTypeActiveConverter x:Key="SummaryTypeActiveConverter" />

    <!--  Per-segment styling: an unset weight / style / color falls back to the entry's base look.  -->
    <converters:BrushToUnsetConverter x:Key="SummaryStyleForeground" />
    <converters:FontWeightToUnsetConverter x:Key="SummaryStyleFontWeight" />
    <converters:FontStyleToUnsetConverter x:Key="SummaryStyleFontStyle" />

    <!--
        Function glyphs for the summary toggle items. The glyph always shows in the drawing's
        own (hardcoded) colors — no IconBrush tint. An ACTIVE aggregate changes only the
        background: the #E5F1FB selection pill below. Disabled items fade the glyph instead.
        Shared as styles (safe — unlike a shared Setter visual, a style applies per element).
    -->
    <Style x:Key="SummaryFunctionIconStyle"
           TargetType="{x:Type sdg:Icon}"
           BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.MenuItemIcon}}">
        <Setter Property="Width" Value="12" />
        <Setter Property="Height" Value="12" />
        <Setter Property="StrokeThickness" Value="2.5" />
    </Style>

    <Style x:Key="SummaryFunctionActivePillStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="#e9e9e9" />
        <Setter Property="BorderBrush" Value="#b5b5b5" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Margin" Value="-2" />
        <Setter Property="Visibility" Value="Collapsed" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType={x:Type MenuItem}}}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!--
        Runtime summary picker. Each toggle item carries its function glyph; the active state
        (SummaryTypeActiveConverter over the descriptor's TotalSummaries; the Count binding only
        forces re-evaluation on collection mutation) tints the glyph and shows the pill via the
        styles above. Items disable via CanExecute when the aggregate is blocked by
        AllowedTotalSummaries or unsupported by the column's FieldType. Each item declares its
        OWN icon element — a shared Setter visual would parent once and render on a single row only.
    -->
    <ContextMenu x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGridTotalSummaryCellContextMenu}"
                 AutomationProperties.AutomationId="cmuTotalSummaryCell"
                 Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.ContextMenu}}"
                 x:Shared="False">
        <MenuItem Command="{x:Static commands:ContextMenuCommands.ToggleCountTotalSummaryCommand}"
                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Count">
            <MenuItem.IsChecked>
                <MultiBinding Mode="OneWay"
                              Converter="{StaticResource SummaryTypeActiveConverter}"
                              ConverterParameter="{x:Static core:SummaryItemType.Count}">
                    <Binding Path="PlacementTarget.Descriptor.TotalSummaries" RelativeSource="{RelativeSource AncestorType={x:Type ContextMenu}}" />
                    <Binding Path="PlacementTarget.Descriptor.TotalSummaries.Count" RelativeSource="{RelativeSource AncestorType={x:Type ContextMenu}}" />
                </MultiBinding>
            </MenuItem.IsChecked>
            <MenuItem.Icon>
                <Grid>
                    <Border Style="{StaticResource SummaryFunctionActivePillStyle}" />
                    <sdg:Icon Style="{StaticResource SummaryFunctionIconStyle}" IconSource="{StaticResource {x:Static sdg:IconKeys.IconCount}}" />
                </Grid>
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Command="{x:Static commands:ContextMenuCommands.ToggleSumTotalSummaryCommand}"
                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Sum">
            <MenuItem.IsChecked>
                <MultiBinding Mode="OneWay"
                              Converter="{StaticResource SummaryTypeActiveConverter}"
                              ConverterParameter="{x:Static core:SummaryItemType.Sum}">
                    <Binding Path="PlacementTarget.Descriptor.TotalSummaries" RelativeSource="{RelativeSource AncestorType={x:Type ContextMenu}}" />
                    <Binding Path="PlacementTarget.Descriptor.TotalSummaries.Count" RelativeSource="{RelativeSource AncestorType={x:Type ContextMenu}}" />
                </MultiBinding>
            </MenuItem.IsChecked>
            <MenuItem.Icon>
                <Grid>
                    <Border Style="{StaticResource SummaryFunctionActivePillStyle}" />
                    <sdg:Icon Style="{StaticResource SummaryFunctionIconStyle}" IconSource="{StaticResource {x:Static sdg:IconKeys.IconSum}}" />
                </Grid>
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Command="{x:Static commands:ContextMenuCommands.ToggleMinTotalSummaryCommand}"
                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Min">
            <MenuItem.IsChecked>
                <MultiBinding Mode="OneWay"
                              Converter="{StaticResource SummaryTypeActiveConverter}"
                              ConverterParameter="{x:Static core:SummaryItemType.Min}">
                    <Binding Path="PlacementTarget.Descriptor.TotalSummaries" RelativeSource="{RelativeSource AncestorType={x:Type ContextMenu}}" />
                    <Binding Path="PlacementTarget.Descriptor.TotalSummaries.Count" RelativeSource="{RelativeSource AncestorType={x:Type ContextMenu}}" />
                </MultiBinding>
            </MenuItem.IsChecked>
            <MenuItem.Icon>
                <Grid>
                    <Border Style="{StaticResource SummaryFunctionActivePillStyle}" />
                    <sdg:Icon Style="{StaticResource SummaryFunctionIconStyle}" IconSource="{StaticResource {x:Static sdg:IconKeys.IconMin}}" />
                </Grid>
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Command="{x:Static commands:ContextMenuCommands.ToggleMaxTotalSummaryCommand}"
                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Max">
            <MenuItem.IsChecked>
                <MultiBinding Mode="OneWay"
                              Converter="{StaticResource SummaryTypeActiveConverter}"
                              ConverterParameter="{x:Static core:SummaryItemType.Max}">
                    <Binding Path="PlacementTarget.Descriptor.TotalSummaries" RelativeSource="{RelativeSource AncestorType={x:Type ContextMenu}}" />
                    <Binding Path="PlacementTarget.Descriptor.TotalSummaries.Count" RelativeSource="{RelativeSource AncestorType={x:Type ContextMenu}}" />
                </MultiBinding>
            </MenuItem.IsChecked>
            <MenuItem.Icon>
                <Grid>
                    <Border Style="{StaticResource SummaryFunctionActivePillStyle}" />
                    <sdg:Icon Style="{StaticResource SummaryFunctionIconStyle}" IconSource="{StaticResource {x:Static sdg:IconKeys.IconMax}}" />
                </Grid>
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Command="{x:Static commands:ContextMenuCommands.ToggleAverageTotalSummaryCommand}"
                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Average">
            <MenuItem.IsChecked>
                <MultiBinding Mode="OneWay"
                              Converter="{StaticResource SummaryTypeActiveConverter}"
                              ConverterParameter="{x:Static core:SummaryItemType.Average}">
                    <Binding Path="PlacementTarget.Descriptor.TotalSummaries" RelativeSource="{RelativeSource AncestorType={x:Type ContextMenu}}" />
                    <Binding Path="PlacementTarget.Descriptor.TotalSummaries.Count" RelativeSource="{RelativeSource AncestorType={x:Type ContextMenu}}" />
                </MultiBinding>
            </MenuItem.IsChecked>
            <MenuItem.Icon>
                <Grid>
                    <Border Style="{StaticResource SummaryFunctionActivePillStyle}" />
                    <sdg:Icon Style="{StaticResource SummaryFunctionIconStyle}" IconSource="{StaticResource {x:Static sdg:IconKeys.IconAverage}}" />
                </Grid>
            </MenuItem.Icon>
        </MenuItem>
        <Separator />
        <MenuItem Command="{x:Static commands:ContextMenuCommands.ClearTotalSummariesCommand}"
                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Clear Summaries" />
        <Separator />
        <!--
            Column-scoped totals editor ("Totals for 'X'") — this column's summary set, with
            cross-column aggregation targets, order, fixed-panel side, prefix/format/suffix.
        -->
        <MenuItem Command="{x:Static commands:ContextMenuCommands.CustomizeTotalSummariesCommand}"
                  CommandParameter="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Customize" >
            <MenuItem.Icon>
                <sdg:Icon IconSource="{StaticResource {x:Static sdg:IconKeys.IconCustomizeSummary}}" />
            </MenuItem.Icon>
        </MenuItem>
    </ContextMenu>

    <!--
        Fixed total summary panel menu. The panel holds its OWN definitions
        (SearchDataGrid.FixedTotalSummaries): Count toggles the grid row-count entry; Customize…
        opens the editor to pick column-specific summaries for the panel. PlacementTarget is the
        panel border inside the grid template, so TemplatedParent reaches the SearchDataGrid.
    -->
    <ContextMenu x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGridFixedTotalSummaryContextMenu}"
                 AutomationProperties.AutomationId="cmuFixedTotalSummary"
                 Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.ContextMenu}}"
                 x:Shared="False">
        <MenuItem Command="{x:Static commands:ContextMenuCommands.ToggleFixedTotalRowCountCommand}"
                  CommandParameter="{Binding PlacementTarget.TemplatedParent, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Count">
            <MenuItem.IsChecked>
                <MultiBinding Mode="OneWay"
                              Converter="{StaticResource SummaryTypeActiveConverter}"
                              ConverterParameter="{x:Static core:SummaryItemType.Count}">
                    <Binding Path="PlacementTarget.TemplatedParent.FixedTotalSummaries" RelativeSource="{RelativeSource AncestorType={x:Type ContextMenu}}" />
                    <Binding Path="PlacementTarget.TemplatedParent.FixedTotalSummaries.Count" RelativeSource="{RelativeSource AncestorType={x:Type ContextMenu}}" />
                </MultiBinding>
            </MenuItem.IsChecked>
            <MenuItem.Icon>
                <Grid>
                    <Border Style="{StaticResource SummaryFunctionActivePillStyle}" />
                    <sdg:Icon Style="{StaticResource SummaryFunctionIconStyle}" IconSource="{StaticResource {x:Static sdg:IconKeys.IconCount}}" />
                </Grid>
            </MenuItem.Icon>
        </MenuItem>
        <Separator />
        <MenuItem Command="{x:Static commands:ContextMenuCommands.OpenFixedTotalSummaryEditorCommand}"
                  CommandParameter="{Binding PlacementTarget.TemplatedParent, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Customize…" >
            <MenuItem.Icon>
                <sdg:Icon IconSource="{StaticResource {x:Static sdg:IconKeys.IconCustomizeSummary}}" />
            </MenuItem.Icon>
        </MenuItem>
    </ContextMenu>

    <!--
        Per-column summary cell. Every data column gets a cell (continuous border + right-click
        surface); columns without summaries render empty. Multiple summaries on one column
        stack vertically, one line per entry. Each entry TextBlock picks up the descriptor's
        resolved ActualTotalSummaryContentStyle (column override → grid default; TargetType
        TextBlock) so consumers can restyle the entry text without retemplating the cell.
    -->
    <Style x:Key="DefaultTotalSummaryEntryTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="#FF333333" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="HorizontalAlignment" Value="Right" />
    </Style>

    <Style x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGridTotalSummaryCell}" TargetType="{x:Type sdg:TotalSummaryCell}">
        <Setter Property="Background" Value="#FFF9F9F9" />
        <Setter Property="BorderBrush" Value="#FFC8C8C8" />
        <Setter Property="BorderThickness" Value="0,0,0,0" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="ContextMenu" Value="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridTotalSummaryCellContextMenu}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:TotalSummaryCell}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            ToolTip="{Binding Descriptor.TotalSummaryText, RelativeSource={RelativeSource TemplatedParent}}">
                        <ItemsControl ItemsSource="{Binding Descriptor.TotalSummaryTextInfo, RelativeSource={RelativeSource TemplatedParent}}"
                                      Margin="4,2"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      IsTabStop="False"
                                      Focusable="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type sdg:SummaryResult}">
                                    <!--
                                        Entry style: the descriptor's resolved
                                        ActualTotalSummaryContentStyle (column override → grid
                                        default) when set, else the default entry look via
                                        TargetNullValue.
                                    -->
                                    <TextBlock IsHitTestVisible="False" Style="{Binding Descriptor.ActualTotalSummaryContentStyle, RelativeSource={RelativeSource AncestorType={x:Type sdg:TotalSummaryCell}}, TargetNullValue={StaticResource DefaultTotalSummaryEntryTextStyle}}">
                                        <Run Text="{Binding PrefixText, Mode=OneWay}"
                                             FontWeight="{Binding PrefixStyle.FontWeight, Converter={StaticResource SummaryStyleFontWeight}}"
                                             FontStyle="{Binding PrefixStyle.FontStyle, Converter={StaticResource SummaryStyleFontStyle}}"
                                             TextDecorations="{Binding PrefixStyle.TextDecorations}"
                                             Foreground="{Binding PrefixStyle.Foreground, Converter={StaticResource SummaryStyleForeground}}" />
                                        <Run Text="{Binding ValueText, Mode=OneWay}"
                                             FontWeight="{Binding ValueStyle.FontWeight, Converter={StaticResource SummaryStyleFontWeight}}"
                                             FontStyle="{Binding ValueStyle.FontStyle, Converter={StaticResource SummaryStyleFontStyle}}"
                                             TextDecorations="{Binding ValueStyle.TextDecorations}"
                                             Foreground="{Binding ValueStyle.Foreground, Converter={StaticResource SummaryStyleForeground}}" />
                                        <Run Text="{Binding SuffixText, Mode=OneWay}"
                                             FontWeight="{Binding SuffixStyle.FontWeight, Converter={StaticResource SummaryStyleFontWeight}}"
                                             FontStyle="{Binding SuffixStyle.FontStyle, Converter={StaticResource SummaryStyleFontStyle}}"
                                             TextDecorations="{Binding SuffixStyle.TextDecorations}"
                                             Foreground="{Binding SuffixStyle.Foreground, Converter={StaticResource SummaryStyleForeground}}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <!--  Read-only gate: drop the picker when the grid disables summary context menus.  -->
            <DataTrigger Binding="{Binding OwnerGrid.SummaryContextMenusEnabled, RelativeSource={RelativeSource Self}}" Value="False">
                <Setter Property="ContextMenu" Value="{x:Null}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridTotalSummaryCell}}" TargetType="{x:Type sdg:TotalSummaryCell}" />

    <!--
        Pinned total summary row hosting the column-aligned panel — same shape as the
        FilterRowPresenter template, with the top seam against the data area.
    -->
    <Style x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGridTotalSummaryRow}" TargetType="{x:Type sdg:TotalSummaryRowPresenter}">
        <Setter Property="Background" Value="#FFF9F9F9" />
        <Setter Property="BorderBrush" Value="#d0d0d0" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:TotalSummaryRowPresenter}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            ClipToBounds="True">
                        <sdg:FilterRowPanel x:Name="PART_SummaryRowPanel" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridTotalSummaryRow}}" TargetType="{x:Type sdg:TotalSummaryRowPresenter}" />

</ResourceDictionary>
