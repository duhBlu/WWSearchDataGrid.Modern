<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf"
                    xmlns:converters="clr-namespace:WWControls.Wpf.Converters;assembly=WWControls.Wpf.Grid"
                    xmlns:commands="clr-namespace:WWControls.Wpf.Commands;assembly=WWControls.Wpf.Grid">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Resources/Icons/Icons.xaml" />
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Controls/Primitives/ContextMenu.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--  Per-segment styling: an unset weight / style / color falls back to the entry's base look.  -->
    <converters:BrushToUnsetConverter x:Key="SummaryStyleForeground" />
    <converters:FontWeightToUnsetConverter x:Key="SummaryStyleFontWeight" />
    <converters:FontStyleToUnsetConverter x:Key="SummaryStyleFontStyle" />
    <!--  Collapses a horizontal summary run when its side has no entries.  -->
    <converters:HasValueToVisibilityConverter x:Key="SummaryRunHasValueToVisibility" />

    <!--
        Default group rendering for a grouped SearchDataGrid. The grid attaches this GroupStyle
        lazily the first time it is grouped (see SearchDataGrid.Grouping.cs / EnsureGroupStyle).
        Each group is an expander whose header shows the group VALUE (rendered per the owning
        column's GroupValueTemplate, resolved by GroupValueTemplateSelector) plus the item count;
        the ItemsPresenter hosts the group's rows (or nested groups).
    -->

    <!--  Fallback group-value rendering when a column declares no GroupValueTemplate.  -->
    <DataTemplate x:Key="DefaultGroupValueTemplate">
        <TextBlock Foreground="#FF262626"
                   Text="{Binding Name}"
                   FontWeight="SemiBold" />
    </DataTemplate>

    <!--
        Shared, stateless selector. Resolves the group's nesting level to the owning grouped column
        and returns that column's GroupValueTemplate (or the default above).
    -->
    <sdg:GroupValueTemplateSelector x:Key="GroupValueTemplateSelector" DefaultTemplate="{StaticResource DefaultGroupValueTemplate}" />

    <!--
        Resolves the header item's owning-column HeaderCaption into the "ColumnName: " prefix
        rendered ahead of the value in DefaultGroupHeaderTemplate.
    -->
    <sdg:GroupColumnNameConverter x:Key="GroupColumnNameConverter" />

    <!--
        Default whole-header rendering. Used as the fallback by GroupHeaderTemplateSelector when
        the owning column declares no GroupHeaderTemplate. Lays out the column's
        GroupValueTemplate-rendered value after the column-name prefix. The row count is NOT
        default chrome — it's an opt-in summary entry (SearchDataGrid.ShowGroupRowCount, "Show
        row count" in the View Totals editor), rendered with the other group summaries in the
        header's left/right summary runs (owned by the row chrome, not this template). A
        column-level GroupHeaderTemplate replaces this template wholesale; summaries persist
        either way.
    -->
    <DataTemplate x:Key="DefaultGroupHeaderTemplate">
        <StackPanel Orientation="Horizontal"
                    IsHitTestVisible="False"
                    Margin="2,3"
                    VerticalAlignment="Center">
            <!--
                Column-name prefix: the owning column's HeaderCaption followed by ": ", read
                directly off the header item via GroupColumnNameConverter. Renders nothing (empty
                string) when the column or caption can't be resolved, so the value slot stands alone.
            -->
            <TextBlock Foreground="#FF1C1C1C"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Text="{Binding Converter={StaticResource GroupColumnNameConverter}}" />
            <!--  Value: per-column GroupValueTemplate, resolved by level.  -->
            <ContentControl VerticalAlignment="Center"
                            Content="{Binding}"
                            ContentTemplateSelector="{StaticResource GroupValueTemplateSelector}" />
        </StackPanel>
    </DataTemplate>

    <!--
        Group-summary run text — shared look for the left (inline after content) and right
        (right-aligned) runs on both header surfaces. Collapses when its run is empty so the
        slot costs nothing on summary-free grids.
    -->
    <Style x:Key="GroupSummaryRunTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="#FF555555" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="{x:Null}">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!--  One styled entry inside a horizontal group-summary run (collapse is handled by the run's ItemsControl).  -->
    <Style x:Key="GroupSummaryRunEntryTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="#FF555555" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <!--  Prefix / value / suffix run entry, each segment carrying its own per-segment style.  -->
    <DataTemplate x:Key="HeaderRunSummaryResultTemplate" DataType="{x:Type sdg:SummaryResult}">
        <TextBlock Style="{StaticResource GroupSummaryRunEntryTextStyle}">
            <Run Text="{Binding PrefixText, Mode=OneWay}"
                 FontWeight="{Binding PrefixStyle.FontWeight, Converter={StaticResource SummaryStyleFontWeight}}"
                 FontStyle="{Binding PrefixStyle.FontStyle, Converter={StaticResource SummaryStyleFontStyle}}"
                 TextDecorations="{Binding PrefixStyle.TextDecorations}"
                 Foreground="{Binding PrefixStyle.Foreground, Converter={StaticResource SummaryStyleForeground}}" />
            <Run Text="{Binding ValueText, Mode=OneWay}"
                 FontWeight="{Binding ValueStyle.FontWeight, Converter={StaticResource SummaryStyleFontWeight}}"
                 FontStyle="{Binding ValueStyle.FontStyle, Converter={StaticResource SummaryStyleFontStyle}}"
                 TextDecorations="{Binding ValueStyle.TextDecorations}"
                 Foreground="{Binding ValueStyle.Foreground, Converter={StaticResource SummaryStyleForeground}}" />
            <Run Text="{Binding SuffixText, Mode=OneWay}"
                 FontWeight="{Binding SuffixStyle.FontWeight, Converter={StaticResource SummaryStyleFontWeight}}"
                 FontStyle="{Binding SuffixStyle.FontStyle, Converter={StaticResource SummaryStyleFontStyle}}"
                 TextDecorations="{Binding SuffixStyle.TextDecorations}"
                 Foreground="{Binding SuffixStyle.Foreground, Converter={StaticResource SummaryStyleForeground}}" />
        </TextBlock>
    </DataTemplate>

    <sdg:GroupHeaderTemplateSelector x:Key="GroupHeaderTemplateSelector" DefaultTemplate="{StaticResource DefaultGroupHeaderTemplate}" />
    <sdg:GroupHeaderMarginConverter x:Key="GroupHeaderMarginConverter" />
    
    <!--
        Sticky group-header strip applied via implicit style to every FixedGroupHeadersPresenter.
        The scroll-driven resolver (SearchDataGrid.FixedGroups.cs) populates ItemsSource with the
        active group chain view-models (one per nesting level, outermost first). The ItemTemplate
        mirrors the in-place group header's look: a chevron plus the entry's content routed through
        GroupHeaderTemplateSelector — the SAME selector the in-place Expander uses — so a column's
        custom GroupHeaderTemplate / GroupValueTemplate renders identically in the strip, falling
        back to the shared DefaultGroupHeaderTemplate chrome (column-prefixed value + count chip on
        the same #FFF3F3F3 / #FFd0d0d0 background). Chevron state reads through
        FixedGroupEntryIsExpandedConverter (which walks entry.RepresentedGroupItem's inner
        Expander.IsExpanded), and clicks fire ToggleFixedGroupCommand — that toggles the
        underlying real expander AND requests a strip refresh so the chevron updates against
        fresh entry instances on the next pass.
        
        Each pinned header is indented per nesting level via FixedGroupIndentConverter so its
        chevron lines up exactly with the in-place header at the same depth.
    -->
    <sdg:FixedGroupIndentConverter x:Key="FixedGroupIndentConverter" />
    <sdg:FixedGroupEntryIsExpandedConverter x:Key="FixedGroupEntryIsExpandedConverter" />

    <!--
        Right-click menu for the in-body flat group-header rows. Mirrors the legacy
        GridSearchDataGridGroupHeaderContextMenu, but its commands take the GroupHeaderRow (the row
        template's DataContext, reached via PlacementTarget.DataContext) instead of an Expander —
        flat headers render as DataGridRows with no GroupItem/Expander. The Expand / Collapse "this
        group" items are visibility-gated on the row's IsExpanded snapshot (fresh: the sentinel is
        rebuilt on every reflatten and the menu opens against the current instance).
    -->
    <ContextMenu x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGridGroupHeaderContextMenu}"
                 AutomationProperties.AutomationId="cmuGroupHeader"
                 Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.ContextMenu}}"
                 x:Shared="False">
        <MenuItem Command="{x:Static commands:ContextMenuCommands.ExpandGroupCommand}"
                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Expand this group">
            <MenuItem.Icon>
                <sdg:Icon Width="14"
                          Height="14"
                          IconSource="{StaticResource {x:Static sdg:IconKeys.IconExpandGroups}}" />
            </MenuItem.Icon>
            <MenuItem.Style>
                <Style TargetType="{x:Type MenuItem}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.IsExpanded, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </MenuItem.Style>
        </MenuItem>
        <MenuItem Command="{x:Static commands:ContextMenuCommands.CollapseGroupCommand}"
                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Collapse this group">
            <MenuItem.Icon>
                <sdg:Icon Width="14"
                          Height="14"
                          IconSource="{StaticResource {x:Static sdg:IconKeys.IconCollapseGroups}}" />
            </MenuItem.Icon>
            <MenuItem.Style>
                <Style TargetType="{x:Type MenuItem}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.IsExpanded, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </MenuItem.Style>
        </MenuItem>
        <Separator />
        <MenuItem Command="{x:Static commands:ContextMenuCommands.ExpandAllAtLevelCommand}"
                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Expand all at this level">
            <MenuItem.Icon>
                <sdg:Icon Width="14"
                          Height="14"
                          IconSource="{StaticResource {x:Static sdg:IconKeys.IconExpandGroups}}" />
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Command="{x:Static commands:ContextMenuCommands.CollapseAllAtLevelCommand}"
                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Collapse all at this level">
            <MenuItem.Icon>
                <sdg:Icon Width="14"
                          Height="14"
                          IconSource="{StaticResource {x:Static sdg:IconKeys.IconCollapseGroups}}" />
            </MenuItem.Icon>
        </MenuItem>
        <Separator />
        <MenuItem Command="{x:Static commands:ContextMenuCommands.UngroupAtLevelCommand}"
                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Ungroup at this level">
            <MenuItem.Icon>
                <sdg:Icon Width="14"
                          Height="14"
                          IconSource="{StaticResource {x:Static sdg:IconKeys.IconUngroup}}" />
            </MenuItem.Icon>
        </MenuItem>
        <Separator x:Name="sepGroupSummaries">
            <Separator.Style>
                <Style TargetType="Separator" BasedOn="{StaticResource {x:Static MenuItem.SeparatorStyleKey}}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.OwningColumn.View.SummaryContextMenusEnabled, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Separator.Style>
        </Separator>
        <MenuItem Command="{x:Static commands:ContextMenuCommands.OpenGroupSummaryEditorCommand}"
                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Customize Group Summaries">
            <MenuItem.Icon>
                <Grid>
                    <Border Style="{StaticResource FooterSummaryFunctionActivePillStyle}" />
                    <sdg:Icon Style="{StaticResource FooterSummaryFunctionIconStyle}" IconSource="{StaticResource {x:Static sdg:IconKeys.IconCustomizeSummary}}" />
                </Grid>
            </MenuItem.Icon>
            <MenuItem.Style>
                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.MenuItem}}">
                    <Style.Triggers>
                        <!--  Read-only gate: the group-header DataContext exposes its owning column's grid.  -->
                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.OwningColumn.View.SummaryContextMenusEnabled, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </MenuItem.Style>
        </MenuItem>
    </ContextMenu>

    <!--
        Flat-grouping header row. Rendered by the themed DataGridRow style (via its IsGroupHeader
        trigger) when the grid materializes a SearchDataGridRow for a GroupHeaderRow sentinel. It
        deliberately mirrors the in-place GroupExpanderTemplate look — the row-header gutter strip,
        per-level indent, chevron, and the SAME GroupHeaderTemplateSelector content (column-prefixed
        value + count chip) — so a flat-mode header is visually indistinguishable from a legacy one.
        The DataContext is the GroupHeaderRow, so Level / IsExpanded / Name / ItemCount bind directly
        and the indent reuses FixedGroupIndentConverter (which takes the level as a primitive, with
        no GroupItem ancestor to walk). Clicks / Space-Enter are handled by SearchDataGridRow itself.
    -->
    <!--
        Expand/collapse chevron for a group header, shared by the in-body flat header row and the
        pinned strip's per-entry template (both reference it by ThemeKey, so the chevron is identical
        fixed or unfixed). The Button supplies a padded, transparent hit target around the 9x9 glyph
        plus the IsMouseOver / IsPressed states the bare Icon couldn't; IconBrush tracks Foreground so
        those triggers recolor the glyph (DarkGray idle, Gray hover, Black pressed). The glyph is a single
        right-pointing caret rotated by the GroupChevron behavior — 0° when collapsed, 90° (= caret-down)
        when expanded — keyed off the DataContext's IsExpanded (a GroupHeaderRow or a
        FixedGroupHeaderEntry, both of which expose it). The rotation animates only on a genuine
        in-place toggle while the grid's AllowGroupExpandAnimation is on; initial realization and
        recycled-container rebinds snap. The toggle command is supplied by each call site
        (ToggleGroupCommand in body, ToggleFixedGroupCommand in the strip).
    -->
    <Style x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGridGroupHeaderChevronButton}" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="DarkGray" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <sdg:Icon x:Name="Chevron"
                                  Width="7"
                                  Height="7"
                                  VerticalAlignment="Center"
                                  RenderTransformOrigin="0.5,0.5"
                                  sdg:GroupChevron.Attach="True"
                                  sdg:GroupChevron.IsExpanded="{Binding IsExpanded}"
                                  IconBrush="{TemplateBinding Foreground}"
                                  IconSource="{StaticResource {x:Static sdg:IconKeys.IconCaretRight}}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="Gray" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Foreground" Value="Black" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════════════════
        Column-aligned group summaries (SearchDataGrid.GroupSummaryDisplayMode =
        AlignByColumns) — a layer INSIDE the group header row, beneath the pinned
        content, whose per-column cells scroll with the columns.
        ═══════════════════════════════════════════════════════════════════════
    -->

    <!--  One aligned summary line. Mirrors the summary-run foreground so aligned values
          read as group chrome, not grid totals.  -->
    <Style x:Key="DefaultGroupSummaryCellEntryTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="#FF555555" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="HorizontalAlignment" Value="Right" />
    </Style>

    <!--  Per-column slot: the column's results stack vertically, right-aligned under the
          column (entries already carry their formatted text). Empty for columns without
          entries — and in Header mode the presenter builds no cells at all.  -->
    <Style x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGridGroupSummaryCell}" TargetType="{x:Type sdg:GroupSummaryCell}">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:GroupSummaryCell}">
                    <Border Background="Transparent">
                        <ItemsControl ItemsSource="{Binding Results, RelativeSource={RelativeSource TemplatedParent}}"
                                      Margin="4,2"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      IsTabStop="False"
                                      Focusable="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type sdg:SummaryResult}">
                                    <TextBlock Style="{StaticResource DefaultGroupSummaryCellEntryTextStyle}">
                                        <Run Text="{Binding PrefixText, Mode=OneWay}"
                                             FontWeight="{Binding PrefixStyle.FontWeight, Converter={StaticResource SummaryStyleFontWeight}}"
                                             FontStyle="{Binding PrefixStyle.FontStyle, Converter={StaticResource SummaryStyleFontStyle}}"
                                             TextDecorations="{Binding PrefixStyle.TextDecorations}"
                                             Foreground="{Binding PrefixStyle.Foreground, Converter={StaticResource SummaryStyleForeground}}" />
                                        <Run Text="{Binding ValueText, Mode=OneWay}"
                                             FontWeight="{Binding ValueStyle.FontWeight, Converter={StaticResource SummaryStyleFontWeight}}"
                                             FontStyle="{Binding ValueStyle.FontStyle, Converter={StaticResource SummaryStyleFontStyle}}"
                                             TextDecorations="{Binding ValueStyle.TextDecorations}"
                                             Foreground="{Binding ValueStyle.Foreground, Converter={StaticResource SummaryStyleForeground}}" />
                                        <Run Text="{Binding SuffixText, Mode=OneWay}"
                                             FontWeight="{Binding SuffixStyle.FontWeight, Converter={StaticResource SummaryStyleFontWeight}}"
                                             FontStyle="{Binding SuffixStyle.FontStyle, Converter={StaticResource SummaryStyleFontStyle}}"
                                             TextDecorations="{Binding SuffixStyle.TextDecorations}"
                                             Foreground="{Binding SuffixStyle.Foreground, Converter={StaticResource SummaryStyleForeground}}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style BasedOn="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridGroupSummaryCell}}" TargetType="{x:Type sdg:GroupSummaryCell}" />

    <!--  Cells host: per-column run in display order in the same extent space as the data
          cells; FixedColumnAlignedPanel additionally anchors pinned columns' cells to the
          viewport edges (and clips scrollable cells sliding under the bands), matching the
          data cells' fixed-column behavior.  -->
    <Style x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGridGroupSummaryCellsPresenter}" TargetType="{x:Type sdg:GroupSummaryCellsPresenter}">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:GroupSummaryCellsPresenter}">
                    <sdg:FixedColumnAlignedPanel x:Name="PART_SummaryCellsPanel" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style BasedOn="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridGroupSummaryCellsPresenter}}" TargetType="{x:Type sdg:GroupSummaryCellsPresenter}" />

    <ControlTemplate x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGridGroupHeaderRow}" TargetType="{x:Type DataGridRow}">
        <!--  #FFF3F3F3 matches the legacy GroupExpanderStyle background; the row's own
              (white / alternating) Background is intentionally ignored here.  -->
        <Border x:Name="HeaderBorder"
                Background="#FFF3F3F3"
                BorderBrush="#FFd0d0d0"
                BorderThickness="0,0,0,1"
                Cursor="Hand"
                ContextMenu="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridGroupHeaderContextMenu}}"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True">
          <Grid>
            <!--
                Column-aligned summary layer (AlignByColumns mode). Lives in EXTENT space — a
                row-header-width spacer then one cell per visible column — so each value sits
                under its target column and scrolls with it, unlike the pinned content above it.
                Hit-test-transparent: clicks fall through to the header row's own handlers. In
                Header mode the presenter builds no cells, so this costs nothing.
            -->
            <DockPanel HorizontalAlignment="Left" IsHitTestVisible="False">
                <Border DockPanel.Dock="Left" Width="{Binding RowHeaderActualWidth, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}}" />
                <sdg:GroupSummaryCellsPresenter VerticalAlignment="Center" />
            </DockPanel>
            <!--
                Viewport-pinned content. Group header rows are extent-wide (they live in the
                scrolling row panel), so a right-aligned summary run at the extent edge would sit
                offscreen whenever the columns overflow. Clamping this inner grid to the
                ScrollViewer's ViewportWidth and counter-translating by HorizontalOffset keeps
                the header text, gutter, and both summary runs pinned in view during horizontal
                scroll (the HeaderBorder behind it stays extent-wide so the chrome never ends
                mid-row). The counter-translation is owned by ViewportPinBehavior — a
                RelativeSource binding on the TranslateTransform itself targets a Freezable with
                no governing FrameworkElement and silently fails to resolve in row templates.
            -->
            <Grid HorizontalAlignment="Left"
                  sdg:ViewportPinBehavior.IsPinned="True"
                  Width="{Binding ViewportWidth, RelativeSource={RelativeSource AncestorType={x:Type ScrollViewer}}}">
                <!--  Row-header gutter strip, kept flush at x=0 regardless of group depth.  -->
                <Border Background="#FFf9f9f9"
                        BorderBrush="#FFd0d0d0"
                        BorderThickness="0,0,1,0"
                        HorizontalAlignment="Left"
                        Width="{Binding RowHeaderActualWidth, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}}"
                        UseLayoutRounding="True"
                        SnapsToDevicePixels="True" />
                <DockPanel>
                    <!--  Right-aligned group-summary run (GroupSummaries with Alignment=Right + the opt-in row count).  -->
                    <ItemsControl DockPanel.Dock="Right"
                                  Margin="12,0,12,0"
                                  VerticalAlignment="Center"
                                  IsTabStop="False"
                                  Focusable="False"
                                  ItemsSource="{Binding GroupSummaryRightInfo}"
                                  ItemTemplate="{StaticResource HeaderRunSummaryResultTemplate}"
                                  Visibility="{Binding GroupSummaryRightInfo, Converter={StaticResource SummaryRunHasValueToVisibility}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <sdg:SimpleStackPanel Orientation="Horizontal" Spacing="12" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <sdg:SimpleStackPanel Orientation="Horizontal"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Spacing="0">
                        <sdg:SimpleStackPanel.Margin>
                            <MultiBinding Converter="{StaticResource FixedGroupIndentConverter}">
                                <Binding Path="Level" />
                                <Binding RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" Path="RowHeaderActualWidth" />
                                <Binding RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" Path="GroupIndentWidth" />
                            </MultiBinding>
                        </sdg:SimpleStackPanel.Margin>
                        <Button Style="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridGroupHeaderChevronButton}}"
                                Command="{x:Static commands:ContextMenuCommands.ToggleGroupCommand}"
                                CommandParameter="{Binding}" />
                        <ContentControl VerticalAlignment="Center"
                                        Content="{Binding}"
                                        ContentTemplateSelector="{StaticResource GroupHeaderTemplateSelector}" />
                        <!--  Left-side group-summary run, inline after the header content.  -->
                        <ItemsControl VerticalAlignment="Center"
                                      Margin="6,0,0,0"
                                      IsTabStop="False"
                                      Focusable="False"
                                      ItemsSource="{Binding GroupSummaryLeftInfo}"
                                      ItemTemplate="{StaticResource HeaderRunSummaryResultTemplate}"
                                      Visibility="{Binding GroupSummaryLeftInfo, Converter={StaticResource SummaryRunHasValueToVisibility}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <sdg:SimpleStackPanel Orientation="Horizontal" Spacing="12" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </sdg:SimpleStackPanel>
                </DockPanel>
            </Grid>
          </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <!--  Keyboard-focus highlight: header rows are focusable, tree-navigable rows. The
                  highlight tracks keyboard focus, not selection — headers never enter SelectedItems.  -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="HeaderBorder" Property="Background" Value="#FFE8E8E8" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="HeaderBorder" Property="Background" Value="#FFD7E8FB" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ContextMenu x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGridFixedGroupHeaderContextMenu}"
                 AutomationProperties.AutomationId="cmuFixedGroupHeader"
                 Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.ContextMenu}}"
                 x:Shared="False">
        <MenuItem Command="{x:Static commands:ContextMenuCommands.ExpandFixedGroupCommand}"
                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Expand this group">
            <MenuItem.Icon>
                <sdg:Icon Width="14"
                          Height="14"
                          IconSource="{StaticResource {x:Static sdg:IconKeys.IconExpandGroups}}" />
            </MenuItem.Icon>
            <MenuItem.Style>
                <Style TargetType="{x:Type MenuItem}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}, Converter={StaticResource FixedGroupEntryIsExpandedConverter}}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </MenuItem.Style>
        </MenuItem>
        <MenuItem Command="{x:Static commands:ContextMenuCommands.CollapseFixedGroupCommand}"
                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Collapse this group">
            <MenuItem.Icon>
                <sdg:Icon Width="14"
                          Height="14"
                          IconSource="{StaticResource {x:Static sdg:IconKeys.IconCollapseGroups}}" />
            </MenuItem.Icon>
            <MenuItem.Style>
                <Style TargetType="{x:Type MenuItem}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}, Converter={StaticResource FixedGroupEntryIsExpandedConverter}}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </MenuItem.Style>
        </MenuItem>
        <Separator />
        <MenuItem Command="{x:Static commands:ContextMenuCommands.ExpandAllAtFixedLevelCommand}"
                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Expand all at this level">
            <MenuItem.Icon>
                <sdg:Icon Width="14"
                          Height="14"
                          IconSource="{StaticResource {x:Static sdg:IconKeys.IconExpandGroups}}" />
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Command="{x:Static commands:ContextMenuCommands.CollapseAllAtFixedLevelCommand}"
                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Collapse all at this level">
            <MenuItem.Icon>
                <sdg:Icon Width="14"
                          Height="14"
                          IconSource="{StaticResource {x:Static sdg:IconKeys.IconCollapseGroups}}" />
            </MenuItem.Icon>
        </MenuItem>
        <Separator />
        <MenuItem Command="{x:Static commands:ContextMenuCommands.UngroupAtFixedLevelCommand}"
                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Ungroup at this level">
            <MenuItem.Icon>
                <sdg:Icon Width="14"
                          Height="14"
                          IconSource="{StaticResource {x:Static sdg:IconKeys.IconUngroup}}" />
            </MenuItem.Icon>
        </MenuItem>
        <Separator>
            <Separator.Style>
                <Style TargetType="Separator" BasedOn="{StaticResource {x:Static MenuItem.SeparatorStyleKey}}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.Column.View.SummaryContextMenusEnabled, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Separator.Style>
        </Separator>
        <MenuItem Command="{x:Static commands:ContextMenuCommands.OpenGroupSummaryEditorFixedCommand}"
                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="Customize Group Summaries">
            <MenuItem.Icon>
                <Grid>
                    <Border Style="{StaticResource FooterSummaryFunctionActivePillStyle}" />
                    <sdg:Icon Style="{StaticResource FooterSummaryFunctionIconStyle}" IconSource="{StaticResource {x:Static sdg:IconKeys.IconCustomizeSummary}}" />
                </Grid>
            </MenuItem.Icon>
            <MenuItem.Style>
                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.MenuItem}}">
                    <Style.Triggers>
                        <!--  Read-only gate: the pinned entry exposes its column's grid via Column.View.  -->
                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.Column.View.SummaryContextMenusEnabled, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </MenuItem.Style>
        </MenuItem>
    </ContextMenu>

    <Style x:Key="{x:Static sdg:ThemeKeys.GridSearchDataGridFixedGroupHeadersPresenter}" TargetType="{x:Type sdg:FixedGroupHeadersPresenter}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate DataType="{x:Type sdg:FixedGroupHeaderEntry}">
                    <Border Background="#FFF3F3F3"
                            BorderBrush="#FFd0d0d0"
                            BorderThickness="0,0,0,1"
                            Cursor="Hand"
                            ContextMenu="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridFixedGroupHeaderContextMenu}}"
                            UseLayoutRounding="True"
                            SnapsToDevicePixels="True">
                        <!--  Click anywhere on the pinned entry toggles the group; the chevron button
                              marks its own clicks handled, so they don't double-fire this binding.  -->
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{x:Static commands:ContextMenuCommands.ToggleFixedGroupCommand}"
                                          CommandParameter="{Binding}" />
                        </Border.InputBindings>
                        <Grid>
                            <Border Background="#FFf9f9f9"
                                    BorderBrush="#FFd0d0d0"
                                    BorderThickness="0,0,1,0"
                                    HorizontalAlignment="Left"
                                    Width="{Binding RowHeaderActualWidth, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}}"
                                    UseLayoutRounding="True"
                                    SnapsToDevicePixels="True" />
                            <!--  The strip is already viewport-width, so the summary runs dock without the
                                  in-body template's viewport pinning.  -->
                            <DockPanel>
                                <ItemsControl DockPanel.Dock="Right"
                                              Margin="12,0,12,0"
                                              VerticalAlignment="Center"
                                              IsTabStop="False"
                                              Focusable="False"
                                              ItemsSource="{Binding GroupSummaryRightInfo}"
                                              ItemTemplate="{StaticResource HeaderRunSummaryResultTemplate}"
                                              Visibility="{Binding GroupSummaryRightInfo, Converter={StaticResource SummaryRunHasValueToVisibility}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <sdg:SimpleStackPanel Orientation="Horizontal" Spacing="12" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                                <sdg:SimpleStackPanel Orientation="Horizontal"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"
                                                      Spacing="0">
                                    <sdg:SimpleStackPanel.Margin>
                                        <MultiBinding Converter="{StaticResource FixedGroupIndentConverter}">
                                            <Binding Path="Level" />
                                            <Binding RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" Path="RowHeaderActualWidth" />
                                            <Binding RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" Path="GroupIndentWidth" />
                                        </MultiBinding>
                                    </sdg:SimpleStackPanel.Margin>
                                    <Button Style="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridGroupHeaderChevronButton}}"
                                            Command="{x:Static commands:ContextMenuCommands.ToggleFixedGroupCommand}"
                                            CommandParameter="{Binding}" />
                                    <ContentControl VerticalAlignment="Center"
                                                    Content="{Binding}"
                                                    ContentTemplateSelector="{StaticResource GroupHeaderTemplateSelector}" />
                                    <ItemsControl VerticalAlignment="Center"
                                                  Margin="6,0,0,0"
                                                  IsTabStop="False"
                                                  Focusable="False"
                                                  ItemsSource="{Binding GroupSummaryLeftInfo}"
                                                  ItemTemplate="{StaticResource HeaderRunSummaryResultTemplate}"
                                                  Visibility="{Binding GroupSummaryLeftInfo, Converter={StaticResource SummaryRunHasValueToVisibility}}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <sdg:SimpleStackPanel Orientation="Horizontal" Spacing="12" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </sdg:SimpleStackPanel>
                            </DockPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:FixedGroupHeadersPresenter}">
                    <Border Background="{TemplateBinding Background}"
                            UseLayoutRounding="True"
                            SnapsToDevicePixels="True">
                        <ItemsPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:ThemeKeys.GridSearchDataGridFixedGroupHeadersPresenter}}" TargetType="{x:Type sdg:FixedGroupHeadersPresenter}" />

</ResourceDictionary>
