<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <!--  Accent (primary) button for the row-edit Update action — keeps white-on-green contrast
          through hover / pressed (the shared PrimitivesButton greys its background on hover).  -->
    <Style x:Key="RowEditUpdateButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#0078d4" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#005a9e" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#00467b" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#b6c1cd" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════════════════
        RowEditPresenter — the bright, column-aligned editor strip shown over the
        row in full-row ("edit entire row") edit mode. Hosts a FilterRowPanel of
        per-column editors with a docked Update / Cancel action bar beneath it.
        ═══════════════════════════════════════════════════════════════════════
    -->

    <Style x:Key="{x:Static sdg:GridThemeKeys.GridSearchDataGridRowEditPresenter}" TargetType="{x:Type sdg:RowEditPresenter}">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="#0179d4" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:RowEditPresenter}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.35" Color="#000000" />
                        </Border.Effect>
                        <DockPanel LastChildFill="True">
                            <!--  Action bar — docked beneath the editor row.  -->
                            <Border DockPanel.Dock="Bottom"
                                    Background="#FFF4F7F9"
                                    BorderBrush="#FFDDE3E8"
                                    BorderThickness="0,1,0,0">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="8,6">
                                    <Button x:Name="PART_UpdateButton"
                                            Style="{StaticResource RowEditUpdateButtonStyle}"
                                            MinWidth="78"
                                            Padding="12,3"
                                            Content="Update"
                                            IsDefault="True" />
                                    <Button x:Name="PART_CancelButton"
                                            Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.Button}}"
                                            MinWidth="78"
                                            Padding="12,3"
                                            Margin="8,0,0,0"
                                            Content="Cancel"
                                            IsCancel="True" />
                                </StackPanel>
                            </Border>

                            <!--  Column-aligned editor row. MinHeight is pushed by the grid to match
                                  the data row it covers, so the editors sit directly over it.  -->
                            <sdg:FilterRowPanel x:Name="PART_RowEditPanel"
                                                MinHeight="{Binding MinHeight, RelativeSource={RelativeSource TemplatedParent}}"
                                                Background="{TemplateBinding Background}" />
                        </DockPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:GridThemeKeys.GridSearchDataGridRowEditPresenter}}" TargetType="{x:Type sdg:RowEditPresenter}" />

</ResourceDictionary>
