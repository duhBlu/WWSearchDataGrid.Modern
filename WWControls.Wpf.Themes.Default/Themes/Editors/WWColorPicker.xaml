<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:WWControls.Wpf.Converters;assembly=WWControls.Wpf.Grid"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <!--
        ═══════════════════════════════════════════════════════════════════════
        WWColorPicker — a swatch toggle that drops a popup with preset swatches,
        HSV sliders, and a hex input. Ported from WPF-CabinetDesigner; the
        CabinetDesigner theme-brush references are rewired to the grid's literal
        palette and the library's own primitives so it ships self-contained.
        ═══════════════════════════════════════════════════════════════════════
    -->

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Primitives/DefaultControls.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <converters:InverseBooleanConverter x:Key="WWColorPicker_InverseBooleanConverter" />

    <!--  Transparency checkerboard behind a swatch.  -->
    <DrawingBrush x:Key="WWColorPicker_CheckeredBrush"
                  Viewport="0,0,10,10"
                  ViewportUnits="Absolute"
                  TileMode="Tile">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#FFFFFF">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,10,10" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#E0E0E0">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="0,0,5,5" />
                            <RectangleGeometry Rect="5,5,5,5" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <Style x:Key="WWColorPicker_SliderThumb_Style" TargetType="{x:Type Thumb}">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Ellipse Width="16"
                             Height="16"
                             StrokeThickness="2">
                        <Ellipse.Style>
                            <Style TargetType="{x:Type Ellipse}">
                                <Setter Property="Stroke" Value="#CCCCCC" />
                                <Setter Property="Fill" Value="#FFFFFF" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Stroke" Value="#AAAAAA" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Invisible repeat buttons so the HSV slider track shows the gradient through.  -->
    <Style x:Key="WWColorPicker_SliderRepeatButton" TargetType="{x:Type RepeatButton}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WWColorPicker_HsvSlider_Style" TargetType="{x:Type Slider}">
        <Setter Property="IsMoveToPointEnabled" Value="True" />
        <Setter Property="IsSnapToTickEnabled" Value="True" />
        <Setter Property="TickFrequency" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Slider}">
                    <Grid>
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource WWColorPicker_SliderRepeatButton}" Command="{x:Static Slider.DecreaseLarge}" />
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource WWColorPicker_SliderRepeatButton}" Command="{x:Static Slider.IncreaseLarge}" />
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource WWColorPicker_SliderThumb_Style}" />
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Toggle button for the color picker (shows swatch + optional hex text)  -->
    <Style x:Key="WWColorPickerToggleButtonStyle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <!--  Same chrome as PrimitivesButton: outer border + inner bottom-lip depth cue.  -->
                    <Border x:Name="border"
                            Background="#ffffff"
                            BorderBrush="#e3e3e3"
                            BorderThickness="1,1,1,0"
                            CornerRadius="4">
                        <Border x:Name="innerBorder"
                                Background="Transparent"
                                BorderBrush="#bfbfbf"
                                BorderThickness="0,0,0,0.8"
                                Margin="0,0,0,-1"
                                CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Stretch"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}" />
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#f0f0f0" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#d6d6d6" />
                            <Setter TargetName="innerBorder" Property="BorderBrush" Value="#b4b4b4" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#f7f7f7" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#ebebeb" />
                            <Setter TargetName="innerBorder" Property="BorderBrush" Value="#c5c5c5" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#F5F5F5" />
                            <Setter Property="Foreground" Value="#999999" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Preset color item template (14x14 swatch)  -->
    <DataTemplate x:Key="WWColorPicker_PresetColorTemplate">
        <Border Background="#FFFFFF"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                Margin="1">
            <Rectangle Width="14" Height="14">
                <Rectangle.Fill>
                    <SolidColorBrush Color="{Binding}" />
                </Rectangle.Fill>
            </Rectangle>
        </Border>
    </DataTemplate>

    <!--  Main WWColorPicker style  -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.ColorPicker}" TargetType="{x:Type sdg:WWColorPicker}">
        <Setter Property="Focusable" Value="False" />

        <Setter Property="MinHeight" Value="24" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:WWColorPicker}">
                    <Grid>
                        <!--  Toggle button  -->
                        <ToggleButton x:Name="PART_ToggleButton"
                                      Style="{StaticResource WWColorPickerToggleButtonStyle}"
                                      IsChecked="{Binding IsOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      IsHitTestVisible="{Binding IsOpen, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource WWColorPicker_InverseBooleanConverter}}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      IsTabStop="True">
                            <Grid Margin="-1" ClipToBounds="True">
                                <!--  Color-only display  -->
                                <Border x:Name="ColorOnly"
                                        Background="{StaticResource WWColorPicker_CheckeredBrush}"
                                        CornerRadius="3"
                                        Margin="3">
                                    <Rectangle RadiusX="3" RadiusY="3">
                                        <Rectangle.Fill>
                                            <SolidColorBrush Color="{Binding SelectedColor, RelativeSource={RelativeSource TemplatedParent}}" />
                                        </Rectangle.Fill>
                                    </Rectangle>
                                </Border>
                                <!--  Color + hex text display  -->
                                <Border x:Name="ColorAndName"
                                        Visibility="Hidden"
                                        CornerRadius="4">
                                    <sdg:SimpleStackPanel Orientation="Horizontal"
                                                          Margin="4,0,0,0"
                                                          Spacing="4">
                                        <Border Background="{StaticResource WWColorPicker_CheckeredBrush}"
                                                BorderBrush="#cccccc"
                                                BorderThickness="1"
                                                Margin="2,4"
                                                HorizontalAlignment="Left"
                                                Width="24"
                                                CornerRadius="4">
                                            <Rectangle RadiusX="4" RadiusY="4">
                                                <Rectangle.Fill>
                                                    <SolidColorBrush Color="{Binding SelectedColor, RelativeSource={RelativeSource TemplatedParent}}" />
                                                </Rectangle.Fill>
                                            </Rectangle>
                                        </Border>
                                        <TextBlock Foreground="{TemplateBinding Foreground}"
                                                   Text="{Binding HexText, RelativeSource={RelativeSource TemplatedParent}}"
                                                   VerticalAlignment="Center" />
                                    </sdg:SimpleStackPanel>
                                </Border>
                            </Grid>
                        </ToggleButton>

                        <!--  Popup  -->
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               IsOpen="{Binding ElementName=PART_ToggleButton, Path=IsChecked}"
                               Focusable="False"
                               StaysOpen="False"
                               HorizontalOffset="1"
                               VerticalOffset="1"
                               PopupAnimation="Slide"
                               Placement="Bottom">
                            <Border Background="#F0F0F0"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Margin="12"
                                    Padding="8"
                                    MinWidth="270"
                                    CornerRadius="4">
                                <Border.Effect>
                                    <DropShadowEffect Color="#02000000"
                                                      Opacity="0.25"
                                                      BlurRadius="8"
                                                      ShadowDepth="2" />
                                </Border.Effect>
                                <StackPanel>
                                    <!--  Preset Colors  -->
                                    <TextBlock Foreground="#666666"
                                               Text="Preset Colors"
                                               Margin="0,0,0,4"
                                               FontSize="11" />
                                    <ListBox x:Name="PART_PresetColorsList"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ItemTemplate="{StaticResource WWColorPicker_PresetColorTemplate}"
                                             ItemsSource="{Binding PresetColors, RelativeSource={RelativeSource TemplatedParent}}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Width="250" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="{x:Type ListBoxItem}">
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0" />
                                                <Setter Property="Cursor" Value="Hand" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                            <Border x:Name="_border"
                                                                    BorderBrush="Transparent"
                                                                    BorderThickness="1">
                                                                <ContentPresenter />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="_border" Property="BorderBrush" Value="#0078D4" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>

                                    <Separator Margin="0,6" />

                                    <!--  HSV Sliders  -->
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="26" />
                                            <RowDefinition Height="26" />
                                            <RowDefinition Height="26" />
                                        </Grid.RowDefinitions>

                                        <!--  Hue  -->
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Foreground="#666666"
                                                   Text="H"
                                                   VerticalAlignment="Center" />
                                        <Grid Grid.Row="0"
                                              Grid.Column="1"
                                              Margin="4,0">
                                            <Border Background="{Binding HueTrackBrush, RelativeSource={RelativeSource TemplatedParent}}"
                                                    VerticalAlignment="Center"
                                                    Height="10"
                                                    CornerRadius="2" />
                                            <Slider x:Name="PART_HueSlider"
                                                    Style="{StaticResource WWColorPicker_HsvSlider_Style}"
                                                    Minimum="0"
                                                    Maximum="360"
                                                    SmallChange="1"
                                                    LargeChange="10"
                                                    Value="{Binding Hue, RelativeSource={RelativeSource TemplatedParent}}" />
                                        </Grid>
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="2"
                                                   Foreground="#666666"
                                                   Text="{Binding Hue, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0:0}}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontSize="11" />

                                        <!--  Saturation  -->
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Foreground="#666666"
                                                   Text="S"
                                                   VerticalAlignment="Center" />
                                        <Grid Grid.Row="1"
                                              Grid.Column="1"
                                              Margin="4,0">
                                            <Border Background="{Binding SaturationTrackBrush, RelativeSource={RelativeSource TemplatedParent}}"
                                                    VerticalAlignment="Center"
                                                    Height="10"
                                                    CornerRadius="2" />
                                            <Slider x:Name="PART_SaturationSlider"
                                                    Style="{StaticResource WWColorPicker_HsvSlider_Style}"
                                                    Minimum="0"
                                                    Maximum="100"
                                                    SmallChange="1"
                                                    LargeChange="10"
                                                    Value="{Binding Saturation, RelativeSource={RelativeSource TemplatedParent}}" />
                                        </Grid>
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="2"
                                                   Foreground="#666666"
                                                   Text="{Binding Saturation, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0:0}}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontSize="11" />

                                        <!--  Brightness  -->
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="0"
                                                   Foreground="#666666"
                                                   Text="B"
                                                   VerticalAlignment="Center" />
                                        <Grid Grid.Row="2"
                                              Grid.Column="1"
                                              Margin="4,0">
                                            <Border Background="{Binding BrightnessTrackBrush, RelativeSource={RelativeSource TemplatedParent}}"
                                                    VerticalAlignment="Center"
                                                    Height="10"
                                                    CornerRadius="2" />
                                            <Slider x:Name="PART_BrightnessSlider"
                                                    Style="{StaticResource WWColorPicker_HsvSlider_Style}"
                                                    Minimum="0"
                                                    Maximum="100"
                                                    SmallChange="1"
                                                    LargeChange="10"
                                                    Value="{Binding Brightness, RelativeSource={RelativeSource TemplatedParent}}" />
                                        </Grid>
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="2"
                                                   Foreground="#666666"
                                                   Text="{Binding Brightness, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0:0}}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontSize="11" />
                                    </Grid>

                                    <!--  Preview + Hex Input  -->
                                    <Grid Margin="0,6,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="PART_PreviewBorder"
                                                Grid.Column="0"
                                                Background="{StaticResource WWColorPicker_CheckeredBrush}"
                                                BorderBrush="#CCCCCC"
                                                BorderThickness="1"
                                                Height="24"
                                                CornerRadius="4">
                                            <Rectangle RadiusX="4" RadiusY="4">
                                                <Rectangle.Fill>
                                                    <SolidColorBrush Color="{Binding SelectedColor, RelativeSource={RelativeSource TemplatedParent}}" />
                                                </Rectangle.Fill>
                                            </Rectangle>
                                        </Border>
                                        <TextBox x:Name="PART_HexTextBox"
                                                 Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.TextBox}}"
                                                 Grid.Column="2"
                                                 Text="{Binding HexText, RelativeSource={RelativeSource TemplatedParent}, UpdateSourceTrigger=LostFocus}"
                                                 VerticalAlignment="Center"
                                                 Height="24"
                                                 FontFamily="Consolas"
                                                 FontSize="12"
                                                 MaxLength="7" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="DisplayColorAndName" Value="True">
                            <Setter TargetName="ColorAndName" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ColorOnly" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#F5F5F5" />
                            <Setter Property="Foreground" Value="#999999" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.ColorPicker}}" TargetType="{x:Type sdg:WWColorPicker}" />

</ResourceDictionary>
