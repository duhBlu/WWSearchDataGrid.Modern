<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf"
                    xmlns:behaviors="clr-namespace:WWControls.Wpf.Behaviors;assembly=WWControls.Wpf.Grid">

    <!--
        Brings in the Sdg.* brush palette these styles reference. Mirrors the merge
        pattern used by every other themed control file in this project.
    -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Primitives/DefaultControls.xaml" />
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Editors/EditorParts.xaml" />
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Editors/Calendar.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        ═══════════════════════════════════════════════════════════════════════
        EditSettings — Default Display & Edit Element Styles
        ═══════════════════════════════════════════════════════════════════════
        Each editor type (Text / ComboBox / Spin / Date / CheckBox) builds its
        display template (and sub-elements like the spin / combo / date drop-down
        buttons) via FrameworkElementFactory and applies one of these styles by
        ComponentResourceKey lookup against EditorThemeKeys; the edit templates
        host the WWxxxEdit controls, whose chrome is owned by WWEditorBase. Consumers
        override at three levels:

        1. Per-column DisplayStyle DP on the EditSettings instance
        — applied as a local Style value, beats the keyed default lookup.
        2. App-level keyed override — redefine the Style under the same
        {x:Static sdg:EditorThemeKeys.X} key in App.xaml / Window.Resources.
        3. Full template replacement via EditTemplate / DisplayTemplate DPs —
        skips the default style and any per-control override.
        
        Keys are typed (ComponentResourceKey) — see EditorThemeKeys.cs. The
        assembly's [ThemeInfo] attribute lets FindResource walk into this Generic.xaml
        automatically, so consumers don't need to merge any dictionary just to get
        defaults.
        
        Color tokens (Sdg.Surface.*, Sdg.Border.*, Sdg.Accent, etc.) live in
        Themes/Primitives/DefaultControls.xaml.
    -->

    <!--#region Display element styles-->

    <!--
        Read-only TextBlock used inside display templates of Text / ComboBox / Spin /
        Date editors. Single inset, vertical centering, ellipsis on overflow.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.DisplayTextBlock}" TargetType="{x:Type TextBlock}">
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!--
        Right-aligned variant for numeric display. Spreadsheet convention: numbers
        line up at the decimal on the right edge so columns of money / counts read cleanly.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.DisplayNumericTextBlock}"
           BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.DisplayTextBlock}}"
           TargetType="{x:Type TextBlock}">
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="TextAlignment" Value="Right" />
    </Style>


    <!--#endregion-->

    <!--#region Edit element styles-->



    <!--
        Flat, borderless stock ComboBox — used by the filter row's combo editor
        (ComboBoxSettings.CreateFilterEditor) and available to consumer combos that should
        match the editors' flat look. WWComboBox's own self-contained
        template lives in WWComboBox.xaml.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.EditComboBox}" TargetType="{x:Type ComboBox}">
        <!--
            Scoped implicit ComboBoxItem style so the in-cell edit-mode dropdown picks up
            the unified dropdown-row look — same hover / selection visuals as the rest of
            the library's popups. Matches the pattern PrimitivesComboBox uses.
        -->
        <Style.Resources>
            <Style TargetType="{x:Type ComboBoxItem}" BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.ComboBoxItem}}" />
        </Style.Resources>
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="BorderBrush" Value="#0078D4" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Border x:Name="MainBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--
                                The whole control acts as the open/close toggle. Custom inner template so
                                the ToggleButton itself contributes no chrome of its own.
                            -->
                            <ToggleButton x:Name="DropDownToggle"
                                          Grid.ColumnSpan="2"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" BorderThickness="0" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <!--
                                Selected-item display sits above the toggle, hit-test invisible so clicks
                                pass through to the toggle.
                            -->
                            <ContentPresenter Grid.Column="0"
                                              IsHitTestVisible="False"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}" />

                            <!--
                                Visual-only chevron — the actual popup toggle is the full-area
                                DropDownToggle stacked behind this. IsHitTestVisible=False keeps
                                clicks routed to that toggle. IsChecked tracks IsDropDownOpen so
                                the button's checked-state visuals (if the style adds any) reflect
                                popup state. Style supplies glyph + font; Foreground TemplateBinding
                                keeps the chevron in sync with ComboBox.Foreground.
                            -->
                            <ToggleButton x:Name="Chevron"
                                          Style="{StaticResource {x:Static sdg:EditorThemeKeys.EditComboBoxDropDownButton}}"
                                          Grid.Column="1"
                                          Foreground="{TemplateBinding Foreground}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          IsHitTestVisible="False" />

                            <Popup x:Name="PART_Popup"
                                   Grid.ColumnSpan="2"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Focusable="False"
                                   Placement="Bottom"
                                   PopupAnimation="None">
                                <Border Background="#FFFFFF"
                                        BorderBrush="#CCCCCC"
                                        BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer>
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#E8E8E8" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Calendar dropdown ToggleButton for DatePickerSettings. Used in BOTH surfaces:
        — SegmentedDateTimeEditor's edit-mode template (functional, opens the popup);
        — DatePickerSettings.CreateDisplayTemplate (visual-only ShowAlways indicator).
        The calendar glyph lives inside this template so overriding the key once retheme both
        surfaces — consumers don't need to touch C# or a parallel display-only key.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.EditDateDropDownButton}" TargetType="{x:Type ToggleButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Foreground" Value="{x:Static SystemColors.ControlTextBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="MainBorder"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <sdg:Icon IconSource="{StaticResource {x:Static sdg:IconKeys.IconCalendar}}"
                                     Width="14"
                                     Height="14"
                                     IconBrush="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#E8E8E8" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#DCDCDC" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#E8E8E8" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>



    <!--#endregion-->

    <!--#region SegmentedDateTimeEditor-->

    <!--
        Footer Buttons (Today / Clear) in the date editor's popup. Visibility is driven from code
        (ShowTodayButton / ShowClearButton + AllowNullInput); this key owns only the look.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.DatePickerPopupButton}" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#0066AA" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,3" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="MainBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#E8E8E8" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#DCDCDC" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Text-only SegmentedDateTimeEditor — the nested time-of-day editor inside the calendar
        popup. Just the masked TextBox: no dropdown button, no popup, no calendar. Besides being
        the right chrome for an inline time field, the missing popup is what keeps the default
        template below from recursing (a SegmentedDateTimeEditor whose template contains a
        SegmentedDateTimeEditor with the same template would instantiate forever).
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.SegmentedTimeEditor}" TargetType="{x:Type sdg:SegmentedDateTimeEditor}">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:SegmentedDateTimeEditor}">
                    <Border Background="#FFFFFF"
                            BorderBrush="#CCCCCC"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="4,2"
                            SnapsToDevicePixels="True">
                        <TextBox x:Name="PART_TextBox"
                                 Style="{StaticResource {x:Static sdg:EditorThemeKeys.EditTextBox}}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type sdg:SegmentedDateTimeEditor}">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:SegmentedDateTimeEditor}">
                    <!-- Always flat: the segmented editor draws no border of its own. Hosted in
                         WWDatePicker the chrome draws the border (cell / edit form); in the filter row
                         it renders edge-to-edge. -->
                    <Border SnapsToDevicePixels="True">
                        <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="PART_TextBox"
                                 Style="{StaticResource {x:Static sdg:EditorThemeKeys.EditTextBox}}" />

                        <!--
                            Calendar glyph is provided by EditDateDropDownButton's ControlTemplate
                            so the same icon appears in DatePickerSettings's display-mode ShowAlways
                            indicator without a parallel definition. Override that one style key
                            to retheme the button + icon in both surfaces.
                        -->
                        <ToggleButton x:Name="PART_DropDownButton"
                                      Style="{StaticResource {x:Static sdg:EditorThemeKeys.EditDateDropDownButton}}"
                                      Grid.Column="1"
                                      Width="22" />

                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               IsOpen="{Binding IsChecked, ElementName=PART_DropDownButton, Mode=TwoWay}"
                               PlacementTarget="{Binding ElementName=PART_DropDownButton}"
                               Placement="Bottom"
                               StaysOpen="False"
                               PopupAnimation="None">
                            <Border Background="#FFFFFF"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True">
                                <DockPanel Margin="4">
                                    <!-- Shared footer: Today / Clear. Both start collapsed; code
                                         shows them per ShowTodayButton / ShowClearButton (+
                                         AllowNullInput for Clear). -->
                                    <StackPanel x:Name="FooterPanel"
                                                DockPanel.Dock="Bottom"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Margin="0,4,0,0">
                                        <Button x:Name="PART_TodayButton"
                                                Style="{StaticResource {x:Static sdg:EditorThemeKeys.DatePickerPopupButton}}"
                                                Content="Today"
                                                Visibility="Collapsed"
                                                Margin="0,0,4,0" />
                                        <Button x:Name="PART_NowButton"
                                                Style="{StaticResource {x:Static sdg:EditorThemeKeys.DatePickerPopupButton}}"
                                                Content="Now"
                                                Visibility="Collapsed"
                                                Margin="0,0,4,0" />
                                        <Button x:Name="PART_ClearButton"
                                                Style="{StaticResource {x:Static sdg:EditorThemeKeys.DatePickerPopupButton}}"
                                                Content="Clear"
                                                Visibility="Collapsed" />
                                    </StackPanel>

                                    <Grid>
                                        <!-- Calendar surface: optional week-number strip + month
                                             view + optional time row. -->
                                        <StackPanel x:Name="CalendarHost">
                                            <Grid x:Name="CalendarRow">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Canvas x:Name="PART_WeekNumbers"
                                                        Width="20"
                                                        Visibility="Collapsed"
                                                        ClipToBounds="False" />
                                                <Calendar x:Name="PART_Calendar"
                                                          Grid.Column="1"
                                                          Style="{StaticResource {x:Static sdg:EditorThemeKeys.Calendar}}"
                                                          sdg:CalendarDecorations.DisableWeekends="{Binding DisableWeekends, RelativeSource={RelativeSource TemplatedParent}}"
                                                          sdg:CalendarDecorations.HighlightHolidays="{Binding HighlightHolidays, RelativeSource={RelativeSource TemplatedParent}}"
                                                          DisplayDateStart="{Binding MinDate, RelativeSource={RelativeSource TemplatedParent}}"
                                                          DisplayDateEnd="{Binding MaxDate, RelativeSource={RelativeSource TemplatedParent}}" />
                                            </Grid>
                                            <!-- Time-of-day row: a text-only segmented editor whose
                                                 mask/value wiring lives in code. -->
                                            <DockPanel x:Name="TimeRow"
                                                       Margin="4,2,4,2"
                                                       Visibility="Collapsed">
                                                <TextBlock Text="Time:"
                                                           DockPanel.Dock="Left"
                                                           VerticalAlignment="Center"
                                                           Foreground="#666666"
                                                           Margin="0,0,6,0" />
                                                <sdg:SegmentedDateTimeEditor x:Name="PART_TimeEditor"
                                                                             Style="{StaticResource {x:Static sdg:EditorThemeKeys.SegmentedTimeEditor}}" />
                                            </DockPanel>
                                        </StackPanel>

                                        <!-- Scroll-list surface: looping month / day / year (+ time)
                                             columns. Column configuration comes from code. -->
                                        <sdg:DateTimeScrollPicker x:Name="PART_ScrollPicker"
                                                                  Visibility="Collapsed"
                                                                  Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                                  MinDate="{Binding MinDate, RelativeSource={RelativeSource TemplatedParent}}"
                                                                  MaxDate="{Binding MaxDate, RelativeSource={RelativeSource TemplatedParent}}"
                                                                  DisableWeekends="{Binding DisableWeekends, RelativeSource={RelativeSource TemplatedParent}}"
                                                                  DefaultDate="{Binding DefaultDate, RelativeSource={RelativeSource TemplatedParent}}" />
                                    </Grid>
                                </DockPanel>
                            </Border>
                        </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Scroll-list mode swaps the popup surface. -->
                        <Trigger Property="PopupMode" Value="ScrollList">
                            <Setter TargetName="CalendarHost" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_ScrollPicker" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!-- Calendar mode with time editing: show the time row under the month view. -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="PopupMode" Value="Calendar" />
                                <Condition Property="IsTimeEditingEnabled" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TimeRow" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <!-- Time-only mask: the calendar row is meaningless; the popup is just the
                             time surface. -->
                        <Trigger Property="HasDateParts" Value="False">
                            <Setter TargetName="CalendarRow" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="ShowWeekNumbers" Value="True">
                            <Setter TargetName="PART_WeekNumbers" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

    <!--#region DateTimeScrollPicker-->

    <Style TargetType="{x:Type sdg:DateTimeScrollPicker}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:DateTimeScrollPicker}">
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <sdg:WWLoopingSelector x:Name="PART_MonthSelector"
                                               Height="120" ItemHeight="24" Margin="2,0" />
                        <sdg:WWLoopingSelector x:Name="PART_DaySelector"
                                               Height="120" ItemHeight="24" MinWidth="34" Margin="2,0" />
                        <sdg:WWLoopingSelector x:Name="PART_YearSelector"
                                               Height="120" ItemHeight="24" Margin="2,0" />
                        <Border x:Name="TimeSeparator" Width="1" Background="#DDDDDD" Margin="4,8" />
                        <sdg:WWLoopingSelector x:Name="PART_HourSelector"
                                               Height="120" ItemHeight="24" MinWidth="30" Margin="2,0" />
                        <sdg:WWLoopingSelector x:Name="PART_MinuteSelector"
                                               Height="120" ItemHeight="24" MinWidth="30" Margin="2,0" />
                        <sdg:WWLoopingSelector x:Name="PART_AmPmSelector"
                                               Height="120" ItemHeight="24" Margin="2,0" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowDate" Value="False">
                            <Setter TargetName="PART_MonthSelector" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_DaySelector" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_YearSelector" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="TimeSeparator" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="ShowTime" Value="False">
                            <Setter TargetName="TimeSeparator" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_HourSelector" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_MinuteSelector" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_AmPmSelector" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Is24Hour" Value="True">
                            <Setter TargetName="PART_AmPmSelector" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

</ResourceDictionary>
