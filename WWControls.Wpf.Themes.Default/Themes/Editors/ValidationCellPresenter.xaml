<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <!--
        ValidationCellPresenter — the layout of a validated editing surface.

        A DockPanel keeps the error badge in a left gutter and lets the real content
        (Content / ContentTemplate, supplied per column by the grid or per row by the property
        grid) fill the rest, so the badge never overlaps the text. When the badge is collapsed
        (no error) it takes no space and the content sits flush left. Retemplate this key to change
        that arrangement — e.g. move the badge to the right, or reserve a fixed-width gutter.

        Lives in the Editors theme slice (keyed off EditorThemeKeys) so both editing hosts — the
        SearchDataGrid and the WWPropertyGrid — share one presenter.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.ValidationCellPresenter}" TargetType="{x:Type sdg:ValidationCellPresenter}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Validation.ErrorTemplate" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:ValidationCellPresenter}">
                    <DockPanel LastChildFill="True">
                        <sdg:ValidationErrorIcon DockPanel.Dock="Left"
                                                 Margin="2,0,4,0"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Center"
                                                 Validation.ErrorTemplate="{x:Null}"
                                                 Item="{Binding ValidatedItem, RelativeSource={RelativeSource TemplatedParent}}"
                                                 PropertyName="{Binding PropertyName, RelativeSource={RelativeSource TemplatedParent}}"
                                                 IsValidationEnabled="{Binding IsValidationEnabled, RelativeSource={RelativeSource TemplatedParent}}"
                                                 OverrideErrorMessage="{Binding EditorErrorMessage, RelativeSource={RelativeSource TemplatedParent}}" />
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </DockPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.ValidationCellPresenter}}" TargetType="{x:Type sdg:ValidationCellPresenter}" />

</ResourceDictionary>
