<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <!--
        ═══════════════════════════════════════════════════════════════════════
        Editors — each editor owns its own chrome
        ═══════════════════════════════════════════════════════════════════════
        Every editor control carries its own default style + control template: a border
        (drawn per ShowBorder, an accent edge on focus), background, padding, disabled
        visual, and the named parts that host its input (PART_TextBox, PART_ComboBox,
        PART_Editor, PART_CheckBox, plus the spinner's PART_UpButton / PART_DownButton).

        Each style is keyed (EditorThemeKeys.TextEdit / SpinEdit / ComboEdit / DateEdit /
        CheckEdit) so a consumer can retheme one editor by that key; a paired implicit style
        (grouped at the bottom of this file) is what each control's DefaultStyleKey resolves.

        Border policy:
        — Bordered by default (standalone use, the edit form).
        — Flat in a grid cell: the control clears ShowBorder when it detects a DataGridCell
          ancestor; the filter row sets ShowBorder=false explicitly.
        — A 1px #CCCCCC edge when ShowBorder is true, gaining an accent #0078D4 edge on focus.
    -->

    <!--
        WWTextEdit — the text editor's own chrome: border (drawn per ShowBorder, an accent edge on
        focus), background, padding, disabled visual, hosting the inner PART_TextBox. Flat inside a
        grid cell (the control clears ShowBorder there), bordered on a form / standalone.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.TextEdit}" TargetType="{x:Type sdg:WWTextEdit}">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="BorderBrush" Value="#CCCCCC" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:WWTextEdit}">
                    <Border x:Name="ChromeBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            SnapsToDevicePixels="True">
                        <TextBox x:Name="PART_TextBox"
                                 Margin="{TemplateBinding Padding}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="0"
                                 Foreground="{TemplateBinding Foreground}"
                                 VerticalContentAlignment="Center"
                                 VerticalAlignment="Stretch"
                                 IsReadOnly="{TemplateBinding IsReadOnly}"
                                 TextAlignment="{TemplateBinding TextAlignment}"
                                 Text="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowBorder" Value="True">
                            <Setter TargetName="ChromeBorder" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ShowBorder" Value="True" />
                                <Condition Property="IsKeyboardFocusWithin" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="ChromeBorder" Property="BorderBrush" Value="#0078D4" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ChromeBorder" Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        WWSpinEdit — its own chrome hosting a right-aligned PART_TextBox and a two-row spinner column
        (PART_UpButton / PART_DownButton). The button glyph + SpinButton style are applied in code
        (WWSpinEdit.OnApplyTemplate); Click / increment / clamp logic lives on the control.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.SpinEdit}" TargetType="{x:Type sdg:WWSpinEdit}">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="BorderBrush" Value="#CCCCCC" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:WWSpinEdit}">
                    <Border x:Name="ChromeBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="PART_TextBox"
                                     Grid.Column="0"
                                     Margin="{TemplateBinding Padding}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="0"
                                     Foreground="{TemplateBinding Foreground}"
                                     TextAlignment="Right"
                                     VerticalContentAlignment="Center"
                                     VerticalAlignment="Stretch"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"
                                     Text="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <RepeatButton x:Name="PART_UpButton" Grid.Row="0" Focusable="False" />
                                <RepeatButton x:Name="PART_DownButton" Grid.Row="1" Focusable="False" />
                            </Grid>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowBorder" Value="True">
                            <Setter TargetName="ChromeBorder" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ShowBorder" Value="True" />
                                <Condition Property="IsKeyboardFocusWithin" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="ChromeBorder" Property="BorderBrush" Value="#0078D4" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ChromeBorder" Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        WWComboEdit — its own chrome hosting the flat inner PART_ComboBox. The combo forwards its
        essentials (items, selection, drop-down state) via TemplateBindings; its flat look
        (chevron / popup / item container) is applied from EditComboBox in code
        (WWComboEdit.OnApplyTemplate), so it stays borderless and this chrome draws the border.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.ComboEdit}" TargetType="{x:Type sdg:WWComboEdit}">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="BorderBrush" Value="#CCCCCC" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:WWComboEdit}">
                    <Border x:Name="ChromeBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            SnapsToDevicePixels="True">
                        <ComboBox x:Name="PART_ComboBox"
                                  Margin="{TemplateBinding Padding}"
                                  Background="Transparent"
                                  VerticalContentAlignment="Center"
                                  HorizontalContentAlignment="Left"
                                  ItemsSource="{TemplateBinding ItemsSource}"
                                  SelectedValuePath="{TemplateBinding SelectedValuePath}"
                                  IsEditable="{TemplateBinding IsEditable}"
                                  SelectedValue="{Binding SelectedValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                  SelectedItem="{Binding SelectedItem, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                  IsDropDownOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowBorder" Value="True">
                            <Setter TargetName="ChromeBorder" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ShowBorder" Value="True" />
                                <Condition Property="IsKeyboardFocusWithin" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="ChromeBorder" Property="BorderBrush" Value="#0078D4" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ChromeBorder" Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        WWDateEdit — its own chrome hosting the segmented date editor (PART_Editor). Forwards the
        date essentials via TemplateBindings; the segmented editor renders flat, so this chrome
        draws the border.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.DateEdit}" TargetType="{x:Type sdg:WWDateEdit}">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="BorderBrush" Value="#CCCCCC" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:WWDateEdit}">
                    <Border x:Name="ChromeBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            SnapsToDevicePixels="True">
                        <sdg:SegmentedDateTimeEditor x:Name="PART_Editor"
                                                     Margin="{TemplateBinding Padding}"
                                                     Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                     Mask="{TemplateBinding Mask}"
                                                     MaskType="{TemplateBinding MaskType}"
                                                     MinDate="{TemplateBinding MinDate}"
                                                     MaxDate="{TemplateBinding MaxDate}"
                                                     TextAlignment="{TemplateBinding TextAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowBorder" Value="True">
                            <Setter TargetName="ChromeBorder" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ShowBorder" Value="True" />
                                <Condition Property="IsKeyboardFocusWithin" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="ChromeBorder" Property="BorderBrush" Value="#0078D4" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ChromeBorder" Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        WWCheckEdit — a glyph, not a bordered input: transparent background so the cell's own
        fill / selection shows through, no border. Hosts PART_CheckBox, whose themed look
        (box + check/indeterminate glyphs + the DataGridCell read-only gate) comes from
        DisplayCheckBox, applied in code (WWCheckEdit.OnApplyTemplate).
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.CheckEdit}" TargetType="{x:Type sdg:WWCheckEdit}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:WWCheckEdit}">
                    <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                        <CheckBox x:Name="PART_CheckBox"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsThreeState="{TemplateBinding IsThreeState}"
                                  IsChecked="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Implicit default styles — each editor's DefaultStyleKey (typeof the control) resolves the
        matching implicit style below, which BasedOn's the keyed definition above. Overriding the
        keyed style reskins the editor; the implicit style is only the DefaultStyleKey seam.
    -->
    <Style TargetType="{x:Type sdg:WWTextEdit}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.TextEdit}}" />
    <Style TargetType="{x:Type sdg:WWSpinEdit}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.SpinEdit}}" />
    <Style TargetType="{x:Type sdg:WWComboEdit}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.ComboEdit}}" />
    <Style TargetType="{x:Type sdg:WWDateEdit}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.DateEdit}}" />
    <Style TargetType="{x:Type sdg:WWCheckEdit}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.CheckEdit}}" />

</ResourceDictionary>
