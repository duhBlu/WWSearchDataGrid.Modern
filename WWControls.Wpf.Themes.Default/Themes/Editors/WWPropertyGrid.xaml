<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <!--  Self-merged dependencies — DefaultControls brings the shared palette, the Icon primitive,
          the themed ScrollBar, and the plain TextBox style the search box rides on. StaticResource
          inside deferred template content only resolves reliably within this dictionary's own merge
          chain (see WWTextBox.xaml).  -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Primitives/DefaultControls.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <BooleanToVisibilityConverter x:Key="WWPropertyGrid_BoolToVis" />

    <!--  Returns the editor the grid resolved onto each WWPropertyItem: a custom template, else the
          settings-built editor, else the placeholder below.  -->
    <sdg:WWPropertyGridEditorSelector x:Key="WWPropertyGrid_EditorSelector" />

    <!--
        ═══════════════════════════════════════════════════════════════════════════════════════════
        PLACEHOLDER EDITOR  (fallback for a property whose CLR type has no built-in editor)
        ═══════════════════════════════════════════════════════════════════════════════════════════
        WWPropertyGrid resolves a typed editor for the common CLR types (string, bool, enum, numeric,
        DateTime) and honors per-property WWPropertyDefinition.EditSettings / EditTemplate. Only a
        property whose type has no natural editor (a complex object, Guid, …) and no custom definition
        lands here — a read-only display of the value.
    -->
    <DataTemplate x:Key="WWPropertyGrid_PlaceholderEditor">
        <TextBlock Text="{Binding Value, Mode=OneWay}"
                   Padding="6,2"
                   VerticalAlignment="Center"
                   Foreground="#1C1C1C"
                   TextTrimming="CharacterEllipsis"
                   ToolTip="No built-in editor for this type — supply one via PropertyDefinitions." />
    </DataTemplate>

    <!--
        ═══════════════════════════════════════════════════════════════════════════════════════════
        CATEGORY EXPANDER  (one per group)
        ═══════════════════════════════════════════════════════════════════════════════════════════
    -->
    <Style x:Key="WWPropertyGrid_CategoryExpander_Style" TargetType="{x:Type Expander}">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="IsExpanded" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Expander}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  Category header  -->
                        <Border x:Name="Header" Background="#F0F0F0" Padding="0,2">
                            <ToggleButton OverridesDefaultStyle="True"
                                          Padding="4"
                                          IsChecked="{Binding Path=IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          VerticalAlignment="Center">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Grid Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <sdg:Icon x:Name="Arrow"
                                                      Grid.Column="0"
                                                      IconBrush="#1C1C1C"
                                                      IconSource="{StaticResource {x:Static sdg:IconKeys.IconCaretRight}}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Width="5"
                                                      Height="5" />
                                            <ContentPresenter Grid.Column="1"
                                                              RecognizesAccessKey="True"
                                                              TextElement.FontWeight="Bold"
                                                              TextElement.Foreground="#1C1C1C" />
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="IconSource" Value="{StaticResource {x:Static sdg:IconKeys.IconCaretDown}}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter ContentSource="Header" />
                            </ToggleButton>
                        </Border>

                        <!--  Category content  -->
                        <Border x:Name="Content"
                                Grid.Row="1"
                                Background="#FFFFFF"
                                Visibility="Collapsed"
                                Padding="0,2,0,4">
                            <ContentPresenter Focusable="False" />
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="Content" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger SourceName="Header" Property="IsMouseOver" Value="True">
                            <Setter TargetName="Header" Property="Background" Value="#E8E8E8" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Wraps each category group in the expander above.  -->
    <Style x:Key="WWPropertyGrid_GroupItemStyle" TargetType="{x:Type GroupItem}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type GroupItem}">
                    <Expander Style="{StaticResource WWPropertyGrid_CategoryExpander_Style}"
                              Header="{Binding Name}"
                              IsExpanded="True">
                        <ItemsPresenter />
                    </Expander>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════════════════════════════════════
        PROPERTY ROW  (Name | Editor)
        ═══════════════════════════════════════════════════════════════════════════════════════════
    -->
    <DataTemplate x:Key="WWPropertyGrid_ItemTemplate">
        <Grid x:Name="Root" Background="Transparent" Cursor="Hand" Margin="2,0,2,2">
            <Grid.InputBindings>
                <MouseBinding Command="{x:Static sdg:WWPropertyGridCommands.SelectItemCommand}"
                              CommandParameter="{Binding}"
                              MouseAction="LeftClick" />
            </Grid.InputBindings>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding NameColumnWidth, RelativeSource={RelativeSource AncestorType={x:Type sdg:WWPropertyGrid}}}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!--  Row 0 hosts both header and editor in the default Left layout; row 1 is used only by
                  the Top layout (editor stacked below the header). See the HeaderShowMode triggers.  -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Name  -->
            <Border x:Name="NameBorder"
                    Grid.Column="0"
                    Grid.Row="0"
                    Background="#FAFAFA"
                    BorderBrush="#E3E3E3"
                    BorderThickness="1,1,0,1"
                    MinHeight="22">
                <TextBlock Text="{Binding DisplayName}"
                           Padding="8,2"
                           VerticalAlignment="Center"
                           Foreground="#1C1C1C"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Description}" />
            </Border>

            <!--  Editor — wrapped in a ValidationCellPresenter so a data-annotation / INotifyDataErrorInfo
                  error surfaces as a badge in the left gutter (the same presenter the SearchDataGrid uses).
                  ValidatedItem is the edited model (Source), which is what carries the attributes; the
                  presenter's own DataContext stays the property item so the editor selector and metadata
                  bindings resolve normally.  -->
            <Border x:Name="EditorBorder"
                    Grid.Column="1"
                    Grid.Row="0"
                    Background="#FFFFFF"
                    BorderBrush="#E3E3E3"
                    BorderThickness="1"
                    MinHeight="22"
                    sdg:WWEditorBase.FlattenEditors="True">
                <Border.Style>
                    <!--  A read-only property presents a non-interactive editor. The value binding runs
                          two-way straight to the model, so disabling the editor host is what enforces
                          read-only across every editor type and custom template alike. Applied to the
                          border (not the validation presenter) so the error badge stays crisp.  -->
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                <Setter Property="IsEnabled" Value="False" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <sdg:ValidationCellPresenter Focusable="False"
                                             VerticalAlignment="Stretch"
                                             Content="{Binding}"
                                             ContentTemplateSelector="{StaticResource WWPropertyGrid_EditorSelector}"
                                             ValidatedItem="{Binding Source}"
                                             PropertyName="{Binding PropertyName}"
                                             IsValidationEnabled="{Binding ActualShowValidationErrors}"
                                             IsTabStop="False" />
            </Border>
        </Grid>

        <DataTemplate.Triggers>
            <!--  Header layout — Left is the default (no trigger). The name column width still comes
                  from the shared NameColumnWidth; the non-Left modes just span both columns.  -->

            <!--  Top: header above the editor, each spanning the full row width.  -->
            <DataTrigger Binding="{Binding ActualHeaderShowMode}" Value="{x:Static sdg:PropertyHeaderShowMode.Top}">
                <Setter TargetName="NameBorder" Property="Grid.ColumnSpan" Value="2" />
                <Setter TargetName="NameBorder" Property="BorderThickness" Value="1,1,1,0" />
                <Setter TargetName="EditorBorder" Property="Grid.Row" Value="1" />
                <Setter TargetName="EditorBorder" Property="Grid.Column" Value="0" />
                <Setter TargetName="EditorBorder" Property="Grid.ColumnSpan" Value="2" />
            </DataTrigger>

            <!--  Hidden: header removed, editor takes the full row width.  -->
            <DataTrigger Binding="{Binding ActualHeaderShowMode}" Value="{x:Static sdg:PropertyHeaderShowMode.Hidden}">
                <Setter TargetName="NameBorder" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="EditorBorder" Property="Grid.Column" Value="0" />
                <Setter TargetName="EditorBorder" Property="Grid.ColumnSpan" Value="2" />
            </DataTrigger>

            <!--  OnlyHeader: editor removed, header takes the full row width (a caption row).  -->
            <DataTrigger Binding="{Binding ActualHeaderShowMode}" Value="{x:Static sdg:PropertyHeaderShowMode.OnlyHeader}">
                <Setter TargetName="EditorBorder" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="NameBorder" Property="Grid.ColumnSpan" Value="2" />
                <Setter TargetName="NameBorder" Property="BorderThickness" Value="1" />
            </DataTrigger>

            <!--  Hover  -->
            <DataTrigger Binding="{Binding IsMouseOver, ElementName=NameBorder}" Value="True">
                <Setter TargetName="NameBorder" Property="Background" Value="#F0F0F0" />
                <Setter TargetName="NameBorder" Property="BorderBrush" Value="#D6D6D6" />
                <Setter TargetName="EditorBorder" Property="BorderBrush" Value="#D6D6D6" />
            </DataTrigger>
            <DataTrigger Binding="{Binding IsMouseOver, ElementName=EditorBorder}" Value="True">
                <Setter TargetName="NameBorder" Property="Background" Value="#F0F0F0" />
                <Setter TargetName="NameBorder" Property="BorderBrush" Value="#D6D6D6" />
                <Setter TargetName="EditorBorder" Property="BorderBrush" Value="#D6D6D6" />
            </DataTrigger>

            <!--  Selected  -->
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter TargetName="NameBorder" Property="Background" Value="#E5F1FB" />
                <Setter TargetName="NameBorder" Property="BorderBrush" Value="#0078D4" />
                <Setter TargetName="EditorBorder" Property="BorderBrush" Value="#0078D4" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!--
        ═══════════════════════════════════════════════════════════════════════════════════════════
        MAIN CONTROL STYLE
        ═══════════════════════════════════════════════════════════════════════════════════════════
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.PropertyGrid}" TargetType="{x:Type sdg:WWPropertyGrid}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="#E3E3E3" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:WWPropertyGrid}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid Background="#FAFAFA" TextElement.Foreground="#1C1C1C">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" MinHeight="40" />
                            </Grid.RowDefinitions>

                            <!--  Title (hidden by default)  -->
                            <Border Grid.Row="0"
                                    Background="#F0F0F0"
                                    Padding="6,4"
                                    Visibility="{Binding ShowTitle, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource WWPropertyGrid_BoolToVis}}">
                                <TextBlock Text="{Binding SelectedObject.GetType.Name, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=''}"
                                           FontWeight="Bold"
                                           Foreground="#1C1C1C" />
                            </Border>

                            <!--  Search box  -->
                            <Grid Grid.Row="1"
                                  Margin="4,4,4,2"
                                  Visibility="{Binding ShowSearchBox, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource WWPropertyGrid_BoolToVis}}">
                                <!--  WWTextBox supplies the watermark and clear button directly, so the
                                      separate overlay TextBlock is no longer needed.  -->
                                <sdg:WWTextBox x:Name="PART_FilterBox"
                                               Watermark="Search properties..."
                                               ShowClearButton="True"
                                               Value="{Binding FilterText, RelativeSource={RelativeSource TemplatedParent}, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <!--  Property list  -->
                            <ScrollViewer Grid.Row="2"
                                          Padding="0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl Background="#FFFFFF"
                                              Focusable="False"
                                              ItemsSource="{Binding PropertyItems, RelativeSource={RelativeSource TemplatedParent}}"
                                              ItemTemplate="{StaticResource WWPropertyGrid_ItemTemplate}"
                                              IsTabStop="False"
                                              VirtualizingStackPanel.IsVirtualizing="True"
                                              VirtualizingStackPanel.VirtualizationMode="Recycling">
                                    <ItemsControl.GroupStyle>
                                        <GroupStyle ContainerStyle="{StaticResource WWPropertyGrid_GroupItemStyle}" />
                                    </ItemsControl.GroupStyle>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </ScrollViewer>

                            <!--  Shared name/editor column splitter — only meaningful for the Left
                                  layout, so it hides when the grid default is a non-Left mode.  -->
                            <Thumb x:Name="PART_ColumnSplitter"
                                   Grid.Row="2"
                                   Background="Transparent"
                                   Focusable="False"
                                   Cursor="SizeWE"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Stretch"
                                   Width="6">
                                <Thumb.Style>
                                    <Style TargetType="Thumb">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HeaderShowMode, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Static sdg:PropertyHeaderShowMode.Top}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HeaderShowMode, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Static sdg:PropertyHeaderShowMode.Hidden}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HeaderShowMode, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Static sdg:PropertyHeaderShowMode.OnlyHeader}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Thumb.Style>
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>

                            <!--  Description splitter  -->
                            <GridSplitter Grid.Row="3"
                                          Background="#E3E3E3"
                                          Cursor="SizeNS"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center"
                                          Height="4"
                                          ResizeDirection="Rows"
                                          ResizeBehavior="PreviousAndNext" />

                            <!--  Description panel — collapses when nothing is selected  -->
                            <Border Grid.Row="4"
                                    Background="#FFFFFF"
                                    BorderBrush="#E3E3E3"
                                    BorderThickness="0,1,0,0"
                                    Padding="6,4"
                                    MinHeight="40">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPropertyItem, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedPropertyItem.DisplayName, RelativeSource={RelativeSource TemplatedParent}}"
                                               FontWeight="Bold"
                                               Foreground="#1C1C1C"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding SelectedPropertyItem.Description, RelativeSource={RelativeSource TemplatedParent}}"
                                               Foreground="#666666"
                                               Margin="0,2,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type sdg:WWPropertyGrid}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.PropertyGrid}}" />

</ResourceDictionary>
