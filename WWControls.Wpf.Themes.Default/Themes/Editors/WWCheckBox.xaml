<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <!--  Self-merged dependencies — StaticResource inside deferred template content only
          resolves reliably within this dictionary's own merge chain (see EditSettings.xaml).  -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Editors/EditorParts.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        WWCheckBox — a glyph, not a bordered input: transparent background so the cell's own
        fill / selection shows through, no border. PART_CheckBox takes its themed look (box +
        check/indeterminate glyphs + the read-only gate) from DisplayCheckBox, applied here in
        the template.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.CheckBox}" TargetType="{x:Type sdg:WWCheckBox}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:WWCheckBox}">
                    <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                        <CheckBox x:Name="PART_CheckBox"
                                  Style="{StaticResource {x:Static sdg:EditorThemeKeys.DisplayCheckBox}}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsThreeState="{TemplateBinding IsThreeState}"
                                  ClickMode="{TemplateBinding EffectiveClickMode}"
                                  IsChecked="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!--  Standalone read-only gate — DisplayCheckBox's own triggers only cover
                              DataGridCell / DataGrid ancestors.  -->
                        <Trigger Property="IsReadOnly" Value="True">
                            <Setter TargetName="PART_CheckBox" Property="IsHitTestVisible" Value="False" />
                            <Setter TargetName="PART_CheckBox" Property="Opacity" Value="0.8" />
                            <Setter TargetName="PART_CheckBox" Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type sdg:WWCheckBox}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.CheckBox}}" />

</ResourceDictionary>
