<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <!--  Self-merged dependencies — StaticResource inside deferred template content only
          resolves reliably within this dictionary's own merge chain (see EditSettings.xaml).  -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Primitives/DefaultControls.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        WWDatePicker — its own chrome hosting the segmented date editor (PART_Editor). Forwards the
        date essentials via TemplateBindings; the segmented editor renders flat, so this chrome
        draws the border.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.DatePicker}" TargetType="{x:Type sdg:WWDatePicker}">
        <Setter Property="sdg:ControlHelper.CornerRadius" Value="{StaticResource {x:Static sdg:PrimitiveThemeKeys.ControlCornerRadius}}" />
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="BorderBrush" Value="#e3e3e3" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:WWDatePicker}">
                    <Grid x:Name="Root" SnapsToDevicePixels="True">
                        <!--  Frame — top/left/right only; the bottom edge is the lip below.  -->
                        <Border x:Name="Frame"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                CornerRadius="{TemplateBinding sdg:ControlHelper.CornerRadius}" />

                        <sdg:SegmentedDateTimeEditor x:Name="PART_Editor"
                                                     Margin="{TemplateBinding Padding}"
                                                     Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                     Mask="{TemplateBinding Mask}"
                                                     MaskType="{TemplateBinding MaskType}"
                                                     MinDate="{TemplateBinding MinDate}"
                                                     MaxDate="{TemplateBinding MaxDate}"
                                                     TextAlignment="{TemplateBinding TextAlignment}"
                                                     CycleModifier="{TemplateBinding CycleModifier}"
                                                     AllowNullInput="{TemplateBinding AllowNullInput}"
                                                     DefaultDate="{TemplateBinding DefaultDate}"
                                                     PopupMode="{TemplateBinding PopupMode}"
                                                     TimeInput="{TemplateBinding TimeInput}"
                                                     ShowClearButton="{TemplateBinding ShowClearButton}"
                                                     ShowTodayButton="{TemplateBinding ShowTodayButton}"
                                                     ShowNowButton="{TemplateBinding ShowNowButton}"
                                                     ShowWeekNumbers="{TemplateBinding ShowWeekNumbers}"
                                                     DisableWeekends="{TemplateBinding DisableWeekends}"
                                                     HighlightHolidays="{TemplateBinding HighlightHolidays}"
                                                     DisplayFormat="{TemplateBinding DisplayFormat}"
                                                     UseMaskAsDisplayFormat="{TemplateBinding UseMaskAsDisplayFormat}" />

                        <!--  Bottom lip — depth cue that becomes the accent underline while focused.  -->
                        <Border x:Name="Lip"
                                Background="Transparent"
                                BorderBrush="#bfbfbf"
                                BorderThickness="0,0,0,1"
                                CornerRadius="0,0,4,4"
                                Height="2"
                                VerticalAlignment="Bottom"
                                IsHitTestVisible="False"
                                Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowBorder" Value="True">
                            <Setter TargetName="Frame" Property="BorderThickness" Value="1,1,1,0" />
                            <Setter TargetName="Lip" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ShowBorder" Value="True" />
                                <Condition Property="IsKeyboardFocusWithin" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Lip" Property="Background" Value="#0179D4" />
                            <Setter TargetName="Lip" Property="BorderBrush" Value="#0078D4" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type sdg:WWDatePicker}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.DatePicker}}" />

</ResourceDictionary>
