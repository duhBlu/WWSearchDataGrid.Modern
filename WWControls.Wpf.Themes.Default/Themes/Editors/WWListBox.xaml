<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Editors/EditorParts.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        WWListBoxItem — the container WWListBox generates for its rows. Same row language as
        WWComboBoxItem (padding 8,5 | radius 4 | hover #F0F0F0 | selected #E5F1FB) plus the
        parent-driven glyph column: a checkbox (Kind=Checked) or a radio dot (Kind=Radio), both
        lit by the row's own IsSelected. In the glyph kinds the glyph carries the selection
        state, so the row highlight stays reserved for Kind=Default.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.ListBoxItem}" TargetType="{x:Type sdg:WWListBoxItem}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:WWListBoxItem}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!--  Checkbox glyph (Kind=Checked) — mirrors DisplayCheckBox's box visual.  -->
                            <Border x:Name="CheckGlyphBox"
                                    Grid.Column="0"
                                    Width="16"
                                    Height="16"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Background="#FFFFFF"
                                    BorderBrush="#AAAAAA"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Visibility="Collapsed">
                                <sdg:Icon x:Name="CheckGlyph"
                                          Width="10"
                                          Height="10"
                                          Opacity="0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          StrokeThickness="3"
                                          IconSource="{StaticResource {x:Static sdg:IconKeys.IconCheck}}"
                                          IconBrush="White" />
                            </Border>

                            <!--  Radio glyph (Kind=Radio) — dot follows IsSelected.  -->
                            <Grid x:Name="RadioGlyph"
                                  Grid.Column="0"
                                  Width="16"
                                  Height="16"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  Visibility="Collapsed">
                                <Ellipse x:Name="RadioOuter" Fill="#FFFFFF" Stroke="#AAAAAA" StrokeThickness="1" />
                                <Ellipse x:Name="RadioDot" Width="6" Height="6" Fill="#0078D4" Opacity="0" />
                            </Grid>

                            <ContentPresenter Grid.Column="1"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Kind" Value="Checked">
                            <Setter TargetName="CheckGlyphBox" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Kind" Value="Radio">
                            <Setter TargetName="RadioGlyph" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="CheckGlyphBox" Property="Background" Value="#0078D4" />
                            <Setter TargetName="CheckGlyphBox" Property="BorderThickness" Value="0" />
                            <Setter TargetName="CheckGlyph" Property="Opacity" Value="1" />
                            <Setter TargetName="RadioDot" Property="Opacity" Value="1" />
                            <Setter TargetName="RadioOuter" Property="Stroke" Value="#0078D4" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#F0F0F0" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="Kind" Value="Default" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="#E5F1FB" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="Kind" Value="Default" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="#D6E8F8" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#9CA3AF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type sdg:WWListBoxItem}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.ListBoxItem}}" />

    <!--
        WWListBox — the platform ListBox template with WWListBoxItem containers (style above)
        and the built-in reorder defaults. Reordering is opt-in (AllowReorder); the engine
        itself lives in the control, not the template.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.ListBox}" TargetType="{x:Type sdg:WWListBox}" BasedOn="{StaticResource {x:Type ListBox}}">
        <Setter Property="ReorderAnimationDuration" Value="200" />
        <Setter Property="AdornerOpacity" Value="0.8" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#DEE2E6" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="2" />
    </Style>

    <Style TargetType="{x:Type sdg:WWListBox}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.ListBox}}" />

</ResourceDictionary>
