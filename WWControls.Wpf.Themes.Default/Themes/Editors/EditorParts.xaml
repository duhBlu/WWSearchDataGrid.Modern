<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <!--  Self-merged dependencies — StaticResource inside deferred template content only
          resolves reliably within this dictionary's own merge chain (see EditSettings.xaml).  -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Primitives/DefaultControls.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        Shared inner-part styles the editor templates reference via StaticResource — the flat
        inner TextBox, the spinner RepeatButton, the combo chevron, and the themed CheckBox.
        Merged BEFORE the per-editor dictionaries (and before EditSettings.xaml, whose
        SegmentedDateTimeEditor template also uses EditTextBox), so those StaticResource
        references always resolve. Each style is keyed on EditorThemeKeys for reskinning.
    -->
    <!--
        Flat inner text input hosted inside an editor's chrome (the segmented date editor's
        PART_TextBox). Always borderless — the editor control's own chrome draws the border,
        so this inner element never draws one of its own.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.EditTextBox}" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,2,4,2" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <!--
        Up/down RepeatButton used by the numeric editor's spinner column (and the spin display
        template). Content is rendered as a Segoe Fluent Icons glyph by the template.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.SpinButton}" TargetType="{x:Type RepeatButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="9" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border x:Name="MainBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <TextBlock Foreground="{TemplateBinding Foreground}"
                                   Text="{TemplateBinding Content}"
                                   IsHitTestVisible="False"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="8" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#E8E8E8" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#DCDCDC" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Chevron drop-down button — the visual caret inside the WWComboBox template, the flat
        EditComboBox template, and the display-mode ShowAlways indicator ComboBoxSettings stamps.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.EditComboBoxDropDownButton}" TargetType="{x:Type ToggleButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,0,9,0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="MainBorder"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <TextBlock Foreground="{TemplateBinding Foreground}"
                                   Text="&#xE70D;"
                                   IsHitTestVisible="False"
                                   Margin="{TemplateBinding Padding}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="10" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        CheckBox shown in checkbox cells (CheckBoxSettings — used as both the cell
        template and the editing template; see CheckBoxSettings.cs). Interactive:
        toggles on click via TwoWay binding without entering edit mode. Focusable=False
        keeps Tab navigation on the cell itself; SearchDataGrid handles Space/Enter on
        the cell to toggle the inner CheckBox.
        
        Read-only handling (block clicks, dim visually, swap cursor) lives in
        CheckBoxSettings.AttachReadOnlyGate. A Style.Triggers DataTrigger bound via
        RelativeSource AncestorType=DataGridCell never fires from a FrameworkElementFactory
        template — the binding silently fails to resolve through the cell's ContentPresenter
        boundary, so the gate is wired in code on Loaded with a DependencyPropertyDescriptor
        listening on DataGridCell.IsReadOnly.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.DisplayCheckBox}" TargetType="{x:Type CheckBox}">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="#AAAAAA" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="6,0,0,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="Box"
                                Grid.Column="0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                VerticalAlignment="Center"
                                Width="16"
                                Height="16"
                                CornerRadius="3">
                            <Grid>
                                <sdg:Icon x:Name="CheckGlyph"
                                             Opacity="0"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Width="10"
                                             Height="10"
                                             StrokeThickness="3"
                                             IconSource="{StaticResource {x:Static sdg:IconKeys.IconCheck}}"
                                             IconBrush="White" />
                                <sdg:Icon x:Name="IndeterminateGlyph"
                                             Opacity="0"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Width="10"
                                             Height="10"
                                             IconBrush="#FFFFFF"
                                             IconSource="{StaticResource {x:Static sdg:IconKeys.IconCheckIntermediate}}" />
                            </Grid>
                        </Border>

                        <ContentPresenter Grid.Column="1"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="#0078D4" />
                            <Setter TargetName="Box" Property="BorderThickness" Value="0" />
                            <Setter TargetName="Box" Property="Padding" Value="1" />
                            <Setter TargetName="CheckGlyph" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="Box" Property="Background" Value="#0078D4" />
                            <Setter TargetName="Box" Property="BorderThickness" Value="0" />
                            <Setter TargetName="Box" Property="Padding" Value="1" />
                            <Setter TargetName="IndeterminateGlyph" Property="Opacity" Value="1" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Box" Property="BorderBrush" Value="#0078D4" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Box" Property="Background" Value="#005A9E" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#999999" />
                            <Setter TargetName="Box" Property="Background" Value="#F5F5F5" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="#CCCCCC" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsReadOnly, RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}}" Value="True">
                <Setter Property="IsHitTestVisible" Value="False" />
                <Setter Property="Opacity" Value="0.8" />
                <Setter Property="Cursor" Value="Arrow" />
            </DataTrigger>
            <DataTrigger Binding="{Binding IsReadOnly, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" Value="True">
                <Setter Property="IsHitTestVisible" Value="False" />
                <Setter Property="Opacity" Value="0.8" />
                <Setter Property="Cursor" Value="Arrow" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
