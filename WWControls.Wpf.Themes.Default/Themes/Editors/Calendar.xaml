<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <!--  Self-merged dependencies — StaticResource inside deferred template content only
          resolves reliably within this dictionary's own merge chain (see EditSettings.xaml).  -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Primitives/DefaultControls.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        Modernized calendar for the date editor's popup. All four styles are KEYED, never
        implicit — the library must not restyle a consumer app's own Calendars — and are applied
        to PART_Calendar in the SegmentedDateTimeEditor template. The Calendar key wires the
        item / day-button / month-year-button keys through the Calendar's style properties, so
        retheming any one key follows through everywhere the popup calendar renders.
    -->

    <!--  Chevron navigation button (previous / next month). Content is set by the template
          below via the shared icon resources.  -->
    <Style x:Key="CalendarNavigationButton" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="MainBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#F0F0F0" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#E0E0E0" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="MainBorder" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Month-year header button (click zooms out to the month / year grid).  -->
    <Style x:Key="CalendarHeaderButton" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="MainBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#F0F0F0" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#E0E0E0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Day cell. CalendarDayButton exposes its states as read-only DPs (IsSelected, IsToday,
        IsInactive, IsBlackedOut), so plain property triggers cover everything without
        VisualStateManager. Trigger order matters — later setters win: hover < inactive fade <
        today ring < selection fill.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.CalendarDayButton}" TargetType="{x:Type CalendarDayButton}">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Margin" Value="1" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CalendarDayButton}">
                    <Grid>
                        <Border x:Name="Bg"
                                Background="Transparent"
                                CornerRadius="4"
                                SnapsToDevicePixels="True" />
                        <Border x:Name="TodayRing"
                                BorderBrush="#0078D4"
                                BorderThickness="1"
                                CornerRadius="4"
                                Visibility="Collapsed"
                                SnapsToDevicePixels="True" />
                        <ContentPresenter x:Name="Content"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#F0F0F0" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#E0E0E0" />
                        </Trigger>
                        <!--  Adjacent-month days render faded.  -->
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="#A8A8A8" />
                        </Trigger>
                        <!--  Weekends read red. The button's DataContext is the day's DateTime,
                              so DayOfWeek drives it; adjacent-month weekends fade like their
                              weekday neighbors. Today / selection styling below still wins.  -->
                        <DataTrigger Binding="{Binding DayOfWeek}" Value="Saturday">
                            <Setter Property="Foreground" Value="#D13438" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DayOfWeek}" Value="Sunday">
                            <Setter Property="Foreground" Value="#D13438" />
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding DayOfWeek}" Value="Saturday" />
                                <Condition Binding="{Binding IsInactive, RelativeSource={RelativeSource Self}}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Foreground" Value="#E5A0A2" />
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding DayOfWeek}" Value="Sunday" />
                                <Condition Binding="{Binding IsInactive, RelativeSource={RelativeSource Self}}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Foreground" Value="#E5A0A2" />
                        </MultiDataTrigger>
                        <Trigger Property="IsToday" Value="True">
                            <Setter TargetName="TodayRing" Property="Visibility" Value="Visible" />
                            <Setter Property="Foreground" Value="#0078D4" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <!--  Selection fill dominates hover and the today ring.  -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#0078D4" />
                            <Setter TargetName="TodayRing" Property="Visibility" Value="Collapsed" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <Trigger Property="IsBlackedOut" Value="True">
                            <Setter TargetName="Content" Property="Opacity" Value="0.3" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Content" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Month / year cell in the zoomed-out views. HasSelectedDays marks the current unit.  -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.CalendarButton}" TargetType="{x:Type CalendarButton}">
        <Setter Property="Width" Value="56" />
        <Setter Property="Height" Value="42" />
        <Setter Property="Margin" Value="1.5" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CalendarButton}">
                    <Grid>
                        <Border x:Name="Bg"
                                Background="Transparent"
                                CornerRadius="4"
                                SnapsToDevicePixels="True" />
                        <ContentPresenter x:Name="Content"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#F0F0F0" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#E0E0E0" />
                        </Trigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="#A8A8A8" />
                        </Trigger>
                        <Trigger Property="HasSelectedDays" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#0078D4" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Content" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        The month/year chrome. Named parts (PART_Root, PART_HeaderButton, PART_Previous/NextButton,
        PART_MonthView, PART_YearView) and the "DayTitleTemplate" template-resource key are the
        contract CalendarItem's code wires against: the month view MUST be a 7×7 grid (day-title
        row + 6 week rows) and the year view a 4×3 grid — the control populates the cells and
        toggles the two views' visibility itself.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.CalendarItem}" TargetType="{x:Type CalendarItem}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CalendarItem}">
                    <ControlTemplate.Resources>
                        <!--  Day-of-week title row (S M T W T F S).  -->
                        <DataTemplate x:Key="DayTitleTemplate">
                            <TextBlock Text="{Binding}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#707070"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,6,0,4" />
                        </DataTemplate>
                    </ControlTemplate.Resources>
                    <Grid x:Name="PART_Root">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="6"
                                SnapsToDevicePixels="True">
                            <DockPanel>
                                <!--  Header: ‹  July 2026  ›  -->
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="PART_PreviousButton"
                                            Style="{StaticResource CalendarNavigationButton}">
                                        <sdg:Icon IconSource="{StaticResource {x:Static sdg:IconKeys.IconChevronLeft}}"
                                                  Width="10" Height="10"
                                                  IconBrush="#505050" />
                                    </Button>
                                    <Button x:Name="PART_HeaderButton"
                                            Grid.Column="1"
                                            Style="{StaticResource CalendarHeaderButton}"
                                            HorizontalAlignment="Center" />
                                    <Button x:Name="PART_NextButton"
                                            Grid.Column="2"
                                            Style="{StaticResource CalendarNavigationButton}">
                                        <sdg:Icon IconSource="{StaticResource {x:Static sdg:IconKeys.IconChevronRight}}"
                                                  Width="10" Height="10"
                                                  IconBrush="#505050" />
                                    </Button>
                                </Grid>

                                <Grid>
                                    <Grid x:Name="PART_MonthView"
                                          Visibility="Visible"
                                          HorizontalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>
                                    </Grid>

                                    <Grid x:Name="PART_YearView"
                                          Visibility="Hidden"
                                          HorizontalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>
                                    </Grid>
                                </Grid>
                            </DockPanel>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!--  CalendarItem's code populates the month / year grids but does NOT
                              toggle them — the view swap is the template's job, keyed off the
                              owning Calendar's DisplayMode (same contract as the stock template).
                              Year and Decade modes both render in PART_YearView.  -->
                        <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType={x:Type Calendar}}}" Value="Year">
                            <Setter TargetName="PART_MonthView" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_YearView" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType={x:Type Calendar}}}" Value="Decade">
                            <Setter TargetName="PART_MonthView" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_YearView" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PART_Root" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="{x:Static sdg:EditorThemeKeys.Calendar}" TargetType="{x:Type Calendar}">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="CalendarItemStyle" Value="{StaticResource {x:Static sdg:EditorThemeKeys.CalendarItem}}" />
        <Setter Property="CalendarDayButtonStyle" Value="{StaticResource {x:Static sdg:EditorThemeKeys.CalendarDayButton}}" />
        <Setter Property="CalendarButtonStyle" Value="{StaticResource {x:Static sdg:EditorThemeKeys.CalendarButton}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Calendar}">
                    <StackPanel x:Name="PART_Root" HorizontalAlignment="Center">
                        <CalendarItem x:Name="PART_CalendarItem"
                                      Style="{TemplateBinding CalendarItemStyle}"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}" />
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
