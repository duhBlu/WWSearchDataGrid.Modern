<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <!--  Self-merged dependencies — StaticResource inside deferred template content only
          resolves reliably within this dictionary's own merge chain (see EditSettings.xaml).  -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Primitives/DefaultControls.xaml" />
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Editors/EditorParts.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        WWTextBox — the text editor's own chrome: a two-part border (Frame + focus-accent Lip,
        drawn per ShowBorder), background, padding, disabled visual, hosting the inner PART_TextBox.
        Flat inside a grid cell (the control clears ShowBorder there), bordered on a form / standalone.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.TextBox}" TargetType="{x:Type sdg:WWTextBox}">
        <Setter Property="sdg:ControlHelper.CornerRadius" Value="{StaticResource {x:Static sdg:PrimitiveThemeKeys.ControlCornerRadius}}" />
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="BorderBrush" Value="#e3e3e3" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:WWTextBox}">
                    <Grid x:Name="Root" SnapsToDevicePixels="True">
                        <!--  Frame — top/left/right only; the bottom edge is the lip below.  -->
                        <Border x:Name="Frame"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                CornerRadius="{TemplateBinding sdg:ControlHelper.CornerRadius}" />

                        <TextBox x:Name="PART_TextBox"
                                 Style="{StaticResource {x:Static sdg:EditorThemeKeys.EditTextBox}}"
                                 Margin="{TemplateBinding Padding}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="0"
                                 Foreground="{TemplateBinding Foreground}"
                                 VerticalContentAlignment="Center"
                                 VerticalAlignment="Stretch"
                                 IsReadOnly="{TemplateBinding IsReadOnly}"
                                 TextAlignment="{TemplateBinding TextAlignment}"
                                 Text="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <!--  Bottom lip — depth cue that becomes the accent underline while focused.  -->
                        <Border x:Name="Lip"
                                Background="Transparent"
                                BorderBrush="#bfbfbf"
                                BorderThickness="0,0,0,1"
                                CornerRadius="0,0,4,4"
                                Height="2"
                                VerticalAlignment="Bottom"
                                IsHitTestVisible="False"
                                Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowBorder" Value="True">
                            <Setter TargetName="Frame" Property="BorderThickness" Value="1,1,1,0" />
                            <Setter TargetName="Lip" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ShowBorder" Value="True" />
                                <Condition Property="IsKeyboardFocusWithin" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Lip" Property="Background" Value="#0179D4" />
                            <Setter TargetName="Lip" Property="BorderBrush" Value="#0078D4" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type sdg:WWTextBox}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.TextBox}}" />

</ResourceDictionary>
