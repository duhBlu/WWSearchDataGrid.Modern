<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <!--  Self-merged dependencies — StaticResource inside deferred template content only
          resolves reliably within this dictionary's own merge chain (see EditSettings.xaml).  -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Primitives/DefaultControls.xaml" />
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Editors/EditorParts.xaml" />
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Primitives/ContextMenu.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        WWTextBox — the text editor's own chrome: a two-part border (Frame + focus-accent Lip,
        drawn per ShowBorder), background, padding, disabled visual, hosting the inner PART_TextBox.
        Flat inside a grid cell (the control clears ShowBorder there), bordered on a form / standalone.
    -->
    <Style x:Key="{x:Static sdg:EditorThemeKeys.TextBox}" TargetType="{x:Type sdg:WWTextBox}">
        <Setter Property="sdg:ControlHelper.CornerRadius" Value="{StaticResource {x:Static sdg:PrimitiveThemeKeys.ControlCornerRadius}}" />
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Foreground" Value="#1C1C1C" />
        <Setter Property="BorderBrush" Value="#e3e3e3" />
        <Setter Property="SelectionBrush" Value="#0078d4" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:WWTextBox}">
                    <Grid x:Name="Root" SnapsToDevicePixels="True">
                        <!--  Frame — top/left/right only; the bottom edge is the lip below.  -->
                        <Border x:Name="Frame"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                CornerRadius="{TemplateBinding sdg:ControlHelper.CornerRadius}" />

                        <!--  Content row: [left glyph] [watermark + text] [right glyph] [clear].
                              Both glyph slots and the clear slot are Auto, so they collapse to zero
                              width when their element is hidden. Padding drives the whole row's inset;
                              the inner TextBox carries no margin of its own.  -->
                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  Optional glyph — sits in column 0 (Left); a trigger relocates it to
                                  column 2 for GlyphPlacement=Right. Hidden when Glyph is null.  -->
                            <sdg:Icon x:Name="GlyphIcon"
                                      Grid.Column="0"
                                      Width="14"
                                      Height="14"
                                      Margin="2,0,6,0"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      IconSource="{TemplateBinding Glyph}"
                                      IconBrush="{TemplateBinding Foreground}" />

                            <Grid Grid.Column="1">
                                <!--  Watermark — behind the text, shown only while the input is empty.
                                      An empty Watermark string renders nothing, so visibility keys on
                                      the text length alone (no need to test the watermark too).  -->
                                <TextBlock x:Name="Watermark"
                                           Text="{TemplateBinding Watermark}"
                                           Foreground="#FF9AA0A6"
                                           FontStyle="Italic"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                           TextWrapping="{TemplateBinding TextWrapping}"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="Collapsed" />

                                <TextBox x:Name="PART_TextBox"
                                         Style="{StaticResource {x:Static sdg:EditorThemeKeys.EditTextBox}}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="0"
                                         Foreground="{TemplateBinding Foreground}"
                                         VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                         VerticalAlignment="Stretch"
                                         IsReadOnly="{TemplateBinding IsReadOnly}"
                                         MaxLength="{TemplateBinding MaxLength}"
                                         TextAlignment="{TemplateBinding TextAlignment}"
                                         AcceptsReturn="{TemplateBinding AcceptsReturn}"
                                         AcceptsTab="{TemplateBinding AcceptsTab}"
                                         TextWrapping="{TemplateBinding TextWrapping}"
                                         MinLines="{TemplateBinding MinLines}"
                                         MaxLines="{TemplateBinding MaxLines}"
                                         HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"
                                         VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"
                                         TextDecorations="{TemplateBinding TextDecorations}"
                                         CharacterCasing="{TemplateBinding CharacterCasing}"
                                         IsUndoEnabled="{TemplateBinding IsUndoEnabled}"
                                         UndoLimit="{TemplateBinding UndoLimit}"
                                         SpellCheck.IsEnabled="{TemplateBinding IsSpellCheckEnabled}"
                                         CaretBrush="{TemplateBinding CaretBrush}"
                                         SelectionBrush="{TemplateBinding SelectionBrush}"
                                         SelectionOpacity="{TemplateBinding SelectionOpacity}" />
                            </Grid>

                            <!--  Clear button — appears while non-empty (see triggers). Minimal inline
                                  template so it carries no default button chrome inside the editor.  -->
                            <Button x:Name="PART_ClearButton"
                                    Grid.Column="3"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Focusable="False"
                                    IsTabStop="False"
                                    Cursor="Hand"
                                    Padding="4"
                                    Margin="0,0,4,0"
                                    ToolTip="Clear"
                                    Visibility="Collapsed">
                                <Button.Template>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                            <sdg:Icon Width="9"
                                                      Height="9"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      IconSource="{StaticResource {x:Static sdg:LucideIconKeys.X}}"
                                                      IconBrush="{TemplateBinding Foreground}" />
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="False">
                                                <Setter Property="Foreground" Value="#999999" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#666666" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter  Property="Foreground" Value="#333333" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!--  Bottom lip — depth cue that becomes the accent underline while focused.  -->
                        <Border x:Name="Lip"
                                Background="Transparent"
                                BorderBrush="#bfbfbf"
                                BorderThickness="0,0,0,1"
                                CornerRadius="0,0,4,4"
                                Height="2"
                                VerticalAlignment="Bottom"
                                IsHitTestVisible="False"
                                Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowBorder" Value="True">
                            <Setter TargetName="Frame" Property="BorderThickness" Value="1,1,1,0" />
                            <Setter TargetName="Lip" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ShowBorder" Value="True" />
                                <Condition Property="IsKeyboardFocusWithin" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Lip" Property="Background" Value="#0179D4" />
                            <Setter TargetName="Lip" Property="BorderBrush" Value="#0078D4" />
                        </MultiTrigger>

                        <!--  Glyph: hide when unset; move to the trailing edge for GlyphPlacement=Right.  -->
                        <Trigger Property="Glyph" Value="{x:Null}">
                            <Setter TargetName="GlyphIcon" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="GlyphPlacement" Value="Right">
                            <Setter TargetName="GlyphIcon" Property="Grid.Column" Value="2" />
                            <Setter TargetName="GlyphIcon" Property="Margin" Value="6,0,2,0" />
                        </Trigger>

                        <!--  Watermark: visible only while the input is empty.  -->
                        <DataTrigger Binding="{Binding Text.Length, ElementName=PART_TextBox}" Value="0">
                            <Setter TargetName="Watermark" Property="Visibility" Value="Visible" />
                        </DataTrigger>

                        <!--  Clear button: opt-in via ShowClearButton, only while non-empty and editable.
                              Later triggers win, so the empty / read-only cases collapse it again.  -->
                        <Trigger Property="ShowClearButton" Value="True">
                            <Setter TargetName="PART_ClearButton" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <DataTrigger Binding="{Binding Text.Length, ElementName=PART_TextBox}" Value="0">
                            <Setter TargetName="PART_ClearButton" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <Trigger Property="IsReadOnly" Value="True">
                            <Setter TargetName="PART_ClearButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type sdg:WWTextBox}" BasedOn="{StaticResource {x:Static sdg:EditorThemeKeys.TextBox}}" />

</ResourceDictionary>
