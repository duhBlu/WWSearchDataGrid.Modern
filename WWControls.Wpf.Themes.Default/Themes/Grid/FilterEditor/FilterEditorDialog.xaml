<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf"
                    xmlns:sdgCore="clr-namespace:WWControls.Core;assembly=WWControls.Core"
                    xmlns:converters="clr-namespace:WWControls.Wpf.Converters;assembly=WWControls.Wpf.Grid">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Primitives/DefaultControls.xaml" />
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Primitives/ContextMenu.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <converters:BooleanToVisibilityCollapsedConverter x:Key="FilterEditorBoolToVis" />
    <converters:FilterEditorDepthToBrushConverter x:Key="FilterEditorDepthToBrush" />

    <!--  Group header action button chrome. The fill color comes from the derived Add / Delete styles.  -->
    <Style x:Key="FilterEditorGroupButtonBase" TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="Margin" Value="4,0,0,0" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FilterEditorAddButton" TargetType="{x:Type Button}" BasedOn="{StaticResource FilterEditorGroupButtonBase}">
        <Setter Property="Background" Value="#42a358" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#358648" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#2c723d" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  Delete button collapses on the root group (the group with no parent).  -->
    <Style x:Key="FilterEditorDeleteButton" TargetType="{x:Type Button}" BasedOn="{StaticResource FilterEditorGroupButtonBase}">
        <Setter Property="Background" Value="#ed4341" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#c83532" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#a82e2c" />
            </Trigger>
            <DataTrigger Binding="{Binding Parent}" Value="{x:Null}">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!--
        Shared template selector. Both group and condition templates are looked up by resource
        key at runtime, so declaration order inside this dictionary doesn't matter.
    -->
    <sdg:FilterEditorNodeTemplateSelector x:Key="FilterEditorNodeTemplateSelector" />

    <!--  Condition row: column chip + search type chip + value chip + hover remove button.  -->
    <DataTemplate x:Key="{x:Static sdg:GridThemeKeys.FilterEditorConditionRow}" DataType="{x:Type sdg:FilterConditionNode}">
        <Grid x:Name="ConditionRoot"
              Background="Transparent"
              Cursor="Hand"
              Margin="0,2">
            <Border Background="Transparent" Padding="2">
                <!--  WrapPanel so a long row (e.g. IsAnyOf with many values) wraps to the next
                     line at the viewport edge instead of stretching horizontally. The hover
                     remove button is the trailing item so it stays beside the value chip.  -->
                <WrapPanel Orientation="Horizontal">
                    <sdg:ColumnNameTokenEditor SelectedColumn="{Binding Column, Mode=TwoWay}" AvailableColumns="{Binding AvailableColumns}" />
                    <sdg:SearchTypeTokenEditor SelectedSearchType="{Binding SearchType, Mode=TwoWay}" ValidSearchTypes="{Binding SearchTemplate.ValidSearchTypes}" />
                    <sdg:ValueTokenEditor SearchTemplate="{Binding SearchTemplate}" />

                    <!--  Remove button — visible only while the row is hovered  -->
                    <Button BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding RemoveCommand}"
                            Padding="0"
                            Margin="2,0,0,0"
                            VerticalAlignment="Center"
                            Width="14"
                            Height="14"
                            ToolTip="Remove condition">
                        <sdg:Icon Width="6"
                                  Height="6"
                                  StrokeThickness="4"
                                  IconSource="{StaticResource {x:Static sdg:LucideIconKeys.X}}"
                                  IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Gray" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="7">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=ConditionRoot, Path=IsMouseOver}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#ed4341" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#c83532" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </WrapPanel>
            </Border>
        </Grid>
    </DataTemplate>

    <!--  Group: depth-tinted card with an AND/OR toggle, Add rule / Add group / Delete, and a recursive child list.  -->
    <DataTemplate x:Key="{x:Static sdg:GridThemeKeys.FilterEditorGroup}" DataType="{x:Type sdg:FilterGroupNode}">
        <Border Background="{Binding Depth, Converter={StaticResource FilterEditorDepthToBrush}}"
                BorderBrush="#C7D3E2"
                BorderThickness="1"
                CornerRadius="5"
                Margin="0,4"
                Padding="8"
                SnapsToDevicePixels="True">
            <StackPanel Orientation="Vertical">

                <!--  Header: AND/OR toggle on the left; Add rule / Add group / Delete on the right.  -->
                <Grid x:Name="GroupHeaderRow">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <sdg:GroupOperatorChip Grid.Column="0" Operator="{Binding Operator, Mode=TwoWay}" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource FilterEditorAddButton}"
                                Command="{Binding AddConditionCommand}"
                                ToolTip="Add rule">
                            <StackPanel Orientation="Horizontal">
                                <sdg:Icon Width="12"
                                          Height="12"
                                          StrokeThickness="3"
                                          IconSource="{StaticResource {x:Static sdg:LucideIconKeys.ListPlus}}"
                                          IconBrush="White" />
                                <TextBlock Text="Add rule" Margin="4,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource FilterEditorAddButton}"
                                Command="{Binding AddGroupCommand}"
                                ToolTip="Add group">
                            <StackPanel Orientation="Horizontal">
                                <sdg:Icon Width="12"
                                          Height="12"
                                          StrokeThickness="3"
                                          IconSource="{StaticResource {x:Static sdg:LucideIconKeys.LayersPlus}}"
                                          IconBrush="White" />
                                <TextBlock Text="Add group" Margin="4,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource FilterEditorDeleteButton}"
                                Command="{Binding RemoveCommand}"
                                ToolTip="Remove group">
                            <StackPanel Orientation="Horizontal">
                                <sdg:Icon Width="10"
                                          Height="10"
                                          StrokeThickness="3"
                                          IconSource="{StaticResource {x:Static sdg:LucideIconKeys.X}}"
                                          IconBrush="White" />
                                <TextBlock Text="Delete" Margin="4,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!--  Recursive body: conditions first (added at the top), nested groups below (added at the bottom).  -->
                <ItemsControl Margin="6,6,0,0"
                              ItemsSource="{Binding Children}"
                              ItemTemplateSelector="{StaticResource FilterEditorNodeTemplateSelector}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </Border>
    </DataTemplate>

    <!--
        FilterEditorDialog default style. The recursive tree templates and chip control styles
        are picked up from Themes/Grid/FilterEditor/*.xaml merged in Generic.xaml.
    -->
    <Style x:Key="{x:Static sdg:GridThemeKeys.FilterEditorDialog}" TargetType="{x:Type sdg:FilterEditorDialog}">
        <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:FilterEditorDialog}">
                    <Border Background="{TemplateBinding Background}">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Body: recursive group tree, rooted at RootGroup  -->
                            <Border Grid.Row="0"
                                    Background="White"
                                    BorderBrush="#E1E5E9"
                                    BorderThickness="1"
                                    Padding="8"
                                    CornerRadius="3">
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                    <ContentControl Content="{Binding RootGroup, RelativeSource={RelativeSource TemplatedParent}}" ContentTemplateSelector="{StaticResource FilterEditorNodeTemplateSelector}" />
                                </ScrollViewer>
                            </Border>

                            <!--  Footer: OK / Cancel / Apply  -->
                            <StackPanel Grid.Row="1"
                                        Orientation="Horizontal"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Right">
                                <Button Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.Button}}"
                                        IsDefault="True"
                                        Command="{Binding OkCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,0,6,0"
                                        Padding="14,4"
                                        MinWidth="72"
                                        Content="OK" />
                                <Button Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.Button}}"
                                        IsCancel="True"
                                        Command="{Binding CancelCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,0,6,0"
                                        Padding="14,4"
                                        MinWidth="72"
                                        Content="Cancel" />
                                <Button Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.Button}}"
                                        Command="{Binding ApplyCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                        Padding="14,4"
                                        MinWidth="72"
                                        Content="Apply" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:GridThemeKeys.FilterEditorDialog}}" TargetType="{x:Type sdg:FilterEditorDialog}" />

</ResourceDictionary>
