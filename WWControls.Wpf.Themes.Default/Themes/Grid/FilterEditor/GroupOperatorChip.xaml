<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <!--  Flat segment button: chrome only; the active/inactive colors are driven by the parent's IsAnd/IsOr triggers.  -->
    <Style x:Key="FilterEditorOperatorSegment" TargetType="{x:Type Button}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#5590cc" />
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="Padding" Value="9,2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="{x:Static sdg:GridThemeKeys.FilterEditorGroupOperatorChip}" TargetType="{x:Type sdg:GroupOperatorChip}">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:GroupOperatorChip}">
                    <Border BorderBrush="#5590cc"
                            BorderThickness="1"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="PART_And"
                                    Style="{StaticResource FilterEditorOperatorSegment}"
                                    Command="{Binding SetAndCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                    Content="AND" />
                            <Border Width="1" Background="#5590cc" />
                            <Button x:Name="PART_Or"
                                    Style="{StaticResource FilterEditorOperatorSegment}"
                                    Command="{Binding SetOrCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                    Content="OR" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsAnd" Value="True">
                            <Setter TargetName="PART_And" Property="Background" Value="#5590cc" />
                            <Setter TargetName="PART_And" Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsOr" Value="True">
                            <Setter TargetName="PART_Or" Property="Background" Value="#5590cc" />
                            <Setter TargetName="PART_Or" Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:GridThemeKeys.FilterEditorGroupOperatorChip}}" TargetType="{x:Type sdg:GroupOperatorChip}" />

</ResourceDictionary>
