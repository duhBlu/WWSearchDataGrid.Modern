<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:commands="clr-namespace:WWControls.Wpf.Commands;assembly=WWControls.Wpf.Grid"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Resources/Icons/Icons.xaml" />
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Primitives/ContextMenu.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        Shared grid-body right-click menu — filter operations, column profiles, export,
        and layout actions. The menu's DataContext is rebound to a Commands.ContextMenuContext
        per opening, so a single instance is fine here (x:Shared defaults to True for ContextMenu).
    -->
    <ContextMenu x:Key="{x:Static sdg:GridThemeKeys.GridSearchDataGridContextMenu}"
                 Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.ContextMenu}}"
                 AutomationProperties.AutomationId="cmuGridBody">
        <!--  Filter operations  -->
        <MenuItem x:Name="miClearAllFilters" sdg:ContextMenuExtensions.ItemId="ClearAllFilters"
                  Command="{x:Static commands:ContextMenuCommands.ClearAllFiltersCommand}"
                  CommandParameter="{Binding Grid}"
                  Header="Clear All Filters (Not Implemented)">
            <MenuItem.Icon>
                <sdg:Icon Width="14"
                             Height="14"
                             IconSource="{StaticResource {x:Static sdg:IconKeys.IconClearFilter}}" />
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem x:Name="miToggleFilterPanel" sdg:ContextMenuExtensions.ItemId="ToggleFilterPanel"
                  Command="{x:Static commands:ContextMenuCommands.ToggleFilterPanelCommand}"
                  CommandParameter="{Binding Grid}"
                  Header="Toggle Filter Panel (Not Implemented)" />
        <MenuItem x:Name="miSaveFilterPreset" sdg:ContextMenuExtensions.ItemId="SaveFilterPreset"
                  Command="{x:Static commands:ContextMenuCommands.SaveFilterPresetCommand}"
                  CommandParameter="{Binding Grid}"
                  Header="Save Filter Preset..." />
        <MenuItem x:Name="miLoadFilterPreset" sdg:ContextMenuExtensions.ItemId="LoadFilterPreset"
                  Command="{x:Static commands:ContextMenuCommands.LoadFilterPresetCommand}"
                  CommandParameter="{Binding Grid}"
                  Header="Load Filter Preset..." />
        <Separator />

        <!--  Column Profiles submenu  -->
        <MenuItem x:Name="miColumnProfiles" sdg:ContextMenuExtensions.ItemId="ColumnProfiles" Header="Column Profiles">
            <MenuItem x:Name="miSaveCurrentProfile" sdg:ContextMenuExtensions.ItemId="SaveCurrentProfile"
                      Command="{x:Static commands:ContextMenuCommands.SaveCurrentProfileCommand}"
                      CommandParameter="{Binding Grid}"
                      Header="Save Current Profile..." />
            <MenuItem x:Name="miLoadProfile" sdg:ContextMenuExtensions.ItemId="LoadProfile"
                      Command="{x:Static commands:ContextMenuCommands.LoadProfileCommand}"
                      CommandParameter="{Binding Grid}"
                      Header="Load Profile..." />
            <MenuItem x:Name="miManageProfiles" sdg:ContextMenuExtensions.ItemId="ManageProfiles"
                      Command="{x:Static commands:ContextMenuCommands.ManageProfilesCommand}"
                      CommandParameter="{Binding Grid}"
                      Header="Manage Profiles... (Not Implemented)" />
        </MenuItem>

        <Separator />

        <!--  Export operations  -->
        <MenuItem x:Name="miExportToCsv" sdg:ContextMenuExtensions.ItemId="ExportToCsv"
                  Command="{x:Static commands:ContextMenuCommands.ExportToCsvCommand}"
                  CommandParameter="{Binding Grid}"
                  Header="Export to CSV (Not Implemented)" />
        <MenuItem x:Name="miExportToExcel" sdg:ContextMenuExtensions.ItemId="ExportToExcel"
                  Command="{x:Static commands:ContextMenuCommands.ExportToExcelCommand}"
                  CommandParameter="{Binding Grid}"
                  Header="Export to Excel (Not Implemented)" />

        <Separator />

        <!--  Layout operations  -->
        <MenuItem x:Name="miShowColumnChooser" sdg:ContextMenuExtensions.ItemId="ColumnChooser"
                  Command="{x:Static commands:ContextMenuCommands.ShowColumnChooserCommand}"
                  CommandParameter="{Binding Grid}"
                  Header="Show Column Chooser">
            <MenuItem.Icon>
                <sdg:Icon Width="14"
                             Height="14"
                             IconSource="{StaticResource {x:Static sdg:IconKeys.IconColumnChooser}}" />
            </MenuItem.Icon>
            <MenuItem.Style>
                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.MenuItem}}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Grid.IsColumnChooserEnabled}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </MenuItem.Style>
        </MenuItem>
        <MenuItem x:Name="miResetLayout" sdg:ContextMenuExtensions.ItemId="ResetLayout"
                  Command="{x:Static commands:ContextMenuCommands.ResetLayoutCommand}"
                  CommandParameter="{Binding Grid}"
                  Header="Reset Layout" />
    </ContextMenu>

</ResourceDictionary>
