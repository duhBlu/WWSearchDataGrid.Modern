<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="http://schemas.wwcontrols.com/wpf">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWControls.Wpf.Themes.Default;component/Themes/Primitives/DefaultControls.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        Default "Filter Rules" tab content. Hosts the same MultiFilterElement custom-tab
        consumers use, so the default popup and a custom popup render identical visuals +
        behavior. ColumnFilterPopup.OnDefaultTabHostLoaded walks the host's visual tree
        and wires the FilterElementBase's Context — same path the Values tab uses.
    -->
    <ControlTemplate x:Key="DefaultRulesTabContent" TargetType="{x:Type ContentControl}">
        <sdg:MultiFilterElement Margin="4,4,4,0" />
    </ControlTemplate>

    <!--
        Default "Filter Values" tab content. Hosts the same CheckedListFilterElement /
        DateTreeFilterElement controls that custom-tab consumers use, so the default popup
        and a custom popup render identical visuals + behavior. ColumnFilterPopup walks the
        host's visual tree on Loaded and wires each FilterElementBase's Context — see
        ColumnFilterPopup.BuildDefaultTabItem / OnDefaultTabHostLoaded.

        Visibility is keyed off FilterValueManager.IsDateTimeColumn: the flat-list element
        shows for non-DateTime columns, the date tree shows for DateTime columns.
    -->
    <ControlTemplate x:Key="DefaultValuesTabContent" TargetType="{x:Type ContentControl}">
        <Grid Margin="4,4,4,0">

            <!--  Flat checkbox list (hidden when DateTime)  -->
            <sdg:CheckedListFilterElement>
                <sdg:CheckedListFilterElement.Style>
                    <Style TargetType="{x:Type sdg:CheckedListFilterElement}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FilterValueManager.IsDateTimeColumn, RelativeSource={RelativeSource AncestorType=sdg:ColumnFilterPopup}}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </sdg:CheckedListFilterElement.Style>
            </sdg:CheckedListFilterElement>

            <!--  DateTime TreeView (hidden when NOT DateTime)  -->
            <sdg:DateTreeFilterElement>
                <sdg:DateTreeFilterElement.Style>
                    <Style TargetType="{x:Type sdg:DateTreeFilterElement}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FilterValueManager.IsDateTimeColumn, RelativeSource={RelativeSource AncestorType=sdg:ColumnFilterPopup}}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </sdg:DateTreeFilterElement.Style>
            </sdg:DateTreeFilterElement>
        </Grid>
    </ControlTemplate>


    <!--  ColumnFilterPopup Style  -->
    <Style x:Key="{x:Static sdg:GridThemeKeys.ColumnFilterPopup}" TargetType="{x:Type sdg:ColumnFilterPopup}">
        <Setter Property="Background" Value="#f4f4f4" />
        <Setter Property="BorderBrush" Value="DarkGray" />
        <Setter Property="VerticalOffset" Value="-24" />
        <Setter Property="HorizontalOffset" Value="-20" />
        <Setter Property="MinWidth" Value="300" />
        <Setter Property="MinHeight" Value="300" />
        <Setter Property="MaxHeight" Value="500" />
        <Setter Property="Margin" Value="12" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:ColumnFilterPopup}">
                    <Grid Margin="{TemplateBinding Margin}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Border.Effect>
                                <DropShadowEffect Color="#02000000"
                                                  Opacity="0.25"
                                                  BlurRadius="8"
                                                  ShadowDepth="2" />
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!--
                                    Single hosting slot for the popup body. The code-behind
                                    constructs a TabControl (with default Rules + Values tabs
                                    when CustomColumnFilterTabs is empty, or the consumer's
                                    custom tabs when it isn't) and assigns it to TabsContent.
                                    No more parallel TabControl-in-XAML + ContentPresenter-for-
                                    custom pair; one path through, picked in code.
                                -->
                                <ContentPresenter Grid.Row="0"
                                                  Margin="4"
                                                  Content="{Binding TabsContent, RelativeSource={RelativeSource TemplatedParent}}" />

                                <!--
                                    Footer pinned to the bottom of the popup (visible across all tabs).
                                    Live-apply vs deferred-apply is controlled grid-wide by
                                    SearchDataGrid.EnableLiveFiltering — the popup honors that DP
                                    at apply time; there's no per-column or per-popup override.
                                -->
                                <Border Grid.Row="1"
                                        BorderThickness="0,1,0,0"
                                        Margin="0"
                                        Padding="4"
                                        CornerRadius="0,0,4,4">
                                    <Button Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.Button}}"
                                            Command="{Binding ClearFilterCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                            HorizontalAlignment="Left"
                                            Content="Clear Filter" />
                                </Border>
                            </Grid>
                        </Border>

                        <!--  Bottom-left resize grip  -->
                        <Thumb x:Name="PART_ResizeBottomLeft"
                               Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.ResizeThumb}}"
                               Cursor="SizeNESW"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Bottom"
                               Panel.ZIndex="10"
                               Width="14"
                               Height="14" />

                        <!--  Bottom-right resize grip  -->
                        <Thumb x:Name="PART_ResizeBottomRight"
                               Style="{StaticResource {x:Static sdg:PrimitiveThemeKeys.ResizeThumb}}"
                               Cursor="SizeNWSE"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"
                               Panel.ZIndex="10"
                               Width="14"
                               Height="14" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:GridThemeKeys.ColumnFilterPopup}}" TargetType="{x:Type sdg:ColumnFilterPopup}" />

</ResourceDictionary>
