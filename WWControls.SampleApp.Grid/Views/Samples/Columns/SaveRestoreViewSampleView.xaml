<UserControl x:Class="WWControls.SampleApp.Grid.Views.Samples.Columns.SaveRestoreViewSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Grid.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Grid.Views.Samples.Columns"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:SaveRestoreViewSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style BasedOn="{StaticResource {x:Static sdg:PrimitiveThemeKeys.Button}}" TargetType="{x:Type Button}">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <!--  A built-in .sdgview entry: name, a "what it changes" chip, and a one-line description.  -->
        <DataTemplate x:Key="PresetItemTemplate">
            <StackPanel Margin="2,4">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#E8EEF7"
                            CornerRadius="3"
                            Padding="5,1"
                            VerticalAlignment="Center"
                            Margin="0,0,6,0">
                        <TextBlock Text="{Binding Kind}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="#3A5A8C" />
                    </Border>
                    <TextBlock Text="{Binding Name}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBlock Text="{Binding Description}"
                           Foreground="#666"
                           FontSize="11.5"
                           TextWrapping="Wrap"
                           Margin="0,3,0,0" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.SaveRestoreView}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Foreground="#444"
                       Margin="16,12,16,4"
                       FontSize="13"
                       TextWrapping="Wrap">
                <Run Text="Saved views — layout and filters" FontWeight="SemiBold" />
                <LineBreak />
                <Run Text="A saved view captures the grid's column layout (order, width, visibility, pinning, sort, grouping) and/or its filters into a portable .sdgview file. Pick a built-in view on the right to apply it — layout-only and filters-only views only change their half, so they compose. Right-click the grid for Column Profiles (layout + filters) and Filter Preset (filters only) to save and load your own files; Reset Layout returns the columns to how they started." />
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="340" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    IsReadOnly="True"
                                    ItemsSource="{Binding Items}"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    ShowFilterRow="True"
                                    AllowScrollAnimation="True"
                                    AllowPerPixelScrolling="True"
                                    ShowGroupRowCount="True"
                                    PersistenceId="SampleOrdersGrid">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn Width="90" FieldName="OrderNumber" Header="Order #" />
                        <sdg:GridColumn Width="210" FieldName="CustomerName" Header="Customer" />
                        <sdg:GridColumn Width="140" FieldName="ProductLineName" Header="Product Line" />
                        <sdg:GridColumn Width="130" FieldName="OrderStatusName" Header="Status" />
                        <sdg:GridColumn Width="70" FieldName="State" Header="State" />
                        <sdg:GridColumn Width="120"
                                        FieldName="OrderDate"
                                        Header="Order Date"
                                        DisplayStringFormat="MM/dd/yyyy"
                                        GroupInterval="DateMonth" />
                        <sdg:GridColumn Width="120"
                                        FieldName="OrderItemsTotalPrice"
                                        Header="Total"
                                        DisplayStringFormat="C2" />
                        <sdg:GridColumn Width="90" FieldName="Submitted" Header="Submitted" />
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Background="#CCCCCC" />

                <DockPanel Grid.Column="2" Background="#FFFFFF" Margin="0">
                    <TextBlock DockPanel.Dock="Top"
                               Text="Built-in views (.sdgview)"
                               FontWeight="SemiBold"
                               Foreground="#333"
                               Margin="12,12,12,2" />
                    <TextBlock DockPanel.Dock="Top"
                               Text="Select one to apply it to the grid."
                               Foreground="#777"
                               FontSize="11.5"
                               Margin="12,0,12,6" />

                    <Border DockPanel.Dock="Bottom"
                            Background="#F6F8FA"
                            BorderBrush="#E1E4E8"
                            BorderThickness="0,1,0,0"
                            Padding="12,10">
                        <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">
                            <Button Click="ResetLayout_Click"
                                    Content="Reset layout"
                                    ToolTip="Restore column order, widths, visibility, pinning, sort, and grouping to how the grid started." />
                            <Button Click="ClearFilters_Click"
                                    Content="Clear all filters"
                                    ToolTip="Remove every column filter, leaving the layout as-is." />
                            <TextBlock Foreground="#777"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Text="Tip: right-click the grid → Column Profiles ▸ Save Current Profile… to save your own view to a file, or Filter Preset ▸ Save/Load for filters only." />
                        </sdg:SimpleStackPanel>
                    </Border>

                    <ListBox x:Name="PresetList"
                             BorderThickness="0"
                             Margin="4,0"
                             ItemsSource="{Binding Presets}"
                             ItemTemplate="{StaticResource PresetItemTemplate}"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="PresetList_SelectionChanged" />
                </DockPanel>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
