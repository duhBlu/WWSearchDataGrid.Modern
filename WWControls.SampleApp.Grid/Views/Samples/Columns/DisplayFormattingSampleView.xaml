<UserControl x:Class="WWControls.SampleApp.Grid.Views.Samples.Columns.DisplayFormattingSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Grid.Controls"
             xmlns:sampleConverters="clr-namespace:WWControls.SampleApp.Grid.Converters"
             xmlns:local="clr-namespace:WWControls.SampleApp.Grid.Views.Samples.Columns"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:DisplayFormattingSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <sampleConverters:SubmittedToStringConverter x:Key="SubmittedToStringConverter" />
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.DisplayFormatting}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Display formatting" />
                <LineBreak />
                <Run Text="Three ways to shape cell text — DisplayStringFormat, DisplayValueConverter, and DisplayMask — with raw / formatted columns side by side. 'Date (round)' uses RoundDateDisplayFormat, which renders the same but also rounds that column's filtering to whole days." />
            </TextBlock>

            <sdg:SearchDataGrid x:Name="Grid"
                                Margin="10"
                                ItemsSource="{Binding Items}"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                IsReadOnly="True">
                <sdg:SearchDataGrid.GridColumns>
                    <!-- Raw integer (no format) -->
                    <sdg:GridColumn Width="100" FieldName="OrderNumber" Header="Order # (raw)" />
                    <!-- Same field with N0 format -->
                    <sdg:GridColumn Width="110" FieldName="OrderNumber" Header="Order # (N0)" DisplayStringFormat="N0" />

                    <!-- Raw decimal -->
                    <sdg:GridColumn Width="110" FieldName="OrderItemsTotalPrice" Header="Total (raw)" />
                    <!-- C2 currency -->
                    <sdg:GridColumn Width="120" FieldName="OrderItemsTotalPrice" Header="Total (C2)" DisplayStringFormat="C2" />

                    <!-- Raw nullable decimal -->
                    <sdg:GridColumn Width="100" FieldName="DiscountPercent" Header="Disc (raw)" />
                    <!-- P0 percent -->
                    <sdg:GridColumn Width="100" FieldName="DiscountPercent" Header="Disc (P0)" DisplayStringFormat="P0" />

                    <!-- Date with full DateTime format -->
                    <sdg:GridColumn Width="160" FieldName="OrderDate" Header="Date (long)" DisplayStringFormat="MM/dd/yyyy h:mm tt" />
                    <!-- Same date with short format -->
                    <sdg:GridColumn Width="110" FieldName="OrderDate" Header="Date (short)" DisplayStringFormat="MM/dd/yyyy" />
                    <!-- RoundDateDisplayFormat: renders date-only like DisplayStringFormat, but also rounds this
                         column's filtering to date-only (its date-only format auto-drives RoundDateTime=true). -->
                    <sdg:GridColumn Width="120" FieldName="OrderDate" Header="Date (round)" RoundDateDisplayFormat="MM/dd/yyyy" />

                    <!-- Bool with custom converter (Yes/No) -->
                    <sdg:GridColumn Width="120" FieldName="Submitted" Header="Submitted (Yes/No)"
                                    UseCheckBoxInSearchBox="False"
                                    DisplayValueConverter="{StaticResource SubmittedToStringConverter}" />
                    <!-- Plain bool -->
                    <sdg:GridColumn Width="100" FieldName="Submitted" Header="Submitted (raw)" />

                    <!-- Display mask example on a string field. ZIP codes are 5-digit; mask shapes them. -->
                    <sdg:GridColumn Width="120" FieldName="ZipCode" Header="ZIP (raw)" />
                    <sdg:GridColumn Width="120" FieldName="ZipCode" Header="ZIP (mask)" DisplayMask="00000" />
                </sdg:SearchDataGrid.GridColumns>
            </sdg:SearchDataGrid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
