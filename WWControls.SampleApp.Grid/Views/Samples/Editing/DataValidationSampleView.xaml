<UserControl x:Class="WWControls.SampleApp.Grid.Views.Samples.Editing.DataValidationSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Grid.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Grid.Views.Samples.Editing"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:DataValidationSampleViewModel />
    </UserControl.DataContext>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.DataValidation}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Data-annotation validation + smart columns" />
                <LineBreak />
                <Run Text="Every column is IsSmart=True, so its header, editor, and mask come from the property's data annotations. Commit an invalid value to see the validation error and have the commit blocked." />
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    ItemsSource="{Binding Employees}"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    ShowValidationAttributeErrors="True"
                                    AllowCommitOnValidationAttributeError="True">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn FieldName="FirstName" IsSmart="True" Width="110" />
                        <sdg:GridColumn FieldName="LastName"  IsSmart="True" Width="110" />
                        <sdg:GridColumn FieldName="Title"     IsSmart="True" Width="160" />
                        <sdg:GridColumn FieldName="Status"    IsSmart="True" Width="110" />
                        <sdg:GridColumn FieldName="HireDate"  IsSmart="True" Width="110" />
                        <sdg:GridColumn FieldName="Salary"    IsSmart="True" Width="100" />
                        <sdg:GridColumn FieldName="ZipCode"   IsSmart="True" Width="90" />
                        <sdg:GridColumn FieldName="Phone"     IsSmart="True" Width="130" />
                        <sdg:GridColumn FieldName="Email"     IsSmart="True" Width="200" />
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Background="#CCCCCC" />

                <ScrollViewer Grid.Column="2" Background="#FFFFFF" VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">

                        <Expander Header="Validation behavior">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="6">
                                <CheckBox Content="Allow commit on validation attribute errors"
                                          IsChecked="{Binding AllowCommitOnValidationAttributeError, ElementName=Grid, Mode=TwoWay}" />
                                <CheckBox Content="Show validation attribute errors"
                                          IsChecked="{Binding ShowValidationAttributeErrors, ElementName=Grid, Mode=TwoWay}" />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Try it" IsExpanded="False">
                            <TextBlock Margin="4" FontSize="11" Foreground="#666" TextWrapping="Wrap">
                                <Run Text="• Clear a Required First or Last name." />
                                <LineBreak />
                                <Run Text="• Push Salary above 1,000,000." />
                                <LineBreak />
                                <Run Text="• Type a 4-digit Zip." />
                                <LineBreak />
                                <Run Text="• Set a future Hire Date." />
                                <LineBreak />
                                <Run Text="Smart editors in play: currency on Salary, date mask on Hire Date, phone mask on Phone, a ComboBox on Status." />
                            </TextBlock>
                        </Expander>

                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
