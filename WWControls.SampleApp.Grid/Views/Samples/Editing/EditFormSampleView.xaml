<UserControl x:Class="WWControls.SampleApp.Grid.Views.Samples.Editing.EditFormSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Grid.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Grid.Views.Samples.Editing"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:EditFormSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <!--
            Custom edit-form layout, toggled on from the side panel. DataContext is the edited row
            item; each EditFormEditor drops in the matching column's editor by FieldName.
        -->
        <DataTemplate x:Key="CustomEditForm">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Name:"
                           Margin="0,4,12,4"
                           VerticalAlignment="Center" />
                <sdg:EditFormEditor Grid.Column="1"
                                    Grid.ColumnSpan="3"
                                    Margin="0,2"
                                    FieldName="Name" />

                <TextBlock Grid.Row="1"
                           Text="Department:"
                           Margin="0,4,12,4"
                           VerticalAlignment="Center" />
                <sdg:EditFormEditor Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="0,2"
                                    FieldName="Department" />

                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           Text="Priority:"
                           Margin="16,4,12,4"
                           VerticalAlignment="Center" />
                <sdg:EditFormEditor Grid.Row="1"
                                    Grid.Column="3"
                                    Margin="0,2"
                                    FieldName="PriorityId" />

                <TextBlock Grid.Row="2"
                           Text="Salary:"
                           Margin="0,4,12,4"
                           VerticalAlignment="Center" />
                <sdg:EditFormEditor Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="0,2"
                                    FieldName="Salary" />

                <TextBlock Grid.Row="2"
                           Grid.Column="2"
                           Text="Active:"
                           Margin="16,4,12,4"
                           VerticalAlignment="Center" />
                <sdg:EditFormEditor Grid.Row="2"
                                    Grid.Column="3"
                                    Margin="0,2"
                                    HorizontalAlignment="Left"
                                    FieldName="IsActive" />
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.EditForm}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Foreground="#444"
                       Margin="16,12,16,4"
                       FontSize="13"
                       TextWrapping="Wrap">
                <Run Text="Inline edit form — edit a whole row through a form" FontWeight="SemiBold" />
                <LineBreak />
                <Run Text="With EditFormShowMode set, the row promotes (on RowEditTrigger) into a caption/editor form hosted in the row's details area instead of the column-aligned strip. The form reuses each column's editor and the row's IEditableObject transaction, so Update commits every field and Cancel reverts them all." />
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="340" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    ItemsSource="{Binding People}"
                                    AutoGenerateColumns="False"
                                    RowEditTrigger="{Binding SelectedTrigger}"
                                    EditFormShowMode="{Binding SelectedShowMode}"
                                    EditFormPostConfirmationMode="{Binding SelectedConfirmation}"
                                    EditFormCaption="Edit Employee">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn IsReadOnly="True"
                                        Width="50"
                                        FieldName="Id"
                                        Header="#"
                                        EditFormCaption="Employee #" />

                        <!--  Name spans the full form width (EditFormColumnSpan = 2 renders it full-width).  -->
                        <sdg:GridColumn Width="2*"
                                        FieldName="Name"
                                        Header="Name"
                                        EditFormColumnSpan="2" />

                        <sdg:GridColumn Width="130"
                                        FieldName="Department"
                                        Header="Department">
                            <sdg:GridColumn.EditSettings>
                                <sdg:ComboBoxSettings ItemsSource="{Binding Departments}" />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>

                        <sdg:GridColumn Width="100"
                                        FieldName="PriorityId"
                                        Header="Priority"
                                        EditFormCaption="Priority level">
                            <sdg:GridColumn.EditSettings>
                                <sdg:ComboBoxSettings ItemsSource="{Binding Priorities}"
                                                      DisplayMemberPath="Name"
                                                      SelectedValuePath="Id" />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>

                        <sdg:GridColumn Width="110"
                                        FieldName="Salary"
                                        Header="Salary"
                                        DisplayStringFormat="C0"
                                        EditFormCaption="Annual Salary">
                            <sdg:GridColumn.EditSettings>
                                <sdg:NumericUpDownSettings Minimum="0"
                                                           Maximum="500000"
                                                           Increment="1000"
                                                           LargeIncrement="10000" />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>

                        <sdg:GridColumn Width="120"
                                        FieldName="StartDate"
                                        Header="Start Date">
                            <sdg:GridColumn.EditSettings>
                                <sdg:DatePickerSettings />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>

                        <sdg:GridColumn Width="70"
                                        FieldName="IsActive"
                                        Header="Active">
                            <sdg:GridColumn.EditSettings>
                                <sdg:CheckBoxSettings />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1"
                              Background="#CCCCCC"
                              HorizontalAlignment="Stretch"
                              Width="5" />

                <ScrollViewer Grid.Column="2"
                              Background="#FFFFFF"
                              Padding="8,4"
                              VerticalScrollBarVisibility="Auto">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">

                        <Expander Header="Form options" IsExpanded="True">
                            <sdg:SimpleStackPanel Orientation="Vertical"
                                                  Margin="4"
                                                  Spacing="8">
                                <TextBlock Text="EditFormShowMode:" FontWeight="Bold" />
                                <ComboBox ItemsSource="{Binding ShowModeChoices}" SelectedItem="{Binding SelectedShowMode, Mode=TwoWay}" />
                                <TextBlock Foreground="#666"
                                           FontSize="11"
                                           TextWrapping="Wrap">
                                    <Run Text="• None — full-row editing uses the column-aligned strip (no form)." />
                                    <LineBreak />
                                    <Run Text="• Inline — the form shows beneath the row; the row's cells stay visible." />
                                    <LineBreak />
                                    <Run Text="• InlineHideRow — the form replaces the row (its cells are hidden)." />
                                </TextBlock>

                                <TextBlock Text="RowEditTrigger:"
                                           Margin="0,4,0,0"
                                           FontWeight="Bold" />
                                <ComboBox ItemsSource="{Binding TriggerChoices}" SelectedItem="{Binding SelectedTrigger, Mode=TwoWay}" />

                                <TextBlock Text="EditFormPostConfirmationMode:"
                                           Margin="0,4,0,0"
                                           FontWeight="Bold" />
                                <ComboBox ItemsSource="{Binding ConfirmationChoices}" SelectedItem="{Binding SelectedConfirmation, Mode=TwoWay}" />
                                <TextBlock Foreground="#666"
                                           Text="When set, moving focus out of a form with unsaved changes prompts before discarding the edit."
                                           FontSize="11"
                                           TextWrapping="Wrap" />

                                <CheckBox x:Name="CustomLayoutToggle"
                                          Margin="0,8,0,0"
                                          Content="Use custom form layout (EditFormTemplate)"
                                          Checked="OnCustomLayoutToggled"
                                          Unchecked="OnCustomLayoutToggled" />
                                <TextBlock Foreground="#666"
                                           Text="Swaps the auto-generated layout for a two-column custom template built from EditFormEditor elements."
                                           FontSize="11"
                                           TextWrapping="Wrap" />

                                <Button Click="OnShowEditFormClick"
                                        Margin="0,8,0,0"
                                        Padding="8,4"
                                        Content="Show edit form for selected row" />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Last action" IsExpanded="True">
                            <TextBlock Foreground="#444"
                                       Text="{Binding LastAction}"
                                       Margin="4"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </Expander>

                        <Expander Header="Try it" IsExpanded="False">
                            <TextBlock Foreground="#666"
                                       Margin="4"
                                       FontSize="11"
                                       TextWrapping="Wrap">
                                <Run Text="• Click any cell — the row opens as a form (Inline shows it under the row; InlineHideRow replaces the row)." />
                                <LineBreak />
                                <Run Text="• Edit fields, then Update to commit them together, or Cancel / Esc to revert the whole row." />
                                <LineBreak />
                                <Run Text="• Select a row and click 'Show edit form' to open it programmatically (works with RowEditTrigger = Never too)." />
                                <LineBreak />
                                <Run Text="• Turn on the custom layout to see EditFormTemplate + EditFormEditor; note Name spans full-width and Salary's caption is customized in the auto layout." />
                                <LineBreak />
                                <Run Text="• Set a confirmation mode, edit a field, then click another row — you'll be asked before the edit is abandoned." />
                            </TextBlock>
                        </Expander>

                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
