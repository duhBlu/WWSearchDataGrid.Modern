<UserControl x:Class="WWControls.SampleApp.Grid.Views.Samples.Editing.EditEntireRowSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Grid.Controls"
             xmlns:local="clr-namespace:WWControls.SampleApp.Grid.Views.Samples.Editing"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:EditEntireRowSampleViewModel />
    </UserControl.DataContext>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.EditEntireRow}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Edit entire row — every cell at once, committed as a unit" />
                <LineBreak />
                <Run Text="Click into any cell and the whole row opens for editing behind a dimming overlay, with Update / Cancel beneath it. Clicking the grid doesn't end editing — the row stays open until you commit or cancel. Cancel reverts every field (the row implements IEditableObject)." />
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    ItemsSource="{Binding People}"
                                    AutoGenerateColumns="False"
                                    RowEditTrigger="{Binding SelectedTrigger}">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn Width="50" FieldName="Id" Header="#" IsReadOnly="True" />

                        <sdg:GridColumn Width="2*" FieldName="Name" Header="Name" />

                        <sdg:GridColumn Width="130" FieldName="Department" Header="Department">
                            <sdg:GridColumn.EditSettings>
                                <sdg:ComboBoxSettings ItemsSource="{Binding Departments}" />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>

                        <sdg:GridColumn Width="100" FieldName="PriorityId" Header="Priority">
                            <sdg:GridColumn.EditSettings>
                                <sdg:ComboBoxSettings ItemsSource="{Binding Priorities}"
                                                          DisplayMemberPath="Name"
                                                          SelectedValuePath="Id" />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>

                        <sdg:GridColumn Width="110" FieldName="Salary" Header="Salary" DisplayStringFormat="C0">
                            <sdg:GridColumn.EditSettings>
                                <sdg:NumericUpDownSettings Minimum="0" Maximum="500000" Increment="1000" LargeIncrement="10000" />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>

                        <sdg:GridColumn Width="120" FieldName="StartDate" Header="Start Date">
                            <sdg:GridColumn.EditSettings>
                                <sdg:DatePickerSettings />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>

                        <sdg:GridColumn Width="70" FieldName="IsActive" Header="Active">
                            <sdg:GridColumn.EditSettings>
                                <sdg:CheckBoxSettings />
                            </sdg:GridColumn.EditSettings>
                        </sdg:GridColumn>
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Background="#CCCCCC" />

                <ScrollViewer Grid.Column="2" Background="#FFFFFF" VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">

                        <Expander Header="Row edit trigger" IsExpanded="True">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="8">
                                <TextBlock FontWeight="Bold" Text="RowEditTrigger:" />
                                <ComboBox ItemsSource="{Binding TriggerChoices}"
                                          SelectedItem="{Binding SelectedTrigger, Mode=TwoWay}" />
                                <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap">
                                    <Run Text="• Never — full-row edit off; cells edit one at a time (stock behaviour)." />
                                    <LineBreak />
                                    <Run Text="• OnCellEditorOpen — the row opens the instant any cell editor opens." />
                                    <LineBreak />
                                    <Run Text="• OnCellValueChange — single-cell editing until you change a value; the first change opens the row." />
                                </TextBlock>

                                <Border Background="#F2F7FC" BorderBrush="#C9DDEE" BorderThickness="1"
                                        CornerRadius="4" Padding="8">
                                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="4">
                                        <TextBlock FontWeight="SemiBold" FontSize="12" Foreground="#0C5460"
                                                   Text="ⓘ  Commit / cancel as a unit" />
                                        <TextBlock FontSize="11" Foreground="#33555F" TextWrapping="Wrap"
                                                   Text="Update commits every cell at once; Cancel reverts the whole row. The revert works because EditRowItem implements IEditableObject — the grid snapshots the row when editing begins and restores it on cancel." />
                                    </sdg:SimpleStackPanel>
                                </Border>
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Last action" IsExpanded="True">
                            <TextBlock Margin="4" FontSize="12" Foreground="#444" TextWrapping="Wrap"
                                       Text="{Binding LastAction}" />
                        </Expander>

                        <Expander Header="Try it" IsExpanded="False">
                            <TextBlock Margin="4" FontSize="11" Foreground="#666" TextWrapping="Wrap">
                                <Run Text="• Click any cell — the row opens behind a dimmed overlay with every cell editable." />
                                <LineBreak />
                                <Run Text="• Edit several cells, then click Update to commit them together." />
                                <LineBreak />
                                <Run Text="• Or click Cancel (or press Esc) to throw the whole row's changes away." />
                                <LineBreak />
                                <Run Text="• Click elsewhere on the grid — nothing happens; the row stays in edit mode." />
                                <LineBreak />
                                <Run Text="• Switch the trigger to OnCellValueChange and tab through cells without editing — the overlay only appears once you change something." />
                            </TextBlock>
                        </Expander>

                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
