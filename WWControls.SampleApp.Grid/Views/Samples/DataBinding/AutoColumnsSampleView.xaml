<UserControl x:Class="WWControls.SampleApp.Grid.Views.Samples.DataBinding.AutoColumnsSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Grid.Controls"
             xmlns:sampleConverters="clr-namespace:WWControls.SampleApp.Grid.Converters"
             xmlns:local="clr-namespace:WWControls.SampleApp.Grid.Views.Samples.DataBinding"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:AutoColumnsSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <sampleConverters:EnumToBooleanConverter x:Key="EnumToBool" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.AutoColumns}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Auto-generated columns from attributes vs schema" />
                <LineBreak />
                <Run Text="AutoGenerateColumns=True with no GridColumns declared. Switch the item-source type to compare how columns are generated from POCO attributes versus a DataTable's schema." />
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="10">
                    <sdg:SearchDataGrid x:Name="PocoGrid"
                                        Visibility="{Binding IsPoco, Converter={StaticResource BoolToVis}}"
                                        ItemsSource="{Binding Customers}"
                                        AutoGenerateColumns="True"
                                        CanUserAddRows="False"
                                        FilterEditorPlacement="Row"
                                        ShowFilterRow="True"
                                        CanUserDeleteRows="False"
                                        ShowCriteriaInFilterRow="True"
                                        IsReadOnly="True" />

                    <sdg:SearchDataGrid x:Name="TableGrid"
                                        Visibility="{Binding IsDataTable, Converter={StaticResource BoolToVis}}"
                                        ItemsSource="{Binding VendorTableView}"
                                        AutoGenerateColumns="True"
                                        CanUserAddRows="False"
                                        FilterEditorPlacement="Row"
                                        ShowFilterRow="True"
                                        CanUserDeleteRows="False"
                                        ShowCriteriaInFilterRow="True"
                                        IsReadOnly="True" />
                </Grid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Background="#CCCCCC" />

                <ScrollViewer Grid.Column="2" Background="#FFFFFF" VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">

                        <Expander Header="Item source">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="4">
                                <RadioButton Content="POCO + Attributes"
                                             GroupName="ItemSourceKind"
                                             IsChecked="{Binding SourceKind, Converter={StaticResource EnumToBool}, ConverterParameter=Poco}" />
                                <RadioButton Content="DataTable"
                                             GroupName="ItemSourceKind"
                                             IsChecked="{Binding SourceKind, Converter={StaticResource EnumToBool}, ConverterParameter=DataTable}" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="11"
                                           Foreground="#666"
                                           TextWrapping="Wrap"
                                           Text="{Binding ActiveDescription}" />
                            </sdg:SimpleStackPanel>
                        </Expander>

                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
