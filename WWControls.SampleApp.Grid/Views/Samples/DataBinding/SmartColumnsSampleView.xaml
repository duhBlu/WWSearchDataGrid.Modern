<UserControl x:Class="WWControls.SampleApp.Grid.Views.Samples.DataBinding.SmartColumnsSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="http://schemas.wwcontrols.com/wpf"
             xmlns:sampleControls="clr-namespace:WWControls.SampleApp.Grid.Controls"
             xmlns:sampleConverters="clr-namespace:WWControls.SampleApp.Grid.Converters"
             xmlns:local="clr-namespace:WWControls.SampleApp.Grid.Views.Samples.DataBinding"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:SmartColumnsSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <sampleConverters:EnumToBooleanConverter x:Key="EnumToBool" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.SmartColumns}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Smart columns — configuration from data annotations" />
                <LineBreak />
                <Run Text="A column flagged IsSmart=True reads its bound property's annotations — [Display], [DisplayFormat] / [DataType], [GridEditor] / [DefaultEditor], and the mask attributes — to configure its header, display format, editor, and mask. Switch modes to compare against plain type-based defaults." />
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="10">
                    <!-- Declared columns, IsSmart off — CLR-type defaults only. -->
                    <sdg:SearchDataGrid x:Name="PlainGrid"
                                        Visibility="{Binding IsPlain, Converter={StaticResource BoolToVis}}"
                                        ItemsSource="{Binding Products}"
                                        AutoGenerateColumns="False"
                                        CanUserAddRows="False"
                                        CanUserDeleteRows="False">
                        <sdg:SearchDataGrid.GridColumns>
                            <sdg:GridColumn FieldName="Sku"          Width="90" />
                            <sdg:GridColumn FieldName="Name"         Width="150" />
                            <sdg:GridColumn FieldName="Category"     Width="100" />
                            <sdg:GridColumn FieldName="UnitPrice"    Width="90" />
                            <sdg:GridColumn FieldName="Discount"     Width="80" />
                            <sdg:GridColumn FieldName="Quantity"     Width="80" />
                            <sdg:GridColumn FieldName="RestockDate"  Width="120" />
                            <sdg:GridColumn FieldName="SupportPhone" Width="130" />
                            <sdg:GridColumn FieldName="Discontinued" Width="100" />
                        </sdg:SearchDataGrid.GridColumns>
                    </sdg:SearchDataGrid>

                    <!-- The same columns with IsSmart on. Product pins its Header in XAML to show
                         that smart mode never overwrites an explicitly set facet. -->
                    <sdg:SearchDataGrid x:Name="SmartGrid"
                                        Visibility="{Binding IsSmart, Converter={StaticResource BoolToVis}}"
                                        ItemsSource="{Binding Products}"
                                        AutoGenerateColumns="False"
                                        CanUserAddRows="False"
                                        CanUserDeleteRows="False">
                        <sdg:SearchDataGrid.GridColumns>
                            <sdg:GridColumn FieldName="Sku"          IsSmart="True" Width="90" />
                            <sdg:GridColumn FieldName="Name"         IsSmart="True" Header="Item (set in XAML)" Width="150" />
                            <sdg:GridColumn FieldName="Category"     IsSmart="True" Width="100" />
                            <sdg:GridColumn FieldName="UnitPrice"    IsSmart="True" Width="90" />
                            <sdg:GridColumn FieldName="Discount"     IsSmart="True" Width="80" />
                            <sdg:GridColumn FieldName="Quantity"     IsSmart="True" Width="80" />
                            <sdg:GridColumn FieldName="RestockDate"  IsSmart="True" Width="120" />
                            <sdg:GridColumn FieldName="SupportPhone" IsSmart="True" Width="130" />
                            <sdg:GridColumn FieldName="Discontinued" IsSmart="True" Width="100" />
                        </sdg:SearchDataGrid.GridColumns>
                    </sdg:SearchDataGrid>

                    <!-- No columns declared — every auto-generated column is created in smart mode. -->
                    <sdg:SearchDataGrid x:Name="AutoGrid"
                                        Visibility="{Binding IsAutoGenerated, Converter={StaticResource BoolToVis}}"
                                        ItemsSource="{Binding Products}"
                                        AutoGenerateColumns="True"
                                        EnableSmartColumnsGeneration="True"
                                        CanUserAddRows="False"
                                        CanUserDeleteRows="False" />
                </Grid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Background="#CCCCCC" />

                <ScrollViewer Grid.Column="2" Background="#FFFFFF" VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">

                        <Expander Header="Column configuration" IsExpanded="True">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="4">
                                <RadioButton Content="Plain (IsSmart off)"
                                             GroupName="SmartMode"
                                             IsChecked="{Binding Mode, Converter={StaticResource EnumToBool}, ConverterParameter=Plain}" />
                                <RadioButton Content="Smart (IsSmart per column)"
                                             GroupName="SmartMode"
                                             IsChecked="{Binding Mode, Converter={StaticResource EnumToBool}, ConverterParameter=Smart}" />
                                <RadioButton Content="Auto-generated + EnableSmartColumnsGeneration"
                                             GroupName="SmartMode"
                                             IsChecked="{Binding Mode, Converter={StaticResource EnumToBool}, ConverterParameter=AutoGenerated}" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="11"
                                           Foreground="#666"
                                           TextWrapping="Wrap"
                                           Text="{Binding ActiveDescription}" />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Annotation map" IsExpanded="False">
                            <TextBlock Margin="4" FontSize="11" Foreground="#666" TextWrapping="Wrap">
                                <Run Text="• [Display(Name)] → header + Column Chooser / Filter Panel label. [Display(Order)] orders auto-generated columns." />
                                <LineBreak />
                                <Run Text="• [DisplayFormat(&quot;P1&quot;)] → display format on Discount. Wins over [DataType]." />
                                <LineBreak />
                                <Run Text="• [DataType(Currency)] → C2 display format on Unit Price; [DataType(Date)] → short date on Restock Date." />
                                <LineBreak />
                                <Run Text="• [GridEditor(Spin)] → up/down editor on Quantity. [GridEditor(ComboBox)] on the Category enum self-populates the drop-down and beats its [DefaultEditor(Text)]." />
                                <LineBreak />
                                <Run Text="• [SimpleMask] → SKU (LL-0000) and Support Phone; UseMaskAsDisplayFormat=true formats the display cell too. [NumericMask(&quot;C2&quot;)] masks Unit Price edits. [DateTimeMask] masks Restock Date and picks a date editor." />
                                <LineBreak />
                                <Run Text="• Smart mode only fills blanks — the Product column's Header is set in XAML and stays." />
                            </TextBlock>
                        </Expander>

                        <Expander Header="Try it" IsExpanded="False">
                            <TextBlock Margin="4" FontSize="11" Foreground="#666" TextWrapping="Wrap">
                                <Run Text="• Double-click a Unit Price cell in Smart mode — the currency mask formats as you type. Compare with Plain." />
                                <LineBreak />
                                <Run Text="• Edit Category — plain gives a text box, smart gives a ComboBox of the enum values." />
                                <LineBreak />
                                <Run Text="• Edit Quantity — smart uses a spin editor from [GridEditor(Spin)]." />
                                <LineBreak />
                                <Run Text="• IsSmart is read once at column generation, so each mode is its own grid — flipping it on a live column has no effect." />
                            </TextBlock>
                        </Expander>

                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
