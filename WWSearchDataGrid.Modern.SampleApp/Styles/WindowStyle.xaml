<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Helpers">

    <!--
        ═══════════════════════════════════════════════════════════════════════
        WINDOW CHROME STYLES
        Adapted from wpfCabinetDesigner Default_Window_Style.
        Uses Theme.* DynamicResource keys — no dependency on ThemeBrushes.
        Uses DwmWindowHelper for proper maximize/shadow/border/corners.
        ═══════════════════════════════════════════════════════════════════════
    -->

    <!--  Window Chrome Button  -->
    <Style x:Key="SampleWindowChromeButtonStyle" TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="{DynamicResource Theme.Window.Button.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Window.Button.Foreground}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource Theme.Window.Button.Background.Hover}" />
                            <Setter Property="Foreground" Value="{DynamicResource Theme.Window.Button.Foreground.Hover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{DynamicResource Theme.Window.Button.Background.Pressed}" />
                            <Setter Property="Foreground" Value="{DynamicResource Theme.Window.Button.Foreground.Pressed}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Close Button with red hover  -->
    <Style x:Key="SampleWindowCloseButtonStyle"
           BasedOn="{StaticResource SampleWindowChromeButtonStyle}"
           TargetType="Button">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource Theme.Window.CloseButton.Hover}" />
                            <Setter Property="Foreground" Value="{DynamicResource Theme.Window.CloseButton.Foreground.Hover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{DynamicResource Theme.Window.CloseButton.Pressed}" />
                            <Setter Property="Foreground" Value="{DynamicResource Theme.Window.CloseButton.Foreground.Hover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Sample App Window Style  -->
    <Style x:Key="SampleAppWindowStyle" TargetType="{x:Type Window}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="WindowStyle" Value="None" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, sans-serif" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="MinWidth" Value="150" />

        <!--  DWM Window Helper  -->
        <Setter Property="helpers:DwmWindowHelper.IsEnabled" Value="True" />
        <Setter Property="helpers:DwmWindowHelper.EnableDropShadow" Value="True" />
        <Setter Property="helpers:DwmWindowHelper.BorderColor" Value="{DynamicResource Theme.Window.Border.Color}" />
        <Setter Property="helpers:DwmWindowHelper.BorderColorInactive" Value="{DynamicResource Theme.Window.Border.Inactive.Color}" />
        <Setter Property="helpers:DwmWindowHelper.CornerPreference" Value="Round" />
        <Setter Property="helpers:DwmWindowHelper.RespectTaskbar" Value="True" />

        <Setter Property="WindowChrome.WindowChrome">
            <Setter.Value>
                <WindowChrome CaptionHeight="30"
                              GlassFrameThickness="0"
                              UseAeroCaptionButtons="False"
                              CornerRadius="0"
                              ResizeBorderThickness="8" />
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Window}">
                    <Grid x:Name="WindowGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  TITLE BAR  -->
                        <Border x:Name="TitleBarBorder"
                                Grid.Row="0"
                                BorderThickness="0"
                                SnapsToDevicePixels="True">
                            <DockPanel x:Name="TitleBar"
                                       Background="{DynamicResource Theme.Window.TitleBar}">

                                <!--  CLOSE  -->
                                <Button x:Name="CloseButton"
                                        Style="{StaticResource SampleWindowCloseButtonStyle}"
                                        DockPanel.Dock="Right"
                                        Command="{x:Static SystemCommands.CloseWindowCommand}"
                                        Padding="15,0"
                                        Content="&#xE711;"
                                        FontWeight="Normal"
                                        RenderOptions.BitmapScalingMode="NearestNeighbor"
                                        FontSize="14"
                                        FontFamily="Segoe MDL2 Assets" />

                                <!--  MAX / RESTORE  -->
                                <Button x:Name="MaxButton"
                                        Style="{StaticResource SampleWindowChromeButtonStyle}"
                                        DockPanel.Dock="Right"
                                        Visibility="Collapsed"
                                        Command="{x:Static SystemCommands.MaximizeWindowCommand}"
                                        Padding="15,0"
                                        Content="&#xE922;"
                                        FontSize="10"
                                        FontWeight="Thin"
                                        FontFamily="Segoe MDL2 Assets" />

                                <!--  MIN  -->
                                <Button x:Name="MinButton"
                                        Style="{StaticResource SampleWindowChromeButtonStyle}"
                                        DockPanel.Dock="Right"
                                        Visibility="Collapsed"
                                        Command="{x:Static SystemCommands.MinimizeWindowCommand}"
                                        Padding="15,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Top"
                                        Content="&#xE921;"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="10"
                                        FontWeight="Thin" />

                                <!--  Icon + Title  -->
                                <Image Source="{TemplateBinding Icon}"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Margin="10,0,0,0"
                                       Width="16"
                                       Height="16"
                                       SnapsToDevicePixels="True"/>

                                <TextBlock Foreground="{DynamicResource Theme.Text.Primary}"
                                           Text="{TemplateBinding Title}"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold" />

                                <!--  Filler  -->
                                <Border DockPanel.Dock="Left" Background="Transparent" />
                            </DockPanel>
                        </Border>

                        <!--  CONTENT  -->
                        <Border x:Name="ContentBorder"
                                Grid.Row="1"
                                Background="{DynamicResource Theme.Window.Content}"
                                ClipToBounds="True">
                            <ContentPresenter />
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!--  Max/Min button visibility  -->
                        <Trigger Property="ResizeMode" Value="CanResize">
                            <Setter TargetName="MaxButton" Property="Visibility" Value="Visible" />
                            <Setter TargetName="MinButton" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="ResizeMode" Value="CanResizeWithGrip">
                            <Setter TargetName="MaxButton" Property="Visibility" Value="Visible" />
                            <Setter TargetName="MinButton" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="ResizeMode" Value="CanMinimize">
                            <Setter TargetName="MinButton" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <!--  Max/Restore icon swap + command swap  -->
                        <Trigger Property="WindowState" Value="Maximized">
                            <Setter TargetName="MaxButton" Property="Content" Value="&#xE923;" />
                            <Setter TargetName="MaxButton" Property="Command" Value="{x:Static SystemCommands.RestoreWindowCommand}" />
                            <Setter Property="WindowChrome.WindowChrome">
                                <Setter.Value>
                                    <WindowChrome CaptionHeight="30"
                                                  GlassFrameThickness="0"
                                                  UseAeroCaptionButtons="False"
                                                  CornerRadius="0"
                                                  ResizeBorderThickness="0" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
