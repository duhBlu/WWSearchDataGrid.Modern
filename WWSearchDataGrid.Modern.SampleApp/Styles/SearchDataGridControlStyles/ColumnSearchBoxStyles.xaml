<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:WWSearchDataGrid.Modern.WPF.Converters;assembly=WWSearchDataGrid.Modern.WPF"
                    xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF">

    <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
    <converters:HasValueToVisibilityConverter x:Key="HasValueToVisibilityConverter" />

    <!--  Custom Search Prefix Tooltip Style (example override)  -->
    <Style x:Key="CustomSearchPrefixTooltipStyle" TargetType="ToolTip">
        <Setter Property="Background" Value="{DynamicResource Theme.Tooltip.Background}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Tooltip.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,8,10,10" />
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <StackPanel Grid.IsSharedSizeScope="True" Margin="2">
                        <!--  Header  -->
                        <TextBlock Text="Search Shortcuts"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="{DynamicResource Theme.Tooltip.Header.Foreground}"
                                   Margin="0,0,0,4" />
                        <!--  Separator  -->
                        <Separator Margin="0,0,0,2"
                                   Background="{DynamicResource Theme.Tooltip.Separator}" />
                        <!--  Groups  -->
                        <ItemsControl ItemsSource="{Binding}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,4,0,0">
                                        <!--  Group header  -->
                                        <TextBlock Text="{Binding GroupName}"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource Theme.Tooltip.GroupHeader.Foreground}"
                                                   Margin="0,0,0,2" />
                                        <!--  Entries  -->
                                        <ItemsControl ItemsSource="{Binding Entries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="Prefix" />
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="Desc" />
                                                        </Grid.ColumnDefinitions>
                                                        <!--  Operator + Placeholder side by side  -->
                                                        <StackPanel Grid.Column="0"
                                                                    Orientation="Horizontal"
                                                                    Margin="8,1,16,1"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Operator}"
                                                                       FontFamily="Cascadia Code, Consolas"
                                                                       FontSize="12"
                                                                       FontWeight="Bold"
                                                                       Foreground="{DynamicResource Theme.Tooltip.Operator.Foreground}" />
                                                            <TextBlock Text="{Binding Placeholder}"
                                                                       FontFamily="Cascadia Code, Consolas"
                                                                       FontSize="12"
                                                                       FontStyle="Italic"
                                                                       Foreground="{DynamicResource Theme.Tooltip.Placeholder.Foreground}" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Description}"
                                                                   FontFamily="Segoe UI"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource Theme.Tooltip.Description.Foreground}"
                                                                   Margin="0,1,0,1"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ColumnSearchBox Style  -->
    <Style x:Key="CustomColumnSearchBoxStyle" TargetType="{x:Type sdg:ColumnSearchBox}">
        <Setter Property="SearchTooltipStyle" Value="{StaticResource CustomSearchPrefixTooltipStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:ColumnSearchBox}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  TextBox for non-checkbox columns  -->
                            <sdg:SearchTextBox x:Name="PART_SearchTextBox"
                                               Grid.Column="0"
                                               BorderThickness="0"
                                               MinHeight="0"
                                               Text="{Binding SearchText, RelativeSource={RelativeSource TemplatedParent}, UpdateSourceTrigger=PropertyChanged}"
                                               Padding="4,2"
                                               HorizontalContentAlignment="Left"
                                               VerticalAlignment="Center"
                                               VerticalContentAlignment="Center"
                                               Height="28"
                                               ShowToggleButton="False"
                                               ShowClearButton="False"
                                               TabIndex="0"
                                               FontSize="12">
                                <sdg:SearchTextBox.Style>
                                    <Style BasedOn="{StaticResource CustomSearchTextboxStyle}" TargetType="{x:Type sdg:SearchTextBox}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCheckboxColumn, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Setter Property="Background" Value="Transparent" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </sdg:SearchTextBox.Style>
                            </sdg:SearchTextBox>

                            <!--  CheckBox for boolean columns  -->
                            <CheckBox x:Name="PART_FilterCheckBox"
                                      Grid.Column="0"
                                      Grid.ColumnSpan="2"
                                      Background="Transparent"
                                      IsChecked="{Binding FilterCheckboxState, RelativeSource={RelativeSource TemplatedParent}}"
                                      Margin="6,5"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      TabIndex="0"
                                      ToolTip="Filter by checkbox state">
                                <CheckBox.Style>
                                    <Style BasedOn="{StaticResource CustomCheckBoxStyle}" TargetType="CheckBox">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCheckboxColumn, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>


                            <Button x:Name="PART_ClearFilterButton"
                                    Grid.Column="1"
                                    Focusable="true"
                                    Cursor="Hand"
                                    Command="{Binding ClearSearchTextCommand, RelativeSource={RelativeSource AncestorType=sdg:ColumnSearchBox}}"
                                    Margin="2,1,5,1"
                                    Padding="4"
                                    VerticalAlignment="Center"
                                    TabIndex="1"
                                    KeyboardNavigation.IsTabStop="True"
                                    ToolTip="Clear filter"
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="10"
                                    Content="&#xE8BB;">
                                <Button.Style>
                                    <Style TargetType="{x:Type Button}">
                                        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Disabled}" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <Border x:Name="border"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="3">
                                                        <ContentPresenter x:Name="contentPresenter"
                                                                          Focusable="False"
                                                                          Margin="{TemplateBinding Padding}"
                                                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                          RecognizesAccessKey="True"
                                                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Theme.ColumnSearchBox.Clear.Hover}" />
                                                <Setter Property="Foreground" Value="{DynamicResource Theme.ColumnSearchBox.Clear.Foreground.Hover}" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Theme.ColumnSearchBox.Clear.Pressed}" />
                                                <Setter Property="Foreground" Value="{DynamicResource Theme.ColumnSearchBox.Clear.Foreground.Pressed}" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.5" />
                                                <Setter Property="Cursor" Value="Arrow" />
                                            </Trigger>
                                            <!--  Show clear button when SearchText has content  -->
                                            <DataTrigger Binding="{Binding SearchText.Length, RelativeSource={RelativeSource AncestorType={x:Type sdg:ColumnSearchBox}}, Converter={StaticResource IntToVisibilityConverter}}" Value="{x:Static Visibility.Visible}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <!--  Show clear button when checkbox has filter applied  -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsCheckboxColumn, RelativeSource={RelativeSource AncestorType={x:Type sdg:ColumnSearchBox}}}" Value="True" />
                                                    <Condition Binding="{Binding HasActiveFilter, RelativeSource={RelativeSource AncestorType={x:Type sdg:ColumnSearchBox}}}" Value="True" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button x:Name="PART_RuleFilterEditorButton"
                                    Grid.Column="2"
                                    Cursor="Hand"
                                    Command="{Binding ShowRuleFilterEditorCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                    Margin="2,1,5,1"
                                    Padding="4"
                                    VerticalAlignment="Center"
                                    TabIndex="2"
                                    KeyboardNavigation.IsTabStop="True"
                                    ToolTip="Show Rule Filter Editor"
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="12"
                                    Content="&#xE71C;">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Disabled}" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <Border x:Name="border"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="3">
                                                        <ContentPresenter x:Name="contentPresenter"
                                                                          Focusable="False"
                                                                          Margin="{TemplateBinding Padding}"
                                                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                          RecognizesAccessKey="True"
                                                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Theme.ColumnSearchBox.Rule.Hover}" />
                                                <Setter Property="Foreground" Value="{DynamicResource Theme.ColumnSearchBox.Rule.Foreground.Hover}" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Theme.ColumnSearchBox.Rule.Pressed}" />
                                                <Setter Property="Foreground" Value="{DynamicResource Theme.ColumnSearchBox.Rule.Foreground.Pressed}" />
                                            </Trigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsComplexFilteringEnabled, RelativeSource={RelativeSource TemplatedParent}}" Value="True" />
                                                    <Condition Binding="{Binding SearchText, RelativeSource={RelativeSource AncestorType={x:Type sdg:ColumnSearchBox}}}" Value="" />
                                                    <Condition Binding="{Binding IsCheckboxColumn, RelativeSource={RelativeSource AncestorType={x:Type sdg:ColumnSearchBox}}}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                            <DataTrigger Binding="{Binding HasAdvancedFilter, RelativeSource={RelativeSource AncestorType={x:Type sdg:ColumnSearchBox}}}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Theme.ColumnSearchBox.Rule.Active}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource Theme.ColumnSearchBox.Rule.Active}" />
                                                <Setter Property="Foreground" Value="{DynamicResource Theme.ColumnSearchBox.Rule.Active.Foreground}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Background" Value="{DynamicResource Theme.ColumnSearchBox.Background}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.ColumnSearchBox.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

</ResourceDictionary>
