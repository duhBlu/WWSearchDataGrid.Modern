<Window x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.DataTableSample.DataTableSampleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
        xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.DataTableSample"
        Title="DataTable Source — SearchDataGrid"
        Style="{DynamicResource SampleAppWindowStyle}"
        Width="1100"
        Height="720"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d">
    <Window.DataContext>
        <local:DataTableSampleViewModel />
    </Window.DataContext>

    <DockPanel>
        <TextBlock DockPanel.Dock="Top"
                   Margin="16,12,16,0"
                   FontSize="13"
                   Foreground="#444"
                   TextWrapping="Wrap">
            <Run FontWeight="SemiBold" Text="VendorProducts DataTable" />
            <LineBreak />
            <Run Text="Tests filtering against a DataTable bound via DataView. Includes DBNull values (UnitCost, LastReceived), a computed expression column (ExtendedCost), and a column name with a space (Lead Time (Days))." />
        </TextBlock>

        <Grid DockPanel.Dock="Bottom" Background="#F0F0F0">
            <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Total Rows: " FontWeight="Bold" Foreground="#1C1C1C" VerticalAlignment="Center" />
                <TextBlock Text="{Binding VendorProducts.Rows.Count, StringFormat={}{0:N0}}"
                           Margin="4,0,16,0"
                           Foreground="#444"
                           VerticalAlignment="Center" />
                <TextBlock Text="Filtered: " FontWeight="Bold" Foreground="#1C1C1C" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ElementName=Grid, Path=Items.Count, StringFormat={}{0:N0}}"
                           Margin="4,0,16,0"
                           Foreground="#444"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <sdg:SearchDataGrid x:Name="Grid"
                            Margin="8"
                            ItemsSource="{Binding VendorProductsView}"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            IsReadOnly="True">
            <sdg:SearchDataGrid.GridColumns>
                <sdg:GridColumn FieldName="ProductId" Header="Product #" Width="90" />
                <sdg:GridColumn FieldName="VendorName" Header="Vendor" Width="180" />
                <sdg:GridColumn FieldName="PartNumber" Header="Part #" Width="120" />
                <sdg:GridColumn FieldName="UnitCost" Header="Unit Cost" Width="100"
                                DisplayStringFormat="C2" />
                <sdg:GridColumn FieldName="LastReceived" Header="Last Received" Width="130"
                                DisplayStringFormat="MM/dd/yyyy" />
                <sdg:GridColumn FieldName="InStock" Header="In Stock" Width="90" />
                <sdg:GridColumn FieldName="Lead Time (Days)" Header="Lead Time" Width="100" />
                <sdg:GridColumn FieldName="ExtendedCost" Header="Extended" Width="120"
                                DisplayStringFormat="C2" />
            </sdg:SearchDataGrid.GridColumns>
        </sdg:SearchDataGrid>
    </DockPanel>
</Window>
