<UserControl x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.AutoFilterRow.CustomTemplatesSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:sampleControls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.AutoFilterRow"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:CustomTemplatesSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style BasedOn="{StaticResource {x:Static sdg:SdgThemeKeys.PrimitivesCheckBox}}" TargetType="{x:Type CheckBox}" />
        <Style BasedOn="{StaticResource SampleRadioButtonStyle}" TargetType="{x:Type RadioButton}" />

        <!--
            Template 1 — Slider editor on a numeric column. The DataContext is the
            EditGridCellData supplied by ColumnFilterControl; binding {Binding Value}
            two-way routes through to SearchValue on the host. Filter semantics are
            whatever the column's DefaultSearchType resolves to (Equals for numerics) —
            this template demonstrates the editor swap; matching is exact equality.
        -->
        <DataTemplate x:Key="TotalSliderFilterTemplate">
            <DockPanel Margin="4,0" LastChildFill="True">
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding Value, StringFormat='C0'}"
                           Margin="6,0,0,0"
                           VerticalAlignment="Center"
                           Width="60"
                           TextAlignment="Right" />
                <Slider VerticalAlignment="Center"
                        Minimum="0"
                        Maximum="25000"
                        TickFrequency="1000"
                        IsSnapToTickEnabled="True"
                        Value="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>
        </DataTemplate>

        <!--
            Template 2 — DatePicker editor. SelectedDate is a DateTime?, written through
            to EditGridCellData.Value; the column's DisplayStringFormat strips the time-
            of-day from the equality check.
        -->
        <DataTemplate x:Key="DatePickerFilterTemplate">
            <DatePicker Margin="2,0"
                        VerticalAlignment="Center"
                        SelectedDate="{Binding Value, Mode=TwoWay}" />
        </DataTemplate>

        <!--
            Template 3 — Radio button group over Column.Tag (a string array set on the
            GridColumn descriptor). Radios don't bind IsChecked back to a shared Value
            cleanly, so the click handler in code-behind walks up to the
            EditGridCellData DataContext and writes Value directly.
        -->
        <DataTemplate x:Key="StatusRadioFilterTemplate">
            <ItemsControl HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          ItemsSource="{Binding Column.Tag}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <RadioButton Click="StatusRadio_Click"
                                     Margin="0,0,8,0"
                                     VerticalContentAlignment="Center"
                                     Content="{Binding}"
                                     GroupName="StatusFilter" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DataTemplate>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.CustomTemplates}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Foreground="#444"
                       Margin="16,12,16,4"
                       FontSize="13"
                       TextWrapping="Wrap">
                <Run Text="Custom auto-filter-row templates" FontWeight="SemiBold" />
                <LineBreak />
                <Run Text="Set GridColumn.AutoFilterRowEditTemplate to swap the default filter editor for any WPF control. The template's DataContext is an EditGridCellData exposing " />
                <Run FontStyle="Italic" Text="Value" />
                <Run Text=" (two-way), " />
                <Run FontStyle="Italic" Text="Column" />
                <Run Text=" (the GridColumn descriptor), and " />
                <Run FontStyle="Italic" Text="View" />
                <Run Text=" (the grid). The template controls only the editor surface — filter " />
                <Run FontStyle="Italic" Text="semantics" />
                <Run Text=" (Equals / Contains / etc.) follow the column's DefaultSearchType." />
            </TextBlock>

            <Border DockPanel.Dock="Bottom"
                    Background="#FAFAFA"
                    BorderBrush="#DDDDDD"
                    BorderThickness="0,1,0,0"
                    Padding="12,8">
                <TextBlock Foreground="#666"
                           FontSize="11"
                           TextWrapping="Wrap">
                    <Run Text="Try:" FontWeight="SemiBold" />
                    <LineBreak />
                    <Run Text="• Move the Total slider — Value (double) flows into SearchValue; the column compares with Equals semantics." />
                    <LineBreak />
                    <Run Text="• Pick a date in the OrderDate filter cell — rows narrow to that date (time stripped via DisplayStringFormat)." />
                    <LineBreak />
                    <Run Text="• Click a Status radio — rows narrow to that status. Click another to switch." />
                    <LineBreak />
                    <Run Text="• Other columns (Order #, Customer, Cancelled) keep the default text / checkbox editors for contrast." />
                </TextBlock>
            </Border>

            <sdg:SearchDataGrid x:Name="Grid"
                                IsReadOnly="True"
                                Margin="10"
                                ItemsSource="{Binding Items}"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                ShowCriteriaInAutoFilterRow="True"
                                EnableRuleFiltering="True"
                                SelectionMode="Extended"
                                SelectionUnit="FullRow">

                <sdg:SearchDataGrid.GridColumns>
                    <sdg:GridColumn Width="80"
                                    FieldName="OrderNumber"
                                    Header="Order #" />
                    <sdg:GridColumn Width="180"
                                    FieldName="CustomerName"
                                    Header="Customer" />
                    <sdg:GridColumn x:Name="StatusColumn"
                                    Width="280"
                                    FieldName="OrderStatusName"
                                    Header="Status"
                                    DefaultSearchType="Equals"
                                    AutoFilterRowEditTemplate="{StaticResource StatusRadioFilterTemplate}">
                        <sdg:GridColumn.Tag>
                            <x:Array Type="sys:String">
                                <sys:String>Submitted</sys:String>
                                <sys:String>In Production</sys:String>
                                <sys:String>Shipped</sys:String>
                                <sys:String>Delivered</sys:String>
                                <sys:String>Cancelled</sys:String>
                            </x:Array>
                        </sdg:GridColumn.Tag>
                    </sdg:GridColumn>
                    <sdg:GridColumn Width="160"
                                    FieldName="OrderDate"
                                    Header="Order Date"
                                    DisplayStringFormat="MM/dd/yyyy"
                                    DefaultSearchType="Equals"
                                    AutoFilterRowEditTemplate="{StaticResource DatePickerFilterTemplate}" />
                    <sdg:GridColumn Width="180"
                                    FieldName="OrderItemsTotalPrice"
                                    Header="Total"
                                    DisplayStringFormat="C2"
                                    DefaultSearchType="Equals"
                                    AutoFilterRowEditTemplate="{StaticResource TotalSliderFilterTemplate}" />
                    <sdg:GridColumn Width="80"
                                    FieldName="OrderCancelled"
                                    Header="Cancelled" />
                </sdg:SearchDataGrid.GridColumns>
            </sdg:SearchDataGrid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
