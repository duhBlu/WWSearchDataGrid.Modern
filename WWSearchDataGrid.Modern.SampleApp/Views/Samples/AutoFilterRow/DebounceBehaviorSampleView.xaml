<UserControl x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.AutoFilterRow.DebounceBehaviorSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:sampleControls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.AutoFilterRow"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:DebounceBehaviorSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <Style BasedOn="{StaticResource {x:Static sdg:SdgThemeKeys.CheckBox}}" TargetType="{x:Type CheckBox}" />
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,6,0,2" />
            <Setter Property="Foreground" Value="#333" />
        </Style>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.DebounceBehavior}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Debounce &amp; live-filter behavior" />
                <LineBreak />
                <Run Text="Three settings interact: " />
                <Run FontStyle="Italic" Text="SearchDataGrid.FilterRowDelay" />
                <Run Text=" debounces keystrokes; " />
                <Run FontStyle="Italic" Text="GridColumn.ImmediateUpdateAutoFilter" />
                <Run Text=" controls whether typing fires the filter at all; the auto-threshold (" />
                <Run FontStyle="Italic" Text="LiveFilteringRowCountThreshold = 100k" />
                <Run Text=") flips immediate-update off by default once the dataset is big enough that live filtering would stall the UI. Switch datasets, tweak the controls, and feel the difference." />
            </TextBlock>

            <Border DockPanel.Dock="Bottom"
                    Background="#FAFAFA"
                    BorderBrush="#DDDDDD"
                    BorderThickness="0,1,0,0"
                    Padding="12,8">
                <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold" Text="Try:" />
                    <LineBreak />
                    <Run Text="• FilterRowDelay=0, ImmediateUpdate=on, 1k rows: filter fires on every keystroke." />
                    <LineBreak />
                    <Run Text="• Slide FilterRowDelay to 500ms: filter waits ~500ms after the last keystroke." />
                    <LineBreak />
                    <Run Text="• Uncheck Immediate update: typing applies nothing — press Enter to commit. Slider has no effect in this mode." />
                    <LineBreak />
                    <Run Text="• Switch to 100k rows: live filtering auto-disables; the badge below reads INACTIVE unless you explicitly re-enable Immediate update." />
                    <LineBreak />
                    <Run Text="• Switch to 1M rows with Immediate update on: typing visibly stalls — the cost the threshold is built to avoid." />
                </TextBlock>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    ItemsSource="{Binding Items}"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    IsReadOnly="True"
                                    EnableRuleFiltering="True"
                                    SelectionMode="Extended"
                                    SelectionUnit="FullRow">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn Width="80"  FieldName="OrderNumber"          Header="Order #" DefaultSearchType="StartsWith" />
                        <sdg:GridColumn Width="120" FieldName="OrderStatusName"      Header="Status" DefaultSearchType="Equals" />
                        <sdg:GridColumn Width="150" FieldName="OrderDate"            Header="Order Date" DisplayStringFormat="MM/dd/yyyy" />
                        <sdg:GridColumn Width="220" FieldName="CustomerName"         Header="Customer" />
                        <sdg:GridColumn Width="160" FieldName="EmployeeName"         Header="Employee" />
                        <sdg:GridColumn Width="100" FieldName="OrderItemsTotalPrice" Header="Total" DisplayStringFormat="C2" />
                        <sdg:GridColumn Width="80"  FieldName="OrderCancelled"       Header="Cancelled" />
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Background="#CCCCCC" />

                <ScrollViewer Grid.Column="2" Background="#FFFFFF" VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">
                        <GroupBox Header="Dataset" Padding="6">
                            <sdg:SimpleStackPanel Orientation="Vertical" Spacing="6">
                                <RadioButton Content="1,000 rows  (below threshold)"
                                             GroupName="DatasetSize"
                                             IsChecked="{Binding IsSmallSelected, Mode=TwoWay}" />
                                <RadioButton Content="100,000 rows  (threshold trips)"
                                             GroupName="DatasetSize"
                                             IsChecked="{Binding IsMediumSelected, Mode=TwoWay}" />
                                <RadioButton Content="1,000,000 rows  (heavy)"
                                             GroupName="DatasetSize"
                                             IsChecked="{Binding IsLargeSelected, Mode=TwoWay}" />
                                <TextBlock FontSize="11" Foreground="#888"
                                           Text="{Binding Status}"
                                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
                            </sdg:SimpleStackPanel>
                        </GroupBox>

                        <GroupBox Header="Filter behavior" Padding="6">
                            <sdg:SimpleStackPanel Orientation="Vertical" Spacing="6">
                                <TextBlock Style="{StaticResource SectionLabelStyle}">
                                    <Run Text="FilterRowDelay:" />
                                    <Run Text="{Binding ElementName=Grid, Path=FilterRowDelay, Mode=OneWay}" />
                                    <Run Text="ms" />
                                </TextBlock>
                                <Slider Minimum="0"
                                        Maximum="2000"
                                        TickFrequency="100"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding ElementName=Grid, Path=FilterRowDelay, Mode=TwoWay}" />

                                <CheckBox Content="Immediate update auto-filter  (all columns)"
                                          IsChecked="{Binding ImmediateUpdateAutoFilter, Mode=TwoWay}"
                                          ToolTip="Applies the value to every column. Per-column granularity is in the Options Playground sample." />

                                <Border Background="#F4F6FA" BorderBrush="#D0D7E2" BorderThickness="1" CornerRadius="3" Padding="6,4" Margin="0,6,0,0">
                                    <TextBlock FontSize="11"
                                               TextWrapping="Wrap"
                                               Text="{Binding EffectiveLiveFilteringLabel}" />
                                </Border>

                                <Border Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="3" Padding="6,4" Margin="0,4,0,0">
                                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2">
                                        <TextBlock FontSize="11" Foreground="#666">
                                            <Run Text="Total rows:" />
                                            <Run Text="{Binding Items.Count, Mode=OneWay, StringFormat=N0}" FontWeight="SemiBold" />
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="#666">
                                            <Run Text="Visible after filter:" />
                                            <Run Text="{Binding ElementName=Grid, Path=Items.Count, Mode=OneWay, StringFormat=N0}" FontWeight="SemiBold" />
                                        </TextBlock>
                                    </sdg:SimpleStackPanel>
                                </Border>

                                <Button Content="Clear all filters"
                                        Margin="0,8,0,0"
                                        HorizontalAlignment="Left"
                                        Click="OnClearAllFiltersClicked" />
                            </sdg:SimpleStackPanel>
                        </GroupBox>
                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
