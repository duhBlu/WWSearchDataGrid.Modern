<UserControl x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.DataBinding.DataTableAutoGenSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:sampleControls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.DataBinding"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:DataTableAutoGenSampleViewModel />
    </UserControl.DataContext>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.DataTableAutoGen}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="DataTable with auto-generated columns" />
                <LineBreak />
                <Run Text="Same Vendor DataTable as the manual-columns sample, but no GridColumns declared. AutoGenerateColumns=True — columns and CLR types come straight from DataTable.Columns via ITypedList. No annotations to draw on, so headers match column names verbatim and no formatting is applied." />
            </TextBlock>

            <sdg:SearchDataGrid x:Name="Grid"
                                Margin="8,4"
                                ItemsSource="{Binding VendorTableView}"
                                AutoGenerateColumns="True"
                                EnableRuleFiltering="True"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                IsReadOnly="False" />
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
