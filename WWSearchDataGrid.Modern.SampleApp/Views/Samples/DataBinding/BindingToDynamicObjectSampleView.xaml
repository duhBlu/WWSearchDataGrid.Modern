<UserControl x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.DataBinding.BindingToDynamicObjectSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:sampleControls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
             xmlns:sampleConverters="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Converters"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.DataBinding"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:BindingToDynamicObjectSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <sampleConverters:EnumToBooleanConverter x:Key="EnumToBool" />
        <Style BasedOn="{StaticResource SampleRadioButtonStyle}" TargetType="{x:Type RadioButton}" />
        <Style BasedOn="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesButton}}" TargetType="{x:Type Button}" />
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.BindingToDynamicObject}">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Margin="16,12,16,4">
                <TextBlock FontSize="13" Foreground="#444" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold" Text="Binding a grid to dynamic (ExpandoObject) rows" />
                    <LineBreak />
                    <Run Text="The rows are ExpandoObjects — bags with no CLR properties — so each column reaches its value through an explicit GridColumn.Binding instead of a reflected FieldName. The three seed columns below are declared as Binding=&quot;{Binding Id, Mode=TwoWay}&quot; etc. Pick a type, add columns at runtime, add rows, and filter — all keyed off the binding path." />
                </TextBlock>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                    <TextBlock Text="New column type:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="#333" />
                    <RadioButton Content="Integer"
                                 Margin="0,0,12,0"
                                 IsChecked="{Binding SelectedColumnType, Converter={StaticResource EnumToBool}, ConverterParameter=Integer}" />
                    <RadioButton Content="String"
                                 Margin="0,0,12,0"
                                 IsChecked="{Binding SelectedColumnType, Converter={StaticResource EnumToBool}, ConverterParameter=String}" />
                    <RadioButton Content="DateTime"
                                 Margin="0,0,12,0"
                                 IsChecked="{Binding SelectedColumnType, Converter={StaticResource EnumToBool}, ConverterParameter=DateTime}" />
                    <RadioButton Content="Bool"
                                 Margin="0,0,12,0"
                                 IsChecked="{Binding SelectedColumnType, Converter={StaticResource EnumToBool}, ConverterParameter=Boolean}" />
                    <RadioButton Content="Combobox"
                                 Margin="0,0,16,0"
                                 IsChecked="{Binding SelectedColumnType, Converter={StaticResource EnumToBool}, ConverterParameter=ComboBox}" />
                    <Button Content="Add Column"
                            Margin="0,0,8,0"
                            Padding="12,4"
                            Click="OnAddColumnClick" />
                    <Button Content="Add Row"
                            Padding="12,4"
                            Command="{Binding AddRowCommand}" />
                </StackPanel>
            </StackPanel>

            <Grid Margin="8,4">
                <sdg:SearchDataGrid x:Name="DynamicGrid"
                                    ItemsSource="{Binding Rows}"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="True"
                                    CanUserDeleteRows="True"
                                    FilterEditorPlacement="Row"
                                    ShowFilterRow="True"
                                    ShowCriteriaInFilterRow="True">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn Header="Id" Binding="{Binding Id, Mode=TwoWay}" />
                        <sdg:GridColumn Header="First Name" Binding="{Binding FirstName, Mode=TwoWay}" />
                        <sdg:GridColumn Header="Last Name" Binding="{Binding LastName, Mode=TwoWay}" />
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
