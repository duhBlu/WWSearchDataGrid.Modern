<UserControl x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.Usability.CopyPasteSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:commands="clr-namespace:WWSearchDataGrid.Modern.WPF.Commands;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:sampleControls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.Usability"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:CopyPasteSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style BasedOn="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesButton}}" TargetType="{x:Type Button}" />
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.CopyPaste}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Copy / paste operations" />
                <LineBreak />
                <Run Text="Select cells or rows in the grid, then copy with Ctrl+C (values) or Ctrl+Shift+C (values with headers) — the same commands the built-in context menu uses. Output is tab-separated, so it pastes cleanly into the box below, Excel, or any editor. Display formatting (currency, dates) is preserved by default." />
                <LineBreak />
                <Run Text="The 'Total (raw copy)' column looks identical to 'Total' on screen — same C2 currency formatting — but sets CopyValueAsDisplayText=False, so it copies the underlying number (1234.56) instead of the formatted text ($1,234.56). Select cells from both Total columns and paste to compare." />
            </TextBlock>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="160" />
                </Grid.RowDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Row="0"
                                    Margin="10,4,10,0"
                                    ItemsSource="{Binding Items}"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    IsReadOnly="True"
                                    SelectionMode="Extended"
                                    SelectionUnit="CellOrRowHeader">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn Width="90" FieldName="OrderNumber" Header="Order #" />
                        <sdg:GridColumn Width="130" FieldName="OrderStatusName" Header="Status" DefaultSearchType="Equals" />
                        <sdg:GridColumn Width="150" FieldName="OrderDate" Header="Order Date" DisplayStringFormat="MM/dd/yyyy" />
                        <sdg:GridColumn Width="200" FieldName="CustomerName" Header="Customer" />
                        <sdg:GridColumn Width="110" FieldName="OrderItemsTotalPrice" Header="Total" DisplayStringFormat="C2" />
                        <!-- Same C2 display as 'Total', but copies the raw value rather than the formatted text. -->
                        <sdg:GridColumn Width="120" FieldName="OrderItemsTotalPrice" Header="Total (raw copy)" DisplayStringFormat="C2" CopyValueAsDisplayText="False" />
                        <sdg:GridColumn Width="90" FieldName="OrderCancelled" Header="Cancelled" />
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,8">
                    <Button Content="Copy"
                            Margin="0,0,8,0"
                            Command="{x:Static commands:ContextMenuCommands.CopySelectedCellValuesCommand}"
                            CommandParameter="{Binding ElementName=Grid}" />
                    <Button Content="Copy With Headers"
                            Command="{x:Static commands:ContextMenuCommands.CopySelectedCellValuesWithHeadersCommand}"
                            CommandParameter="{Binding ElementName=Grid}" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Margin="10,0,10,4"
                           FontSize="11"
                           Foreground="#666"
                           Text="Paste target (Ctrl+V):" />

                <TextBox Grid.Row="3"
                         Margin="10,0,10,10"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         FontFamily="Consolas"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap" />
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
