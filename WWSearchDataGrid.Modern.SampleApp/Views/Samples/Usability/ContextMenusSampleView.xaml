<UserControl x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.Usability.ContextMenusSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:sampleControls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.Usability"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:ContextMenusSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style BasedOn="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesCheckBox}}" TargetType="{x:Type CheckBox}" />
        <Style BasedOn="{StaticResource SampleExpanderStyle}" TargetType="{x:Type Expander}" />
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,6,0,2" />
            <Setter Property="Foreground" Value="#333" />
        </Style>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.ContextMenus}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Built-in context menus" />
                <LineBreak />
                <Run Text="Right-click different surfaces of the grid — a cell, a column header, or a row header — to see the built-in menus. They ship with the default theme; no wiring needed. Some items are gated by grid properties (toggle them on the right) or by context (e.g. Clear Column Filter appears only when that column is filtered)." />
            </TextBlock>

            <Border DockPanel.Dock="Bottom"
                    Background="#FAFAFA"
                    BorderBrush="#DDDDDD"
                    BorderThickness="0,1,0,0"
                    Padding="12,8">
                <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold" Text="Menus:" />
                    <LineBreak />
                    <Run Text="• Cell — Copy, Copy With Headers, Copy Cell Value, Filter By This Value." />
                    <LineBreak />
                    <Run Text="• Column header — Copy, Sort, Best Fit, Column Chooser, Hide Column, Fixed (Pin Left/Right/Unpin), Clear Filter, Open Filter Editor." />
                    <LineBreak />
                    <Run Text="• Row header — row-level operations." />
                </TextBlock>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="300" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    AllowFixedColumnMenu="True"
                                    IsColumnChooserEnabled="True"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    IsReadOnly="True"
                                    SelectionMode="Extended"
                                    SelectionUnit="CellOrRowHeader">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn Width="90" FieldName="OrderNumber" Header="Order #" />
                        <sdg:GridColumn Width="130" FieldName="OrderStatusName" Header="Status" DefaultSearchType="Equals" />
                        <sdg:GridColumn Width="150" FieldName="OrderDate" Header="Order Date" DisplayStringFormat="MM/dd/yyyy" />
                        <sdg:GridColumn Width="200" FieldName="CustomerName" Header="Customer" />
                        <sdg:GridColumn Width="110" FieldName="OrderItemsTotalPrice" Header="Total" DisplayStringFormat="C2" />
                        <sdg:GridColumn Width="90" FieldName="OrderCancelled" Header="Cancelled" />
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#CCCCCC" />

                <ScrollViewer Grid.Column="2" Padding="8,4" Background="#FFFFFF" VerticalScrollBarVisibility="Auto">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">
                        <GroupBox Header="Header-menu options" Padding="6">
                            <sdg:SimpleStackPanel Orientation="Vertical" Spacing="6">
                                <CheckBox Content="AllowFixedColumnMenu"
                                          IsChecked="{Binding ElementName=Grid, Path=AllowFixedColumnMenu, Mode=TwoWay}"
                                          ToolTip="Shows / hides the Fixed (Pin Left / Pin Right / Unpin) submenu in the column-header menu." />
                                <CheckBox Content="IsColumnChooserEnabled"
                                          IsChecked="{Binding ElementName=Grid, Path=IsColumnChooserEnabled, Mode=TwoWay}"
                                          ToolTip="Shows / hides the Column Chooser item in the column-header menu." />
                                <TextBlock FontSize="11"
                                           Foreground="#666"
                                           TextWrapping="Wrap"
                                           Text="Right-click a column header after toggling to see the items appear / disappear." />
                            </sdg:SimpleStackPanel>
                        </GroupBox>

                        <Border Background="#FFF3CD"
                                BorderBrush="#FFE069"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8">
                            <TextBlock FontSize="11" Foreground="#856404" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Text="🚧 Planned: " />
                                <Run Text="injecting custom menu items into the built-in menus is not yet supported — it needs a custom context-menu-item API. The built-in items above are fully available today." />
                            </TextBlock>
                        </Border>
                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
