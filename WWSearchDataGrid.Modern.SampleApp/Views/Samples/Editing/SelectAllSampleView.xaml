<UserControl x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.Editing.SelectAllSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:sampleControls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.Editing"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:SelectAllSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style BasedOn="{StaticResource {x:Static sdg:SdgThemeKeys.ComboBox}}" TargetType="{x:Type ComboBox}" />
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.SelectAll}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Select-All columns" />
                <LineBreak />
                <Run Text="A boolean column with IsSelectAllColumn=True gets a select-all checkbox in its header. Toggle it to flip every value. SelectAllScope decides which rows are affected: FilteredRows (only currently visible rows after filters), SelectedRows (only the user's current selection), or AllItems (every row regardless of filter or selection). Try filtering by Status before toggling." />
            </TextBlock>

            <Border DockPanel.Dock="Bottom"
                    Background="#FAFAFA"
                    Padding="10,8"
                    BorderBrush="#DDDDDD"
                    BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Select-All Scope:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox x:Name="ScopeCombo" SelectedIndex="0" Width="160"
                              ToolTip="FilteredRows: only rows currently passing filters. SelectedRows: only selected rows. AllItems: every row regardless of filter or selection.">
                        <sdg:SelectAllScope>FilteredRows</sdg:SelectAllScope>
                        <sdg:SelectAllScope>SelectedRows</sdg:SelectAllScope>
                        <sdg:SelectAllScope>AllItems</sdg:SelectAllScope>
                    </ComboBox>
                </StackPanel>
            </Border>

            <sdg:SearchDataGrid x:Name="Grid"
                                ItemsSource="{Binding Tasks}"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                EnableRuleFiltering="True"
                                SelectionMode="Extended"
                                SelectionUnit="FullRow"
                                EditorShowMode="MouseDown">
                <sdg:SearchDataGrid.GridColumns>
                    <sdg:GridColumn Width="50" FieldName="Id" Header="#" ReadOnly="True" />
                    <sdg:GridColumn Width="2*" FieldName="Title" Header="Title" ReadOnly="True" />
                    <sdg:GridColumn Width="120" FieldName="Status" Header="Status" ReadOnly="True" />
                    <sdg:GridColumn Width="100" FieldName="AssignedTo" Header="Assigned" ReadOnly="True" />

                    <!-- The select-all column. SelectAllScope binds to the ComboBox below. -->
                    <sdg:GridColumn Width="80" FieldName="IsComplete" Header="Done"
                                    IsSelectAllColumn="True"
                                    SelectAllScope="{Binding ElementName=ScopeCombo, UpdateSourceTrigger=PropertyChanged, Path=SelectedItem}">
                        <sdg:GridColumn.EditSettings>
                            <sdg:CheckBoxEditSettings />
                        </sdg:GridColumn.EditSettings>
                    </sdg:GridColumn>
                </sdg:SearchDataGrid.GridColumns>
            </sdg:SearchDataGrid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
