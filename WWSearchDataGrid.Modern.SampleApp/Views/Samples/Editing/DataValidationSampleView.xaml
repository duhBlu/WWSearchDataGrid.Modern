<UserControl x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.Editing.DataValidationSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:sampleControls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.Editing"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:DataValidationSampleViewModel />
    </UserControl.DataContext>
    <UserControl.Resources>
        <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesComboBox}}" />
        <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesCheckBox}}" />
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.DataValidation}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Data-annotation validation + smart columns" />
                <LineBreak />
                <Run Text="Every column is IsSmart=True, so it reads its property's data annotations to pick a header, editor, and mask (currency on Salary, date mask on Hire Date, phone mask on Phone, a ComboBox on Status). Edit a cell to an invalid value — clear a Required name, push Salary above 1,000,000, type a 4-digit Zip, or set a future Hire Date — to see the validation error and have the commit blocked. Use the toggles below to allow commit-on-error or turn error display off entirely." />
            </TextBlock>

            <Border DockPanel.Dock="Bottom"
                    Margin="16,4,16,12"
                    Padding="12,8"
                    Background="#F5F5F5"
                    CornerRadius="4">
                <StackPanel Orientation="Horizontal">
                    <CheckBox Content="Allow commit on validation attribute errors"
                              Margin="0,0,20,0"
                              VerticalAlignment="Center"
                              IsChecked="{Binding AllowCommitOnValidationAttributeError, ElementName=Grid, Mode=TwoWay}" />
                    <CheckBox Content="Show validation attribute errors"
                              VerticalAlignment="Center"
                              IsChecked="{Binding ShowValidationAttributeErrors, ElementName=Grid, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <sdg:SearchDataGrid x:Name="Grid"
                                Margin="8"
                                ItemsSource="{Binding Employees}"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                ShowValidationAttributeErrors="True"
                                AllowCommitOnValidationAttributeError="True">
                <sdg:SearchDataGrid.GridColumns>
                    <sdg:GridColumn FieldName="FirstName" IsSmart="True" Width="110" />
                    <sdg:GridColumn FieldName="LastName"  IsSmart="True" Width="110" />
                    <sdg:GridColumn FieldName="Title"     IsSmart="True" Width="160" />
                    <sdg:GridColumn FieldName="Status"    IsSmart="True" Width="110" />
                    <sdg:GridColumn FieldName="HireDate"  IsSmart="True" Width="110" />
                    <sdg:GridColumn FieldName="Salary"    IsSmart="True" Width="100" />
                    <sdg:GridColumn FieldName="ZipCode"   IsSmart="True" Width="90" />
                    <sdg:GridColumn FieldName="Phone"     IsSmart="True" Width="130" />
                    <sdg:GridColumn FieldName="Email"     IsSmart="True" Width="200" />
                </sdg:SearchDataGrid.GridColumns>
            </sdg:SearchDataGrid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
