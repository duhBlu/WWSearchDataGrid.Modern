<UserControl x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.Editing.DataErrorIndicationSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:sampleControls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.Editing"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:DataErrorIndicationSampleViewModel />
    </UserControl.DataContext>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.DataErrorIndication}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Severity-aware error badges from a self-reporting row" />
                <LineBreak />
                <Run Text="Each row is a PersonInfo deriving from ObservableValidator, so it reports its own errors through INotifyDataErrorInfo — the grid reads them directly instead of reflecting over attributes. Implementing IValidationSeverityProvider turns the single red badge into three tones: a missing First/Last name is a blocking Error (red), a missing Address or Email is an advisory Info (blue), and a badly formatted Phone or Email is a Warning (amber). Edit a cell and commit — the badge re-evaluates the moment the row revalidates. Commit-on-error is on, so advisory badges never block an edit." />
            </TextBlock>

            <sdg:SearchDataGrid x:Name="Grid"
                                Margin="8"
                                ItemsSource="{Binding People}"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                ShowValidationAttributeErrors="True"
                                AllowCommitOnValidationAttributeError="True">
                <sdg:SearchDataGrid.GridColumns>
                    <sdg:GridColumn FieldName="FirstName" IsSmart="True" Width="120" />
                    <sdg:GridColumn FieldName="LastName"  IsSmart="True" Width="120" />
                    <sdg:GridColumn FieldName="Address"   IsSmart="True" Width="190" />
                    <sdg:GridColumn FieldName="Phone"     IsSmart="True" Width="140" />
                    <sdg:GridColumn FieldName="Email"     IsSmart="True" Width="220" />
                </sdg:SearchDataGrid.GridColumns>
            </sdg:SearchDataGrid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
