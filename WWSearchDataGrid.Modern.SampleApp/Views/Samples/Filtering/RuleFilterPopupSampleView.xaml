<UserControl x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.Filtering.RuleFilterPopupSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:sampleControls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.Filtering"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:RuleFilterPopupSampleViewModel />
    </UserControl.DataContext>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.RuleFilterPopup}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Rule filter popup (ColumnFilterEditor)" />
                <LineBreak />
                <Run Text="Click the funnel icon in any column header to open the rule editor. Two tabs: 'Rules' lets you build multi-criteria expressions joined with AND / OR; 'Filter Values' shows the distinct values for the column with checkboxes. EnableRuleFiltering=True grid-wide and per-column enables the popup." />
            </TextBlock>

            <Border DockPanel.Dock="Bottom"
                    Background="#FAFAFA"
                    BorderBrush="#DDDDDD"
                    BorderThickness="0,1,0,0"
                    Padding="12,8">
                <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold" Text="Try:" />
                    <Run Text="Click the funnel icon in the Status column header. On the Rules tab, add multiple criteria; on the Filter Values tab, uncheck values you want to exclude. Hit OK and the FilterPanel chip strip at the top of the grid shows the active filter." />
                </TextBlock>
            </Border>

            <sdg:SearchDataGrid x:Name="Grid"
                                Margin="10"
                                ItemsSource="{Binding Items}"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                IsReadOnly="True"
                                EnableRuleFiltering="True"
                                SelectionMode="Extended"
                                SelectionUnit="FullRow">
                <sdg:SearchDataGrid.GridColumns>
                    <sdg:GridColumn Width="80" FieldName="OrderNumber" Header="Order #" />
                    <sdg:GridColumn Width="120" FieldName="OrderStatusName" Header="Status" DefaultSearchType="Equals" />
                    <sdg:GridColumn Width="100" FieldName="OrderLocationName" Header="Location" DefaultSearchType="Equals" />
                    <sdg:GridColumn Width="150" FieldName="OrderDate" Header="Date" DisplayStringFormat="MM/dd/yyyy" />
                    <sdg:GridColumn Width="200" FieldName="CustomerName" Header="Customer" />
                    <sdg:GridColumn Width="160" FieldName="EmployeeName" Header="Employee" />
                    <sdg:GridColumn Width="100" FieldName="OrderItemsTotalPrice" Header="Total" DisplayStringFormat="C2" />
                    <sdg:GridColumn Width="80" FieldName="OrderCancelled" Header="Cancelled" />
                </sdg:SearchDataGrid.GridColumns>
            </sdg:SearchDataGrid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
