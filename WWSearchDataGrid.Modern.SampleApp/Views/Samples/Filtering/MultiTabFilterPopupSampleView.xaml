<UserControl x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.Filtering.MultiTabFilterPopupSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:sampleControls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.Filtering"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:MultiTabFilterPopupSampleViewModel />
    </UserControl.DataContext>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.MultiTabFilterPopup}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Multi-tab custom filter popup" />
                <LineBreak />
                <Run Text="The default popup is tabbed (Rules + Values). Custom popups can be too: CustomColumnFilterTabs takes any number of ColumnFilterTab entries, each with its own header and template. The popup hosts them in a TabControl styled to match the default chrome, and every tab's PART_FilterElement gets its own FilterElementContext — they all drive the same column's SearchTemplateController, so switching tabs swaps the editing surface without losing filter state." />
            </TextBlock>

            <Border DockPanel.Dock="Bottom"
                    Background="#FAFAFA"
                    BorderBrush="#DDDDDD"
                    BorderThickness="0,1,0,0"
                    Padding="12,8">
                <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold" Text="Try:" />
                    <Run Text="Open the Order Date popup — pick &quot;This Month&quot; on the Periods tab, then switch to the Calendar tab. The tree reflects the dates the period rule produced. Or open Total — set a range on the Slider tab, switch to Rule, and inspect the underlying Between template." />
                </TextBlock>
            </Border>

            <sdg:SearchDataGrid x:Name="Grid"
                                Margin="10"
                                ItemsSource="{Binding Items}"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                IsReadOnly="True"
                                SelectionMode="Extended"
                                SelectionUnit="FullRow">
                <sdg:SearchDataGrid.GridColumns>
                    <sdg:GridColumn Width="80" FieldName="OrderNumber" Header="Order #" />
                    <sdg:GridColumn Width="120" FieldName="OrderStatusName" Header="Status" />

                    <!--
                        Order Date: two custom tabs — Periods (DateInterval enum picker) and
                        Calendar (Year/Month/Day tree). Same column, same controller, two ways
                        to author the date filter.
                    -->
                    <sdg:GridColumn Width="140"
                                    FieldName="OrderDate"
                                    Header="Order Date"
                                    DisplayStringFormat="MM/dd/yyyy">
                        <sdg:GridColumn.CustomColumnFilterTabs>
                            <sdg:ColumnFilterTab Header="Periods">
                                <sdg:ColumnFilterTab.Template>
                                    <ControlTemplate>
                                        <sdg:DatePeriodsFilterElement x:Name="PART_FilterElement" Margin="6" />
                                    </ControlTemplate>
                                </sdg:ColumnFilterTab.Template>
                            </sdg:ColumnFilterTab>
                            <sdg:ColumnFilterTab Header="Calendar">
                                <sdg:ColumnFilterTab.Template>
                                    <ControlTemplate>
                                        <sdg:DateTreeFilterElement x:Name="PART_FilterElement"
                                                                   Margin="6"
                                                                   ShowCounts="True" />
                                    </ControlTemplate>
                                </sdg:ColumnFilterTab.Template>
                            </sdg:ColumnFilterTab>
                        </sdg:GridColumn.CustomColumnFilterTabs>
                    </sdg:GridColumn>

                    <sdg:GridColumn Width="180" FieldName="CustomerName" Header="Customer" />

                    <!--
                        Total: three custom tabs — Slider (Between with numeric inputs),
                        Values (CheckedList of distinct prices), and Rule (single-rule editor
                        for "is greater than X", "is between A and B", etc.).
                    -->
                    <sdg:GridColumn Width="120"
                                    FieldName="OrderItemsTotalPrice"
                                    Header="Total"
                                    DisplayStringFormat="C2">
                        <sdg:GridColumn.CustomColumnFilterTabs>
                            <sdg:ColumnFilterTab Header="Slider">
                                <sdg:ColumnFilterTab.Template>
                                    <ControlTemplate>
                                        <sdg:RangeFilterElement x:Name="PART_FilterElement"
                                                                Margin="6"
                                                                SliderMinimum="0"
                                                                SliderMaximum="100000" />
                                    </ControlTemplate>
                                </sdg:ColumnFilterTab.Template>
                            </sdg:ColumnFilterTab>
                            <sdg:ColumnFilterTab Header="Values">
                                <sdg:ColumnFilterTab.Template>
                                    <ControlTemplate>
                                        <sdg:CheckedListFilterElement x:Name="PART_FilterElement"
                                                                      Margin="6"
                                                                      ShowCounts="True" />
                                    </ControlTemplate>
                                </sdg:ColumnFilterTab.Template>
                            </sdg:ColumnFilterTab>
                            <sdg:ColumnFilterTab Header="Rule">
                                <sdg:ColumnFilterTab.Template>
                                    <ControlTemplate>
                                        <sdg:MultiFilterElement x:Name="PART_FilterElement" Margin="6" />
                                    </ControlTemplate>
                                </sdg:ColumnFilterTab.Template>
                            </sdg:ColumnFilterTab>
                        </sdg:GridColumn.CustomColumnFilterTabs>
                    </sdg:GridColumn>

                    <sdg:GridColumn Width="80" FieldName="OrderCancelled" Header="Cancelled" />
                </sdg:SearchDataGrid.GridColumns>
            </sdg:SearchDataGrid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
