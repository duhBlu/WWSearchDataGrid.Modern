<UserControl x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.Filtering.CustomPredicateSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:sampleControls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.Filtering"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:CustomPredicateSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style BasedOn="{StaticResource {x:Static sdg:SdgThemeKeys.CheckBox}}" TargetType="{x:Type CheckBox}" />
        <Style BasedOn="{StaticResource SampleExpanderStyle}" TargetType="{x:Type Expander}" />
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.CustomPredicate}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Custom Predicate&lt;object&gt; + FilterPanel events" />
                <LineBreak />
                <Run Text="A custom SearchFilter delegate runs alongside any column filters. Enter a substring on the right and check 'Apply predicate' to filter rows whose Notes contain it. The bottom panel logs every FilterPanel event in real time — toggle filters off, remove chips, swap AND/OR, clear all." />
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    ItemsSource="{Binding Items}"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    IsReadOnly="True"
                                    EnableRuleFiltering="True"
                                    SelectionMode="Extended"
                                    SelectionUnit="FullRow">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn Width="80" FieldName="OrderNumber" Header="Order #" DefaultSearchType="StartsWith" />
                        <sdg:GridColumn Width="120" FieldName="OrderStatusName" Header="Status" DefaultSearchType="Equals" />
                        <sdg:GridColumn Width="200" FieldName="CustomerName" Header="Customer" />
                        <sdg:GridColumn Width="160" FieldName="EmployeeName" Header="Employee" />
                        <sdg:GridColumn Width="100" FieldName="OrderItemsTotalPrice" Header="Total" DisplayStringFormat="C2" />
                        <sdg:GridColumn Width="200" FieldName="SpecialInstructionsText" Header="Notes" />
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Background="#CCCCCC" />

                <DockPanel Grid.Column="2" Background="#FFFFFF">
                    <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" Padding="8,4">
                        <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">

                            <Expander Header="Custom SearchFilter predicate" IsExpanded="True"
                                      ToolTip="A Predicate&lt;object&gt; applied alongside column filters. Receives each OrderItem; return true to keep.">
                                <sdg:SimpleStackPanel Orientation="Vertical" Spacing="6" Margin="4">
                                    <TextBlock Text="Notes contain:" FontWeight="Bold" />
                                    <TextBox Text="{Binding CustomPredicateText, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox IsChecked="{Binding CustomPredicateActive}" Content="Apply predicate"
                                              ToolTip="When checked, only rows whose SpecialInstructionsText contains the entered substring (case-insensitive) are kept. Leave the textbox blank to filter to rows with notes only." />
                                </sdg:SimpleStackPanel>
                            </Expander>

                            <Expander Header="FilterPanel events" IsExpanded="True"
                                      ToolTip="Live log of FiltersEnabledChanged, FilterRemoved, ValueRemovedFromToken, OperatorToggled, ClearAllFiltersRequested.">
                                <ListBox ItemsSource="{Binding EventLog}"
                                         Height="240"
                                         FontFamily="Consolas"
                                         FontSize="11" />
                            </Expander>

                        </sdg:SimpleStackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
