<UserControl x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.Filtering.SearchModesSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:sampleControls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.Filtering"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:SearchModesSampleViewModel />
    </UserControl.DataContext>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.SearchModes}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Per-column search modes" />
                <LineBreak />
                <Run Text="DefaultSearchType chooses how each column's search box matches: StartsWith (string default), EndsWith, Contains, or Equals. UseCheckBoxInSearchBox, AllowFilterPopup, and AllowAutoFilter tune or remove the per-column editors." />
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    ItemsSource="{Binding Items}"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    IsReadOnly="True"
                                    SelectionMode="Extended"
                                    SelectionUnit="FullRow">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn Width="80" FieldName="OrderNumber" Header="Order #" ShowCriteriaInFilterRow="True" />
                        <sdg:GridColumn Width="120" FieldName="OrderStatusName" Header="Status" DefaultSearchType="Equals" />
                        <sdg:GridColumn Width="100" FieldName="OrderLocationName" Header="Location" DefaultSearchType="Equals" />
                        <sdg:GridColumn Width="200" FieldName="CustomerName" Header="Customer" />
                        <sdg:GridColumn Width="160" FieldName="EmployeeName" Header="Employee" DefaultSearchType="Contains" />
                        <sdg:GridColumn Width="120" FieldName="DealerPO" Header="Dealer PO" DefaultSearchType="EndsWith" />
                        <sdg:GridColumn Width="80" FieldName="OrderCancelled" Header="Cancelled" />
                        <sdg:GridColumn Width="60" FieldName="State" Header="State" DefaultSearchType="Equals" AllowFilterPopup="False" />
                        <sdg:GridColumn Width="200" FieldName="SpecialInstructionsText" Header="Notes (no filter)" AllowAutoFilter="False" />
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Background="#CCCCCC" />

                <ScrollViewer Grid.Column="2" Background="#FFFFFF" VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">

                        <Expander Header="Grid-level filtering">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="4">
                                <CheckBox IsChecked="{Binding ElementName=Grid, Path=AllowFilterPopup}"
                                          Content="Allow Filter Popup"
                                          ToolTip="Master switch for the funnel-icon rule popup. When off, columns fall back to plain text search." />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Try it" IsExpanded="False">
                            <TextBlock Margin="4" FontSize="11" Foreground="#666" TextWrapping="Wrap">
                                <Run Text="• Type '500' in Order # — matches anchor at the start (StartsWith)." />
                                <LineBreak />
                                <Run Text="• Type 'Submitted' in Status — exact match only (Equals)." />
                                <LineBreak />
                                <Run Text="• Type a partial name in Customer — anchored at the start (string default StartsWith). Override to Contains on a column when you want match-anywhere." />
                                <LineBreak />
                                <Run Text="• State has rule-filtering OFF — only the simple search box, no funnel icon." />
                                <LineBreak />
                                <Run Text="• Notes has filtering disabled entirely — no search box at all." />
                            </TextBlock>
                        </Expander>

                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
