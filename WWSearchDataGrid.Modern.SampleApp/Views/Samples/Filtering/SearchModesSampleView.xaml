<UserControl x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.Filtering.SearchModesSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:sampleControls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.Filtering"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:SearchModesSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style BasedOn="{StaticResource {x:Static sdg:SdgThemeKeys.CheckBox}}" TargetType="{x:Type CheckBox}" />
        <Style BasedOn="{StaticResource SampleExpanderStyle}" TargetType="{x:Type Expander}" />
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.SearchModes}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Per-column search modes" />
                <LineBreak />
                <Run Text="DefaultSearchMode chooses how a column's search box matches: Contains anywhere, StartsWith / EndsWith for prefix / suffix, Equals for exact match. UseCheckBoxInSearchBox swaps the text box for a tri-state checkbox on bool columns. AllowFiltering=False hides the search box entirely. EnableRuleFiltering toggles the funnel-icon rule popup." />
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    ItemsSource="{Binding Items}"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    IsReadOnly="True"
                                    EnableRuleFiltering="True"
                                    SelectionMode="Extended"
                                    SelectionUnit="FullRow">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn Width="80" FieldName="OrderNumber" Header="Order #" DefaultSearchMode="StartsWith" />
                        <sdg:GridColumn Width="120" FieldName="OrderStatusName" Header="Status" DefaultSearchMode="Equals" />
                        <sdg:GridColumn Width="100" FieldName="OrderLocationName" Header="Location" DefaultSearchMode="Equals" />
                        <sdg:GridColumn Width="200" FieldName="CustomerName" Header="Customer" />
                        <sdg:GridColumn Width="160" FieldName="EmployeeName" Header="Employee" DefaultSearchMode="Contains" />
                        <sdg:GridColumn Width="120" FieldName="DealerPO" Header="Dealer PO" DefaultSearchMode="EndsWith" />
                        <sdg:GridColumn Width="80" FieldName="OrderCancelled" Header="Cancelled" />
                        <sdg:GridColumn Width="60" FieldName="State" Header="State" DefaultSearchMode="Equals" EnableRuleFiltering="False" />
                        <sdg:GridColumn Width="200" FieldName="SpecialInstructionsText" Header="Notes (no filter)" AllowFiltering="False" />
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Background="#CCCCCC" />

                <ScrollViewer Grid.Column="2" Background="#FFFFFF" VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">
                        <Expander Header="Grid-level filtering" IsExpanded="True">
                            <sdg:SimpleStackPanel Orientation="Vertical" Spacing="4" Margin="4">
                                <CheckBox IsChecked="{Binding ElementName=Grid, Path=EnableRuleFiltering}"
                                          Content="Enable Rule Filtering"
                                          ToolTip="Master switch for the funnel-icon rule popup. When off, columns fall back to plain text search." />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <TextBlock Margin="4" FontSize="11" Foreground="#666" TextWrapping="Wrap">
                            <Run FontWeight="SemiBold" Text="Try:" />
                            <LineBreak />
                            <Run Text="• Type '500' in Order # — matches anchor at the start (StartsWith)." />
                            <LineBreak />
                            <Run Text="• Type 'Submitted' in Status — exact match only (Equals)." />
                            <LineBreak />
                            <Run Text="• Type a partial name in Customer — matches anywhere (Contains)." />
                            <LineBreak />
                            <Run Text="• State has rule-filtering OFF — only the simple search box, no funnel icon." />
                            <LineBreak />
                            <Run Text="• Notes has filtering disabled entirely — no search box at all." />
                        </TextBlock>
                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
