<Window x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.AutoGeneratedColumnsSample.AutoGeneratedColumnsSampleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
        xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.AutoGeneratedColumnsSample"
        Title="Auto-Generated Columns — SearchDataGrid"
        Style="{DynamicResource SampleAppWindowStyle}"
        Width="1100"
        Height="720"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d">
    <Window.DataContext>
        <local:AutoGeneratedColumnsSampleViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="16,12,16,4"
                   FontSize="13"
                   Foreground="#444"
                   TextWrapping="Wrap">
            <Run FontWeight="SemiBold" Text="Customers — POCO with [Display] / [Browsable] attributes" />
            <LineBreak />
            <Run Text="No GridColumns declared. AutoGenerateColumns=True. Headers come from [Display(Name)], order from [Display(Order)]. InternalId is hidden by [Browsable(false)]; InternalNotes by [Display(AutoGenerateField=false)]." />
        </TextBlock>

        <sdg:SearchDataGrid Grid.Row="1"
                            Margin="8"
                            ItemsSource="{Binding Customers}"
                            AutoGenerateColumns="True"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            IsReadOnly="True" />

        <TextBlock Grid.Row="2"
                   Margin="16,12,16,4"
                   FontSize="13"
                   Foreground="#444"
                   TextWrapping="Wrap">
            <Run FontWeight="SemiBold" Text="Vendors — DataTable, no annotations" />
            <LineBreak />
            <Run Text="No GridColumns declared. AutoGenerateColumns=True. Columns and types come straight from DataTable.Columns via ITypedList." />
        </TextBlock>

        <sdg:SearchDataGrid Grid.Row="3"
                            Margin="8"
                            ItemsSource="{Binding VendorTableView}"
                            AutoGenerateColumns="True"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            IsReadOnly="True" />
    </Grid>
</Window>
