<UserControl x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.AnimationPerformance.ScrollingAnimationSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:sampleControls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
             xmlns:sampleConverters="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Converters"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.AnimationPerformance"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:ScrollingAnimationSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <sampleConverters:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />

        <Style BasedOn="{StaticResource {x:Static sdg:SdgThemeKeys.Button}}" TargetType="{x:Type Button}" />
        <Style BasedOn="{StaticResource {x:Static sdg:SdgThemeKeys.CheckBox}}" TargetType="{x:Type CheckBox}" />
        <Style BasedOn="{StaticResource SampleRadioButtonStyle}" TargetType="{x:Type RadioButton}" />
        <Style BasedOn="{StaticResource SampleSliderStyle}" TargetType="{x:Type Slider}" />
        <Style BasedOn="{StaticResource SampleExpanderStyle}" TargetType="{x:Type Expander}" />
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.ScrollingAnimation}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Scrolling animation" />
                <LineBreak />
                <Run Text="Mouse-wheel momentum / inertia. Per-pixel scrolling switches from row-stepping to smooth sub-row positioning — required for animation. ScrollAnimationMode picks the deceleration curve; Custom routes to a Storyboard built in OnCustomScrollAnimation in code-behind." />
                <LineBreak />
                <Run FontWeight="SemiBold" Foreground="#A04040" Text="Note:" />
                <Run Text="These features have a performance cost — best suited to modest datasets (≤ 100k rows). For large-dataset tuning see the Large Datasets sample." />
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    ItemsSource="{Binding Items}"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    IsReadOnly="True"
                                    EnableRuleFiltering="True"
                                    SelectionMode="Extended"
                                    SelectionUnit="FullRow"
                                    AllowPerPixelScrolling="True"
                                    AllowScrollAnimation="True"
                                    AllowCascadeUpdate="False"
                                    RowAnimationKind="Opacity"
                                    RowAnimationEasing="EaseInOut"
                                    RowOpacityAnimationDuration="300"
                                    CascadeStagger="0"
                                    CustomScrollAnimation="OnCustomScrollAnimation">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn Width="80"  FieldName="OrderNumber"           Header="Order #" />
                        <sdg:GridColumn Width="100" FieldName="OrderStatusName"       Header="Status"   DefaultSearchType="Equals" />
                        <sdg:GridColumn Width="150" FieldName="OrderDate"             Header="Date"     DisplayStringFormat="MM/dd/yyyy h:mm tt" />
                        <sdg:GridColumn Width="200" FieldName="CustomerName"          Header="Customer" />
                        <sdg:GridColumn Width="160" FieldName="EmployeeName"          Header="Employee" />
                        <sdg:GridColumn Width="100" FieldName="OrderItemsTotalPrice"  Header="Total"    DisplayStringFormat="C2" />
                        <sdg:GridColumn Width="100" FieldName="AmountDue"             Header="Due"      DisplayStringFormat="C2" />
                        <sdg:GridColumn Width="80"  FieldName="OrderCancelled"        Header="Cancelled" />
                        <sdg:GridColumn Width="60"  FieldName="State"                 Header="State"    DefaultSearchType="Equals" />
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Background="#CCCCCC" />

                <ScrollViewer Grid.Column="2" Background="#FFFFFF" VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">

                        <Expander Header="Scroll behavior" IsExpanded="True">
                            <sdg:SimpleStackPanel Orientation="Vertical" Spacing="6" Margin="4">
                                <CheckBox IsChecked="{Binding ElementName=Grid, Path=AllowPerPixelScrolling}" Content="Per-Pixel Scrolling" />
                                <CheckBox IsChecked="{Binding ElementName=Grid, Path=AllowScrollAnimation}" Content="Scroll Animation" />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Animation mode" IsExpanded="True"
                                  IsEnabled="{Binding ElementName=Grid, Path=AllowScrollAnimation}">
                            <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2" Margin="4">
                                <RadioButton Content="Ease Out"
                                             IsChecked="{Binding ElementName=Grid, Path=ScrollAnimationMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=EaseOut}"
                                             GroupName="ScrollAnimMode" />
                                <RadioButton Content="Ease In/Out"
                                             IsChecked="{Binding ElementName=Grid, Path=ScrollAnimationMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=EaseInOut}"
                                             GroupName="ScrollAnimMode" />
                                <RadioButton Content="Linear"
                                             IsChecked="{Binding ElementName=Grid, Path=ScrollAnimationMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Linear}"
                                             GroupName="ScrollAnimMode" />
                                <RadioButton Content="Custom (Storyboard)"
                                             IsChecked="{Binding ElementName=Grid, Path=ScrollAnimationMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Custom}"
                                             GroupName="ScrollAnimMode"
                                             ToolTip="Uses an exponential ease-out built in OnCustomScrollAnimation in code-behind." />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Duration" IsExpanded="True"
                                  IsEnabled="{Binding ElementName=Grid, Path=AllowScrollAnimation}">
                            <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2" Margin="4">
                                <TextBlock Text="{Binding ElementName=DurationSlider, Path=Value, StringFormat='{}{0:F0}ms'}" />
                                <Slider x:Name="DurationSlider"
                                        Minimum="200" Maximum="2000"
                                        TickFrequency="100" IsSnapToTickEnabled="True"
                                        Value="{Binding ElementName=Grid, Path=ScrollAnimationDuration}" />
                            </sdg:SimpleStackPanel>
                        </Expander>

                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
