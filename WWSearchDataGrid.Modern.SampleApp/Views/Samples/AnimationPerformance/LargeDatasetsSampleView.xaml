<UserControl x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.AnimationPerformance.LargeDatasetsSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:sampleControls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.AnimationPerformance"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:LargeDatasetsSampleViewModel />
    </UserControl.DataContext>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.LargeDatasets}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Large datasets &amp; virtualization" />
                <LineBreak />
                <Run Text="Push the grid up to 1M rows, then tune virtualization, live scrolling, and filter-row debounce to keep scrolling and typing smooth. For momentum / per-pixel scrolling see the Scrolling Animation sample." />
            </TextBlock>

            <sampleControls:SampleFooterControl DockPanel.Dock="Bottom"
                                                RowCount="{Binding RowCount, Mode=TwoWay}"
                                                GenerateCommand="{Binding GenerateCommand}"
                                                ClearCommand="{Binding ClearCommand}" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    ItemsSource="{Binding Items}"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    IsReadOnly="True"
                                    AllowFilterPopup="True"
                                    SelectionMode="Extended"
                                    SelectionUnit="FullRow">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn Width="80"  FieldName="OrderNumber"           Header="Order #" />
                        <sdg:GridColumn Width="100" FieldName="OrderStatusName"       Header="Status"   DefaultSearchType="Equals" />
                        <sdg:GridColumn Width="150" FieldName="OrderDate"             Header="Date"     DisplayStringFormat="MM/dd/yyyy h:mm tt" RoundDateTime="True"/>
                        <sdg:GridColumn Width="200" FieldName="CustomerName"          Header="Customer" />
                        <sdg:GridColumn Width="160" FieldName="EmployeeName"          Header="Employee" />
                        <sdg:GridColumn Width="100" FieldName="OrderItemsTotalPrice"  Header="Total"    DisplayStringFormat="C2" />
                        <sdg:GridColumn Width="100" FieldName="AmountDue"             Header="Due"      DisplayStringFormat="C2" />
                        <sdg:GridColumn Width="80"  FieldName="OrderCancelled"        Header="Cancelled" />
                        <sdg:GridColumn Width="60"  FieldName="State"                 Header="State"    DefaultSearchType="Equals" />
                        <sdg:GridColumn Width="110" FieldName="ScheduleDate"          Header="Schedule" DisplayStringFormat="MM/dd/yyyy" />
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Background="#CCCCCC" />

                <ScrollViewer Grid.Column="2" Background="#FFFFFF" VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">

                        <Expander Header="Quick scale" IsExpanded="True">
                            <sdg:SimpleStackPanel Orientation="Horizontal" Spacing="6" Margin="4">
                                <Button Content="1k"   Click="OnScaleClick" Tag="1000" />
                                <Button Content="10k"  Click="OnScaleClick" Tag="10000" />
                                <Button Content="100k" Click="OnScaleClick" Tag="100000" />
                                <Button Content="1M"   Click="OnScaleClick" Tag="1000000" />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Virtualization" IsExpanded="True">
                            <sdg:SimpleStackPanel Orientation="Vertical" Spacing="6" Margin="4">
                                <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2"
                                                      ToolTip="Pages of off-screen rows pre-realized above and below the viewport.">
                                    <TextBlock Text="{Binding ElementName=CacheLengthSlider, Path=Value, StringFormat='Cache: {0:F1} pages'}" />
                                    <Slider x:Name="CacheLengthSlider"
                                            Minimum="0.5" Maximum="5.0"
                                            TickFrequency="0.5" IsSnapToTickEnabled="True"
                                            Value="{Binding ElementName=Grid, Path=VirtualizationCacheLength}" />
                                </sdg:SimpleStackPanel>
                                <CheckBox IsChecked="{Binding ElementName=Grid, Path=EnableColumnVirtualization}"
                                          Content="Column Virtualization" />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Live scrolling" IsExpanded="True">
                            <sdg:SimpleStackPanel Orientation="Vertical" Spacing="4" Margin="4">
                                <CheckBox IsChecked="{Binding ElementName=Grid, Path=EnableLiveScrolling}" Content="Live Scrolling" />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Filter behavior" IsExpanded="True">
                            <sdg:SimpleStackPanel Orientation="Vertical" Spacing="6" Margin="4">
                                <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2"
                                                      ToolTip="Debounces filter-row keystrokes while live filtering is on. Has no effect when EnableLiveFiltering is off.">
                                    <TextBlock>
                                        <Run Text="FilterRowDelay:" />
                                        <Run Text="{Binding ElementName=Grid, Path=FilterRowDelay, Mode=OneWay}" />
                                        <Run Text="ms" />
                                    </TextBlock>
                                    <Slider Minimum="0" Maximum="2000"
                                            TickFrequency="100" IsSnapToTickEnabled="True"
                                            Value="{Binding ElementName=Grid, Path=FilterRowDelay, Mode=TwoWay}" />
                                </sdg:SimpleStackPanel>
                                <CheckBox Content="EnableLiveFiltering"
                                          IsChecked="{Binding ElementName=Grid, Path=EnableLiveFiltering, Mode=TwoWay}"
                                          ToolTip="Grid-wide live-filtering toggle. When off, typing and popup edits defer until you commit (Enter / Tab / focus loss / popup close)." />
                                <Button Content="Clear all filters"
                                        Margin="0,4,0,0"
                                        HorizontalAlignment="Left"
                                        Click="OnClearAllFiltersClicked" />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Tuning tips">
                            <TextBlock Margin="4" FontSize="11" Foreground="#666" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Text="At 100k+:" />
                                <Run Text="leave column virtualization on. Keep cache between 1.5–3 pages. Avoid per-pixel / scroll-animation." />
                                <LineBreak />
                                <Run FontWeight="SemiBold" Text="At 1M:" />
                                <Run Text="disable Live Scrolling. Cache 1.0–1.5 pages. Item-mode scrolling only." />
                                <LineBreak />
                                <Run FontWeight="SemiBold" Text="Filter row at scale:" />
                                <Run Text="at 100k+ rows with live filtering on, raise FilterRowDelay (300–500ms) so typing isn't refiltering on every keystroke. At 1M, turn EnableLiveFiltering off entirely — commit on Enter." />
                            </TextBlock>
                        </Expander>

                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
