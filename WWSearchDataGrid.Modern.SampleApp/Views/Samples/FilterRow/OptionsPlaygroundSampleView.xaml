<UserControl x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.FilterRow.OptionsPlaygroundSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:sampleControls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.FilterRow"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:OptionsPlaygroundSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style BasedOn="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesCheckBox}}" TargetType="{x:Type CheckBox}" />
        <Style BasedOn="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesButton}}" TargetType="{x:Type Button}" />
        <Style BasedOn="{StaticResource SampleExpanderStyle}" TargetType="{x:Type Expander}" />
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,6,0,2" />
            <Setter Property="Foreground" Value="#333" />
        </Style>

        <Style BasedOn="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesComboBox}}" TargetType="{x:Type ComboBox}" />
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.OptionsPlayground}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Filter-row options playground" />
                <LineBreak />
                <Run Text="Every grid-level and column-level filter-row DP, exposed as runtime toggles. Pick a column from the dropdown to see and tweak its per-column settings; the grid-level group above always binds to the grid." />
            </TextBlock>

            <Border DockPanel.Dock="Bottom"
                    Background="#FAFAFA"
                    BorderBrush="#DDDDDD"
                    BorderThickness="0,1,0,0"
                    Padding="12,8">
                <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold" Text="Try:" />
                    <LineBreak />
                    <Run Text="• Toggle ShowCriteriaInFilterRow — every cell sprouts a search-type selector." />
                    <LineBreak />
                    <Run Text="• Uncheck EnableLiveFiltering on the grid, then type — filter waits for Enter." />
                    <LineBreak />
                    <Run Text="• Pick Cancelled, set AllowAutoFilter=false — cell greys but keeps its space." />
                    <LineBreak />
                    <Run Text="• Pick Cancelled, set AllowFiltering=false — cell collapses entirely." />
                </TextBlock>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    ItemsSource="{Binding Items}"
                                    AutoGenerateColumns="False"
                                    FilterClearButtonMode="Edit"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    IsReadOnly="True"
                                    ShowCriteriaInFilterRow="True"
                                    SelectionMode="Extended"
                                    SelectionUnit="FullRow">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn x:Name="OrderNumberColumn"
                                        Width="80"
                                        FieldName="OrderNumber"
                                        Header="Order #" />
                        <sdg:GridColumn x:Name="CustomerNameColumn"
                                        Width="200"
                                        FieldName="CustomerName"
                                        Header="Customer" />
                        <sdg:GridColumn x:Name="StatusColumn"
                                        Width="120"
                                        FieldName="OrderStatusName"
                                        Header="Status"
                                        DefaultSearchType="Equals" />
                        <sdg:GridColumn x:Name="OrderDateColumn"
                                        Width="150"
                                        FieldName="OrderDate"
                                        Header="Order Date"
                                        DisplayStringFormat="MM/dd/yyyy" />
                        <sdg:GridColumn x:Name="TotalColumn"
                                        Width="100"
                                        FieldName="OrderItemsTotalPrice"
                                        Header="Total"
                                        DisplayStringFormat="C2" />
                        <sdg:GridColumn x:Name="CancelledColumn"
                                        Width="80"
                                        FieldName="OrderCancelled"
                                        Header="Cancelled" />
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Background="#CCCCCC" />

                <ScrollViewer Grid.Column="2" Background="#FFFFFF" VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">
                        <GroupBox Header="Grid settings" Padding="6">
                            <sdg:SimpleStackPanel Orientation="Vertical" Spacing="6">
                                <CheckBox Content="ShowCriteriaInFilterRow"
                                          IsChecked="{Binding ElementName=Grid, Path=ShowCriteriaInFilterRow, Mode=TwoWay}"
                                          ToolTip="Grid-wide default. Individual columns can override via ShowCriteriaInFilterRow (bool?)." />

                                <CheckBox Content="EnableLiveFiltering"
                                          IsChecked="{Binding ElementName=Grid, Path=EnableLiveFiltering, Mode=TwoWay}"
                                          ToolTip="When checked, filter changes apply as you make them. When unchecked, typing and popup edits are deferred until you commit (Enter / Tab / focus loss / popup close)." />

                                <TextBlock Style="{StaticResource SectionLabelStyle}">
                                    <Run Text="FilterRowDelay:" />
                                    <Run Text="{Binding ElementName=Grid, Path=FilterRowDelay, Mode=OneWay}" />
                                    <Run Text="ms" />
                                </TextBlock>
                                <Slider Minimum="0"
                                        Maximum="2000"
                                        TickFrequency="250"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding ElementName=Grid, Path=FilterRowDelay, Mode=TwoWay}" />

                                <TextBlock Style="{StaticResource SectionLabelStyle}" Text="FilterClearButtonMode" />
                                <ComboBox ItemsSource="{Binding FilterClearButtonModeChoices}"
                                          SelectedItem="{Binding ElementName=Grid, Path=FilterClearButtonMode, Mode=TwoWay}" />

                                <Button Content="Clear all filters"
                                        Margin="0,8,0,0"
                                        HorizontalAlignment="Left"
                                        Click="OnClearAllFiltersClicked" />
                            </sdg:SimpleStackPanel>
                        </GroupBox>

                        <GroupBox Header="Selected column settings" Padding="6">
                            <sdg:SimpleStackPanel Orientation="Vertical" Spacing="6">
                                <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Column" />
                                <ComboBox ItemsSource="{Binding Columns}"
                                          SelectedItem="{Binding SelectedColumnConfig, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayLabel" />

                                <Border DataContext="{Binding SelectedColumnConfig}"
                                        Margin="0,6,0,0">
                                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="6">
                                        <CheckBox Content="AllowFiltering  (cell collapsed when off)"
                                                  IsChecked="{Binding AllowFiltering, Mode=TwoWay}" />
                                        <CheckBox Content="AllowAutoFilter  (cell greyed when off)"
                                                  IsChecked="{Binding AllowAutoFilter, Mode=TwoWay}" />

                                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="ShowCriteriaInFilterRow override" />
                                        <ComboBox ItemsSource="{Binding DataContext.ShowCriteriaOverrideChoices, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding ShowCriteriaOverride, Mode=TwoWay}" />

                                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="DefaultSearchType" />
                                        <ComboBox ItemsSource="{Binding DataContext.DefaultSearchTypeChoices, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedItem="{Binding DefaultSearchType, Mode=TwoWay}" />
                                    </sdg:SimpleStackPanel>
                                </Border>
                            </sdg:SimpleStackPanel>
                        </GroupBox>
                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
