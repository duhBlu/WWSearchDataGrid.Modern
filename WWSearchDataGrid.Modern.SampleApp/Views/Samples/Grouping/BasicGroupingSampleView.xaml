<UserControl x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.Grouping.BasicGroupingSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:sampleControls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.Grouping"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:BasicGroupingSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style BasedOn="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesButton}}" TargetType="{x:Type Button}">
            <!--  Rail buttons share a uniform width.  -->
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style BasedOn="{StaticResource {x:Static sdg:ThemeKeys.PrimitivesCheckBox}}" TargetType="{x:Type CheckBox}" />

        <!--  Small muted label for the rail section dividers.  -->
        <Style x:Key="SectionHeaderText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#6F7A8C" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,10,0,2" />
        </Style>

        <!--
            GroupValueTemplate for the Status column. DataContext is the CollectionViewGroup, so
            the value binds to Name. A colored chip in front of the value shows that the group
            header value is fully templatable (the count suffix is rendered by the group chrome).
        -->
        <DataTemplate x:Key="StatusGroupValueTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Foreground" Value="#1c1c1c" />
                            <Style.Triggers>
                                <Trigger Property="Text" Value="Delivered">
                                    <Setter Property="Foreground" Value="#235094" />
                                </Trigger>
                                <Trigger Property="Text" Value="Submitted">
                                    <Setter Property="Foreground" Value="#196e20" />
                                </Trigger>
                                <Trigger Property="Text" Value="In Production">
                                    <Setter Property="Foreground" Value="#ba6728" />
                                </Trigger>
                                <Trigger Property="Text" Value="Cancelled">
                                    <Setter Property="Foreground" Value="#942020" />
                                </Trigger>
                                <Trigger Property="Text" Value="Shipped">
                                    <Setter Property="Foreground" Value="#7828ba" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <!--
            GroupHeaderTemplate for the Product Line column. Replaces the WHOLE header — not just
            the value slot — so this template also owns the row-count badge layout. DataContext
            is the CollectionViewGroup (Name = group value, ItemCount = row count).
        -->
        <DataTemplate x:Key="ProductLineGroupHeaderTemplate">
            <Border BorderBrush="#FF4C8BF5"
                    BorderThickness="0,0,0,0"
                    Padding="6,4">

                <sdg:SimpleStackPanel Orientation="Horizontal" Spacing="5" IsHitTestVisible="False">
                    <!--
                        Run.Text is BindsTwoWayByDefault (unlike TextBlock.Text), so the binding
                        to CollectionViewGroup.Name MUST be OneWay — Name is read-only and the
                        default TwoWay push would throw at attach time.
                    -->
                    <TextBlock VerticalAlignment="Center">
                        <Run Foreground="#FF6F7A8C" Text="Product line:" />
                        <Run Foreground="#FF1A3C6E"
                             Text="{Binding Name, Mode=OneWay}"
                             FontWeight="SemiBold" />
                    </TextBlock>
                    <Border Background="#FF4C8BF5"
                            Padding="8,1"
                            VerticalAlignment="Center"
                            CornerRadius="9">
                        <TextBlock Foreground="White"
                                   Text="{Binding ItemCount}"
                                   FontWeight="SemiBold"
                                   FontSize="11" />
                    </Border>
                </sdg:SimpleStackPanel>

            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.BasicGrouping}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Foreground="#444"
                       Margin="16,12,16,4"
                       FontSize="13"
                       TextWrapping="Wrap">
                <Run Text="Basic grouping" FontWeight="SemiBold" />
                <LineBreak />
                <Run Text="The grid groups its rows by every column whose GridColumn.GroupIndex is &gt;= 0, ordered by that index. The Status column below declares GroupIndex=&quot;0&quot; in XAML, so the grid loads pre-grouped by status. Each group renders as an expander showing the group value and its row count." />
                <LineBreak />
                <Run Text="Use the buttons (or right-click a column header → Group By This Column) to add nested group levels at runtime via GroupBy / Ungroup / ClearGrouping. Grouping leads sorting: a group sort sits ahead of any header-click sort, and the filter row keeps working while grouped." />
            </TextBlock>

            <!--  Controls rail — docked right of the grid, organized into sections.  -->
            <Border DockPanel.Dock="Right"
                    Width="230"
                    Margin="0,8,10,10">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,0,12,0">
                    <sdg:SimpleStackPanel Spacing="6">

                        <TextBlock Style="{StaticResource SectionHeaderText}" Text="GROUP BY" />
                        <Button Click="GroupByStatus_Click" Content="Status" />
                        <Button Click="GroupByProductLine_Click" Content="Product Line" />
                        <Button Click="GroupByState_Click" Content="State" />
                        <Button Click="GroupByMonth_Click" Content="Month (Date)" />
                        <Button Click="ClearGrouping_Click" Content="Clear Grouping" />

                        <TextBlock Style="{StaticResource SectionHeaderText}" Text="EXPANSION" />
                        <Button Click="ExpandAll_Click" Content="Expand All" />
                        <Button Click="CollapseAll_Click" Content="Collapse All" />
                        <!--
                            Refresh recycles every GroupItem container. With expansion-state
                            persistence in play (see SearchDataGrid.TrackGroupExpansion), per-group
                            user toggles survive the refresh and replay on the next realization.
                        -->
                        <Button Click="RefreshItems_Click"
                                Content="Refresh Items"
                                ToolTip="Calls Items.Refresh — exercises the per-group expansion-state persistence." />

                        <!--
                            Group expansion knobs (Phase 3.1.c):
                            · AutoExpandAllGroups (default true) — initial state for newly-materialized
                              groups. Toggling at runtime also expands/collapses every realized group.
                            · ExpandGroupsRecursively — a parent expander cascades its state to nested groups.
                            · UseGroupExpansionAnimation — animated chrome (rotating chevron + content ScaleY).
                        -->
                        <TextBlock Style="{StaticResource SectionHeaderText}" Text="OPTIONS" />
                        <CheckBox IsChecked="{Binding ShowGroupedColumns, ElementName=Grid}"
                                  Content="Show grouped columns" />
                        <CheckBox IsChecked="{Binding AllowGrouping, ElementName=Grid}"
                                  Content="Allow grouping" />
                        <CheckBox IsChecked="{Binding AutoExpandAllGroups, ElementName=Grid}"
                                  Content="Auto-expand all groups" />
                        <CheckBox IsChecked="{Binding ExpandGroupsRecursively, ElementName=Grid}"
                                  Content="Expand groups recursively" />
                        <CheckBox IsChecked="{Binding UseGroupExpansionAnimation, ElementName=Grid}"
                                  Content="Use group expansion animation" />
                        <!--
                            AllowFixedGroups (Phase 3.1.f): the group header(s) for the topmost
                            visible row stay pinned to the top of the data area as the grid
                            scrolls. Sibling-group transitions slide the topmost pinned row up
                            to make room (push transition). Add nested levels via the GROUP BY
                            buttons above to see multi-level stair-stepped pinning.
                        -->
                        <CheckBox IsChecked="{Binding AllowFixedGroups, ElementName=Grid}"
                                  Content="Allow fixed groups"
                                  ToolTip="Pin the current group chain to the top of the data area while scrolling." />

                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Border>

            <sdg:SearchDataGrid x:Name="Grid"
                                IsReadOnly="True"
                                Margin="10,8,0,10"
                                ItemsSource="{Binding Items}"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                AllowScrollAnimation="True"
                                AllowPerPixelScrolling="True"
                                AllowFixedGroups="True"
                                IsGroupPanelVisible="True">
                <sdg:SearchDataGrid.GridColumns>
                    <!--  Declarative grouping: the grid loads pre-grouped by status.  -->
                    <sdg:GridColumn Width="140"
                                    FieldName="OrderStatusName"
                                    Header="Status"
                                    GroupIndex="0"
                                    GroupValueTemplate="{StaticResource StatusGroupValueTemplate}" />
                    <sdg:GridColumn Width="100"
                                    FieldName="OrderNumber"
                                    Header="Order #" />
                    <sdg:GridColumn Width="160"
                                    FieldName="CustomerName"
                                    Header="Customer" />
                    <!--
                        GroupHeaderTemplate replaces the WHOLE group header (including the count
                        chip). Compare with the Status column above, which only customizes the
                        value slot via GroupValueTemplate while keeping the default chrome.
                    -->
                    <sdg:GridColumn Width="140"
                                    FieldName="ProductLineName"
                                    Header="Product Line"
                                    GroupHeaderTemplate="{StaticResource ProductLineGroupHeaderTemplate}" />
                    <sdg:GridColumn Width="60"
                                    FieldName="State"
                                    Header="State" />
                    <sdg:GridColumn Width="120"
                                    FieldName="OrderItemsTotalPrice"
                                    Header="Total"
                                    DisplayStringFormat="C2" />
                    <!--  GroupInterval=DateMonth buckets this date column by calendar month when grouped.  -->
                    <sdg:GridColumn Width="150"
                                    FieldName="OrderDate"
                                    Header="Order Date"
                                    DisplayStringFormat="MM/dd/yyyy"
                                    GroupInterval="DateMonth" />
                </sdg:SearchDataGrid.GridColumns>
            </sdg:SearchDataGrid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>