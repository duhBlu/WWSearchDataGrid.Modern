<UserControl x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Samples.Columns.BestFitSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
             xmlns:sampleControls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Samples.Columns"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <local:BestFitSampleViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <x:Array x:Key="BestFitModes" Type="sdg:BestFitMode">
            <sdg:BestFitMode>Default</sdg:BestFitMode>
            <sdg:BestFitMode>VisibleRows</sdg:BestFitMode>
            <sdg:BestFitMode>AllRows</sdg:BestFitMode>
        </x:Array>
    </UserControl.Resources>

    <sampleControls:SampleHostControl Sources="{x:Static sampleControls:SampleSources.BestFit}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Margin="16,12,16,4"
                       FontSize="13"
                       Foreground="#444"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="Best fit (auto-width)" />
                <LineBreak />
                <Run Text="Auto-size columns to content via the header context menu, a double-click on a column-resize gripper, or the API. Each column header names the Best Fit setting it demonstrates." />
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <sdg:SearchDataGrid x:Name="Grid"
                                    Grid.Column="0"
                                    Margin="10"
                                    ItemsSource="{Binding Items}"
                                    AutoGenerateColumns="False"
                                    AllowBestFit="True"
                                    BestFitMode="VisibleRows"
                                    BestFitFillViewport="True"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    IsReadOnly="True">
                    <sdg:SearchDataGrid.GridColumns>
                        <sdg:GridColumn Width="90" FieldName="OrderNumber" Header="Order #" />

                        <!-- Long outliers live past row ~150 — AllRows catches them, VisibleRows doesn't. -->
                        <sdg:GridColumn x:Name="CustomerColumn" Width="120" FieldName="CustomerName"
                                        Header="Customer (outliers deep)" />

                        <!-- Per-column mode override: always viewport-only regardless of grid mode. -->
                        <sdg:GridColumn Width="120" FieldName="JobName" Header="Job (VisibleRows)"
                                        BestFitMode="VisibleRows" />

                        <!-- Opt-out: menu item disabled, gripper double-click = stock Width=Auto. -->
                        <sdg:GridColumn Width="120" FieldName="DealerName" Header="Dealer (opt-out)"
                                        AllowBestFit="False" />

                        <!-- Area=Rows: the deliberately long header doesn't count toward the fit. -->
                        <sdg:GridColumn Width="100" FieldName="OrderItemsTotalPrice"
                                        Header="Total — long header ignored (Rows)"
                                        DisplayStringFormat="C2"
                                        BestFitArea="Rows" />

                        <!-- Display pipeline: fit measures the formatted date, not the raw value. -->
                        <sdg:GridColumn Width="100" FieldName="OrderDate" Header="Date"
                                        DisplayStringFormat="MM/dd/yyyy" />

                        <!-- Checkbox column: no text representation, measures realized cells only. -->
                        <sdg:GridColumn Width="90" FieldName="Submitted" Header="Submitted" />
                    </sdg:SearchDataGrid.GridColumns>
                </sdg:SearchDataGrid>

                <GridSplitter Grid.Column="1"
                              Width="5"
                              HorizontalAlignment="Stretch"
                              Background="#CCCCCC" />

                <ScrollViewer Grid.Column="2"
                              Padding="8,4"
                              Background="#FFFFFF"
                              VerticalScrollBarVisibility="Auto">
                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">

                        <Expander Header="Grid settings">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="6">
                                <CheckBox Content="Allow best fit (grid)"
                                          IsChecked="{Binding AllowBestFit, ElementName=Grid}" />
                                <CheckBox Content="Fill viewport"
                                          IsChecked="{Binding BestFitFillViewport, ElementName=Grid}"
                                          Click="OnFillViewportToggled"
                                          ToolTip="Best Fit All Columns stretches the columns to fill the viewport when they fit, and overflows to a scrollbar (full width, still resizable) when their content is wider than the viewport." />
                                <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2">
                                    <TextBlock FontWeight="Bold" Text="Mode:" />
                                    <ComboBox ItemsSource="{StaticResource BestFitModes}"
                                              SelectedItem="{Binding BestFitMode, ElementName=Grid}" />
                                </sdg:SimpleStackPanel>
                                <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2">
                                    <TextBlock FontWeight="Bold" Text="On source change:" />
                                    <ComboBox ItemsSource="{StaticResource BestFitModes}"
                                              SelectedItem="{Binding BestFitModeOnSourceChange, ElementName=Grid}" />
                                </sdg:SimpleStackPanel>
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Actions">
                            <sdg:SimpleStackPanel Margin="4" Orientation="Vertical" Spacing="4">
                                <Button Content="Best Fit All Columns"
                                        HorizontalAlignment="Stretch"
                                        Click="OnBestFitAllColumns" />
                                <Button Content="Best Fit Customer"
                                        HorizontalAlignment="Stretch"
                                        Click="OnBestFitCustomer" />
                                <Button Content="Reload Data"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding ReloadDataCommand}"
                                        ToolTip="Swaps the ItemsSource with alternating outlier lengths. Set 'On source change' to AllRows to watch columns re-fit after each load." />
                            </sdg:SimpleStackPanel>
                        </Expander>

                        <Expander Header="Customer column measurements">
                            <TextBlock Margin="4" FontSize="12" Foreground="#666" TextWrapping="Wrap">
                                <Run Text="ActualDataWidth (widest measured content):" />
                                <Run Text="{Binding ActualDataWidth, ElementName=CustomerColumn, Mode=OneWay, StringFormat={}{0:F1}}" FontWeight="SemiBold" />
                                <Run Text="px" />
                                <LineBreak />
                                <Run Text="ActualWidth (rendered):" />
                                <Run Text="{Binding ActualWidth, ElementName=CustomerColumn, Mode=OneWay, StringFormat={}{0:F1}}" FontWeight="SemiBold" />
                                <Run Text="px" />
                            </TextBlock>
                        </Expander>

                        <Expander Header="Try it" IsExpanded="False">
                            <TextBlock Margin="4" FontSize="11" Foreground="#666" TextWrapping="Wrap">
                                <Run Text="• A few rows past #150 carry long Customer / Job values that viewport-only sizing misses — scroll to the top, run Best Fit, then switch the mode and compare." />
                                <LineBreak />
                                <Run Text="• 'Job (VisibleRows)' pins its own BestFitMode, so it always fits the viewport only." />
                                <LineBreak />
                                <Run Text="• 'Dealer (opt-out)' sets AllowBestFit=False — its menu item disables and gripper double-click falls back to the stock auto-size." />
                                <LineBreak />
                                <Run Text="• 'Total (Rows)' sets BestFitArea=Rows, so its deliberately long header is ignored when fitting." />
                                <LineBreak />
                                <Run Text="• 'Fill viewport' makes Best Fit All stretch the columns to fill the grid when they fit (drag the splitter wider and they grow with it), and overflow to a scrollbar when their combined content is wider than the viewport — columns stay resizable either way, and opted-out columns (Dealer) keep their own width while the rest fill around them." />
                            </TextBlock>
                        </Expander>

                    </sdg:SimpleStackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </sampleControls:SampleHostControl>
</UserControl>
