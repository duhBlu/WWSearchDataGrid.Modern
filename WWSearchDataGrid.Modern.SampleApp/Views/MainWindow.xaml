<Window x:Class="WWSearchDataGrid.Modern.SampleApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp"
        xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF;assembly=WWSearchDataGrid.Modern.WPF"
        xmlns:sdgCore="clr-namespace:WWSearchDataGrid.Modern.Core;assembly=WWSearchDataGrid.Modern.Core"
        xmlns:sampleConverters="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Converters"
        xmlns:sdgConverters="clr-namespace:WWSearchDataGrid.Modern.WPF.Converters;assembly=WWSearchDataGrid.Modern.WPF"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        xmlns:controls="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Controls"
        Title="SearchDataGrid Demo"
        Style="{DynamicResource SampleAppWindowStyle}"
        Width="1280"
        Height="800"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d">
    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Window.Resources>

        <!--  Converters  -->
        <sampleConverters:BooleanToStringConverter x:Key="BooleanToStringConverter" />
        <sampleConverters:NullToBooleanConverter x:Key="NullToBooleanConverter" />
        <sampleConverters:ColumnDisplayNameConverter x:Key="ColumnDisplayNameConverter" />
        <sampleConverters:PriorityToTextConverter x:Key="PriorityToTextConverter" />
        <sdgConverters:MaskFormatConverter x:Key="MaskFormatConverter" />
        <sampleConverters:SubmittedToStringConverter x:Key="SubmittedToStringConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <sampleConverters:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />

        <!--  Data  -->
        <CollectionViewSource x:Key="ComboBoxItemsSource" Source="{Binding ComboBoxItems}" />
        <CollectionViewSource x:Key="ComboBoxStringSource" Source="{Binding ComboBoxStringValues}" />

        <!--  Sample app button style  -->
        <Style BasedOn="{StaticResource SdgButtonStyle}" TargetType="{x:Type Button}" />
        <Style BasedOn="{StaticResource SdgCheckBoxStyle}" TargetType="{x:Type CheckBox}" />
        <Style BasedOn="{StaticResource SdgComboBoxStyle}" TargetType="{x:Type ComboBox}" />
        <Style BasedOn="{StaticResource SdgRadioButtonStyle}" TargetType="{x:Type RadioButton}" />
        <Style BasedOn="{StaticResource SdgSliderStyle}" TargetType="{x:Type Slider}" />
        <Style BasedOn="{StaticResource SdgExpanderStyle}" TargetType="{x:Type Expander}" />
        
    </Window.Resources>

    <DockPanel>

        <!--  Control Panel  -->
        <Grid DockPanel.Dock="Bottom" Background="#F0F0F0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  Item Counter  -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Margin="15,0,0,0"
                        VerticalAlignment="Center">

                <TextBlock Foreground="#1C1C1C"
                           Text="Total Data Items: "
                           VerticalAlignment="Center"
                           FontWeight="Bold" />
                <TextBlock Foreground="#444444"
                           Text="{Binding ItemCount, StringFormat={}{0:N0}}"
                           VerticalAlignment="Center" />

                <TextBlock Foreground="#1C1C1C"
                           Text="Filtered Rows: "
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold" />
                <TextBlock Foreground="#444444"
                           Text="{Binding ElementName=SearchDataGrid, Path=Items.Count, StringFormat={}{0:N0}, UpdateSourceTrigger=PropertyChanged}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!--  Buttons  -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <sdg:NumericUpDown VerticalContentAlignment="Center"
                                   Increment="1000"
                                   Value="{Binding ItemsToGenerate, Mode=TwoWay}" />
                <Button Command="{Binding GenerateItemsCommand}"
                        CommandParameter="{Binding ItemsToGenerate}"
                        Margin="5"
                        Padding="10,5"
                        Content="Generate Data" />

                <Button Command="{Binding ClearDataCommand}"
                        Margin="5"
                        Padding="10,5"
                        Content="Clear Data" />
            </StackPanel>
        </Grid>

        <!--  SearchDataGrid with Property Panel  -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <sdg:SearchDataGrid x:Name="SearchDataGrid"
                                Grid.Column="0"
                                IsReadOnly="False"
                                Margin="10"
                                IsColumnChooserEnabled="True"
                                IsColumnChooserConfinedToGrid="False"
                                EnableRuleFiltering="True"
                                SelectionMode="Extended"
                                SelectionUnit="CellOrRowHeader"
                                ItemsSource="{Binding OrderItems}"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                RowAnimationBegin="OnCustomRowAnimationBegin"
                                CustomScrollAnimation="OnCustomScrollAnimation">
                <sdg:SearchDataGrid.GridColumns>

                    <!--  Order #: starts-with search  -->
                    <sdg:GridColumn Width="80"
                                    FieldName="OrderNumber"
                                    Header="Order #"
                                    DefaultSearchMode="StartsWith"
                                    EnableRuleFiltering="False" />

                    <!--  Order Status: enum-like text  -->
                    <sdg:GridColumn Width="100"
                                    FieldName="OrderStatusName"
                                    Header="Status"
                                    DefaultSearchMode="Equals" />

                    <!--  Order Location  -->
                    <sdg:GridColumn Width="100"
                                    FieldName="OrderLocationName"
                                    Header="Location"
                                    DefaultSearchMode="Equals" />

                    <!--  Order Date: date + time format  -->
                    <sdg:GridColumn Width="150"
                                    FieldName="OrderDate"
                                    Header="Order Date"
                                    DisplayStringFormat="MM/dd/yyyy h:mm tt" />

                    <!--  Customer Name: text search  -->
                    <sdg:GridColumn Width="200"
                                    FieldName="CustomerName"
                                    Header="Customer" />

                    <!--  Employee: text search  -->
                    <sdg:GridColumn Width="160"
                                    FieldName="EmployeeName"
                                    Header="Employee" />

                    <!--  Dealer PO  -->
                    <sdg:GridColumn Width="110"
                                    FieldName="DealerPO"
                                    Header="Dealer PO" />

                    <!--  Job Name  -->
                    <sdg:GridColumn Width="130"
                                    FieldName="JobName"
                                    Header="Job Name" />

                    <!--  Product Line: enum-like  -->
                    <sdg:GridColumn Width="90"
                                    FieldName="ProductLineName"
                                    Header="Product Line"
                                    DefaultSearchMode="Equals" />

                    <!--  Order Type  -->
                    <sdg:GridColumn Width="170"
                                    FieldName="OrderTypeName"
                                    Header="Order Type"
                                    DefaultSearchMode="Equals" />

                    <!--  Cancelled: boolean checkbox  -->
                    <sdg:GridColumn Width="80"
                                    FieldName="OrderCancelled"
                                    Header="Cancelled"
                                    FieldType="{x:Type sys:Boolean}"
                                    UseCheckBoxInSearchBox="True" />

                    <!--  Quantity: integer  -->
                    <sdg:GridColumn Width="55"
                                    FieldName="OrderItemsTotalQuantity"
                                    Header="Qty" />

                    <!--  Total Price: currency format  -->
                    <sdg:GridColumn Width="100"
                                    FieldName="OrderItemsTotalPrice"
                                    Header="Total Price"
                                    DisplayStringFormat="C2" />

                    <!--  Amount Due: currency format  -->
                    <sdg:GridColumn Width="100"
                                    FieldName="AmountDue"
                                    Header="Amount Due"
                                    DisplayStringFormat="C2" />

                    <!--  Discount: percentage  -->
                    <sdg:GridColumn Width="80"
                                    FieldName="DiscountPercent"
                                    Header="Discount %"
                                    DisplayStringFormat="P0" />

                    <!--  Sales Rep  -->
                    <sdg:GridColumn Width="170"
                                    FieldName="SalesSubRepName"
                                    Header="Sales Rep" />

                    <!--  Ship Via: enum-like  -->
                    <sdg:GridColumn Width="80"
                                    FieldName="ShipViaTypeName"
                                    Header="Ship Via"
                                    DefaultSearchMode="Equals" />

                    <!--  City  -->
                    <sdg:GridColumn Width="110"
                                    FieldName="City"
                                    Header="City" />

                    <!--  State  -->
                    <sdg:GridColumn Width="50"
                                    FieldName="State"
                                    Header="State"
                                    DefaultSearchMode="Equals" />

                    <!--  Zip Code  -->
                    <sdg:GridColumn Width="70"
                                    FieldName="ZipCode"
                                    Header="Zip"
                                    DefaultSearchMode="StartsWith" />

                    <!--  Schedule Date: nullable date  -->
                    <sdg:GridColumn Width="110"
                                    FieldName="ScheduleDate"
                                    Header="Schedule Date"
                                    DisplayStringFormat="MM/dd/yyyy" />

                    <!--  Submitted: DisplayValueConverter shows Yes/No  -->
                    <sdg:GridColumn Width="80"
                                    FieldName="Submitted"
                                    Header="Submitted"
                                    DisplayValueConverter="{StaticResource SubmittedToStringConverter}" />

                    <!--  Load/Drop Numbers  -->
                    <sdg:GridColumn Width="60"
                                    FieldName="LoadNumber"
                                    Header="Load #" />
                    <sdg:GridColumn Width="60"
                                    FieldName="DropNumber"
                                    Header="Drop #" />

                    <!--  Special Instructions: nullable long text  -->
                    <sdg:GridColumn Width="200"
                                    FieldName="SpecialInstructionsText"
                                    Header="Special Instructions"
                                    EnableRuleFiltering="False" />

                </sdg:SearchDataGrid.GridColumns>
            </sdg:SearchDataGrid>

            <!--  GridSplitter  -->
            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          Width="5">
                <GridSplitter.Style>
                    <Style TargetType="{x:Type GridSplitter}">
                        <Setter Property="Background" Value="#CCCCCC" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DDDDDD" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter Property="Background" Value="#0078D4" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <!--  Property Panel  -->
            <ScrollViewer Grid.Column="2"
                          Background="#FFFFFF"
                          VerticalScrollBarVisibility="Auto"
                          Padding="8,4">
                <sdg:SimpleStackPanel Orientation="Vertical" Spacing="8">

                    <!-- ══════════════════════════════════════════ -->
                    <!--  GRID SETTINGS                            -->
                    <!-- ══════════════════════════════════════════ -->

                    <!--  Selection  -->
                    <Expander Header="Selection" ToolTip="Controls how rows and cells are selected in the grid.">
                        <sdg:SimpleStackPanel Orientation="Vertical" Spacing="6" Margin="4">

                            <Expander Header="Selection Mode" Padding="4"
                                      ToolTip="Determines whether one or multiple rows can be selected at once.">
                                <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2">
                                    <RadioButton Content="Single"
                                                 IsChecked="{Binding ElementName=SearchDataGrid, Path=SelectionMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Single}"
                                                 GroupName="SelectionMode"
                                                 ToolTip="Only one row or cell can be selected at a time. Clicking a new item deselects the previous one." />
                                    <RadioButton Content="Extended"
                                                 IsChecked="{Binding ElementName=SearchDataGrid, Path=SelectionMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Extended}"
                                                 GroupName="SelectionMode"
                                                 ToolTip="Multiple rows can be selected using Ctrl+Click (toggle individual) or Shift+Click (select range)." />
                                </sdg:SimpleStackPanel>
                            </Expander>

                            <Expander Header="Selection Unit" Padding="4"
                                      ToolTip="Defines the granularity of what gets selected when the user clicks.">
                                <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2">
                                    <RadioButton Content="Cell"
                                                 IsChecked="{Binding ElementName=SearchDataGrid, Path=SelectionUnit, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Cell}"
                                                 GroupName="SelectionUnit"
                                                 ToolTip="Individual cells are selected. Clicking a cell selects only that cell, not the entire row." />
                                    <RadioButton Content="Full Row"
                                                 IsChecked="{Binding ElementName=SearchDataGrid, Path=SelectionUnit, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=FullRow}"
                                                 GroupName="SelectionUnit"
                                                 ToolTip="Clicking anywhere in a row selects the entire row. Individual cell selection is not possible." />
                                    <RadioButton Content="Cell or Row Header"
                                                 IsChecked="{Binding ElementName=SearchDataGrid, Path=SelectionUnit, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=CellOrRowHeader}"
                                                 GroupName="SelectionUnit"
                                                 ToolTip="Clicking a cell selects that cell. Clicking the row header selects the entire row. Supports both modes." />
                                </sdg:SimpleStackPanel>
                            </Expander>

                            <CheckBox IsChecked="{Binding ElementName=SearchDataGrid, Path=CanUserReorderColumns}"
                                      Content="Allow Column Reorder"
                                      ToolTip="When enabled, users can drag column headers to rearrange column order. Columns snap into their new position when dropped." />
                        </sdg:SimpleStackPanel>
                    </Expander>

                    <!--  Appearance  -->
                    <Expander Header="Appearance" ToolTip="Visual options for gridlines and filtering UI.">
                        <sdg:SimpleStackPanel Orientation="Vertical" Spacing="4" Margin="4">
                            <CheckBox IsChecked="{Binding ElementName=SearchDataGrid, Path=ShowHorizontalGridLines}"
                                      Content="Horizontal Grid Lines"
                                      ToolTip="Toggles the thin horizontal lines drawn between each row. These lines are rendered independently from cell content and are not affected by row animations." />
                            <CheckBox IsChecked="{Binding ElementName=SearchDataGrid, Path=ShowVerticalGridLines}"
                                      Content="Vertical Grid Lines"
                                      ToolTip="Toggles the thin vertical lines drawn between each column. These are rendered as cell borders and will animate along with cell content when cascade update is enabled." />
                            <CheckBox IsChecked="{Binding ElementName=SearchDataGrid, Path=EnableRuleFiltering}"
                                      Content="Enable Rule Filtering"
                                      ToolTip="Enables advanced multi-criteria filtering with custom rules and logical operators (AND/OR). When disabled, only simple text-based search filtering is available per column. This is the grid-level setting; individual columns can override it." />
                        </sdg:SimpleStackPanel>
                    </Expander>

                    <!--  Column Chooser  -->
                    <Expander Header="Column Chooser" ToolTip="A floating window that lets users show/hide columns by toggling checkboxes.">
                        <sdg:SimpleStackPanel Orientation="Vertical" Spacing="4" Margin="4">
                            <CheckBox IsChecked="{Binding ElementName=SearchDataGrid, Path=IsColumnChooserEnabled}"
                                      Content="Enable"
                                      ToolTip="Master switch for the Column Chooser feature. When disabled, the 'Show Column Chooser' context menu item is hidden, the chooser window cannot be opened, and any open chooser is automatically closed." />
                            <CheckBox IsEnabled="{Binding ElementName=SearchDataGrid, Path=IsColumnChooserEnabled}"
                                      IsChecked="{Binding ElementName=SearchDataGrid, Path=IsColumnChooserVisible}"
                                      Content="Show Window"
                                      ToolTip="Opens or closes the Column Chooser window. The window is non-modal, allowing interaction with the grid while the chooser is open. Unchecking this closes the window." />
                            <CheckBox IsEnabled="{Binding ElementName=SearchDataGrid, Path=IsColumnChooserEnabled}"
                                      IsChecked="{Binding ElementName=SearchDataGrid, Path=IsColumnChooserConfinedToGrid}"
                                      Content="Confine to Grid"
                                      ToolTip="When enabled, the Column Chooser window cannot be dragged outside the grid's visible area. Its position is automatically adjusted if it would exceed the grid bounds. When disabled, the window can be moved freely anywhere on screen." />
                        </sdg:SimpleStackPanel>
                    </Expander>

                    <!--  Scrolling  -->
                    <Expander Header="Scrolling" ToolTip="Controls how the grid scrolls and whether momentum/inertia animation is applied to mouse wheel input.">
                        <sdg:SimpleStackPanel Orientation="Vertical" Spacing="6" Margin="4">
                            <CheckBox IsChecked="{Binding ElementName=SearchDataGrid, Path=EnableLiveScrolling}"
                                      Content="Live Scrolling"
                                      ToolTip="When enabled, grid content updates in real-time as you drag the scrollbar thumb. When disabled (deferred scrolling), the grid only updates when you release the thumb. Disable for very large datasets (100k+ rows) if thumb-dragging stutters." />
                            <CheckBox IsChecked="{Binding ElementName=SearchDataGrid, Path=AllowPerPixelScrolling}"
                                      Content="Per-Pixel Scrolling"
                                      ToolTip="Switches from item-based scrolling (each scroll step jumps exactly one row) to pixel-based scrolling (smooth sub-row positioning). Required for scroll animation. Item-based is better for keyboard navigation and accessibility.&#x0A;&#x0A;⚠ Performance: do NOT enable on large datasets. Pixel mode invalidates the virtualizing panel on every fractional-pixel scroll change, producing choppy scrolling past ~100k rows. Item mode (the default) scales cleanly to millions of rows." />
                            <CheckBox IsChecked="{Binding ElementName=SearchDataGrid, Path=AllowScrollAnimation}"
                                      Content="Scroll Animation"
                                      ToolTip="Enables animated momentum/inertia scrolling for mouse wheel input. Each wheel tick adds velocity that decays over time, producing a smooth coasting effect. Automatically enables per-pixel scrolling. The content position interpolates toward a physics-driven target, spreading row virtualization work across frames.&#x0A;&#x0A;⚠ Performance: inherits the per-pixel-scrolling performance cliff and compounds it with per-frame ScrollToVerticalOffset calls. Suitable up to ~100k rows; leave off for larger datasets." />

                            <Expander Header="Animation Mode" Padding="4"
                                      IsEnabled="{Binding ElementName=SearchDataGrid, Path=AllowScrollAnimation}"
                                      ToolTip="Controls the deceleration curve of the scroll animation. Only applies when Scroll Animation is enabled.">
                                <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2">
                                    <RadioButton Content="Ease Out"
                                                 IsChecked="{Binding ElementName=SearchDataGrid, Path=ScrollAnimationMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=EaseOut}"
                                                 GroupName="ScrollAnimMode"
                                                 ToolTip="Starts at full speed and gradually decelerates to a stop. Feels responsive and natural — the most common choice for scroll momentum." />
                                    <RadioButton Content="Ease In/Out"
                                                 IsChecked="{Binding ElementName=SearchDataGrid, Path=ScrollAnimationMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=EaseInOut}"
                                                 GroupName="ScrollAnimMode"
                                                 ToolTip="Starts slowly, accelerates through the middle, then decelerates to a stop. Creates a gentle, cushioned feel on both ends of the scroll." />
                                    <RadioButton Content="Linear"
                                                 IsChecked="{Binding ElementName=SearchDataGrid, Path=ScrollAnimationMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Linear}"
                                                 GroupName="ScrollAnimMode"
                                                 ToolTip="Decelerates at a constant rate — like a ball rolling to a stop on a flat surface. No acceleration curve, just uniform slowdown." />
                                    <RadioButton Content="Custom"
                                                 IsChecked="{Binding ElementName=SearchDataGrid, Path=ScrollAnimationMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Custom}"
                                                 GroupName="ScrollAnimMode"
                                                 ToolTip="Handle the CustomScrollAnimation event in code to provide your own deceleration curve or Storyboard-based animation." />
                                </sdg:SimpleStackPanel>
                            </Expander>

                            <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2"
                                                  IsEnabled="{Binding ElementName=SearchDataGrid, Path=AllowScrollAnimation}"
                                                  ToolTip="How long the scroll animation takes to fully decelerate after the last wheel input. Shorter values feel snappy; longer values let the content coast further. Internally converted to a friction coefficient.">
                                <TextBlock Text="{Binding ElementName=ScrollDurationSlider, Path=Value, StringFormat='Duration: {0:F0}ms'}" />
                                <Slider x:Name="ScrollDurationSlider"
                                        Minimum="200" Maximum="2000"
                                        TickFrequency="100" IsSnapToTickEnabled="True"
                                        Value="{Binding ElementName=SearchDataGrid, Path=ScrollAnimationDuration}" />
                            </sdg:SimpleStackPanel>
                        </sdg:SimpleStackPanel>
                    </Expander>

                    <!--  Cascade Update (Row Animation)  -->
                    <Expander Header="Cascade Update" ToolTip="Cascading data updates: rows asynchronously animate their content as they enter the viewport. During fast scrolling, rows that fly past before completing the animation are cancelled — reducing rendering work.">
                        <sdg:SimpleStackPanel Orientation="Vertical" Spacing="6" Margin="4">
                            <CheckBox IsChecked="{Binding ElementName=SearchDataGrid, Path=AllowCascadeUpdate}"
                                      Content="Enable"
                                      ToolTip="Master switch for cascading data updates. When enabled, every row entering the viewport plays an animation on its cell content. Rows that scroll off before the animation completes are cancelled, reducing rendering work during fast scrolling." />

                            <Expander Header="Row Animation" Padding="4"
                                      IsEnabled="{Binding ElementName=SearchDataGrid, Path=AllowCascadeUpdate}"
                                      ToolTip="Specifies the type of animation played when rows enter the viewport.">
                                <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2">
                                    <RadioButton Content="None"
                                                 IsChecked="{Binding ElementName=SearchDataGrid, Path=RowAnimationKind, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=None}"
                                                 GroupName="RowAnimKind"
                                                 ToolTip="No animation. Rows appear instantly at full opacity. Use this if cascade update is enabled but you only want the performance benefit of deferred rendering without visual animation." />
                                    <RadioButton Content="Opacity"
                                                 IsChecked="{Binding ElementName=SearchDataGrid, Path=RowAnimationKind, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Opacity}"
                                                 GroupName="RowAnimKind"
                                                 ToolTip="Animates row cell content from transparent to fully opaque. The easing curve is controlled by the Easing setting below." />
                                    <RadioButton Content="Custom"
                                                 IsChecked="{Binding ElementName=SearchDataGrid, Path=RowAnimationKind, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Custom}"
                                                 GroupName="RowAnimKind"
                                                 ToolTip="Handle the RowAnimationBegin event in code to apply your own animation to the DataGridCellsPresenter. The event provides the row and its cells presenter so you can animate Opacity, RenderTransform, or any other property." />
                                </sdg:SimpleStackPanel>
                            </Expander>

                            <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2"
                                                  IsEnabled="{Binding ElementName=SearchDataGrid, Path=AllowCascadeUpdate}"
                                                  ToolTip="Duration of the per-row animation in milliseconds. Longer durations create a more visible fade effect but also mean rows at low opacity for longer during fast scrolling. Shorter durations feel snappier but the animation is less noticeable.">
                                <TextBlock Text="{Binding ElementName=RowAnimDurationSlider, Path=Value, StringFormat='Duration: {0:F0}ms'}" />
                                <Slider x:Name="RowAnimDurationSlider"
                                        Minimum="50" Maximum="1000"
                                        TickFrequency="25" IsSnapToTickEnabled="True"
                                        Value="{Binding ElementName=SearchDataGrid, Path=RowOpacityAnimationDuration}" />
                            </sdg:SimpleStackPanel>

                            <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2"
                                                  IsEnabled="{Binding ElementName=SearchDataGrid, Path=AllowCascadeUpdate}"
                                                  ToolTip="Delay between consecutive row animations in a burst, creating a visible cascading wave effect. Each row in a burst starts its fade-in N milliseconds after the previous row. Set to 0 to disable stagger (all rows animate simultaneously). The cascade resets when there's a gap between rows, so each new burst starts fresh.">
                                <TextBlock Text="{Binding ElementName=CascadeStaggerSlider, Path=Value, StringFormat='Cascade Stagger: {0:F0}ms'}" />
                                <Slider x:Name="CascadeStaggerSlider"
                                        Minimum="0" Maximum="100"
                                        TickFrequency="5" IsSnapToTickEnabled="True"
                                        Value="{Binding ElementName=SearchDataGrid, Path=CascadeStagger}" />
                            </sdg:SimpleStackPanel>

                            <Expander Header="Easing" Padding="4"
                                      IsEnabled="{Binding ElementName=SearchDataGrid, Path=AllowCascadeUpdate}"
                                      ToolTip="Controls the acceleration curve of the row opacity animation. Only applies when Row Animation is set to Opacity.">
                                <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2">
                                    <RadioButton Content="None (Instant)"
                                                 IsChecked="{Binding ElementName=SearchDataGrid, Path=RowAnimationEasing, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=None}"
                                                 GroupName="RowEasing"
                                                 ToolTip="Instant transition to full opacity. Effectively disables the visual animation while keeping cascade update active for performance." />
                                    <RadioButton Content="Linear"
                                                 IsChecked="{Binding ElementName=SearchDataGrid, Path=RowAnimationEasing, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Linear}"
                                                 GroupName="RowEasing"
                                                 ToolTip="Constant-rate fade from transparent to opaque. No acceleration or deceleration — uniform progress over the full duration." />
                                    <RadioButton Content="Ease Out"
                                                 IsChecked="{Binding ElementName=SearchDataGrid, Path=RowAnimationEasing, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=EaseOut}"
                                                 GroupName="RowEasing"
                                                 ToolTip="Fades in quickly at first, then gradually slows as it approaches full opacity. The most natural-feeling entrance." />
                                    <RadioButton Content="Ease In"
                                                 IsChecked="{Binding ElementName=SearchDataGrid, Path=RowAnimationEasing, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=EaseIn}"
                                                 GroupName="RowEasing"
                                                 ToolTip="Fades in slowly at first, then accelerates toward full opacity. Content appears to 'arrive' at the end." />
                                    <RadioButton Content="Ease In/Out"
                                                 IsChecked="{Binding ElementName=SearchDataGrid, Path=RowAnimationEasing, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=EaseInOut}"
                                                 GroupName="RowEasing"
                                                 ToolTip="Slow start, fast middle, slow end. Creates a smooth, cushioned transition." />
                                </sdg:SimpleStackPanel>
                            </Expander>
                        </sdg:SimpleStackPanel>
                    </Expander>

                    <!--  Performance  -->
                    <Expander Header="Performance" ToolTip="Settings that affect scrolling performance and memory usage. Tune these for large datasets.">
                        <sdg:SimpleStackPanel Orientation="Vertical" Spacing="6" Margin="4">
                            <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2"
                                                  ToolTip="Controls how many pages of off-screen rows the VirtualizingStackPanel keeps pre-realized in memory above and below the visible viewport. Higher values mean smoother scrolling because rows are already prepared when they scroll into view, but use more memory. At 2.0 pages, roughly 60 extra row containers are kept alive. Default: 2.0.">
                                <TextBlock Text="{Binding ElementName=CacheLengthSlider, Path=Value, StringFormat='Virtualization Cache: {0:F1} pages'}" />
                                <Slider x:Name="CacheLengthSlider"
                                        Minimum="0.5" Maximum="5.0"
                                        TickFrequency="0.5" IsSnapToTickEnabled="True"
                                        Value="{Binding ElementName=SearchDataGrid, Path=VirtualizationCacheLength}" />
                            </sdg:SimpleStackPanel>
                            <CheckBox IsChecked="{Binding ElementName=SearchDataGrid, Path=EnableColumnVirtualization}"
                                      Content="Column Virtualization"
                                      ToolTip="When enabled, only columns currently visible in the horizontal viewport are realized. Columns scrolled off-screen horizontally are virtualized (not created in the visual tree). Significantly improves performance for grids with 20+ columns by reducing the number of cell containers per row." />
                        </sdg:SimpleStackPanel>
                    </Expander>

                    <!-- ══════════════════════════════════════════ -->
                    <!--  COLUMN PROPERTIES (focused column)       -->
                    <!-- ══════════════════════════════════════════ -->

                    <Expander DataContext="{Binding ElementName=SearchDataGrid, Path=LastFocusedGridColumn}"
                              ToolTip="Properties for the currently focused column. Click a column cell in the grid to select it.">
                        <Expander.Header>
                            <TextBlock>
                                <Run Text="Column:" />
                                <Run Text="{Binding ElementName=SearchDataGrid, Path=LastFocusedGridColumn.HeaderCaption, Mode=OneWay}" FontWeight="Bold" />
                            </TextBlock>
                        </Expander.Header>
                        <sdg:SimpleStackPanel Orientation="Vertical"
                                              IsEnabled="{Binding Converter={StaticResource NullToBooleanConverter}}"
                                              Spacing="8" Margin="4">

                            <!--  Identity  -->
                            <Expander Header="Identity" ToolTip="Core identification properties for this column.">
                                <sdg:SimpleStackPanel Orientation="Vertical" Spacing="4" Margin="4">
                                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2"
                                                          ToolTip="The property name on the data object that this column is bound to. This is set at design time and cannot be changed at runtime.">
                                        <TextBlock Text="Field Name:" FontWeight="Bold" />
                                        <TextBlock Text="{Binding FieldName, FallbackValue='(none)'}" />
                                    </sdg:SimpleStackPanel>
                                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2"
                                                          ToolTip="The text displayed in the column header. Changes are reflected immediately in the grid.">
                                        <TextBlock Text="Header:" FontWeight="Bold" />
                                        <TextBox Text="{Binding Header, UpdateSourceTrigger=PropertyChanged}" />
                                    </sdg:SimpleStackPanel>
                                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2"
                                                          ToolTip="Optional display name override. When set, the filter panel and column chooser show this name instead of the Header text. Leave empty to use the Header value.">
                                        <TextBlock Text="Display Name:" FontWeight="Bold" />
                                        <TextBox Text="{Binding ColumnDisplayName, UpdateSourceTrigger=PropertyChanged}" />
                                    </sdg:SimpleStackPanel>
                                </sdg:SimpleStackPanel>
                            </Expander>

                            <!--  Filtering & Search  -->
                            <Expander Header="Filtering &amp; Search" ToolTip="Controls how users can filter and search within this column.">
                                <sdg:SimpleStackPanel Orientation="Vertical" Spacing="4" Margin="4">
                                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2"
                                                          ToolTip="Overrides the FieldName for filtering purposes. Use this when the display property differs from the property you want to filter on (e.g., display 'StatusName' but filter on 'StatusId').">
                                        <TextBlock Text="Filter Member Path:" FontWeight="Bold" />
                                        <TextBox Text="{Binding FilterMemberPath, UpdateSourceTrigger=PropertyChanged}" />
                                    </sdg:SimpleStackPanel>
                                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2"
                                                          ToolTip="How the column's search box matches text by default. Contains: matches anywhere in the value. StartsWith: matches from the beginning. EndsWith: matches from the end. Equals: exact match only.">
                                        <TextBlock Text="Default Search Mode:" FontWeight="Bold" />
                                        <ComboBox SelectedItem="{Binding DefaultSearchMode}">
                                            <ComboBox.Items>
                                                <sdg:DefaultSearchMode>Contains</sdg:DefaultSearchMode>
                                                <sdg:DefaultSearchMode>StartsWith</sdg:DefaultSearchMode>
                                                <sdg:DefaultSearchMode>EndsWith</sdg:DefaultSearchMode>
                                                <sdg:DefaultSearchMode>Equals</sdg:DefaultSearchMode>
                                            </ComboBox.Items>
                                        </ComboBox>
                                    </sdg:SimpleStackPanel>
                                    <CheckBox IsChecked="{Binding EnableRuleFiltering}" Content="Rule Filtering"
                                              ToolTip="Enables the advanced rule-based filtering UI for this specific column. When enabled, users can create multi-criteria filter rules with AND/OR logic. This is the per-column override — the grid-level setting must also be enabled." />
                                    <CheckBox IsChecked="{Binding UseCheckBoxInSearchBox}" Content="CheckBox Filter"
                                              ToolTip="Replaces the text search box with a tri-state checkbox for boolean columns. The checkbox cycles through True, False, and All (no filter) states." />
                                    <CheckBox IsChecked="{Binding AllowFiltering}" Content="Allow Filtering"
                                              ToolTip="When unchecked, the search box / filter UI is completely hidden for this column. Users cannot filter by this column at all." />
                                    <CheckBox IsChecked="{Binding AllowSorting}" Content="Allow Sorting"
                                              ToolTip="When unchecked, clicking the column header does not sort the grid by this column. The sort indicator arrow is hidden." />
                                </sdg:SimpleStackPanel>
                            </Expander>

                            <!--  Display Formatting  -->
                            <Expander Header="Display Formatting" ToolTip="Controls how cell values are formatted for display.">
                                <sdg:SimpleStackPanel Orientation="Vertical" Spacing="4" Margin="4">
                                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2"
                                                          ToolTip="A .NET format string applied to cell values before display. Examples: 'C2' for currency ($1,234.56), 'N0' for integer with commas (1,234), 'P1' for percent (85.3%), 'MM/dd/yyyy' for dates.">
                                        <TextBlock Text="String Format:" FontWeight="Bold" />
                                        <TextBox Text="{Binding DisplayStringFormat, UpdateSourceTrigger=PropertyChanged}" />
                                    </sdg:SimpleStackPanel>
                                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2"
                                                          ToolTip="An input/display mask pattern. Characters: '0' = required digit, '9' = optional digit, 'L' = required letter, '?' = optional letter. Example: '(000) 000-0000' formats phone numbers.">
                                        <TextBlock Text="Display Mask:" FontWeight="Bold" />
                                        <TextBox Text="{Binding DisplayMask, UpdateSourceTrigger=PropertyChanged}" />
                                    </sdg:SimpleStackPanel>
                                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2"
                                                          ToolTip="An IValueConverter instance that transforms the raw cell value into a display value. Set programmatically in code — cannot be edited here.">
                                        <TextBlock Text="Value Converter:" FontWeight="Bold" />
                                        <TextBlock Foreground="#666" Text="{Binding DisplayValueConverter, TargetNullValue='(none)'}" />
                                    </sdg:SimpleStackPanel>
                                </sdg:SimpleStackPanel>
                            </Expander>

                            <!--  Layout  -->
                            <Expander Header="Layout" ToolTip="Controls column visibility, position locking, and user interaction permissions.">
                                <sdg:SimpleStackPanel Orientation="Vertical" Spacing="4" Margin="4">
                                    <CheckBox IsChecked="{Binding Visible}" Content="Visible"
                                              ToolTip="When unchecked, the column is hidden from the grid. It can be shown again via the Column Chooser or by checking this box." />
                                    <CheckBox IsChecked="{Binding Fixed}" Content="Fixed (Frozen)"
                                              ToolTip="When checked, the column is frozen to the left side of the grid and does not scroll horizontally with the other columns. Useful for identifier columns that should always be visible." />
                                    <CheckBox IsChecked="{Binding ReadOnly}" Content="Read Only"
                                              ToolTip="When checked, cells in this column cannot be edited even if the grid's IsReadOnly is false. The cell enters a read-only state when double-clicked." />
                                    <CheckBox IsChecked="{Binding AllowMoving}" Content="Allow Moving"
                                              ToolTip="When unchecked, this column's header cannot be dragged to reorder it. The column stays in its current position regardless of the grid-level CanUserReorderColumns setting." />
                                    <CheckBox IsChecked="{Binding AllowResizing}" Content="Allow Resizing"
                                              ToolTip="When unchecked, the column width cannot be changed by dragging the header border. The column stays at its defined width." />
                                    <CheckBox IsChecked="{Binding ShowInColumnChooser}" Content="Show in Chooser"
                                              ToolTip="When unchecked, this column does not appear in the Column Chooser window. Use this for columns that should not be user-hideable (e.g., required identifier columns)." />
                                </sdg:SimpleStackPanel>
                            </Expander>

                            <!--  Select All  -->
                            <Expander Header="Select All" ToolTip="Adds a select-all checkbox to the column header for boolean columns.">
                                <sdg:SimpleStackPanel Orientation="Vertical" Spacing="4" Margin="4">
                                    <CheckBox IsChecked="{Binding IsSelectAllColumn}" Content="Is Select All Column"
                                              ToolTip="When checked, a select-all checkbox appears in this column's header. Toggling it sets all matching boolean values to True or False. Only works for columns bound to boolean properties." />
                                    <sdg:SimpleStackPanel Orientation="Vertical" Spacing="2"
                                                          ToolTip="Determines which items are affected when the select-all checkbox is toggled. FilteredRows: only currently visible/filtered rows. SelectedRows: only rows in the current selection. AllItems: every item in the data source regardless of filtering or selection.">
                                        <TextBlock Text="Scope:" FontWeight="Bold" />
                                        <ComboBox SelectedItem="{Binding SelectAllScope}">
                                            <ComboBox.Items>
                                                <sdg:SelectAllScope>FilteredRows</sdg:SelectAllScope>
                                                <sdg:SelectAllScope>SelectedRows</sdg:SelectAllScope>
                                                <sdg:SelectAllScope>AllItems</sdg:SelectAllScope>
                                            </ComboBox.Items>
                                        </ComboBox>
                                    </sdg:SimpleStackPanel>
                                </sdg:SimpleStackPanel>
                            </Expander>

                        </sdg:SimpleStackPanel>
                    </Expander>

                </sdg:SimpleStackPanel>
            </ScrollViewer>

            <!--  Loading Overlay  -->
            <Border Grid.ColumnSpan="3"
                    Background="#80FFFFFF"
                    Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVisibility}}"
                    Panel.ZIndex="50">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <controls:WWSpinningWheel Width="56" Height="56" />
                    <TextBlock Foreground="#1C1C1C"
                               Text="{Binding GeneratingStatus}"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>

        </Grid>
    </DockPanel>
</Window>
