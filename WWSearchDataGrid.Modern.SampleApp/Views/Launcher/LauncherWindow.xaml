<Window x:Class="WWSearchDataGrid.Modern.SampleApp.Views.Launcher.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:launcher="clr-namespace:WWSearchDataGrid.Modern.SampleApp.Views.Launcher"
        Title="WWSearchDataGrid — Sample Browser"
        Style="{DynamicResource SampleAppWindowStyle}"
        Width="1500"
        Height="880"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d">
    <Window.Resources>
        <!-- Chevron icon style for the navigator collapse/expand button. Glyph swaps with IsChecked
             on the templated parent ToggleButton: ◀ when expanded, ▶ when collapsed. -->
        <Style x:Key="NavigatorChevronStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#444" />
            <Setter Property="Text" Value="&#xE76B;" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="False">
                    <Setter Property="Text" Value="&#xE76C;" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Borderless toggle button style for the navigator collapse handle. -->
        <Style x:Key="NavigatorToggleButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E5E5E5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#FAFAFA">
        <Grid.ColumnDefinitions>
            <!-- Navigator column. Width is driven from code-behind: a stored "expanded" width when
                 NavigatorToggle.IsChecked, or a thin strip (just wide enough for the expand chevron)
                 when collapsed. User drags on the splitter overwrite the stored expanded width. -->
            <ColumnDefinition x:Name="NavigatorColumn" Width="240" MinWidth="32" />
            <ColumnDefinition x:Name="SplitterColumn" Width="5" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Master: header + sample tree  -->
        <DockPanel x:Name="NavigatorPane" Grid.Column="0" Background="#F4F4F4">
            <!-- Title + collapse toggle. When collapsed, the title block is hidden and only the
                 chevron toggle remains visible, centered in the thin strip. -->
            <Grid DockPanel.Dock="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="NavigatorHeader" Grid.Column="0" Margin="12,12,4,8">
                    <TextBlock Foreground="#1C1C1C"
                               Text="WWSearchDataGrid Samples"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Foreground="#666"
                               Text="Browse focused samples grouped by category."
                               Margin="0,2,0,0"
                               FontSize="11"
                               TextWrapping="Wrap" />
                </StackPanel>

                <ToggleButton x:Name="NavigatorToggle"
                              Grid.Column="1"
                              Style="{StaticResource NavigatorToggleButtonStyle}"
                              IsChecked="True"
                              Margin="0,8,4,0"
                              VerticalAlignment="Top"
                              ToolTip="Collapse / expand the sample list"
                              Checked="OnNavigatorToggleChanged"
                              Unchecked="OnNavigatorToggleChanged">
                    <TextBlock Style="{StaticResource NavigatorChevronStyle}" />
                </ToggleButton>
            </Grid>

            <TreeView x:Name="SampleTree"
                      Background="Transparent"
                      BorderThickness="0"
                      Margin="4,0,4,8"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      SelectedItemChanged="OnSampleSelectedItemChanged">
                <TreeView.Resources>
                    <!--  Category template: name only; description on tooltip.  -->
                    <HierarchicalDataTemplate DataType="{x:Type launcher:SampleCategory}" ItemsSource="{Binding Samples}">
                        <Border Padding="0" ToolTip="{Binding Description}">
                            <TextBlock Foreground="#1C1C1C"
                                       Text="{Binding Name}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                    </HierarchicalDataTemplate>

                    <!--  Sample leaf template: name only; description on tooltip.  -->
                    <DataTemplate DataType="{x:Type launcher:SampleDefinition}">
                        <Border Padding="0" ToolTip="{Binding Description}">
                            <TextBlock Foreground="#1C1C1C"
                                       Text="{Binding Name}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                    </DataTemplate>
                </TreeView.Resources>

                <TreeView.ItemContainerStyle>
                    <!--
                        Custom TreeViewItem template: neutral gray selection background plus a 3px
                        accent pill on the left edge (modern ComboBox-item selection style). The
                        full default WPF template is replaced so the system-default dark-blue
                        SystemColors highlight doesn't bleed through.
                    -->
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="True" />
                        <Setter Property="Margin" Value="0,0,0,1" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Foreground" Value="#1C1C1C" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TreeViewItem">
                                    <StackPanel>
                                        <Border x:Name="SelectionBorder"
                                                Background="Transparent"
                                                MinHeight="24"
                                                CornerRadius="3"
                                                SnapsToDevicePixels="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="6" />
                                                    <ColumnDefinition Width="14" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <!--  Accent pill — only visible when IsSelected  -->
                                                <Border x:Name="AccentPill"
                                                        Grid.Column="0"
                                                        Background="#0078D4"
                                                        Visibility="Collapsed"
                                                        Margin="2,4,0,4"
                                                        HorizontalAlignment="Left"
                                                        Width="2"
                                                        CornerRadius="1" />

                                                <!--  Expand / collapse chevron  -->
                                                <ToggleButton x:Name="Expander"
                                                              Grid.Column="1"
                                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                              Focusable="False"
                                                              ClickMode="Press">
                                                    <ToggleButton.Template>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border Background="Transparent" Padding="1">
                                                                <TextBlock x:Name="Chevron"
                                                                           Text="&#xE70D;"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="10"
                                                                           FontFamily="Segoe Fluent Icons" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="Chevron" Property="RenderTransform">
                                                                        <Setter.Value>
                                                                            <RotateTransform Angle="0" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </ToggleButton.Template>
                                                </ToggleButton>

                                                <!--  Header content  -->
                                                <ContentPresenter Grid.Column="2"
                                                                  Margin="0,3"
                                                                  VerticalAlignment="Center"
                                                                  ContentSource="Header"
                                                                  SnapsToDevicePixels="True" />
                                            </Grid>
                                        </Border>

                                        <!--  Children, indented  -->
                                        <ItemsPresenter x:Name="ItemsHost" Margin="14,0,0,0" />
                                    </StackPanel>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsExpanded" Value="False">
                                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                                        </Trigger>
                                        <Trigger Property="HasItems" Value="False">
                                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="SelectionBorder" Property="Background" Value="#EFEFEF" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="SelectionBorder" Property="Background" Value="#E5E5E5" />
                                            <Setter TargetName="AccentPill" Property="Visibility" Value="Visible" />
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsSelected" Value="True" />
                                                <Condition Property="IsMouseOver" Value="True" />
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="SelectionBorder" Property="Background" Value="#DDDDDD" />
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>
        </DockPanel>

        <!-- Splitter between navigator and detail. Hidden (zero-width column) while the navigator is
             collapsed so there's nothing to drag from a closed pane. ShowsPreview defers the actual
             resize to mouse-up so the live SearchDataGrid on the right doesn't re-realize row
             containers on every drag-tick when the user is expanding the detail pane. -->
        <GridSplitter x:Name="NavigatorSplitter"
                      Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#E0E0E0"
                      ShowsPreview="True"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Columns" />

        <!--  Detail: hosted sample content  -->
        <Border Grid.Column="2"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1,0,0,0">
            <ContentPresenter x:Name="SampleHost" />
        </Border>
    </Grid>
</Window>
