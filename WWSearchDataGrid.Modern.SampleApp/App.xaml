<Application x:Class="WWSearchDataGrid.Modern.SampleApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WWSearchDataGrid.Modern.SampleApp"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Color resources (light mode default) -->
                <ResourceDictionary Source="/Styles/Colors/LightColors.xaml"/>
                <!-- Window style (shared across themes) -->
                <ResourceDictionary Source="/Styles/WindowStyle.xaml"/>
                <!-- Default generic control styles -->
                <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF;component/Themes/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
