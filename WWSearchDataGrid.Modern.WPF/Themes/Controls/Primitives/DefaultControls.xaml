<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ═══════════════════════════════════════════════════════════════
        GENERIC THEME — Shared Color Palette & Primitive Control Styles
        ═══════════════════════════════════════════════════════════════
        All colors used by the generic (non-custom) theme are defined here.
        Consuming XAML files reference these via {StaticResource}.
    -->

    <!--#region Color Palette-->

    <!--  Surfaces  -->
    <SolidColorBrush x:Key="Sdg.Surface.Primary" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Sdg.Surface.Secondary" Color="#F8F9FA" />
    <SolidColorBrush x:Key="Sdg.Surface.Tertiary" Color="#F0F0F0" />
    <SolidColorBrush x:Key="Sdg.Surface.Hover" Color="#E8E8E8" />
    <SolidColorBrush x:Key="Sdg.Surface.Pressed" Color="#DCDCDC" />
    <SolidColorBrush x:Key="Sdg.Surface.Input" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Sdg.Surface.Disabled" Color="#F5F5F5" />

    <!--  Text  -->
    <SolidColorBrush x:Key="Sdg.Text.Primary" Color="#1C1C1C" />
    <SolidColorBrush x:Key="Sdg.Text.Secondary" Color="#444444" />
    <SolidColorBrush x:Key="Sdg.Text.Tertiary" Color="#666666" />
    <SolidColorBrush x:Key="Sdg.Text.Disabled" Color="#999999" />
    <SolidColorBrush x:Key="Sdg.Text.OnAccent" Color="#FFFFFF" />

    <!--  Borders  -->
    <SolidColorBrush x:Key="Sdg.Border.Default" Color="#CCCCCC" />
    <SolidColorBrush x:Key="Sdg.Border.Subtle" Color="#E0E0E0" />
    <SolidColorBrush x:Key="Sdg.Border.Strong" Color="#AAAAAA" />
    <SolidColorBrush x:Key="Sdg.Border.Focused" Color="#0078D4" />

    <!--  Accent  -->
    <SolidColorBrush x:Key="Sdg.Accent" Color="#0078D4" />
    <SolidColorBrush x:Key="Sdg.Accent.Hover" Color="#005A9E" />
    <SolidColorBrush x:Key="Sdg.Accent.Pressed" Color="#004578" />

    <!--  Selection — lightweight accent tints for rows/cells (text stays dark for readability)  -->
    <SolidColorBrush x:Key="Sdg.Selection.Background" Color="#CCE4F7" />
    <SolidColorBrush x:Key="Sdg.Selection.Background.Hover" Color="#B3D7F2" />
    <SolidColorBrush x:Key="Sdg.Selection.Background.Inactive" Color="#EDEDED" />

    <!--  Status  -->
    <SolidColorBrush x:Key="Sdg.Status.Error" Color="#CC0000" />
    <SolidColorBrush x:Key="Sdg.Status.Error.Hover" Color="#990000" />

    <!--  Scrollbar  -->
    <SolidColorBrush x:Key="Sdg.Scrollbar.Track" Color="Transparent" />
    <SolidColorBrush x:Key="Sdg.Scrollbar.Track.Hover" Color="Transparent" />
    <SolidColorBrush x:Key="Sdg.Scrollbar.Thumb" Color="#646464" />
    <SolidColorBrush x:Key="Sdg.Scrollbar.Thumb.Hover" Color="#646464" />
    <SolidColorBrush x:Key="Sdg.Scrollbar.Thumb.Pressed" Color="#646464" />
    <SolidColorBrush x:Key="Sdg.Scrollbar.Arrow" Color="#646464" />

    <!--#endregion-->

    <!--#region Button Style-->

    <Style x:Key="SdgButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{StaticResource Sdg.Surface.Primary}" />
        <Setter Property="Foreground" Value="{StaticResource Sdg.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Sdg.Border.Default}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Sdg.Surface.Hover}" />
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Sdg.Border.Strong}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Sdg.Surface.Pressed}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Sdg.Surface.Disabled}" />
                            <Setter Property="Foreground" Value="{StaticResource Sdg.Text.Disabled}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

    <!--#region CheckBox Style-->

    <Style x:Key="SdgCheckBoxStyle" TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{StaticResource Sdg.Text.Primary}" />
        <Setter Property="Background" Value="{StaticResource Sdg.Surface.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Sdg.Border.Strong}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="6,0,0,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="Box"
                                Grid.Column="0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                VerticalAlignment="Center"
                                Width="16"
                                Height="16"
                                CornerRadius="3">
                            <TextBlock x:Name="Glyph"
                                       Foreground="{StaticResource Sdg.Text.OnAccent}"
                                       Opacity="0"
                                       Text="&#xE73E;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="12" />
                        </Border>

                        <ContentPresenter Grid.Column="1"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource Sdg.Accent}" />
                            <Setter TargetName="Box" Property="BorderThickness" Value="0" />
                            <Setter TargetName="Box" Property="Padding" Value="1" />
                            <Setter TargetName="Glyph" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource Sdg.Accent}" />
                            <Setter TargetName="Box" Property="BorderThickness" Value="0" />
                            <Setter TargetName="Box" Property="Padding" Value="1" />
                            <Setter TargetName="Glyph" Property="Text" Value="&#xE738;" />
                            <Setter TargetName="Glyph" Property="FontSize" Value="10" />
                            <Setter TargetName="Glyph" Property="Opacity" Value="1" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Sdg.Accent}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource Sdg.Accent.Hover}" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource Sdg.Text.Disabled}" />
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource Sdg.Surface.Disabled}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Sdg.Border.Default}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

    <!--#region Resize Thumb Style-->

    <Style x:Key="SdgResizeThumbStyle" TargetType="{x:Type Thumb}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border Background="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

    <!--#region ComboBox Style-->

    <!--  Transparent toggle used as full-width hit area  -->
    <Style x:Key="SdgComboBoxToggleButtonStyle" TargetType="{x:Type ToggleButton}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="ClickMode" Value="Release" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="3"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SdgComboBoxStyle" TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="{StaticResource Sdg.Surface.Primary}" />
        <Setter Property="Foreground" Value="{StaticResource Sdg.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Sdg.Border.Default}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid x:Name="LayoutRoot">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                        </Grid.ColumnDefinitions>

                        <!--  Background (spans both columns)  -->
                        <Border x:Name="Background"
                                Grid.ColumnSpan="2"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" />

                        <!--  Selected content (column 0 only)  -->
                        <ContentPresenter x:Name="ContentPresenter"
                                          Grid.Column="0"
                                          IsHitTestVisible="False"
                                          Margin="4,2,0,2"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />

                        <!--  Toggle (transparent hit area, spans full width)  -->
                        <ToggleButton x:Name="ToggleButton"
                                      Style="{StaticResource SdgComboBoxToggleButtonStyle}"
                                      Grid.ColumnSpan="2"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />

                        <!--  Chevron (column 1, pass-through)  -->
                        <TextBlock x:Name="Arrow"
                                   Grid.Column="1"
                                   Text="&#xE70D;"
                                   IsHitTestVisible="False"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe Fluent Icons" />

                        <!--  Editable text (hidden for standard combo)  -->
                        <TextBox x:Name="PART_EditableTextBox"
                                 Style="{x:Null}"
                                 Grid.Column="0"
                                 Background="Transparent"
                                 Visibility="Hidden"
                                 IsReadOnly="{TemplateBinding IsReadOnly}"
                                 Focusable="True"
                                 Margin="{TemplateBinding Padding}" />

                        <!--  Dropdown  -->
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                               Placement="Bottom"
                               StaysOpen="False"
                               PopupAnimation="Slide"
                               PlacementTarget="{Binding ElementName=Background}">
                            <Border Padding="4">
                                <Border Background="Transparent">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000"
                                                          Opacity="0.2"
                                                          BlurRadius="12"
                                                          ShadowDepth="2"
                                                          Direction="270" />
                                    </Border.Effect>
                                    <Border Background="{StaticResource Sdg.Surface.Primary}"
                                            BorderBrush="{StaticResource Sdg.Border.Default}"
                                            BorderThickness="1"
                                            Padding="2"
                                            MinWidth="{Binding ActualWidth, ElementName=LayoutRoot}"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                            CornerRadius="3">
                                        <ScrollViewer>
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Border>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Background" Property="Background" Value="{StaticResource Sdg.Surface.Secondary}" />
                            <Setter TargetName="Background" Property="BorderBrush" Value="{StaticResource Sdg.Border.Strong}" />
                        </Trigger>
                        <Trigger SourceName="ToggleButton" Property="IsChecked" Value="True">
                            <Setter TargetName="Background" Property="BorderBrush" Value="{StaticResource Sdg.Border.Focused}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource Sdg.Text.Disabled}" />
                            <Setter TargetName="Arrow" Property="Foreground" Value="{StaticResource Sdg.Text.Disabled}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Resources>
            <Style TargetType="{x:Type ComboBoxItem}">
                <Setter Property="Padding" Value="4,2" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                            <Border x:Name="Bd"
                                    Background="Transparent"
                                    Padding="{TemplateBinding Padding}"
                                    CornerRadius="2">
                                <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Sdg.Surface.Hover}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Sdg.Surface.Hover}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Style.Resources>
    </Style>

    <!--#endregion-->

    <!--#region TabControl & TabItem Style-->

    <Style x:Key="SdgTabControlStyle" TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="{StaticResource Sdg.Surface.Tertiary}"
                                Margin="-4,-4,-4,0"
                                Padding="4,4,0,0"
                                CornerRadius="4,4,0,0 ">

                            <TabPanel Background="Transparent"
                                      HorizontalAlignment="Center"
                                      IsItemsHost="True" />
                        </Border>
                        <Border Grid.Row="1"
                                BorderBrush="{StaticResource Sdg.Border.Strong}"
                                BorderThickness="0,0,0,1"
                                Margin="-4,0" />
                        <ContentPresenter Grid.Row="2"
                                          Margin="0,0,0,0"
                                          ContentSource="SelectedContent" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SdgTabItemStyle" TargetType="{x:Type TabItem}">
        <Setter Property="Foreground" Value="{StaticResource Sdg.Text.Tertiary}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabItem}">
                    <Border x:Name="TabBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="0,0,0,2"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          TextElement.FontWeight="{TemplateBinding FontWeight}"
                                          ContentSource="Header" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Sdg.Accent}" />
                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource Sdg.Accent}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsSelected" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="{StaticResource Sdg.Text.Primary}" />
                            <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource Sdg.Surface.Hover}" />
                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource Sdg.Surface.Hover}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

    <!--#region ScrollBar Style-->

    <!--  Vertical ScrollBar Context Menu  -->
    <ContextMenu x:Key="SdgVScrollBarContextMenu" x:Shared="True">
        <MenuItem Command="ScrollBar.ScrollHereCommand"
                  CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                  Header="Scroll Here" />
        <Separator Background="{StaticResource Sdg.Border.Subtle}" />
        <MenuItem Command="ScrollBar.ScrollToTopCommand"
                  CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                  Header="Top" />
        <MenuItem Command="ScrollBar.ScrollToBottomCommand"
                  CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                  Header="Bottom" />
        <Separator Background="{StaticResource Sdg.Border.Subtle}" />
        <MenuItem Command="ScrollBar.PageUpCommand"
                  CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                  Header="Page Up" />
        <MenuItem Command="ScrollBar.PageDownCommand"
                  CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                  Header="Page Down" />
        <Separator Background="{StaticResource Sdg.Border.Subtle}" />
        <MenuItem Command="ScrollBar.LineUpCommand"
                  CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                  Header="Scroll Up" />
        <MenuItem Command="ScrollBar.LineDownCommand"
                  CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                  Header="Scroll Down" />
    </ContextMenu>

    <!--  Horizontal ScrollBar Context Menu  -->
    <ContextMenu x:Key="SdgHScrollBarContextMenu" x:Shared="True">
        <MenuItem Command="ScrollBar.ScrollHereCommand"
                  CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                  Header="Scroll Here" />
        <Separator Background="{StaticResource Sdg.Border.Subtle}" />
        <MenuItem Command="ScrollBar.ScrollToLeftEndCommand"
                  CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                  Header="Left" />
        <MenuItem Command="ScrollBar.ScrollToRightEndCommand"
                  CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                  Header="Right" />
        <Separator Background="{StaticResource Sdg.Border.Subtle}" />
        <MenuItem Command="ScrollBar.PageLeftCommand"
                  CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                  Header="Page Left" />
        <MenuItem Command="ScrollBar.PageRightCommand"
                  CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                  Header="Page Right" />
        <Separator Background="{StaticResource Sdg.Border.Subtle}" />
        <MenuItem Command="ScrollBar.LineLeftCommand"
                  CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                  Header="Scroll Left" />
        <MenuItem Command="ScrollBar.LineRightCommand"
                  CommandTarget="{Binding Path=PlacementTarget, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
                  Header="Scroll Right" />
    </ContextMenu>

    <!--  Transparent page-button (covers the track between thumb and arrow)  -->
    <Style x:Key="SdgScrollBarPageButtonStyle" TargetType="{x:Type RepeatButton}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="SdgScrollBarVerticalTemplate" TargetType="{x:Type ScrollBar}">
        <Grid Width="12"
              ClipToBounds="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
                <RowDefinition Height="14" />
            </Grid.RowDefinitions>

            <!--  Always-visible track  -->
            <Border x:Name="TrackBackground"
                    Grid.RowSpan="3"
                    Background="{StaticResource Sdg.Scrollbar.Track}"
                    CornerRadius="6" />

            <!--  Line-Up button  -->
            <RepeatButton x:Name="PART_LineUpButton"
                          OverridesDefaultStyle="True"
                          Grid.Row="0"
                          Focusable="False"
                          Command="ScrollBar.LineUpCommand"
                          IsTabStop="False">
                <RepeatButton.Template>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" CornerRadius="4,4,0,0">
                            <TextBlock Foreground="{StaticResource Sdg.Scrollbar.Arrow}"
                                       Text="&#xEDDB;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="7" />
                        </Border>
                    </ControlTemplate>
                </RepeatButton.Template>
            </RepeatButton>

            <!--  Track + Thumb  -->
            <Track x:Name="PART_Track"
                   Grid.Row="1"
                   Focusable="False"
                   ClipToBounds="False"
                   IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource SdgScrollBarPageButtonStyle}" Command="ScrollBar.PageUpCommand" />
                </Track.DecreaseRepeatButton>

                <Track.Thumb>
                    <Thumb OverridesDefaultStyle="True"
                           MinHeight="1"
                           IsTabStop="False"
                           ClipToBounds="False">
                        <Thumb.Template>
                            <ControlTemplate TargetType="{x:Type Thumb}">
                                <Border x:Name="ThumbVisual"
                                        Background="{StaticResource Sdg.Scrollbar.Thumb}"
                                        Margin="2"
                                        CornerRadius="4" />
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ThumbVisual" Property="Background" Value="{StaticResource Sdg.Scrollbar.Thumb.Hover}" />
                                    </Trigger>
                                    <Trigger Property="IsDragging" Value="True">
                                        <Setter TargetName="ThumbVisual" Property="Background" Value="{StaticResource Sdg.Scrollbar.Thumb.Pressed}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Track.Thumb>

                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource SdgScrollBarPageButtonStyle}" Command="ScrollBar.PageDownCommand" />
                </Track.IncreaseRepeatButton>
            </Track>

            <!--  Line-Down button  -->
            <RepeatButton x:Name="PART_LineDownButton"
                          OverridesDefaultStyle="True"
                          Grid.Row="2"
                          Focusable="False"
                          Command="ScrollBar.LineDownCommand"
                          IsTabStop="False">
                <RepeatButton.Template>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" CornerRadius="0,0,4,4">
                            <TextBlock Foreground="{StaticResource Sdg.Scrollbar.Arrow}"
                                       Text="&#xEDDC;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="8" />
                        </Border>
                    </ControlTemplate>
                </RepeatButton.Template>
            </RepeatButton>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="TrackBackground" Property="Background" Value="{StaticResource Sdg.Scrollbar.Track.Hover}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="SdgScrollBarHorizontalTemplate" TargetType="{x:Type ScrollBar}">
        <Grid Height="12"
              ClipToBounds="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
            </Grid.ColumnDefinitions>

            <!--  Always-visible track  -->
            <Border x:Name="TrackBackground"
                    Grid.ColumnSpan="3"
                    Background="{StaticResource Sdg.Scrollbar.Track}"
                    CornerRadius="6" />

            <!--  Line-Left button  -->
            <RepeatButton x:Name="PART_LineLeftButton"
                          OverridesDefaultStyle="True"
                          Grid.Column="0"
                          Focusable="False"
                          Command="ScrollBar.LineLeftCommand"
                          IsTabStop="False">
                <RepeatButton.Template>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" CornerRadius="4,0,0,4">
                            <TextBlock Foreground="{StaticResource Sdg.Scrollbar.Arrow}"
                                       Text="&#xEDD9;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="8" />
                        </Border>
                    </ControlTemplate>
                </RepeatButton.Template>
            </RepeatButton>

            <!--  Track + Thumb  -->
            <Track x:Name="PART_Track"
                   Grid.Column="1"
                   Focusable="False"
                   ClipToBounds="False"
                   IsDirectionReversed="False">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource SdgScrollBarPageButtonStyle}" Command="ScrollBar.PageLeftCommand" />
                </Track.DecreaseRepeatButton>

                <Track.Thumb>
                    <Thumb OverridesDefaultStyle="True"
                           MinWidth="20"
                           IsTabStop="False"
                           ClipToBounds="False">
                        <Thumb.Template>
                            <ControlTemplate TargetType="{x:Type Thumb}">
                                <Border x:Name="ThumbVisual"
                                        Background="{StaticResource Sdg.Scrollbar.Thumb}"
                                        Margin="2"
                                        CornerRadius="2" />
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ThumbVisual" Property="Background" Value="{StaticResource Sdg.Scrollbar.Thumb.Hover}" />
                                    </Trigger>
                                    <Trigger Property="IsDragging" Value="True">
                                        <Setter TargetName="ThumbVisual" Property="Background" Value="{StaticResource Sdg.Scrollbar.Thumb.Pressed}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Track.Thumb>

                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource SdgScrollBarPageButtonStyle}" Command="ScrollBar.PageRightCommand" />
                </Track.IncreaseRepeatButton>
            </Track>

            <!--  Line-Right button  -->
            <RepeatButton x:Name="PART_LineRightButton"
                          OverridesDefaultStyle="True"
                          Grid.Column="2"
                          Focusable="False"
                          Command="ScrollBar.LineRightCommand"
                          IsTabStop="False">
                <RepeatButton.Template>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" CornerRadius="0,4,4,0">
                            <TextBlock Foreground="{StaticResource Sdg.Scrollbar.Arrow}"
                                       Text="&#xEDDA;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="8" />
                        </Border>
                    </ControlTemplate>
                </RepeatButton.Template>
            </RepeatButton>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="TrackBackground" Property="Background" Value="{StaticResource Sdg.Scrollbar.Track.Hover}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="SdgScrollBarStyle" TargetType="{x:Type ScrollBar}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template" Value="{StaticResource SdgScrollBarVerticalTemplate}" />
        <Setter Property="ContextMenu" Value="{StaticResource SdgVScrollBarContextMenu}" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Template" Value="{StaticResource SdgScrollBarHorizontalTemplate}" />
                <Setter Property="ContextMenu" Value="{StaticResource SdgHScrollBarContextMenu}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  Implicit: every ScrollBar inside a control that merges DefaultControls picks this up  -->
    <Style BasedOn="{StaticResource SdgScrollBarStyle}" TargetType="{x:Type ScrollBar}" />

    <!--#endregion-->

</ResourceDictionary>
