<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdgCore="clr-namespace:WWSearchDataGrid.Modern.Core;assembly=WWSearchDataGrid.Modern.Core"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF"
                    xmlns:converters="clr-namespace:WWSearchDataGrid.Modern.WPF.Converters">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF;component/Themes/Controls/Primitives/DefaultControls.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF;component/Templates/SharedFilterRuleTemplates.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF;component/Themes/Controls/Primitives/NumericUpDown.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF;component/Themes/Controls/Primitives/SearchTextBox.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--  Converters  -->
    <converters:SearchTypeToBetweenVisibilityConverter x:Key="BetweenValueVisibilityConverter" />

    <converters:BooleanToVisibilityCollapsedConverter x:Key="BooleanToVisibilityCollapsedConverter" />
    <converters:FilterInputTemplateToVisibilityConverter x:Key="FilterInputTemplateToVisibilityConverter" />
    <converters:EnumToStringConverter x:Key="EnumToStringConverter" />


    <!--  Compact remove button style (shared across rules)  -->
    <Style x:Key="RuleRemoveButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="#999" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="ToolTip" Value="Remove rule" />
        <Setter Property="Content" Value="&#xE711;" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#CC0000" />
                <Setter Property="Background" Value="#10FF0000" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  ColumnFilterEditor-specific Search Group Content Template  -->
    <DataTemplate x:Key="AdvancedFilterSearchGroupContentTemplate" DataType="{x:Type sdgCore:SearchTemplateGroup}">
        <StackPanel>
            <ItemsControl ItemsSource="{Binding SearchTemplates}"
                          Grid.IsSharedSizeScope="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!--  Compact single-line rule layout  -->
                        <Border BorderBrush="#E8E8E8"
                                BorderThickness="0,0,0,0"
                                Padding="2,3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="RuleOperator" />
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="RuleSearchType" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="RuleRemove" />
                                </Grid.ColumnDefinitions>

                                <!--  AND/OR operator (fixed width, content hidden on first rule)  -->
                                <ComboBox Style="{StaticResource {x:Static sdg:SdgThemeKeys.ComboBox}}"
                                          Grid.Column="0"
                                          Visibility="{Binding IsOperatorVisible, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}"
                                          Margin="0,0,4,0"
                                          Padding="4,2"
                                          VerticalContentAlignment="Center"
                                          MinWidth="46"
                                          FontSize="11"
                                          SelectedItem="{Binding OperatorName}">
                                    <sys:String>And</sys:String>
                                    <sys:String>Or</sys:String>
                                </ComboBox>

                                <!--  Search type dropdown (fixed width for alignment)  -->
                                <ComboBox Style="{StaticResource {x:Static sdg:SdgThemeKeys.ComboBox}}"
                                          Grid.Column="1"
                                          Margin="0,0,4,0"
                                          Padding="4,2"
                                          HorizontalAlignment="Stretch"
                                          VerticalContentAlignment="Center"
                                          FontSize="11"
                                          ItemsSource="{Binding ValidSearchTypes}"
                                          SelectedItem="{Binding SearchType}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{Binding Converter={StaticResource SearchTypeToIconConverter}}"
                                                       Width="14"
                                                       Height="14"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Converter={StaticResource EnumToStringConverter}}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <!--  Value input (inline, fills remaining space)  -->
                                <ContentControl Grid.Column="2"
                                                VerticalAlignment="Center"
                                                Content="{Binding}">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding InputTemplate}" Value="SingleSearchTextBox">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource SingleSearchTextBoxTemplate}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding InputTemplate}" Value="DualSearchTextBox">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource DualSearchTextBoxTemplate}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding InputTemplate}" Value="DualDateTimePicker">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource DualDateTimePickerTemplate}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding InputTemplate}" Value="NumericUpDown">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource NumericUpDownTemplate}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding InputTemplate}" Value="NoInput">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource NoInputTemplate}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding InputTemplate}" Value="SearchTextBoxList">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource SearchTextBoxListTemplate}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding InputTemplate}" Value="DateTimePickerList">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource DateTimePickerListTemplate}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding InputTemplate}" Value="DateIntervalCheckList">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource DateIntervalCheckListTemplate}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>

                                <!--  Remove button  -->
                                <Button Style="{StaticResource RuleRemoveButtonStyle}"
                                        Grid.Column="3"
                                        VerticalAlignment="Top"
                                        Command="{Binding RemoveSearchTemplateCommand, RelativeSource={RelativeSource AncestorType=sdg:ColumnFilterEditor}}"
                                        CommandParameter="{Binding}"
                                        Margin="4,4,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!--  Inline "Add Rule" button — sits after the last rule like a placeholder  -->
            <Button Style="{StaticResource {x:Static sdg:SdgThemeKeys.Button}}"
                    Background="Transparent"
                    BorderBrush="{StaticResource Sdg.Border.Subtle}"
                    BorderThickness="1"
                    Cursor="Hand"
                    Command="{Binding AddSearchTemplateCommand, RelativeSource={RelativeSource AncestorType=sdg:ColumnFilterEditor}}"
                    Margin="0,4,0,0"
                    Padding="6,3"
                    HorizontalAlignment="Center"
                    FontSize="11"
                    Content="Add Rule" />

        </StackPanel>
    </DataTemplate>

    <!--  ColumnFilterEditor Style  -->
    <Style x:Key="{x:Static sdg:SdgThemeKeys.ColumnFilterEditor}" TargetType="{x:Type sdg:ColumnFilterEditor}">
        <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" />
        <Setter Property="BorderBrush" Value="DarkGray" />
        <Setter Property="VerticalOffset" Value="-24" />
        <Setter Property="HorizontalOffset" Value="-24" />
        <Setter Property="MinWidth" Value="300" />
        <Setter Property="MinHeight" Value="300" />
        <Setter Property="MaxHeight" Value="500" />
        <Setter Property="Margin" Value="12" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:ColumnFilterEditor}">
                    <Grid Margin="{TemplateBinding Margin}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Border.Effect>
                                <DropShadowEffect Color="#02000000"
                                                  Opacity="0.25"
                                                  BlurRadius="8"
                                                  ShadowDepth="2" />
                            </Border.Effect>
                            <Grid Margin="0,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Operator ComboBox  -->
                            <ComboBox x:Name="PART_OperatorComboBox"
                                      Style="{StaticResource {x:Static sdg:SdgThemeKeys.ComboBox}}"
                                      Grid.Row="0"
                                      Visibility="{Binding IsOperatorVisible, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top"
                                      VerticalContentAlignment="Center"
                                      Panel.ZIndex="1"
                                      Margin="2,2,0,0"
                                      Width="50"
                                      Height="22"
                                      MinHeight="20"
                                      MinWidth="0"
                                      ToolTip="Combine with previous filters"
                                      SelectedItem="{Binding GroupOperatorName, RelativeSource={RelativeSource TemplatedParent}}">
                                <sys:String>And</sys:String>
                                <sys:String>Or</sys:String>
                            </ComboBox>

                            <!--  Tabbed Interface: Filter Rules + Filter Values  -->
                            <TabControl x:Name="PART_TabControl"
                                        Style="{StaticResource {x:Static sdg:SdgThemeKeys.TabControl}}"
                                        Grid.Row="0">

                                <!--  TAB 1: Filter Rules (existing functionality)  -->
                                    <TabItem Style="{StaticResource {x:Static sdg:SdgThemeKeys.TabItem}}" Header="Filter Rules">
                                        <ScrollViewer Margin="4,4,4,0" VerticalScrollBarVisibility="Auto">
                                        <ContentControl Content="{Binding SearchTemplateController, RelativeSource={RelativeSource TemplatedParent}}">
                                            <ContentControl.Style>
                                                <Style TargetType="ContentControl">
                                                    <Setter Property="ContentTemplate">
                                                        <Setter.Value>
                                                            <DataTemplate>
                                                                <ItemsControl ItemsSource="{Binding SearchGroups}" VirtualizingPanel.IsVirtualizing="False">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <StackPanel Orientation="Vertical" />
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate DataType="{x:Type sdgCore:SearchTemplateGroup}">
                                                                            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource AdvancedFilterSearchGroupContentTemplate}" />
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </DataTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ContentControl.Style>
                                        </ContentControl>
                                    </ScrollViewer>
                                </TabItem>

                                <!--  TAB 2: Filter Values (checkbox list)  -->
                                <TabItem Style="{StaticResource {x:Static sdg:SdgThemeKeys.TabItem}}" Header="Filter Values">
                                    <DockPanel Margin="4,4,4,0">

                                        <!--  Top: Select All checkbox + Search  -->
                                        <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding FilterValueManager.SelectAllState, RelativeSource={RelativeSource AncestorType=sdg:ColumnFilterEditor}, Mode=OneWay}"
                                                      Command="{Binding SelectAllValuesCommand, RelativeSource={RelativeSource AncestorType=sdg:ColumnFilterEditor}}"
                                                      Margin="0,0,8,0"
                                                      Style="{StaticResource {x:Static sdg:SdgThemeKeys.CheckBox}}"
                                                      IsThreeState="True"
                                                      Content="Select All"
                                                      FontSize="11" />
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding FilterValueManager.SearchText, RelativeSource={RelativeSource AncestorType=sdg:ColumnFilterEditor}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=200}"
                                                     Padding="4,2"
                                                     VerticalContentAlignment="Center"
                                                     FontSize="11" />
                                        </Grid>

                                        <!--  Bottom: Status  -->
                                        <TextBlock DockPanel.Dock="Bottom"
                                                   Foreground="Gray"
                                                   Margin="0,4,0,2"
                                                   HorizontalAlignment="Right"
                                                   FontSize="11">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0:N0} / {1:N0} selected">
                                                    <Binding RelativeSource="{RelativeSource AncestorType=sdg:ColumnFilterEditor}" Path="FilterValueManager.CheckedCount" />
                                                    <Binding RelativeSource="{RelativeSource AncestorType=sdg:ColumnFilterEditor}" Path="FilterValueManager.TotalCount" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>

                                        <!--  Center: Flat list for non-DateTime, TreeView for DateTime.
                                             Wrapped in a Grid so whichever is visible fills the DockPanel's remaining space.  -->
                                        <Grid>

                                        <!--  Flat checkbox list (hidden when DateTime)  -->
                                        <ListBox Background="Transparent"
                                                 BorderThickness="0"
                                                 ItemsSource="{Binding FilterValueManager.ValueItems, RelativeSource={RelativeSource AncestorType=sdg:ColumnFilterEditor}}"
                                                 ScrollViewer.CanContentScroll="True"
                                                 VirtualizingPanel.IsVirtualizing="True"
                                                 VirtualizingPanel.VirtualizationMode="Recycling">
                                            <ListBox.Style>
                                                <Style TargetType="ListBox">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FilterValueManager.IsDateTimeColumn, RelativeSource={RelativeSource AncestorType=sdg:ColumnFilterEditor}}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.Style>
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}" />
                                                    <Style.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="Transparent" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsChecked}"
                                                              Margin="2,1"
                                                              Style="{StaticResource {x:Static sdg:SdgThemeKeys.CheckBox}}"
                                                              VerticalContentAlignment="Center">
                                                        <CheckBox.Content>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding DisplayValue}"
                                                                           VerticalAlignment="Center" />
                                                                <TextBlock Grid.Column="1"
                                                                           Foreground="Gray"
                                                                           Text="{Binding Count, StringFormat='({0:N0})'}"
                                                                           Margin="8,0,0,0"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="10" />
                                                            </Grid>
                                                        </CheckBox.Content>
                                                    </CheckBox>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <!--  DateTime TreeView (hidden when NOT DateTime)  -->
                                        <TreeView Background="Transparent"
                                                  BorderThickness="0"
                                                  ItemsSource="{Binding FilterValueManager.DateTreeRoots, RelativeSource={RelativeSource AncestorType=sdg:ColumnFilterEditor}}">
                                            <TreeView.Style>
                                                <Style TargetType="TreeView">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FilterValueManager.IsDateTimeColumn, RelativeSource={RelativeSource AncestorType=sdg:ColumnFilterEditor}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TreeView.Style>
                                            <TreeView.ItemContainerStyle>
                                                <Style TargetType="TreeViewItem">
                                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                                </Style>
                                            </TreeView.ItemContainerStyle>
                                            <TreeView.ItemTemplate>
                                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                    <CheckBox IsChecked="{Binding IsChecked}"
                                                              Margin="2,1"
                                                              Style="{StaticResource {x:Static sdg:SdgThemeKeys.CheckBox}}"
                                                              IsThreeState="False">
                                                        <CheckBox.Content>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                                                <TextBlock Foreground="Gray"
                                                                           Text="{Binding TotalCount, StringFormat=' ({0:N0})'}"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="10" />
                                                            </StackPanel>
                                                        </CheckBox.Content>
                                                    </CheckBox>
                                                </HierarchicalDataTemplate>
                                            </TreeView.ItemTemplate>
                                        </TreeView>
                                        </Grid>
                                    </DockPanel>
                                </TabItem>
                            </TabControl>

                            <!--  Footer pinned to the bottom of the popup (visible from both tabs).
                                  Layout: Clear Filter button on the left, Live filter checkbox
                                  on the right. The checkbox is two-way bound to the editor's
                                  IsLiveApplyEnabled DP, which the editor's static change handler
                                  propagates up to GridColumn.ImmediateUpdateAutoFilter so the
                                  choice persists across popup open/close and also drives the
                                  in-header SearchTextBox's debounce mode.  -->
                            <Border Grid.Row="1" Background="{StaticResource Sdg.Surface.Tertiary}" BorderBrush="{StaticResource Sdg.Border.Strong}" CornerRadius="0,0,4,4" Margin="0" Padding="4" BorderThickness="0,1,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Style="{StaticResource {x:Static sdg:SdgThemeKeys.Button}}"
                                            Command="{Binding ClearFilterCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                            HorizontalAlignment="Left"
                                            Content="Clear Filter" />

                                    <CheckBox Grid.Column="2"
                                              IsChecked="{Binding IsLiveApplyEnabled, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Margin="8,0,4,0"
                                              Content="Live filter"
                                              ToolTip="When checked, filter changes apply to the grid as you make them. When unchecked, changes are deferred until the editor closes — useful for very large grids. Auto-defaults to off when the grid has 100,000+ rows." />
                                </Grid>
                            </Border>
                            </Grid>
                        </Border>

                        <!--  Bottom-left resize grip  -->
                        <Thumb x:Name="PART_ResizeBottomLeft"
                               Width="14"
                               Height="14"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Bottom"
                               Cursor="SizeNESW"
                               Style="{StaticResource {x:Static sdg:SdgThemeKeys.ResizeThumb}}"
                               Panel.ZIndex="10" />

                        <!--  Bottom-right resize grip  -->
                        <Thumb x:Name="PART_ResizeBottomRight"
                               Width="14"
                               Height="14"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"
                               Cursor="SizeNWSE"
                               Style="{StaticResource {x:Static sdg:SdgThemeKeys.ResizeThumb}}"
                               Panel.ZIndex="10" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:SdgThemeKeys.ColumnFilterEditor}}" TargetType="{x:Type sdg:ColumnFilterEditor}" />

</ResourceDictionary>