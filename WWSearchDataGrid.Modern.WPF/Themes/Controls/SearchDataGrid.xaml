<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:commands="clr-namespace:WWSearchDataGrid.Modern.WPF.Commands"
    xmlns:converters="clr-namespace:WWSearchDataGrid.Modern.WPF.Converters"
    xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF;component/Themes/Controls/Primitives/DefaultControls.xaml" />
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF;component/Themes/Controls/FilterPanel.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <converters:NullOrEmptyToBooleanConverter x:Key="NullOrEmptyToBooleanConverter" />
    <converters:BooleanToVisibilityCollapsedConverter x:Key="BooleanToVisibilityCollapsedConverter" />
    <converters:AutoFilterRowVisibilityConverter x:Key="AutoFilterRowVisibilityConverter" />

    <Style x:Key="{x:Static sdg:SdgThemeKeys.SelectAllButton}" TargetType="{x:Type Button}">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Width" Value="{Binding RowHeaderWidth, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border
                            x:Name="Border"
                            Margin="0,0,0,0"
                            Background="#F0F0F0"
                            BorderBrush="#d0d0d0"
                            BorderThickness="0,0,1,1" />
                        <Polygon
                            x:Name="Arrow"
                            Margin="8,8,3,3"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Fill="#666"
                            Opacity="0.5"
                            Points="0,10 10,10 10,0"
                            Stretch="Uniform" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Arrow" Property="Opacity" Value="0.8" />
                            <Setter TargetName="Border" Property="Background" Value="#E0F0FF" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Arrow" Property="Opacity" Value="1" />
                            <Setter TargetName="Border" Property="Background" Value="#CCE0FF" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Arrow" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="{x:Static sdg:SdgThemeKeys.SearchDataGridRowHeader}" TargetType="{x:Type DataGridRowHeader}">
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="#FF444444" />
        <Setter Property="Background" Value="#F9F9F9" />
        <Setter Property="BorderBrush" Value="#FFd0d0d0" />
        <Setter Property="BorderThickness" Value="1,0,1,1" />


        <Setter Property="ContextMenu">
            <Setter.Value>
                <ContextMenu AutomationProperties.AutomationId="cmuRowHeader">
                    <MenuItem
                        x:Name="miCopy"
                        Command="{x:Static commands:ContextMenuCommands.CopySelectedCellValuesCommand}"
                        CommandParameter="{Binding Grid}"
                        Header="Copy" />
                    <MenuItem
                        x:Name="miCopyWithHeaders"
                        Command="{x:Static commands:ContextMenuCommands.CopySelectedCellValuesWithHeadersCommand}"
                        CommandParameter="{Binding Grid}"
                        Header="Copy With Headers" />
                </ContextMenu>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DataGridRowHeader}">
                    <Grid>
                        <Border
                            x:Name="HeaderBorder"
                            Margin="-1,0,0,0"
                            Padding="0,0,20,0"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>

                        <TextBlock
                            x:Name="RowStateIndicator"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                            FontSize="12"
                            Foreground="#FF444444"
                            Text=""
                            Visibility="Collapsed" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Background" Value="#FFF0F0F0" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}}" Value="True">
                            <Setter Property="Foreground" Value="White" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}}" Value="True">
                            <Setter TargetName="RowStateIndicator" Property="Visibility" Value="Visible" />
                            <Setter TargetName="RowStateIndicator" Property="Text" Value="&#xE76C;" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsEditing, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}}" Value="True">
                            <Setter TargetName="RowStateIndicator" Property="Visibility" Value="Visible" />
                            <Setter TargetName="RowStateIndicator" Property="Text" Value="&#xE70F;" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Default (implicit, TargetType-only) style for the custom headers presenter. The
        presenter calls DefaultStyleKeyProperty.OverrideMetadata(typeof(SearchDataGridColumnHeadersPresenter)),
        so WPF looks up a Style under the type key in this theme dictionary; without this
        entry the presenter has no Template, the column-headers band renders empty, and
        no SearchDataGridColumnHeader instances are produced.
        
        The control template retargets PART_FillerColumnHeader to SearchDataGridColumnHeader.
        The DataGrid pushes its ColumnHeaderStyle setter to the filler header at
        ApplyTemplate time; that setter's TargetType is SearchDataGridColumnHeader, so the
        stock DataGridColumnHeader filler would fail the strict TargetType check.
    -->
    <Style TargetType="{x:Type sdg:SearchDataGridColumnHeadersPresenter}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:SearchDataGridColumnHeadersPresenter}">
                    <Grid>
                        <sdg:SearchDataGridColumnHeader x:Name="PART_FillerColumnHeader" IsHitTestVisible="False" />
                        <ItemsPresenter />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="{x:Static sdg:SdgThemeKeys.SearchDataGridColumnHeader}" TargetType="{x:Type sdg:SearchDataGridColumnHeader}">
        <Setter Property="AllowDrop" Value="True" />
        <Setter Property="ContextMenu">
            <Setter.Value>
                <ContextMenu AutomationProperties.AutomationId="cmuColumnHeader">
                    <!--  Column-specific Copy Operations  -->
                    <MenuItem
                        x:Name="miCopy"
                        Command="{x:Static commands:ContextMenuCommands.CopySelectedCellValuesCommand}"
                        CommandParameter="{Binding Grid}"
                        Header="Copy" />
                    <MenuItem
                        x:Name="miCopyWithHeaders"
                        Command="{x:Static commands:ContextMenuCommands.CopySelectedCellValuesWithHeadersCommand}"
                        CommandParameter="{Binding Grid}"
                        Header="Copy With Headers" />
                    <Separator />

                    <!--  Sorting  -->
                    <MenuItem
                        x:Name="miSortAscending"
                        Command="{x:Static commands:ContextMenuCommands.SortAscendingCommand}"
                        CommandParameter="{Binding}"
                        Header="Sort Ascending" />
                    <MenuItem
                        x:Name="miSortDescending"
                        Command="{x:Static commands:ContextMenuCommands.SortDescendingCommand}"
                        CommandParameter="{Binding}"
                        Header="Sort Descending" />
                    <MenuItem
                        x:Name="miClearSorting"
                        Command="{x:Static commands:ContextMenuCommands.ClearSortingCommand}"
                        CommandParameter="{Binding}"
                        Header="Clear Sorting" />
                    <Separator />

                    <!--  Column Operations  -->
                    <MenuItem
                        x:Name="miBestFitColumn"
                        Command="{x:Static commands:ContextMenuCommands.BestFitColumnCommand}"
                        CommandParameter="{Binding}"
                        Header="Best Fit Column" />
                    <MenuItem
                        x:Name="miBestFitAllColumns"
                        Command="{x:Static commands:ContextMenuCommands.BestFitAllColumnsCommand}"
                        CommandParameter="{Binding}"
                        Header="Best Fit All Columns" />
                    <Separator />

                    <!--  Visibility and Layout  -->
                    <MenuItem
                        x:Name="miShowColumnChooser"
                        Command="{x:Static commands:ContextMenuCommands.ShowColumnChooserCommand}"
                        CommandParameter="{Binding Grid}"
                        Header="Show Column Chooser">
                        <MenuItem.Style>
                            <Style TargetType="MenuItem">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Grid.IsColumnChooserEnabled}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </MenuItem.Style>
                    </MenuItem>
                    <MenuItem
                        x:Name="miHideColumn"
                        Command="{x:Static commands:ContextMenuCommands.HideSelectedColumnCommand}"
                        CommandParameter="{Binding Column}"
                        Header="Hide Column" />

                    <!--  Conditional Filtering (only shows when there's an active filter)  -->
                    <Separator>
                        <Separator.Style>
                            <Style TargetType="Separator">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasActiveFilter}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Separator.Style>
                    </Separator>
                    <MenuItem
                        x:Name="miClearColumnFilter"
                        Command="{x:Static commands:ContextMenuCommands.ClearColumnFilterCommand}"
                        CommandParameter="{Binding ColumnSearchBox}"
                        Header="Clear Column Filter (Not Implemented)">
                        <MenuItem.Style>
                            <Style TargetType="MenuItem">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasActiveFilter}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </MenuItem.Style>
                    </MenuItem>
                </ContextMenu>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:SearchDataGridColumnHeader}">
                    <!--
                        Phase 5: the embedded ColumnSearchBox is removed entirely. The
                        DataGridColumnHeader template now hosts only the header chrome
                        (select-all checkbox, header text, sort arrow, gripper). The
                        per-column filter editor lives in the pinned AutoFilterRowPresenter
                        below the headers.
                    -->
                    <Grid>
                        <Border
                            x:Name="HeaderBorder"
                            Margin="0,0,0,0"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="0,0,1,1">
                            <!--
                                Layout: [select-all][header text Auto][filter button Auto][spacer *][sort arrow Auto].
                                Header text sizes to its content (Auto), filter button sits
                                immediately to its right at a fixed width, the * spacer absorbs
                                remaining horizontal space, and the sort arrow stays at the far
                                right. Whether the button is Opacity 0 or 1, the Auto column
                                still reserves its 22px slot — header text and sort arrow stay
                                put across hover transitions.
                            -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Select All Checkbox (visible only when IsSelectAllColumn is true AND column is boolean)  -->
                                <StackPanel
                                    Grid.Column="0"
                                    Margin="0,0,4,0"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">

                                    <CheckBox
                                        x:Name="PART_SelectAllCheckBox"
                                        VerticalAlignment="Center"
                                        IsThreeState="True"
                                        Style="{StaticResource {x:Static sdg:SdgThemeKeys.CheckBox}}"
                                        Visibility="Collapsed" />

                                    <!--  Row Count Display (visible only when using SelectedRows scope)  -->
                                    <TextBlock
                                        x:Name="PART_SelectAllRowCount"
                                        Margin="0,0,0,2"
                                        VerticalAlignment="Center"
                                        FontSize="10"
                                        Foreground="#666666"
                                        Visibility="Collapsed" />
                                </StackPanel>

                                <!--  Header Content  -->
                                <ContentPresenter
                                    Grid.Column="1"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />

                                <Button
                                    x:Name="PART_RuleFilterEditorButton"
                                    Grid.Column="2"
                                    Width="22"
                                    Margin="-1,0,2,0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Command="{x:Static commands:ContextMenuCommands.ShowFilterEditorCommand}"
                                    CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                    Content="&#xE71C;"
                                    Cursor="Hand"
                                    Focusable="False"
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="12"
                                    IsHitTestVisible="True"
                                    KeyboardNavigation.IsTabStop="False"
                                    ToolTip="Column Filter Editor">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Opacity" Value="0" />
                                            <Setter Property="Foreground" Value="#BFBFBF" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderBrush" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="3">
                                                            <ContentPresenter
                                                                Margin="{TemplateBinding Padding}"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Focusable="False"
                                                                RecognizesAccessKey="True"
                                                                TextElement.Foreground="{TemplateBinding Foreground}" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGridColumnHeader}}}" Value="True">
                                                    <Setter Property="Opacity" Value="1" />
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="#141414" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Foreground" Value="#000000" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!--  Sort Arrow (Grid.Column=4, with the *-spacer at Column=3 pushing it right)  -->
                                <TextBlock
                                    x:Name="SortArrow"
                                    Grid.Column="4"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe Fluent Icons"
                                    Foreground="{TemplateBinding Foreground}"
                                    Visibility="Collapsed" />
                            </Grid>
                        </Border>

                        <!--  Column Resizers  -->
                        <Thumb
                            x:Name="PART_LeftHeaderGripper"
                            Width="1"
                            HorizontalAlignment="Left"
                            Panel.ZIndex="55"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0,0,1,0"
                            Cursor="SizeWE" />


                        <Thumb
                            x:Name="PART_RightHeaderGripper"
                            Width="1"
                            HorizontalAlignment="Right"
                            BorderBrush="{Binding VerticalGridLinesBrush, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}}"
                            BorderThickness="1,0,0,0"
                            Cursor="SizeWE" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding ActualHasItems, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type sdg:SearchDataGrid}}}" Value="False">
                            <Setter TargetName="HeaderBorder" Property="BorderThickness" Value="0,0,0,1" />
                        </DataTrigger>

                        <!--  Sort Direction  -->
                        <Trigger Property="SortDirection" Value="Ascending">
                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SortArrow" Property="Text" Value="&#xE972;" />
                        </Trigger>

                        <Trigger Property="SortDirection" Value="Descending">
                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SortArrow" Property="Text" Value="&#xE971;" />
                        </Trigger>

                        <!--  Mouse States  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Background" Value="#FFF0F0F0" />
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Background" Value="#FFE0E0E0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="#FF333333" />
        <Setter Property="Background" Value="#FFF9F9F9" />
        <Setter Property="BorderBrush" Value="#FFd0d0d0" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style x:Key="{x:Static sdg:SdgThemeKeys.SearchDataGridCell}" TargetType="{x:Type DataGridCell}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="ContextMenu">
            <Setter.Value>
                <ContextMenu AutomationProperties.AutomationId="cmuCell">
                    <MenuItem
                        x:Name="miCopy"
                        Command="{x:Static commands:ContextMenuCommands.CopySelectedCellValuesCommand}"
                        CommandParameter="{Binding Grid}"
                        Header="Copy" />
                    <MenuItem
                        x:Name="miCopyWithHeaders"
                        Command="{x:Static commands:ContextMenuCommands.CopySelectedCellValuesWithHeadersCommand}"
                        CommandParameter="{Binding Grid}"
                        Header="Copy With Headers" />
                </ContextMenu>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DataGridCell}">
                    <Grid>
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <Border
                            BorderBrush="{Binding VerticalGridLinesBrush, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                            BorderThickness="0,0,1,0"
                            IsHitTestVisible="False"
                            Visibility="{Binding ShowVerticalGridLines, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}" />
                        <Border
                            BorderBrush="{Binding HorizontalGridLinesBrush, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                            BorderThickness="0,0,0,1"
                            IsHitTestVisible="False"
                            Visibility="{Binding ShowHorizontalGridLines, RelativeSource={RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}" />
                        <!--  Focus indicator — keyboard-focused cell.  -->
                        <Border
                            x:Name="FocusBorder"
                            BorderBrush="{StaticResource Sdg.Border.Focused}"
                            BorderThickness="1"
                            IsHitTestVisible="False"
                            Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="FocusBorder" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True" />
                    <Condition Property="IsSelected" Value="False" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{StaticResource Sdg.Surface.Hover}" />
            </MultiTrigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource Sdg.Selection.Background}" />
                <Setter Property="Foreground" Value="{StaticResource Sdg.Text.Primary}" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsSelected" Value="True" />
                    <Condition Property="IsMouseOver" Value="True" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{StaticResource Sdg.Selection.Background.Hover}" />
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsSelected" Value="True" />
                    <Condition Property="Selector.IsSelectionActive" Value="False" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{StaticResource Sdg.Selection.Background.Inactive}" />
                <Setter Property="Foreground" Value="{StaticResource Sdg.Text.Primary}" />
            </MultiTrigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{StaticResource Sdg.Text.Disabled}" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="{x:Static sdg:SdgThemeKeys.SearchDataGridRow}" TargetType="{x:Type DataGridRow}">
        <Setter Property="Background" Value="{Binding RowBackground, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" />
        <Setter Property="ValidationErrorTemplate" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DataGridRow}">
                    <Border
                        x:Name="DGR_Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <SelectiveScrollingGrid>
                            <SelectiveScrollingGrid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </SelectiveScrollingGrid.ColumnDefinitions>
                            <SelectiveScrollingGrid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </SelectiveScrollingGrid.RowDefinitions>

                            <DataGridCellsPresenter Grid.Column="1" ItemsPanel="{TemplateBinding ItemsPanel}" />

                            <DataGridDetailsPresenter
                                Grid.Row="1"
                                Grid.Column="1"
                                SelectiveScrollingGrid.SelectiveScrollingOrientation="{Binding AreRowDetailsFrozen, ConverterParameter={x:Static SelectiveScrollingOrientation.Vertical}, Converter={x:Static DataGrid.RowDetailsScrollingConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                Visibility="{TemplateBinding DetailsVisibility}" />

                            <DataGridRowHeader
                                Grid.RowSpan="2"
                                SelectiveScrollingGrid.SelectiveScrollingOrientation="Vertical"
                                Visibility="{Binding HeadersVisibility, ConverterParameter={x:Static DataGridHeadersVisibility.Row}, Converter={x:Static DataGrid.HeadersVisibilityConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" />
                        </SelectiveScrollingGrid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="{x:Static sdg:SdgThemeKeys.SearchDataGrid}" TargetType="{x:Type sdg:SearchDataGrid}">
        <Setter Property="CellStyle" Value="{StaticResource {x:Static sdg:SdgThemeKeys.SearchDataGridCell}}" />
        <Setter Property="RowStyle" Value="{StaticResource {x:Static sdg:SdgThemeKeys.SearchDataGridRow}}" />
        <Setter Property="ContextMenu">
            <Setter.Value>
                <ContextMenu AutomationProperties.AutomationId="cmuGridBody">
                    <!--  Filter operations  -->
                    <MenuItem
                        x:Name="miClearAllFilters"
                        Command="{x:Static commands:ContextMenuCommands.ClearAllFiltersCommand}"
                        CommandParameter="{Binding Grid}"
                        Header="Clear All Filters (Not Implemented)" />
                    <MenuItem
                        x:Name="miToggleFilterPanel"
                        Command="{x:Static commands:ContextMenuCommands.ToggleFilterPanelCommand}"
                        CommandParameter="{Binding Grid}"
                        Header="Toggle Filter Panel (Not Implemented)" />
                    <MenuItem
                        x:Name="miSaveFilterPreset"
                        Command="{x:Static commands:ContextMenuCommands.SaveFilterPresetCommand}"
                        CommandParameter="{Binding Grid}"
                        Header="Save Filter Preset (Not Implemented)" />
                    <MenuItem
                        x:Name="miLoadFilterPreset"
                        Command="{x:Static commands:ContextMenuCommands.LoadFilterPresetCommand}"
                        CommandParameter="{Binding Grid}"
                        Header="Load Filter Preset (Not Implemented)" />
                    <Separator />

                    <!--  Column Profiles submenu  -->
                    <MenuItem x:Name="miColumnProfiles" Header="Column Profiles">
                        <MenuItem
                            x:Name="miSaveCurrentProfile"
                            Command="{x:Static commands:ContextMenuCommands.SaveCurrentProfileCommand}"
                            CommandParameter="{Binding Grid}"
                            Header="Save Current Profile (Not Implemented)" />
                        <MenuItem
                            x:Name="miLoadProfile"
                            Command="{x:Static commands:ContextMenuCommands.LoadProfileCommand}"
                            CommandParameter="{Binding Grid}"
                            Header="Load Profile... (Not Implemented)" />
                        <MenuItem
                            x:Name="miManageProfiles"
                            Command="{x:Static commands:ContextMenuCommands.ManageProfilesCommand}"
                            CommandParameter="{Binding Grid}"
                            Header="Manage Profiles... (Not Implemented)" />
                    </MenuItem>

                    <Separator />

                    <!--  Export operations  -->
                    <MenuItem
                        x:Name="miExportToCsv"
                        Command="{x:Static commands:ContextMenuCommands.ExportToCsvCommand}"
                        CommandParameter="{Binding Grid}"
                        Header="Export to CSV (Not Implemented)" />
                    <MenuItem
                        x:Name="miExportToExcel"
                        Command="{x:Static commands:ContextMenuCommands.ExportToExcelCommand}"
                        CommandParameter="{Binding Grid}"
                        Header="Export to Excel (Not Implemented)" />

                    <Separator />

                    <!--  Layout operations  -->
                    <MenuItem
                        x:Name="miShowColumnChooser"
                        Command="{x:Static commands:ContextMenuCommands.ShowColumnChooserCommand}"
                        CommandParameter="{Binding Grid}"
                        Header="Show Column Chooser">
                        <MenuItem.Style>
                            <Style TargetType="MenuItem">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Grid.IsColumnChooserEnabled}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </MenuItem.Style>
                    </MenuItem>
                    <MenuItem
                        x:Name="miResetLayout"
                        Command="{x:Static commands:ContextMenuCommands.ResetLayoutCommand}"
                        CommandParameter="{Binding Grid}"
                        Header="Reset Layout (Not Implemented)" />
                </ContextMenu>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:SearchDataGrid}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ScrollViewer
                                x:Name="DG_ScrollViewer"
                                Grid.Row="0"
                                sdg:HorizontalScrollBehavior.EnableShiftMouseWheelScroll="True"
                                CanContentScroll="true"
                                Focusable="false">
                                <ScrollViewer.Template>
                                    <ControlTemplate TargetType="ScrollViewer">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>


                                            <!--  Per-Column Select All  -->
                                            <Button
                                                Panel.ZIndex="2"
                                                Command="{x:Static DataGrid.SelectAllCommand}"
                                                Focusable="false"
                                                Style="{StaticResource {x:Static sdg:SdgThemeKeys.SelectAllButton}}" />

                                            <!--
                                                Filler under the SelectAllButton, aligned with the pinned
                                                AutoFilterRowPresenter. Without this, Row 1 / Column 0
                                                renders empty (SearchDataGrid Background bleeds through),
                                                leaving a visible gap to the left of the filter row at the
                                                row-header column. Visibility mirrors the filter row so the
                                                gap is only filled when the filter row is showing.
                                            -->
                                            <Border
                                                Grid.Row="1"
                                                Grid.Column="0"
                                                Background="#FFf9f9f9"
                                                BorderBrush="#FFd0d0d0"
                                                BorderThickness="0,0,1,1"
                                                SnapsToDevicePixels="True"
                                                UseLayoutRounding="True">
                                                <Border.Visibility>
                                                    <MultiBinding Converter="{StaticResource AutoFilterRowVisibilityConverter}">
                                                        <Binding Path="ShowAutoFilterRow" RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" />
                                                        <Binding Path="AutoFilterRowPosition" RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" />
                                                    </MultiBinding>
                                                </Border.Visibility>
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontFamily="Segoe Fluent Icons"
                                                    Text="&#xE71C;" />
                                            </Border>

                                            <!--
                                                Column Headers. Use the custom presenter so the
                                                column header containers are SearchDataGridColumnHeader
                                                instances rather than stock DataGridColumnHeader. The
                                                custom header type carries the OnClick override that
                                                suppresses sort when the click originated on an
                                                interactive child (the filter-popup button).
                                            -->
                                            <sdg:SearchDataGridColumnHeadersPresenter
                                                x:Name="PART_ColumnHeadersPresenter"
                                                Grid.Column="1"
                                                Margin="0,0,0,0" />

                                            <!--
                                                Pinned filter row. Lives in the same template grid-column
                                                as PART_ColumnHeadersPresenter so the horizontal scroll
                                                view applied by the ScrollViewer's clip and the
                                                FilterRowPanel's own offset binding stay aligned at the
                                                frozen-column boundary. Phase 2 hosts placeholder borders;
                                                Phase 3 swaps in ColumnFilterControl instances.
                                            -->
                                            <sdg:AutoFilterRowPresenter
                                                x:Name="PART_AutoFilterRow"
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Style="{StaticResource {x:Static sdg:SdgThemeKeys.AutoFilterRowPresenter}}">
                                                <sdg:AutoFilterRowPresenter.Visibility>
                                                    <MultiBinding Converter="{StaticResource AutoFilterRowVisibilityConverter}">
                                                        <Binding Path="ShowAutoFilterRow" RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" />
                                                        <Binding Path="AutoFilterRowPosition" RelativeSource="{RelativeSource AncestorType={x:Type sdg:SearchDataGrid}}" />
                                                    </MultiBinding>
                                                </sdg:AutoFilterRowPresenter.Visibility>
                                            </sdg:AutoFilterRowPresenter>

                                            <!--
                                                Header-bottom separator. Shifted to row 2 (top edge of
                                                content) so it sits BELOW the filter row, not between the
                                                headers and the filter row. The negative top margin keeps
                                                it overlapping the header / filter-row gridline at the
                                                content seam.
                                            -->
                                            <Border
                                                x:Name="PART_ColumnHeaderBottomBorder"
                                                Grid.Row="2"
                                                Grid.Column="1"
                                                Height="1"
                                                Margin="0,-1,0,0"
                                                VerticalAlignment="Top"
                                                Panel.ZIndex="2"
                                                Background="#d0d0d0" />

                                            <!--  Rows  -->
                                            <ScrollContentPresenter
                                                x:Name="PART_ScrollContentPresenter"
                                                Grid.Row="2"
                                                Grid.ColumnSpan="2"
                                                Margin="0,0,0,0"
                                                CanContentScroll="{TemplateBinding CanContentScroll}" />

                                            <!--
                                                Placeholder: top-right gap (above the vertical scrollbar).
                                                Spans header + filter rows so the gap covers both bands
                                                visually. Matches column search box (top strip, white) +
                                                column header (bottom). Visibility follows the vertical
                                                scrollbar so it collapses when the scrollbar does. Left
                                                edge is provided by ContentRightSeparator below — no left
                                                BorderThickness here.
                                            -->
                                            <Grid Grid.Row="0"
                                                  Grid.RowSpan="2"
                                                  Grid.Column="2"
                                                  Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Border Grid.Row="0"
                                                        Height="{Binding ActualHeight, ElementName=PART_ColumnHeadersPresenter}"
                                                        Background="#F9F9F9"
                                                        SnapsToDevicePixels="True"
                                                        UseLayoutRounding="True" />
                                                <Border Grid.Row="1"
                                                        Height="{Binding ActualHeight, ElementName=PART_AutoFilterRow}"
                                                        Background="#F9F9F9"
                                                        BorderBrush="#FFd0d0d0"
                                                        BorderThickness="0,1,0,1"
                                                        Margin="0,-1,0,0"
                                                        SnapsToDevicePixels="True"
                                                        UseLayoutRounding="True" />
                                            </Grid>


                                            <!--  Scrollbars  -->
                                            <ScrollBar
                                                x:Name="PART_VerticalScrollBar"
                                                Grid.Row="2"
                                                Grid.Column="2"
                                                Maximum="{TemplateBinding ScrollableHeight}"
                                                Orientation="Vertical"
                                                ViewportSize="{TemplateBinding ViewportHeight}"
                                                Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                                Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}" />
                                            <Grid Grid.Row="3" Grid.Column="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="{Binding NonFrozenColumnsViewportHorizontalOffset, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <ScrollBar
                                                    x:Name="PART_HorizontalScrollBar"
                                                    Grid.Column="1"
                                                    Maximum="{TemplateBinding ScrollableWidth}"
                                                    Orientation="Horizontal"
                                                    ViewportSize="{TemplateBinding ViewportWidth}"
                                                    Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                                    Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}" />
                                            </Grid>

                                            <!--
                                                Placeholder: bottom-left gap (below row header area, left of horizontal scrollbar).
                                                Matches row header background. Top edge is provided by
                                                ContentBottomSeparator below — only the col0/col1 internal
                                                separator stays (right BorderThickness=1).
                                            -->
                                            <Border
                                                Grid.Row="3"
                                                Grid.Column="0"
                                                Background="#F9F9F9"
                                                BorderBrush="#FFd0d0d0"
                                                BorderThickness="0,0,1,0"
                                                Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" />
                                            <!--
                                                Placeholder: bottom-right corner (intersection of both scrollbars).
                                                Keeps its own left + top edges because the two separators below stop
                                                at the col1/col2 and row1/row2 boundaries — those edges of the corner
                                                live entirely inside col 2 / row 2 where the separators don't reach.
                                            -->
                                            <Border
                                                Grid.Row="3"
                                                Grid.Column="2"
                                                Margin="-1,-1,0,0"
                                                Background="#F9F9F9"
                                                BorderBrush="#FFd0d0d0"
                                                BorderThickness="1,1,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding ComputedVerticalScrollBarVisibility, RelativeSource={RelativeSource TemplatedParent}}" Value="Visible" />
                                                                    <Condition Binding="{Binding ComputedHorizontalScrollBarVisibility, RelativeSource={RelativeSource TemplatedParent}}" Value="Visible" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>

                                            <Border
                                                x:Name="ContentRightSeparator"
                                                Grid.Row="0"
                                                Grid.RowSpan="3"
                                                Grid.Column="0"
                                                Grid.ColumnSpan="2"
                                                Margin="0,0,0,0"
                                                Panel.ZIndex="3"
                                                Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" 
                                                BorderBrush="#FFd0d0d0"
                                                BorderThickness="0,0,1,0"
                                                IsHitTestVisible="False"
                                                SnapsToDevicePixels="True"
                                                UseLayoutRounding="True" />
                                            <Border
                                                x:Name="ContentBottomSeparator"
                                                Grid.Row="0"
                                                Grid.RowSpan="3"
                                                Grid.Column="0"
                                                Grid.ColumnSpan="2"
                                                Panel.ZIndex="3"
                                                BorderBrush="#FFd0d0d0"
                                                Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" 
                                                BorderThickness="0,0,0,1"
                                                IsHitTestVisible="False"
                                                SnapsToDevicePixels="True"
                                                UseLayoutRounding="True" />
                                        </Grid>
                                    </ControlTemplate>
                                </ScrollViewer.Template>
                                <ItemsPresenter />
                            </ScrollViewer>

                            <!--  FilterPanel  -->
                            <sdg:FilterPanel
                                x:Name="PART_FilterPanel"
                                Grid.Row="1"
                                Style="{StaticResource {x:Static sdg:SdgThemeKeys.FilterPanel}}" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Background" Value="White" />
        <Setter Property="RowHeaderStyle" Value="{StaticResource {x:Static sdg:SdgThemeKeys.SearchDataGridRowHeader}}" />
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource {x:Static sdg:SdgThemeKeys.SearchDataGridColumnHeader}}" />
        <Setter Property="RowHeaderWidth" Value="24" />
        <Setter Property="BorderBrush" Value="#FFd0d0d0" />
        <!--
            Explicit BorderThickness=1 on all sides. Control.BorderThickness defaults to
            Thickness(0) and DataGrid doesn't OverrideMetadata for it — without this setter
            the outer perimeter is invisible, which is why the bottom edge disappears when the
            horizontal scrollbar collapses (the ContentBottomSeparator was the only thing
            drawing a bottom line). The separator handles the seam between content and
            scrollbars when they're visible; this outer Border handles the perimeter at all
            times, including when scrollbars collapse and the separator goes with them.
        -->
        <Setter Property="BorderThickness" Value="1" />
        <!--
            Cascades pixel-snapped layout to every descendant. Without this, individual cells
            and rows can land at sub-pixel positions while the separator (already snapped via
            UseLayoutRounding on its own element) sits one device pixel further out — leaving
            a 1px sliver of cell content visible past the separator at the saturated-scroll
            edge. Forces the entire visual tree onto integer device pixels so the cell's outer
            gridline and the separator land on the same pixel reliably.
        -->
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="RowBackground" Value="White" />
        <Setter Property="AlternatingRowBackground" Value="#FFF9F9F9" />
        <Setter Property="HorizontalGridLinesBrush" Value="#FFd0d0d0" />
        <Setter Property="VerticalGridLinesBrush" Value="#FFd0d0d0" />


        <Setter Property="HeadersVisibility" Value="All" />
        <Setter Property="GridLinesVisibility" Value="None" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="CanUserResizeRows" Value="False" />
        <Setter Property="CanUserReorderColumns" Value="True" />
        <Setter Property="CanUserResizeColumns" Value="True" />
        <Setter Property="CanUserSortColumns" Value="True" />
        <Setter Property="IsSynchronizedWithCurrentItem" Value="True" />


        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="SelectionMode" Value="Extended" />
        <Setter Property="SelectionUnit" Value="FullRow" />
        <Setter Property="EnableRowVirtualization" Value="True" />
        <Setter Property="EnableColumnVirtualization" Value="True" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.IsVirtualizingWhenGrouping" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Item" />
        <Setter Property="ScrollViewer.IsDeferredScrollingEnabled" Value="False" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
    </Style>

    <Style BasedOn="{StaticResource {x:Static sdg:SdgThemeKeys.SearchDataGrid}}" TargetType="{x:Type sdg:SearchDataGrid}" />
</ResourceDictionary>