<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sdg="clr-namespace:WWSearchDataGrid.Modern.WPF"
                    xmlns:behaviors="clr-namespace:WWSearchDataGrid.Modern.WPF.Behaviors">

    <!--
        Brings in the Sdg.* brush palette these styles reference. Mirrors the merge
        pattern used by every other themed control file in this project.
    -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WWSearchDataGrid.Modern.WPF;component/Themes/Controls/Primitives/DefaultControls.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        ═══════════════════════════════════════════════════════════════════════
        EditSettings — Default Display & Edit Element Styles
        ═══════════════════════════════════════════════════════════════════════
        Each editor type (Text / ComboBox / Spin / Date / CheckBox) builds
        its cell template via FrameworkElementFactory and applies one of these styles
        by ComponentResourceKey lookup against EditSettingsThemeKeys. Consumers override
        at three levels:
        
        1. Per-column EditorStyle / DisplayStyle DPs on the EditSettings instance
        — applied as a local Style value, beats the keyed default lookup.
        2. App-level keyed override — redefine the Style under the same
        {x:Static sdg:EditSettingsThemeKeys.X} key in App.xaml / Window.Resources.
        3. Full template replacement via EditTemplate / DisplayTemplate DPs —
        skips the default style and any per-control override.
        
        Keys are typed (ComponentResourceKey) — see EditSettingsThemeKeys.cs. The
        assembly's [ThemeInfo] attribute lets FindResource walk into this Generic.xaml
        automatically, so consumers don't need to merge any dictionary just to get
        defaults.
        
        Color tokens (Sdg.Surface.*, Sdg.Border.*, Sdg.Accent, etc.) live in
        Themes/Controls/Primitives/DefaultControls.xaml.
    -->

    <!--#region Display element styles-->

    <!--
        Read-only TextBlock used inside display templates of Text / ComboBox / Spin /
        Date editors. Single inset, vertical centering, ellipsis on overflow.
    -->
    <Style x:Key="{x:Static sdg:EditSettingsThemeKeys.DisplayTextBlock}" TargetType="{x:Type TextBlock}">
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource Sdg.Text.Primary}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!--
        Right-aligned variant for numeric display. Spreadsheet convention: numbers
        line up at the decimal on the right edge so columns of money / counts read cleanly.
    -->
    <Style x:Key="{x:Static sdg:EditSettingsThemeKeys.DisplayNumericTextBlock}"
           BasedOn="{StaticResource {x:Static sdg:EditSettingsThemeKeys.DisplayTextBlock}}"
           TargetType="{x:Type TextBlock}">
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="TextAlignment" Value="Right" />
    </Style>

    <!--
        CheckBox shown in checkbox cells (CheckBoxEditSettings — used as both the cell
        template and the editing template; see CheckBoxEditSettings.cs). Interactive:
        toggles on click via TwoWay binding without entering edit mode. Focusable=False
        keeps Tab navigation on the cell itself; SearchDataGrid handles Space/Enter on
        the cell to toggle the inner CheckBox.
        
        Read-only handling (block clicks, dim visually, swap cursor) lives in
        CheckBoxEditSettings.AttachReadOnlyGate. A Style.Triggers DataTrigger bound via
        RelativeSource AncestorType=DataGridCell never fires from a FrameworkElementFactory
        template — the binding silently fails to resolve through the cell's ContentPresenter
        boundary, so the gate is wired in code on Loaded with a DependencyPropertyDescriptor
        listening on DataGridCell.IsReadOnly.
    -->
    <Style x:Key="{x:Static sdg:EditSettingsThemeKeys.DisplayCheckBox}" TargetType="{x:Type CheckBox}">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Foreground" Value="{StaticResource Sdg.Text.Primary}" />
        <Setter Property="Background" Value="{StaticResource Sdg.Surface.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Sdg.Border.Strong}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="6,0,0,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="Box"
                                Grid.Column="0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                VerticalAlignment="Center"
                                Width="16"
                                Height="16"
                                CornerRadius="3">
                            <TextBlock x:Name="Glyph"
                                       Foreground="{StaticResource Sdg.Text.OnAccent}"
                                       Opacity="0"
                                       Text="&#xE73E;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="12" />
                        </Border>

                        <ContentPresenter Grid.Column="1"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource Sdg.Accent}" />
                            <Setter TargetName="Box" Property="BorderThickness" Value="0" />
                            <Setter TargetName="Box" Property="Padding" Value="1" />
                            <Setter TargetName="Glyph" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource Sdg.Accent}" />
                            <Setter TargetName="Box" Property="BorderThickness" Value="0" />
                            <Setter TargetName="Box" Property="Padding" Value="1" />
                            <Setter TargetName="Glyph" Property="Text" Value="&#xE738;" />
                            <Setter TargetName="Glyph" Property="FontSize" Value="10" />
                            <Setter TargetName="Glyph" Property="Opacity" Value="1" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Sdg.Accent}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource Sdg.Accent.Hover}" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource Sdg.Text.Disabled}" />
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource Sdg.Surface.Disabled}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Sdg.Border.Default}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsReadOnly, RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}}" Value="True">
                <Setter Property="IsHitTestVisible" Value="False" />
                <Setter Property="Opacity" Value="0.55" />
                <Setter Property="Cursor" Value="Arrow" />
            </DataTrigger>
            <DataTrigger Binding="{Binding IsReadOnly, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" Value="True">
                <Setter Property="IsHitTestVisible" Value="False" />
                <Setter Property="Opacity" Value="0.55" />
                <Setter Property="Cursor" Value="Arrow" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!--#endregion-->

    <!--#region Edit element styles-->

    <!--
        Flat TextBox used inside edit templates of Text editors. Borderless
        until focus, accent border on focus, fills the cell. The trigger toggles
        BorderThickness on focus rather than swapping brushes — keeps the default
        WPF TextBox template intact, just changes its visible chrome.
    -->
    <Style x:Key="{x:Static sdg:EditSettingsThemeKeys.EditTextBox}" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{StaticResource Sdg.Surface.Input}" />
        <Setter Property="Foreground" Value="{StaticResource Sdg.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Sdg.Border.Focused}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,2,4,2" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderThickness" Value="0" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  Right-aligned numeric edit variant — used by SpinEditSettings.  -->
    <Style x:Key="{x:Static sdg:EditSettingsThemeKeys.EditNumericTextBox}"
           BasedOn="{StaticResource {x:Static sdg:EditSettingsThemeKeys.EditTextBox}}"
           TargetType="{x:Type TextBox}">
        <Setter Property="TextAlignment" Value="Right" />
    </Style>



    <!--
        Chevron drop-down button used inside the EditComboBox ControlTemplate. Must be
        declared BEFORE EditComboBox (which references it via StaticResource) so the
        forward-reference doesn't fail in any XAML-loader path. WPF generally tolerates
        forward StaticResource references inside Style.Setters (resolution is deferred),
        but the rule is unreliable across BAML / runtime / debugger combinations — most
        visibly breaking the ComboBox chevron in dynamically-instantiated hosts (the
        filter-row's per-column ColumnFilterControl is one such host). Backward order is
        the dependable form.
    -->
    <Style x:Key="{x:Static sdg:EditSettingsThemeKeys.EditComboBoxDropDownButton}" TargetType="{x:Type ToggleButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,0,9,0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Foreground" Value="{StaticResource Sdg.Text.Primary}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="MainBorder"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <TextBlock Foreground="{TemplateBinding Foreground}"
                                   Text="&#xE70D;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="10"
                                   Margin="{TemplateBinding Padding}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Flat ComboBox for ComboBoxEditSettings edit mode. Uses the custom ControlTemplate
        above so Background / BorderBrush / BorderThickness actually take effect. Borderless
        until focus, accent border on focus.
    -->
    <Style x:Key="{x:Static sdg:EditSettingsThemeKeys.EditComboBox}" TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="{StaticResource Sdg.Surface.Input}" />
        <Setter Property="Foreground" Value="{StaticResource Sdg.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Sdg.Border.Focused}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Border x:Name="MainBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--
                                The whole control acts as the open/close toggle. Custom inner template so
                                the ToggleButton itself contributes no chrome of its own.
                            -->
                            <ToggleButton x:Name="DropDownToggle"
                                          Grid.ColumnSpan="2"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" BorderThickness="0" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <!--
                                Selected-item display sits above the toggle, hit-test invisible so clicks
                                pass through to the toggle.
                            -->
                            <ContentPresenter Grid.Column="0"
                                              IsHitTestVisible="False"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}" />

                            <!-- Visual-only chevron — the actual popup toggle is the full-area
                                 DropDownToggle stacked behind this. IsHitTestVisible=False keeps
                                 clicks routed to that toggle. IsChecked tracks IsDropDownOpen so
                                 the button's checked-state visuals (if the style adds any) reflect
                                 popup state. Style supplies glyph + font; Foreground TemplateBinding
                                 keeps the chevron in sync with ComboBox.Foreground. -->
                            <ToggleButton x:Name="Chevron"
                                          Grid.Column="1"
                                          IsChecked="{Binding IsDropDownOpen, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          IsHitTestVisible="False"
                                          Foreground="{TemplateBinding Foreground}"
                                          Style="{StaticResource {x:Static sdg:EditSettingsThemeKeys.EditComboBoxDropDownButton}}" />

                            <Popup x:Name="PART_Popup"
                                   Grid.ColumnSpan="2"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Focusable="False"
                                   Placement="Bottom"
                                   PopupAnimation="None">
                                <Border Background="{StaticResource Sdg.Surface.Primary}"
                                        BorderBrush="{StaticResource Sdg.Border.Default}"
                                        BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer>
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="{StaticResource Sdg.Surface.Hover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <!--<Setter Property="BorderThickness" Value="1" />-->
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--
        Calendar dropdown ToggleButton for DateEditSettings. Used in BOTH surfaces:
        — SegmentedDateTimeEditor's edit-mode template (functional, opens the popup);
        — DateEditSettings.CreateDisplayTemplate (visual-only ShowAlways indicator).
        The calendar glyph lives inside this template so overriding the key once retheme both
        surfaces — consumers don't need to touch C# or a parallel display-only key.
    -->
    <Style x:Key="{x:Static sdg:EditSettingsThemeKeys.EditDateDropDownButton}" TargetType="{x:Type ToggleButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Foreground" Value="{x:Static SystemColors.ControlTextBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="MainBorder"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <TextBlock Foreground="{TemplateBinding Foreground}"
                                   Text="&#xE787;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="{StaticResource Sdg.Surface.Hover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="{StaticResource Sdg.Surface.Pressed}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="{StaticResource Sdg.Surface.Hover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    
    <Style x:Key="{x:Static sdg:EditSettingsThemeKeys.SpinButton}" TargetType="{x:Type RepeatButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource Sdg.Text.Primary}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="9" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border x:Name="MainBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="8"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="{StaticResource Sdg.Surface.Hover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="{StaticResource Sdg.Surface.Pressed}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

    <!--#region SegmentedDateTimeEditor-->

    <Style TargetType="{x:Type sdg:SegmentedDateTimeEditor}">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sdg:SegmentedDateTimeEditor}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="PART_TextBox" Style="{StaticResource {x:Static sdg:EditSettingsThemeKeys.EditTextBox}}" />

                        <!-- Calendar glyph is provided by EditDateDropDownButton's ControlTemplate
                             so the same icon appears in DateEditSettings's display-mode ShowAlways
                             indicator without a parallel definition. Override that one style key
                             to retheme the button + icon in both surfaces. -->
                        <ToggleButton x:Name="PART_DropDownButton"
                                      Style="{StaticResource {x:Static sdg:EditSettingsThemeKeys.EditDateDropDownButton}}"
                                      Grid.Column="1"
                                      Width="22" />

                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               IsOpen="{Binding IsChecked, ElementName=PART_DropDownButton, Mode=TwoWay}"
                               PlacementTarget="{Binding ElementName=PART_DropDownButton}"
                               Placement="Bottom"
                               StaysOpen="False"
                               PopupAnimation="None">
                            <Border Background="{StaticResource Sdg.Surface.Primary}"
                                    BorderBrush="{StaticResource Sdg.Border.Default}"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True">
                                <Calendar x:Name="PART_Calendar"
                                          SelectedDate="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          DisplayDateStart="{Binding MinDate, RelativeSource={RelativeSource TemplatedParent}}"
                                          DisplayDateEnd="{Binding MaxDate, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

</ResourceDictionary>
